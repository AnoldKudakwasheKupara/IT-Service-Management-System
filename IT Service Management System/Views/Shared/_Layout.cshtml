<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - Axis IT Operations</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --primary-light: #dbeafe;
            --primary-glow: rgba(59,130,246,0.25);
            --sidebar-bg: #0f172a;
            --sidebar-hover: #1e293b;
            --sidebar-active: #3b82f6;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-light: #e2e8f0;
            --text-muted: #94a3b8;
            --bg-main: #f1f5f9;
            --bg-card: #ffffff;
            --border-light: #e2e8f0;
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-md: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -2px rgba(0, 0, 0, 0.04);
            --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
            --transition-smooth: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            margin: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg-main);
            color: var(--text-primary);
            font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--border-light);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        /* layout */
        .app-layout {
            display: flex;
            height: 100vh;
            width: 100%;
            overflow: hidden;
        }

        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            backdrop-filter: blur(0px);
            color: var(--text-light);
            display: flex;
            flex-direction: column;
            transition: var(--transition-smooth);
            z-index: 20;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.08);
            overflow-y: auto;
            scrollbar-width: thin;
        }

        .sidebar-header {
            padding: 1.5rem 1.5rem 1rem 1.5rem;
            font-weight: 700;
            font-size: 1.35rem;
            letter-spacing: -0.3px;
            color: white;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            margin-bottom: 1rem;
        }

        .sidebar-header i {
            font-size: 1.6rem;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 2px 5px rgba(59,130,246,0.3);
        }

        .nav-group {
            padding: 0.75rem 1.5rem 0.4rem 1.5rem;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            color: #64748b;
            margin-top: 0.5rem;
        }

        .nav-item {
            padding: 0.7rem 1.5rem;
            margin: 0.2rem 0.8rem;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            border-radius: 12px;
            transition: var(--transition-smooth);
            position: relative;
        }

        .nav-item i {
            width: 22px;
            font-size: 1.1rem;
            text-align: center;
            transition: var(--transition-smooth);
        }

        .nav-item:hover {
            background: var(--sidebar-hover);
            color: white;
            transform: translateX(4px);
        }

        .nav-item.active {
            background: linear-gradient(95deg, rgba(59,130,246,0.2) 0%, rgba(59,130,246,0.05) 100%);
            color: white;
            font-weight: 600;
            border-left: 3px solid var(--primary);
            box-shadow: var(--shadow-sm);
        }

        .nav-item.active i {
            color: var(--primary);
        }

        /* MAIN AREA */
        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--bg-main);
        }

        /* TOPBAR - modern floating effect */
        .topbar {
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226,232,240,0.6);
            height: 70px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 10;
            transition: var(--transition-smooth);
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .topbar-left h5 {
            margin: 0;
            font-weight: 700;
            font-size: 1.25rem;
            background: linear-gradient(135deg, var(--text-primary), #334155);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.2px;
        }

        .mobile-toggle {
            display: none;
            background: white;
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 8px 12px;
            transition: var(--transition-smooth);
        }

        .mobile-toggle:hover {
            background: var(--primary-light);
            border-color: var(--primary);
        }

        /* USER PROFILE - enhanced */
        .user-profile {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .profile-link {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            padding: 6px 12px 6px 8px;
            border-radius: 60px;
            transition: var(--transition-smooth);
            background: rgba(255,255,255,0.5);
        }

        .profile-link:hover {
            background: white;
            box-shadow: var(--shadow-sm);
            transform: scale(1.02);
        }

        .user-avatar {
            width: 42px;
            height: 42px;
            border-radius: 42px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1rem;
            box-shadow: 0 4px 8px rgba(59,130,246,0.2);
            transition: var(--transition-smooth);
        }

        .user-info {
            line-height: 1.3;
        }

        .user-name {
            font-weight: 700;
            color: var(--text-primary);
            font-size: 0.9rem;
        }

        .user-role {
            font-size: 0.7rem;
            color: var(--primary);
            font-weight: 500;
            background: var(--primary-light);
            padding: 2px 8px;
            border-radius: 30px;
            display: inline-block;
        }

        .btn-logout {
            background: rgba(239,68,68,0.1);
            border: none;
            color: #ef4444;
            border-radius: 40px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-smooth);
        }

        .btn-logout:hover {
            background: #ef4444;
            color: white;
            transform: scale(1.05);
            box-shadow: 0 6px 12px rgba(239,68,68,0.25);
        }

        /* CONTENT - smooth scrolling + card enhancements */
        .content {
            padding: 1.8rem 2rem 2rem 2rem;
            overflow-y: auto;
            scroll-behavior: smooth;
        }

        /* global button and card enhancements (for inner pages) */
        .btn-modern {
            padding: 8px 18px;
            border-radius: 40px;
            font-weight: 500;
            transition: var(--transition-smooth);
            letter-spacing: -0.2px;
        }

        .btn-modern:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow-sm);
        }

        .btn-primary-modern {
            background: var(--primary);
            border: none;
            color: white;
        }

        .btn-primary-modern:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

        /* card component style (makes any card beautiful) */
        .card {
            border: none;
            border-radius: 24px;
            background: var(--bg-card);
            box-shadow: var(--shadow-sm);
            transition: var(--transition-smooth);
            overflow: hidden;
        }

        .card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }
        /* overlay for mobile */
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(3px);
            z-index: 1040;
            display: none;
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .sidebar-overlay.active {
            display: block;
            opacity: 1;
        }

        /* loading / smooth entry animation */
        .fade-in {
            animation: fadeInUp 0.4s ease-out;
        }


        /* Utility for modern tables & inputs (global theme) */
        .table {
            border-collapse: separate;
            border-spacing: 0;
            width: 100%;
        }

        .table thead th {
            background: #f8fafc;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--border-light);
            padding: 1rem 0.8rem;
        }

        .table tbody tr {
            transition: var(--transition-smooth);
        }

        .table tbody tr:hover {
            background: #fefefe;
            transform: scale(1.002);
        }

        input, select, textarea {
            border-radius: 14px !important;
            border: 1px solid var(--border-light) !important;
            padding: 0.6rem 1rem !important;
            transition: var(--transition-smooth) !important;
        }

        input:focus, select:focus, textarea:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px var(--primary-glow) !important;
            outline: none !important;
        }

        /* custom badge */
        .badge-modern {
            padding: 4px 12px;
            border-radius: 50px;
            font-weight: 500;
            font-size: 0.7rem;
        }
    </style>
</head>

<body>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isAuthPage = currentController == "Account" &&
            (currentAction == "Login" || currentAction == "ForgotPassword" || currentAction == "SetPassword");
    }

    @if (!isAuthPage)
    {
        <!-- Mobile Overlay -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

        <div class="app-layout">

            <!-- SIDEBAR (updated icons + micro-interactions) -->
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <i class="fas fa-headset"></i>
                    <span>Axis IT</span>
                </div>

                <div class="nav-group">Core</div>
                <a class="nav-item @(currentController == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>

                <a class="nav-item @(currentController == "Tickets" ? "active" : "")"
                   asp-controller="Tickets" asp-action="Index">
                    <i class="fas fa-ticket-alt"></i> Tickets
                </a>

                <div class="nav-group">Administration</div>
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a class="nav-item @(currentController == "Users" ? "active" : "")"
                       asp-controller="Users" asp-action="Index">
                        <i class="fas fa-users"></i> Users
                    </a>
                }

                <a class="nav-item @(currentController == "Departments" ? "active" : "")"
                   asp-controller="Departments" asp-action="Index">
                    <i class="fas fa-building"></i> Departments
                </a>

                <a class="nav-item @(currentController == "AuditLogs" ? "active" : "")"
                   asp-controller="AuditLogs" asp-action="Index">
                    <i class="fas fa-history"></i> Audit Logs
                </a>

                <div class="nav-group">Operations</div>
                <a class="nav-item @(currentController == "Activity" ? "active" : "")"
                   asp-controller="Activity" asp-action="Index">
                    <i class="fas fa-tasks"></i> Activity Tracker
                </a>

                <a class="nav-item @(currentController == "ActivityCategories" ? "active" : "")"
                   asp-controller="ActivityCategories" asp-action="Index">
                    <i class="fas fa-tags"></i> Categories
                </a>

                <a class="nav-item @(currentController == "PaymentSchedule" ? "active" : "")"
                   asp-controller="PaymentSchedule" asp-action="Index">
                    <i class="fas fa-credit-card"></i> Payments
                </a>

                <div class="nav-group">Assets & Security</div>
                <a class="nav-item @(currentController == "Assets" ? "active" : "")"
                   asp-controller="Assets" asp-action="Index">
                    <i class="fas fa-laptop-code"></i> Assets
                </a>

                <a class="nav-item @(currentController == "SSLCertificates" ? "active" : "")"
                   asp-controller="SSLCertificates" asp-action="Index">
                    <i class="fas fa-shield-alt"></i> SSL Tracker
                </a>

                <div class="nav-group">HR Management</div>

                <a class="nav-item @(currentController == "ExitClearance" ? "active" : "")"
                   asp-controller="ExitClearance"
                   asp-action="Index">

                    <i class="fas fa-file-signature"></i>
                    Exit Clearance

                </a>
            </aside>



            <!-- MAIN AREA -->
            <div class="main-area">

                <!-- TOPBAR with blur and smooth design -->
                <div class="topbar">
                    <div class="topbar-left">
                        <button class="mobile-toggle btn btn-light" onclick="toggleSidebar()" aria-label="Toggle menu">
                            <i class="fas fa-bars"></i>
                        </button>
                        <h5>@ViewData["Title"]</h5>
                    </div>

                    <!-- user profile section with modern look -->
                    <div class="user-profile">
                        <a asp-controller="Users" asp-action="Profile" class="profile-link">
                            <div class="user-avatar">
                                @{
                                    var userName = Context.Session.GetString("UserName");
                                    var initial = string.IsNullOrEmpty(userName) ? "U" : userName.Substring(0, 1).ToUpper();
                                }
                                @initial
                            </div>
                            <div class="user-info">
                                <div class="user-name">@Context.Session.GetString("UserName")</div>
                                <div class="user-role">@Context.Session.GetString("UserRole")</div>
                            </div>
                        </a>

                        <a class="btn btn-logout" asp-controller="Account" asp-action="Logout" title="Logout">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    </div>
                </div>

                <!-- CONTENT area with smooth fade-in -->
                <main class="content fade-in">
                    @RenderBody()
                </main>

            </div>
        </div>
    }
    else
    {
        <main class="fade-in" style="background: var(--bg-main); min-height:100vh;">
            @RenderBody()
        </main>
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Enhanced smooth sidebar toggling with overlay and animations
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("sidebarOverlay");
            sidebar.classList.toggle("active");
            if (sidebar.classList.contains("active")) {
                overlay.classList.add("active");
                document.body.style.overflow = "hidden";
            } else {
                overlay.classList.remove("active");
                document.body.style.overflow = "";
            }
        }

        function closeSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("sidebarOverlay");
            sidebar.classList.remove("active");
            overlay.classList.remove("active");
            document.body.style.overflow = "";
        }

        // optional: close sidebar when window resizes above mobile breakpoint
        window.addEventListener('resize', function() {
            if (window.innerWidth > 768) {
                const sidebar = document.getElementById("sidebar");
                const overlay = document.getElementById("sidebarOverlay");
                if (sidebar.classList.contains("active")) {
                    sidebar.classList.remove("active");
                    overlay.classList.remove("active");
                    document.body.style.overflow = "";
                }
            }
        });

        // Smooth page transition effect (subtle highlight for active nav)
        document.addEventListener("DOMContentLoaded", function() {
            // add ripple effect on nav items
            const navItems = document.querySelectorAll('.nav-item');
            navItems.forEach(item => {
                item.addEventListener('click', function(e) {
                    // don't interfere with actual href, just style feedback
                    if (!e.ctrlKey && !e.metaKey) {
                        // optional ripple effect can be added
                        this.style.transition = 'all 0.15s';
                        this.style.transform = 'translateX(2px)';
                        setTimeout(() => {
                            this.style.transform = '';
                        }, 120);
                    }
                });
            });

            // make any existing buttons more polished (fallback to modern classes)
            const allBtns = document.querySelectorAll('.btn');
            allBtns.forEach(btn => {
                if (!btn.classList.contains('btn-logout') && !btn.classList.contains('btn-modern') && !btn.classList.contains('mobile-toggle')) {
                    btn.classList.add('btn-modern');
                }
            });

            // add card effect to any card-like element if missing
            const cards = document.querySelectorAll('.card');
            cards.forEach(card => {
                card.classList.add('card'); // already, ensure smoothness
            });
        });
    </script>

    @RenderSection("Scripts", required: false)

    <!-- Additional micro-animations for smooth scrolling and improved UX -->
    <style>
        /* graceful loading for content blocks */
        .content * {
            animation: fadeIn 0.2s ease forwards;
        }

        /* better focus rings */
        a, button, .nav-item {
            outline: none;
        }

        a:focus-visible, button:focus-visible, .nav-item:focus-visible {
            outline: 2px solid var(--primary);
            outline-offset: 2px;
            border-radius: 8px;
        }

        /* smooth topbar shadow on scroll */
        .topbar {
            transition: box-shadow 0.2s, background 0.2s;
        }
        .main-area {
            scroll-behavior: smooth;
        }
    </style>

    <script>
        // dynamic shadow on topbar based on scroll
        (function() {
            const mainContent = document.querySelector('.content');
            const topbar = document.querySelector('.topbar');
            if (mainContent && topbar) {
                mainContent.addEventListener('scroll', function() {
                    if (mainContent.scrollTop > 10) {
                        topbar.style.boxShadow = '0 4px 20px rgba(0,0,0,0.05)';
                        topbar.style.background = 'rgba(255,255,255,0.95)';
                    } else {
                        topbar.style.boxShadow = 'none';
                        topbar.style.background = 'rgba(255,255,255,0.85)';
                    }
                });
            }
        })();
    </script>

</body>
</html>