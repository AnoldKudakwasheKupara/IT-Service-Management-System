<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - Axis IT Operations</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Toastr notifications -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.css" />

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --primary: #3b82f6;
                --primary-dark: #2563eb;
                --primary-light: #dbeafe;
                --primary-glow: rgba(59,130,246,0.25);

                /* Semantic colors (shared across all pages) */
                --success: #2c9e6e;
                --success-light: #e6f5e9;
                --warning: #f5b042;
                --warning-light: #fff5e6;
                --danger: #e53e3e;
                --danger-light: #fff5f5;
                --info: #3b82f6;

                /* Neutral / gray scale (slate) */
                --gray-50: #f8fafc;
                --gray-100: #f1f5f9;
                --gray-200: #e2e8f0;
                --gray-300: #cbd5e1;
                --gray-400: #94a3b8;
                --gray-500: #64748b;
                --gray-600: #475569;
                --gray-700: #334155;
                --gray-800: #1e293b;

                --sidebar-bg: #0f172a;
                --sidebar-hover: #1e293b;
                --sidebar-active: #3b82f6;
                --text-primary: #0f172a;
                --text-secondary: #475569;
                --text-light: #e2e8f0;
                --text-muted: #94a3b8;
                --bg-main: #f1f5f9;
                --bg-card: #ffffff;
                --border-light: #e2e8f0;
                --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
                --shadow-md: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -2px rgba(0, 0, 0, 0.04);
                --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
                --shadow-xl: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
                --transition-smooth: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
                --radius-lg: 1.5rem;
                --radius-md: 1rem;
                --radius-sm: 0.75rem;
            }

            body {
                margin: 0;
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                background: var(--bg-main);
                color: var(--text-primary);
                font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
            }

            ::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }

            ::-webkit-scrollbar-track {
                background: var(--border-light);
                border-radius: 10px;
            }

            ::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

                ::-webkit-scrollbar-thumb:hover {
                    background: var(--primary);
                }

            /* ============================================================
                               LAYOUT
                               ============================================================ */
            .app-layout {
                display: flex;
                height: 100vh;
                width: 100%;
                overflow: hidden;
            }

            /* ============================================================
                               SIDEBAR — premium dark
                               ============================================================ */
            .sidebar {
                width: 280px;
                background: var(--sidebar-bg);
                color: var(--text-light);
                display: flex;
                flex-direction: column;
                transition: var(--transition-smooth);
                z-index: 20;
                box-shadow: 4px 0 20px rgba(0, 0, 0, 0.08);
                overflow-y: auto;
                scrollbar-width: thin;
                flex-shrink: 0;
            }

                .sidebar::-webkit-scrollbar {
                    width: 4px;
                }

                .sidebar::-webkit-scrollbar-track {
                    background: transparent;
                }

                .sidebar::-webkit-scrollbar-thumb {
                    background: rgba(255,255,255,0.2);
                    border-radius: 10px;
                }

            .sidebar-header {
                padding: 1.75rem 1.5rem 1.25rem 1.5rem;
                font-weight: 700;
                font-size: 1.35rem;
                letter-spacing: -0.3px;
                color: white;
                display: flex;
                align-items: center;
                gap: 12px;
                border-bottom: 1px solid rgba(255,255,255,0.06);
                margin-bottom: 0.5rem;
            }

                .sidebar-header i {
                    font-size: 1.6rem;
                    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
                    -webkit-background-clip: text;
                    background-clip: text;
                    color: transparent;
                    text-shadow: 0 2px 5px rgba(59,130,246,0.3);
                }

                .sidebar-header span {
                    background: linear-gradient(135deg, #fff, #94a3b8);
                    -webkit-background-clip: text;
                    background-clip: text;
                    color: transparent;
                }

            .nav-group {
                padding: 0.75rem 1.5rem 0.4rem 1.5rem;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                font-weight: 600;
                color: #64748b;
                margin-top: 0.5rem;
            }

            .nav-item {
                padding: 0.7rem 1.5rem;
                margin: 0.15rem 0.8rem;
                display: flex;
                align-items: center;
                gap: 12px;
                color: #94a3b8;
                text-decoration: none;
                font-size: 0.875rem;
                font-weight: 500;
                border-radius: var(--radius-sm);
                transition: var(--transition-smooth);
                position: relative;
                cursor: pointer;
            }

                .nav-item i {
                    width: 22px;
                    font-size: 1.05rem;
                    text-align: center;
                    transition: var(--transition-smooth);
                    color: #64748b;
                }

                .nav-item:hover {
                    background: var(--sidebar-hover);
                    color: white;
                    transform: translateX(4px);
                }

                    .nav-item:hover i {
                        color: var(--primary);
                    }

                .nav-item.active {
                    background: linear-gradient(95deg, rgba(59,130,246,0.15) 0%, rgba(59,130,246,0.05) 100%);
                    color: white;
                    font-weight: 600;
                    border-left: 3px solid var(--primary);
                }

                    .nav-item.active i {
                        color: var(--primary);
                    }

            /* badge indicator on nav items */
            .nav-badge {
                margin-left: auto;
                background: var(--primary);
                color: white;
                font-size: 0.6rem;
                padding: 2px 8px;
                border-radius: 20px;
                font-weight: 600;
            }

            /* ============================================================
                               MAIN AREA
                               ============================================================ */
            .main-area {
                flex: 1;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                background: var(--bg-main);
            }

            /* ============================================================
                               TOPBAR — glass effect
                               ============================================================ */
            .topbar {
                background: rgba(255,255,255,0.75);
                backdrop-filter: blur(16px) saturate(180%);
                -webkit-backdrop-filter: blur(16px) saturate(180%);
                border-bottom: 1px solid rgba(226,232,240,0.5);
                height: 72px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 2rem;
                position: sticky;
                top: 0;
                z-index: 10;
                transition: var(--transition-smooth);
            }

            .topbar-left {
                display: flex;
                align-items: center;
                gap: 16px;
            }

                .topbar-left h5 {
                    margin: 0;
                    font-weight: 700;
                    font-size: 1.1rem;
                    color: var(--text-primary);
                    letter-spacing: -0.2px;
                }

                    .topbar-left h5 small {
                        font-weight: 400;
                        color: var(--text-muted);
                        font-size: 0.75rem;
                        margin-left: 0.5rem;
                    }

            .mobile-toggle {
                display: none;
                background: white;
                border: 1px solid var(--border-light);
                border-radius: var(--radius-sm);
                padding: 8px 12px;
                transition: var(--transition-smooth);
                color: var(--text-secondary);
            }

                .mobile-toggle:hover {
                    background: var(--primary-light);
                    border-color: var(--primary);
                    color: var(--primary);
                }

            /* ============================================================
                               USER PROFILE
                               ============================================================ */
            .user-profile {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .profile-link {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
                padding: 6px 14px 6px 8px;
                border-radius: 60px;
                transition: var(--transition-smooth);
                background: rgba(255,255,255,0.5);
            }

                .profile-link:hover {
                    background: white;
                    box-shadow: var(--shadow-sm);
                    transform: scale(1.02);
                    text-decoration: none;
                }

            .user-avatar {
                width: 38px;
                height: 38px;
                border-radius: 50%;
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 0.9rem;
                box-shadow: 0 4px 8px rgba(59,130,246,0.2);
                transition: var(--transition-smooth);
                flex-shrink: 0;
            }

            .user-info {
                line-height: 1.3;
            }

            .user-name {
                font-weight: 600;
                color: var(--text-primary);
                font-size: 0.85rem;
            }

            .user-role {
                font-size: 0.65rem;
                color: var(--primary);
                font-weight: 600;
                background: var(--primary-light);
                padding: 2px 10px;
                border-radius: 30px;
                display: inline-block;
            }

            .logout-form {
                display: flex;
                margin: 0;
            }

            .btn-logout {
                background: rgba(239,68,68,0.1);
                border: none;
                color: #ef4444;
                border-radius: 50%;
                width: 40px;
                height: 40px;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: var(--transition-smooth);
                cursor: pointer;
            }

                .btn-logout:hover {
                    background: #ef4444;
                    color: white;
                    transform: scale(1.05);
                    box-shadow: 0 6px 12px rgba(239,68,68,0.25);
                }

            /* ============================================================
                               CONTENT
                               ============================================================ */
            .content {
                padding: 1.8rem 2rem 2rem 2rem;
                overflow-y: auto;
                scroll-behavior: smooth;
                flex: 1;
            }

            /* ============================================================
                               GLOBAL COMPONENTS
                               ============================================================ */
            .card {
                border: none;
                border-radius: var(--radius-md);
                background: var(--bg-card);
                box-shadow: var(--shadow-sm);
                transition: var(--transition-smooth);
                overflow: hidden;
            }

                .card:hover {
                    box-shadow: var(--shadow-md);
                    transform: translateY(-2px);
                }

            .btn-modern {
                padding: 8px 20px;
                border-radius: 40px;
                font-weight: 500;
                transition: var(--transition-smooth);
                letter-spacing: -0.2px;
                border: none;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

                .btn-modern:hover {
                    transform: translateY(-2px);
                    box-shadow: var(--shadow-md);
                }

            .btn-primary-modern {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                color: white;
            }

                .btn-primary-modern:hover {
                    background: linear-gradient(135deg, var(--primary-dark), #1d4ed8);
                    color: white;
                }

            /* ============================================================
                               SIDEBAR OVERLAY (mobile)
                               ============================================================ */
            .sidebar-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.4);
                backdrop-filter: blur(4px);
                z-index: 1040;
                display: none;
                opacity: 0;
                transition: opacity 0.3s ease;
            }

                .sidebar-overlay.active {
                    display: block;
                    opacity: 1;
                }

            /* ============================================================
                               ANIMATIONS
                               ============================================================ */
            .fade-in {
                animation: fadeInUp 0.5s ease-out;
            }

            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* ============================================================
                               RESPONSIVE
                               ============================================================ */
            @@media (max-width: 992px) {
                .sidebar {
                    position: fixed;
                    top: 0;
                    left: -320px;
                    height: 100%;
                    z-index: 1050;
                    box-shadow: var(--shadow-xl);
                    width: 300px;
                }

                    .sidebar.active {
                        left: 0;
                    }

                .mobile-toggle {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .topbar {
                    padding: 0 1rem;
                }

                .content {
                    padding: 1rem;
                }

                .user-info {
                    display: none;
                }

                .profile-link {
                    padding: 6px 10px 6px 6px;
                }
            }

            @@media (max-width: 576px) {
                .topbar-left h5 small {
                    display: none;
                }

                .content {
                    padding: 0.75rem;
                }

                .btn-logout {
                    width: 36px;
                    height: 36px;
                }
            }

            /* ============================================================
                               PRINT
                               ============================================================ */
            @@media print {
                .sidebar, .topbar, .btn-logout, .mobile-toggle {
                    display: none !important;
                }

                .main-area {
                    overflow: visible !important;
                }

                .content {
                    padding: 1rem !important;
                    overflow: visible !important;
                }

                .card {
                    box-shadow: none !important;
                    transform: none !important;
                    break-inside: avoid;
                }
            }
    </style>
</head>

<body>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isAuthPage = currentController == "Account" &&
            (currentAction == "Login" || currentAction == "ForgotPassword" || currentAction == "SetPassword");
    }

    @if (!isAuthPage)
    {
        <!-- Mobile Overlay -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

        <div class="app-layout">

            <!-- SIDEBAR -->
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <i class="fas fa-headset"></i>
                    <span>Axis IT</span>
                </div>

                @{
                    var navRole = Context.Session.GetString("UserRole");
                    var navFull = navRole == "Admin" || navRole == "SystemsAdmin";
                    var navHr = navRole == "HR";
                }

                <div class="nav-group">Core</div>
                <a class="nav-item @(currentController == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>

                <a class="nav-item @(currentController == "Tickets" ? "active" : "")"
                   asp-controller="Tickets" asp-action="Index">
                    <i class="fas fa-ticket-alt"></i> Tickets
                    <span class="nav-badge">@(ViewBag.OpenTicketCount ?? 0)</span>
                </a>

                <a class="nav-item @(currentController == "Activity" ? "active" : "")"
                   asp-controller="Activity" asp-action="Index">
                    <i class="fas fa-tasks"></i> Activity Tracker
                </a>

                <a class="nav-item @(currentController == "ExitClearance" && currentAction == "Mine" ? "active" : "")"
                   asp-controller="ExitClearance" asp-action="Mine">
                    <i class="fas fa-file-signature"></i> My Exit Clearance
                </a>

                @if (navFull)
                {
                    <div class="nav-group">Reports</div>
                    <a class="nav-item @(currentController == "Reports" && currentAction != "Hr" ? "active" : "")"
                       asp-controller="Reports" asp-action="Index">
                        <i class="fas fa-chart-pie"></i> Reports
                    </a>
                    <a class="nav-item @(currentController == "Compliance" ? "active" : "")"
                       asp-controller="Compliance" asp-action="Index">
                        <i class="fas fa-scale-balanced"></i> Compliance
                    </a>
                }

                @if (navFull)
                {
                    <div class="nav-group">Administration</div>
                    <a class="nav-item @(currentController == "Users" ? "active" : "")"
                       asp-controller="Users" asp-action="Index">
                        <i class="fas fa-users"></i> Users
                    </a>
                    <a class="nav-item @(currentController == "Departments" ? "active" : "")"
                       asp-controller="Departments" asp-action="Index">
                        <i class="fas fa-building"></i> Departments
                    </a>
                    <a class="nav-item @(currentController == "AuditLogs" ? "active" : "")"
                       asp-controller="AuditLogs" asp-action="Index">
                        <i class="fas fa-history"></i> Audit Logs
                    </a>
                }

                @if (navFull)
                {
                    <div class="nav-group">Security</div>
                    <a class="nav-item @(currentController == "Security" ? "active" : "")"
                       asp-controller="Security" asp-action="Index">
                        <i class="fas fa-shield-halved"></i> Security Dashboard
                    </a>
                    <a class="nav-item @(currentController == "Configuration" ? "active" : "")"
                       asp-controller="Configuration" asp-action="Index">
                        <i class="fas fa-sliders"></i> Configuration
                    </a>
                    <a class="nav-item @(currentController == "Backup" ? "active" : "")"
                       asp-controller="Backup" asp-action="Index">
                        <i class="fas fa-database"></i> Backup &amp; Recovery
                    </a>
                }

                @if (navFull)
                {
                    <div class="nav-group">Operations</div>
                    <a class="nav-item @(currentController == "ActivityCategories" ? "active" : "")"
                       asp-controller="ActivityCategories" asp-action="Index">
                        <i class="fas fa-tags"></i> Categories
                    </a>
                    <a class="nav-item @(currentController == "PaymentSchedule" ? "active" : "")"
                       asp-controller="PaymentSchedule" asp-action="Index">
                        <i class="fas fa-credit-card"></i> Payments
                    </a>
                    <a class="nav-item @(currentController == "MaintenanceRecords" ? "active" : "")"
                       asp-controller="MaintenanceRecords" asp-action="Index">
                        <i class="fas fa-tools"></i> Maintenance
                    </a>
                    <a class="nav-item @(currentController == "UserAccessRights" ? "active" : "")"
                       asp-controller="UserAccessRights" asp-action="Index">
                        <i class="fas fa-user-shield"></i> Access Rights
                    </a>
                }




                @if (navFull)
                {
                    <div class="nav-group">Assets & Security</div>
                    <a class="nav-item @(currentController == "Assets" ? "active" : "")"
                       asp-controller="Assets" asp-action="Index">
                        <i class="fas fa-laptop-code"></i> Assets
                    </a>
                    <a class="nav-item @(currentController == "SSLCertificates" ? "active" : "")"
                       asp-controller="SSLCertificates" asp-action="Index">
                        <i class="fas fa-shield-alt"></i> SSL Tracker
                        <span class="nav-badge">@(ViewBag.ExpiringCertCount ?? 0)</span>
                    </a>
                }

                @if (navFull || navHr)
                {
                    <div class="nav-group">HR Management</div>
                    @if (navHr)
                    {
                        <a class="nav-item @(currentController == "Reports" && currentAction == "Hr" ? "active" : "")"
                           asp-controller="Reports" asp-action="Hr">
                            <i class="fas fa-chart-pie"></i> HR Report
                        </a>
                    }
                    <a class="nav-item @(currentController == "ExitClearance" && currentAction != "Mine" ? "active" : "")"
                       asp-controller="ExitClearance" asp-action="Index">
                        <i class="fas fa-file-signature"></i>
                        Exit Clearance
                        <span class="nav-badge">@(ViewBag.PendingClearances ?? 0)</span>
                    </a>
                    <a class="nav-item @(currentController == "ExitInterview" ? "active" : "")"
                       asp-controller="ExitInterview" asp-action="Index">
                        <i class="fas fa-clipboard-list"></i>
                        Exit Interview
                    </a>
                    <a class="nav-item @(currentController == "EngagementStayInterview" ? "active" : "")"
                       asp-controller="EngagementStayInterview" asp-action="Index">
                        <i class="fas fa-user-friends"></i>
                        Engagement Stay Interview
                    </a>
                    <a class="nav-item @(currentController == "TalentIdentification" ? "active" : "")"
                       asp-controller="TalentIdentification" asp-action="Index">
                        <i class="fas fa-user-tie"></i>
                        Talent Identification
                    </a>
                }
            </aside>

            <!-- MAIN AREA -->
            <div class="main-area">

                <!-- TOPBAR -->
                <div class="topbar">
                    <div class="topbar-left">
                        <button class="mobile-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
                            <i class="fas fa-bars"></i>
                        </button>
                        <h5>
                            @ViewData["Title"]
                            <small>Axis IT Operations</small>
                        </h5>
                    </div>

                    <!-- User Profile -->
                    <div class="user-profile">
                        <a asp-controller="Users" asp-action="Profile" class="profile-link">
                            <div class="user-avatar">
                                @{
                                    var userName = Context.Session.GetString("UserName");
                                    var initial = string.IsNullOrEmpty(userName) ? "U" : userName.Substring(0, 1).ToUpper();
                                }
                                @initial
                            </div>
                            <div class="user-info">
                                <div class="user-name">@Context.Session.GetString("UserName")</div>
                                <div class="user-role">@Context.Session.GetString("UserRole")</div>
                            </div>
                        </a>

                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-logout" title="Logout">
                                <i class="fas fa-sign-out-alt"></i>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- CONTENT -->
                <main class="content fade-in">
                    @RenderBody()
                </main>

            </div>
        </div>
    }
    else
    {
        <main style="background: var(--bg-main); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
            @RenderBody()
        </main>
    }

    <!-- jQuery + Toastr (global notifications) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.js"></script>
    <script>
        // Global Toastr configuration + helper.
        toastr.options = {
            closeButton: true,
            progressBar: true,
            newestOnTop: true,
            positionClass: "toast-top-right",
            timeOut: 4000,
            extendedTimeOut: 1500,
            preventDuplicates: true
        };
        // Convenience global so any page/script can raise a toast.
        window.notify = function (type, message, title) {
            if (!message) return;
            (toastr[type] || toastr.info)(message, title || "");
        };
    </script>

    @* Bridge server-side TempData/ViewBag messages to Toastr on page load *@
    @{
        var _toastSuccess = TempData["Success"] as string ?? ViewBag.Success as string;
        var _toastError = TempData["Error"] as string ?? ViewBag.Error as string;
        var _toastInfo = TempData["Info"] as string ?? ViewBag.Info as string;
        var _toastWarning = TempData["Warning"] as string ?? ViewBag.Warning as string;
    }
    @if (_toastSuccess != null || _toastError != null || _toastInfo != null || _toastWarning != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                @if (_toastSuccess != null) { <text>toastr.success(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(_toastSuccess)));</text> }
                @if (_toastError != null) { <text>toastr.error(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(_toastError)));</text> }
                @if (_toastInfo != null) { <text>toastr.info(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(_toastInfo)));</text> }
                @if (_toastWarning != null) { <text>toastr.warning(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(_toastWarning)));</text> }
            });
        </script>
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Sidebar toggle with overlay
        function toggleSidebar() {
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebarOverlay");
        sidebar.classList.toggle("active");
        if (sidebar.classList.contains("active")) {
        overlay.classList.add("active");
        document.body.style.overflow = "hidden";
        } else {
        overlay.classList.remove("active");
        document.body.style.overflow = "";
        }
        }

        function closeSidebar() {
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebarOverlay");
        sidebar.classList.remove("active");
        overlay.classList.remove("active");
        document.body.style.overflow = "";
        }

        // Close sidebar on resize to desktop
        window.addEventListener('resize', function() {
        if (window.innerWidth > 992) {
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebarOverlay");
        if (sidebar.classList.contains("active")) {
        sidebar.classList.remove("active");
        overlay.classList.remove("active");
        document.body.style.overflow = "";
        }
        }
        });

        // Topbar shadow on scroll
        document.addEventListener("DOMContentLoaded", function() {
        const mainContent = document.querySelector('.content');
        const topbar = document.querySelector('.topbar');
        if (mainContent && topbar) {
        mainContent.addEventListener('scroll', function() {
        if (mainContent.scrollTop > 10) {
        topbar.style.boxShadow = '0 4px 20px rgba(0,0,0,0.06)';
        topbar.style.background = 'rgba(255,255,255,0.85)';
        } else {
        topbar.style.boxShadow = 'none';
        topbar.style.background = 'rgba(255,255,255,0.75)';
        }
        });
        }

        // Active nav item highlight enhancement
        const navItems = document.querySelectorAll('.nav-item');
        navItems.forEach(item => {
        item.addEventListener('click', function(e) {
        if (!e.ctrlKey && !e.metaKey) {
        this.style.transition = 'all 0.15s';
        this.style.transform = 'translateX(2px)';
        setTimeout(() => {
        this.style.transform = '';
        }, 120);
        }
        });
        });
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>