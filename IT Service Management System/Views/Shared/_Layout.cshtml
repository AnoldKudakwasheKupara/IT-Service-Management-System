<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IT Service Management System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IT_Service_Management_System.styles.css" asp-append-version="true" />
</head>
<body>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isLoginPage = currentController == "Account" && currentAction == "Login";
    }

    <!-- 🔹 NAVBAR (HIDDEN ON LOGIN PAGE) -->
    @if (!isLoginPage)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">

                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        Axis IT Helpdesk
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                        <!-- LEFT MENU -->
                        <ul class="navbar-nav flex-grow-1">

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                                    Home
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">
                                    Privacy
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Tickets" asp-action="Index">
                                    Tickets
                                </a>
                            </li>

                            @if (Context.Session.GetString("UserRole") == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Users" asp-action="Index">
                                        Users
                                    </a>
                                </li>
                            }

                        </ul>

                        <!-- RIGHT MENU -->
                        <ul class="navbar-nav">

                            @if (Context.Session.GetString("UserName") != null)
                            {
                                <li class="nav-item d-flex align-items-center me-3">
                                    <span>
                                        👤 @Context.Session.GetString("UserName")
                                        (@Context.Session.GetString("UserRole"))
                                    </span>
                                </li>

                                <li class="nav-item">
                                    <a class="btn btn-danger btn-sm"
                                           asp-controller="Account"
                                           asp-action="Logout">
                                        Logout
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="btn btn-primary btn-sm"
                                           asp-controller="Account"
                                           asp-action="Login">
                                        Login
                                    </a>
                                </li>
                            }

                        </ul>

                    </div>
                </div>
            </nav>
        </header>
    }

    <!-- 🔹 MAIN CONTENT -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- 🔹 FOOTER (HIDDEN ON LOGIN PAGE) -->
    @if (!isLoginPage)
    {
        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Axis IT Helpdesk -
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>