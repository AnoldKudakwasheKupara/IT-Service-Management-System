<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Axis IT Helpdesk</title>
    <script type="importmap"></script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IT_Service_Management_System.styles.css" asp-append-version="true" />

    
    <style>
            /* Modern Global Styles */
            :root {
                --primary-dark: #1e4c6b;
                --primary: #2c7da0;
                --primary-light: #61a5c2;
                --secondary: #2c3e4e;
                --success: #2c9e6e;
                --danger: #e53e3e;
                --warning: #f5b042;
                --info: #3b82f6;
                --gray-50: #f8fafc;
                --gray-100: #f1f5f9;
                --gray-200: #e2e8f0;
                --gray-300: #cbd5e1;
                --gray-400: #94a3b8;
                --gray-500: #64748b;
                --gray-600: #475569;
                --gray-700: #334155;
                --gray-800: #1e293b;
                --gray-900: #0f172a;
                --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
                --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
                --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
                --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                background: linear-gradient(135deg, #f5f7fa 0%, #eef2f6 100%);
                color: var(--gray-800);
                line-height: 1.5;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* Modern Navbar - Fixed positioning */
            .navbar-modern {
                background: white;
                box-shadow: var(--shadow-sm);
                border-bottom: 1px solid var(--gray-200);
                padding: 0;
                position: sticky;
                top: 0;
                z-index: 1030;
            }

            .navbar-container {
                max-width: 1400px;
                margin: 0 auto;
                padding: 0.75rem 1.5rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                flex-wrap: wrap;
            }

            .navbar-brand-modern {
                font-weight: 700;
                font-size: 1.35rem;
                color: var(--primary-dark);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                white-space: nowrap;
            }

                .navbar-brand-modern:hover {
                    color: var(--primary);
                }

                .navbar-brand-modern i {
                    font-size: 1.5rem;
                    color: var(--primary);
                }

            /* Navigation Menu */
            .navbar-menu {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                flex-wrap: wrap;
            }

            .nav-links {
                display: flex;
                align-items: center;
                gap: 0.25rem;
                list-style: none;
                margin: 0;
                padding: 0;
            }

            .nav-item {
                list-style: none;
            }

            .nav-link-modern {
                color: var(--gray-600);
                font-weight: 500;
                padding: 0.5rem 1rem;
                border-radius: 0.5rem;
                text-decoration: none;
                transition: all 0.2s ease;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                font-size: 0.9rem;
            }

                .nav-link-modern:hover {
                    color: var(--primary);
                    background-color: var(--gray-100);
                }

                .nav-link-modern.active {
                    color: var(--primary);
                    background-color: rgba(44, 125, 160, 0.08);
                    font-weight: 600;
                }

            /* User Section */
            .user-section {
                display: flex;
                align-items: center;
                gap: 1rem;
                margin-left: 1rem;
            }

            .user-profile {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.25rem 0.75rem;
                background: var(--gray-100);
                border-radius: 2rem;
                transition: all 0.2s;
            }

            .user-avatar {
                width: 36px;
                height: 36px;
                background: linear-gradient(135deg, var(--primary), var(--primary-light));
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 600;
                font-size: 0.875rem;
            }

            .user-info {
                display: flex;
                flex-direction: column;
                line-height: 1.3;
            }

            .user-name {
                font-weight: 600;
                font-size: 0.875rem;
                color: var(--gray-800);
            }

            .user-role {
                font-size: 0.7rem;
                color: var(--gray-500);
            }

            /* Modern Buttons */
            .btn-modern {
                padding: 0.5rem 1.25rem;
                border-radius: 0.5rem;
                font-weight: 600;
                font-size: 0.875rem;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                text-decoration: none;
                border: none;
                cursor: pointer;
            }

            .btn-modern-primary {
                background: linear-gradient(100deg, var(--primary-dark), var(--primary));
                color: white;
            }

                .btn-modern-primary:hover {
                    transform: translateY(-1px);
                    box-shadow: var(--shadow-md);
                    color: white;
                }

            .btn-modern-danger {
                background: linear-gradient(100deg, #c53030, var(--danger));
                color: white;
            }

                .btn-modern-danger:hover {
                    transform: translateY(-1px);
                    box-shadow: var(--shadow-md);
                    color: white;
                }

            /* Main Content Area - Fixed spacing */
            .main-content {
                flex: 1;
                padding: 2rem 0;
            }

            .container-custom {
                max-width: 1400px;
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            /* Modern Footer */
            .footer-modern {
                background: white;
                border-top: 1px solid var(--gray-200);
                padding: 1.5rem 0;
                margin-top: auto;
                color: var(--gray-500);
                font-size: 0.875rem;
            }

            .footer-container {
                max-width: 1400px;
                margin: 0 auto;
                padding: 0 1.5rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 1rem;
            }

            .footer-modern a {
                color: var(--primary);
                text-decoration: none;
                transition: color 0.2s;
            }

                .footer-modern a:hover {
                    color: var(--primary-dark);
                    text-decoration: underline;
                }

            /* Mobile Toggle Button */
            .navbar-toggler {
                display: none;
                background: none;
                border: none;
                font-size: 1.5rem;
                cursor: pointer;
                color: var(--gray-600);
                padding: 0.5rem;
            }


            /* Card styling for consistency */
            .card-modern {
                background: white;
                border: none;
                border-radius: 1rem;
                box-shadow: var(--shadow-sm);
                transition: all 0.3s ease;
            }

                .card-modern:hover {
                    box-shadow: var(--shadow-md);
                }

            /* Alert styling */
            .alert-modern {
                border-radius: 0.75rem;
                border: none;
                padding: 1rem;
                margin-bottom: 1rem;
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }

            /* Scrollbar Styling */
            ::-webkit-scrollbar {
                width: 8px;
                height: 8px;
            }

            ::-webkit-scrollbar-track {
                background: var(--gray-100);
            }

            ::-webkit-scrollbar-thumb {
                background: var(--gray-400);
                border-radius: 4px;
            }

                ::-webkit-scrollbar-thumb:hover {
                    background: var(--gray-500);
                }
    </style>
</head>
<body>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isLoginPage = currentController == "Account" && currentAction == "Login";
        var isForgotPasswordPage = currentController == "Account" && currentAction == "ForgotPassword";
        var isSetPasswordPage = currentController == "Account" && currentAction == "SetPassword";
        
        // Hide navbar and footer on authentication pages
        var isAuthPage = isLoginPage || isForgotPasswordPage || isSetPasswordPage;
    }

    <!-- MODERN NAVBAR (HIDDEN ON AUTH PAGES) -->
    @if (!isAuthPage)
    {
        <nav class="navbar-modern">
            <div class="navbar-container">
                <a class="navbar-brand-modern" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-headset"></i>
                    <span>Axis IT Helpdesk</span>
                </a>

                <button class="navbar-toggler" type="button" onclick="toggleMenu()">
                    <i class="fas fa-bars"></i>
                </button>

                <div class="navbar-menu" id="navbarMenu">
                    <ul class="nav-links">
                        <li class="nav-item">
                            <a class="nav-link-modern @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                                   asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i>
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link-modern @(currentController == "Tickets" ? "active" : "")"
                                   asp-controller="Tickets" asp-action="Index">
                                <i class="fas fa-ticket-alt"></i>
                                Tickets
                            </a>
                        </li>

                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link-modern @(currentController == "Users" ? "active" : "")"
                                       asp-controller="Users" asp-action="Index">
                                    <i class="fas fa-users"></i>
                                    Users
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link-modern @(currentController == "Home" && currentAction == "Privacy" ? "active" : "")"
                                   asp-controller="Home" asp-action="Privacy">
                                <i class="fas fa-shield-alt"></i>
                                Privacy
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link-modern @(currentController == "AuditLogs" ? "active" : "")"
                                   asp-controller="AuditLogs" asp-action="Index">
                                <i class="fas fa-users"></i>
                                Audit Logs
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link-modern @(currentController == "Assets" ? "active" : "")"
                                   asp-controller="Assets" asp-action="Index">
                                <i class="fas fa-laptop"></i>
                                Asset Register
                                </a>
                        </li>
                    </ul>



                    <div class="user-section">
                        @if (Context.Session.GetString("UserName") != null)
                        {
                            <div class="user-profile">
                                <div class="user-avatar">
                                    @Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper()
                                </div>
                                <div class="user-info">
                                    <a asp-controller="Users" asp-action="Profile" class="text-decoration-none">
                                        👤 @Context.Session.GetString("UserName")
                                        (@Context.Session.GetString("UserRole"))
                                    </a>
                                </div>
                            </div>
                            <a class="btn-modern btn-modern-danger"
                                   asp-controller="Account" asp-action="Logout">
                                <i class="fas fa-sign-out-alt"></i>
                                Logout
                            </a>
                        }
                        else
                        {
                            <a class="btn-modern btn-modern-primary"
                                   asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt"></i>
                                Login
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    }

    <!-- MAIN CONTENT AREA -->
    <div class="main-content">
        <div class="container-custom">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- MODERN FOOTER (HIDDEN ON AUTH PAGES) -->
    @if (!isAuthPage)
    {
        <footer class="footer-modern">
            <div class="footer-container">
                <div>
                    <span>&copy; @DateTime.Now.Year - Axis IT Helpdesk</span>
                    <span class="mx-2">•</span>
                    <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <span class="mx-2">•</span>
                    <a href="#" id="supportLink">Support</a>
                </div>
                <div>
                    <span class="me-2">
                        <i class="fas fa-shield-alt text-success"></i> SSL Secured
                    </span>
                    <span>
                        <i class="fas fa-chart-line text-primary"></i> v2.0
                    </span>
                </div>
            </div>
        </footer>
    }

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // Mobile menu toggle
        function toggleMenu() {
        const menu = document.getElementById('navbarMenu');
        menu.classList.toggle('active');
        }

        // Close mobile menu when clicking a link
        document.querySelectorAll('.nav-link-modern').forEach(link => {
        link.addEventListener('click', () => {
        const menu = document.getElementById('navbarMenu');
        if (menu.classList.contains('active')) {
        menu.classList.remove('active');
        }
        });
        });

        document.addEventListener('DOMContentLoaded', function() {
        // Auto-hide alerts after 5 seconds
        const alerts = document.querySelectorAll('.alert-modern:not(.persistent)');
        alerts.forEach(alert => {
        setTimeout(() => {
        alert.style.transition = 'opacity 0.3s';
        alert.style.opacity = '0';
        setTimeout(() => alert.remove(), 300);
        }, 5000);
        });
            
        // Support link functionality
        const supportLink = document.getElementById('supportLink');
        if (supportLink) {
        supportLink.addEventListener('click', function(e) {
        e.preventDefault();
        showSupportNotification();
        });
        }
            
        function showSupportNotification() {
        const toast = document.createElement('div');
        toast.className = 'position-fixed bottom-0 end-0 p-3';
        toast.style.zIndex = '1050';
        toast.innerHTML = `
        <div class="bg-white rounded-lg shadow-lg p-3" style="min-width: 250px; border-left: 4px solid #2c7da0;">
        <div class="d-flex justify-content-between align-items-start mb-2">
        <strong class="text-primary">
        <i class="fas fa-headset me-2"></i>Axis IT Support
        </strong>
        <button type="button" class="btn-close" onclick="this.closest('.position-fixed').remove()"></button>
        </div>
        <div class="small">
        <div><i class="fas fa-envelope me-2 text-muted"></i> support@axisit.com</div>
        <div class="mt-1"><i class="fas fa-phone me-2 text-muted"></i> +1 (555) 123-4567</div>
        <hr class="my-2">
        <div class="text-muted">Available 24/7 for urgent issues</div>
        </div>
        </div>
        `;
        document.body.appendChild(toast);
        setTimeout(() => {
        toast.remove();
        }, 8000);
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>