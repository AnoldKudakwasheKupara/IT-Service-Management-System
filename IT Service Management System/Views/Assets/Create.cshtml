@model IT_Service_Management_System.ViewModels.AssetCreateViewModel

@{
    ViewData["Title"] = "Add Asset Record - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-plus-circle me-2" style="color: var(--success);"></i>
                    Add Asset Record
                </h1>
                <p class="text-muted mt-2">Create a new asset record for IT equipment tracking</p>
            </div>
        </div>
    </div>

    <div class="add-asset-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-box me-2"></i>
                <span>Asset Information</span>
            </div>
            <div class="form-steps">
                <span class="step active">1</span>
                <span class="step-line"></span>
                <span class="step">2</span>
                <span class="step-line"></span>
                <span class="step">3</span>
            </div>
        </div>

        <form asp-action="Create" method="post" id="createAssetForm">
            @Html.AntiForgeryToken()
            
            <div class="card-body-custom">
                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Asset.Date" class="form-label">
                                <i class="fas fa-calendar"></i>
                                Transaction Date
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-alt input-icon"></i>
                                <input asp-for="Asset.Date" type="date" class="form-control-modern" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>
                            <span asp-validation-for="Asset.Date" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Date when the asset was issued or returned
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Asset.UserId" class="form-label">
                                <i class="fas fa-user"></i>
                                User
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="Asset.UserId" class="form-control-modern">
                                    <option value="">-- Select User --</option>
                                    @foreach (var user in Model.Users)
                                    {
                                        <option value="@user.Id">
                                            @user.FirstName @user.LastName
                                        </option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="Asset.UserId" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> User who received or returned the asset
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Asset.ItemName" class="form-label">
                                <i class="fas fa-laptop"></i>
                                Item Name
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-box input-icon"></i>
                                <input asp-for="Asset.ItemName" class="form-control-modern" placeholder="Enter item name (e.g., Laptop, Monitor, Mouse)" />
                            </div>
                            <span asp-validation-for="Asset.ItemName" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Name of the asset being tracked
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Asset.SerialNumber" class="form-label">
                                <i class="fas fa-barcode"></i>
                                Serial Number
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-qrcode input-icon"></i>
                                <input asp-for="Asset.SerialNumber" class="form-control-modern" placeholder="Enter serial number or asset tag" />
                            </div>
                            <span asp-validation-for="Asset.SerialNumber" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Unique serial number or asset identification code
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Asset.ActionType" class="form-label">
                                <i class="fas fa-exchange-alt"></i>
                                Action Type
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="Asset.ActionType" class="form-control-modern" id="actionSelect">
                                    <option value="Issued">Issued</option>
                                    <option value="Returned">Returned</option>
                                </select>
                            </div>
                            <span asp-validation-for="Asset.ActionType" class="validation-message text-danger"></span>
                            <div class="action-info" id="actionInfo">
                                <i class="fas fa-info-circle"></i>
                                <span id="actionDescription"></span>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Asset.Condition" class="form-label">
                                <i class="fas fa-chart-line"></i>
                                Condition
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="Asset.Condition" class="form-control-modern" id="conditionSelect">
                                    <option value="New">New</option>
                                    <option value="Good">Good</option>
                                    <option value="Fair">Fair</option>
                                    <option value="Poor">Poor</option>
                                </select>
                            </div>
                            <span asp-validation-for="Asset.Condition" class="validation-message text-danger"></span>
                            <div class="condition-info" id="conditionInfo">
                                <i class="fas fa-info-circle"></i>
                                <span id="conditionDescription"></span>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Asset.IssuedBy" class="form-label">
                                <i class="fas fa-user-check"></i>
                                Issued By
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-signature input-icon"></i>
                                <input asp-for="Asset.IssuedBy" class="form-control-modern" placeholder="Name of person issuing the asset" />
                            </div>
                            <span asp-validation-for="Asset.IssuedBy" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Staff member who processed this transaction
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Asset.Remarks" class="form-label">
                                <i class="fas fa-comment"></i>
                                Remarks
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-pen textarea-icon"></i>
                                <textarea asp-for="Asset.Remarks" class="form-control-textarea" rows="3" placeholder="Additional notes or comments about this asset..."></textarea>
                            </div>
                            <span asp-validation-for="Asset.Remarks" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Any additional information about this asset transaction
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tips Section -->
                <div class="tips-section">
                    <div class="tips-header">
                        <i class="fas fa-lightbulb"></i>
                        <span>Asset Management Tips</span>
                    </div>
                    <div class="tips-grid">
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Use accurate serial numbers for tracking</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Document asset condition clearly</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Include purchase date if known in remarks</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Update condition when asset is returned</span>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-save" id="submitBtn">
                        <i class="fas fa-save"></i>
                        Save Asset Record
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Add Asset Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Add Asset Card */
    .add-asset-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .form-steps {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .step {
        width: 30px;
        height: 30px;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

    .step.active {
        background: var(--success);
        border-color: var(--success);
        color: white;
    }

    .step-line {
        width: 40px;
        height: 2px;
        background: var(--gray-300);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label i {
        color: var(--primary);
        font-size: 0.875rem;
    }

    .required {
        color: var(--danger);
        font-size: 1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .input-icon-wrapper i.input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

    .form-control-modern:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    /* Textarea Styling */
    .textarea-wrapper {
        position: relative;
    }

    .textarea-icon {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
        resize: vertical;
    }

    .form-control-textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    /* Select Styling */
    .select-wrapper {
        position: relative;
    }

    .select-wrapper select {
        appearance: none;
        cursor: pointer;
        background: white;
    }

    .select-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        pointer-events: none;
        font-size: 0.75rem;
    }

    /* Action & Condition Info */
    .action-info, .condition-info {
        background: var(--gray-50);
        padding: 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-left: 3px solid var(--primary);
    }

    .action-info i, .condition-info i {
        color: var(--primary);
    }

    /* Tips Section */
    .tips-section {
        background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 2rem;
        border-left: 3px solid var(--info);
    }

    .tips-header {
        font-weight: 600;
        color: var(--info);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .tips-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 0.75rem;
    }

    .tip-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        color: var(--gray-700);
    }

    .tip-item i {
        color: var(--success);
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-hint i {
        font-size: 0.7rem;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-save {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-cancel:hover {
        background: var(--gray-50);
        color: var(--gray-700);
        text-decoration: none;
    }


</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Action descriptions
        const actionSelect = document.getElementById('actionSelect');
        const actionDescription = document.getElementById('actionDescription');
        
        const actionDescriptions = {
            'Issued': 'Asset is being issued to the selected user',
            'Returned': 'Asset is being returned from the selected user'
        };
        
        function updateActionDescription() {
            var selectedAction = actionSelect.value;
            if (selectedAction && actionDescriptions[selectedAction]) {
                actionDescription.textContent = actionDescriptions[selectedAction];
                
                // Update visual styling
                var actionInfo = document.getElementById('actionInfo');
                if (selectedAction === 'Issued') {
                    actionInfo.style.borderLeftColor = 'var(--success)';
                    actionInfo.querySelector('i').style.color = 'var(--success)';
                } else {
                    actionInfo.style.borderLeftColor = 'var(--warning)';
                    actionInfo.querySelector('i').style.color = 'var(--warning)';
                }
            }
        }
        
        if (actionSelect) {
            updateActionDescription();
            actionSelect.addEventListener('change', updateActionDescription);
        }
        
        // Condition descriptions
        const conditionSelect = document.getElementById('conditionSelect');
        const conditionDescription = document.getElementById('conditionDescription');
        
        const conditionDescriptions = {
            'New': 'Brand new, never used, in original packaging',
            'Good': 'Well-maintained, fully functional, minor signs of use',
            'Fair': 'Some wear and tear, fully functional',
            'Poor': 'Significant wear, may require maintenance or replacement'
        };
        
        function updateConditionDescription() {
            var selectedCondition = conditionSelect.value;
            if (selectedCondition && conditionDescriptions[selectedCondition]) {
                conditionDescription.textContent = conditionDescriptions[selectedCondition];
                
                // Update visual styling
                var conditionInfo = document.getElementById('conditionInfo');
                if (selectedCondition === 'New') {
                    conditionInfo.style.borderLeftColor = 'var(--info)';
                    conditionInfo.querySelector('i').style.color = 'var(--info)';
                } else if (selectedCondition === 'Good') {
                    conditionInfo.style.borderLeftColor = 'var(--success)';
                    conditionInfo.querySelector('i').style.color = 'var(--success)';
                } else if (selectedCondition === 'Fair') {
                    conditionInfo.style.borderLeftColor = 'var(--warning)';
                    conditionInfo.querySelector('i').style.color = 'var(--warning)';
                } else {
                    conditionInfo.style.borderLeftColor = 'var(--danger)';
                    conditionInfo.querySelector('i').style.color = 'var(--danger)';
                }
            }
        }
        
        if (conditionSelect) {
            updateConditionDescription();
            conditionSelect.addEventListener('change', updateConditionDescription);
        }
        
        // Form validation
        const form = document.getElementById('createAssetForm');
        const submitBtn = document.getElementById('submitBtn');
        
        if (form) {
            form.addEventListener('submit', function(e) {
                var date = document.querySelector('[name="Asset.Date"]').value;
                var userId = document.querySelector('[name="Asset.UserId"]').value;
                var itemName = document.querySelector('[name="Asset.ItemName"]').value.trim();
                var serialNumber = document.querySelector('[name="Asset.SerialNumber"]').value.trim();
                var actionType = actionSelect.value;
                var condition = conditionSelect.value;
                var issuedBy = document.querySelector('[name="Asset.IssuedBy"]').value.trim();
                
                if (!date) {
                    e.preventDefault();
                    showValidationError('Transaction date is required');
                    document.querySelector('[name="Asset.Date"]').focus();
                    return false;
                }
                
                if (!userId) {
                    e.preventDefault();
                    showValidationError('Please select a user');
                    document.querySelector('[name="Asset.UserId"]').focus();
                    return false;
                }
                
                if (!itemName) {
                    e.preventDefault();
                    showValidationError('Item name is required');
                    document.querySelector('[name="Asset.ItemName"]').focus();
                    return false;
                }
                
                if (itemName.length < 2) {
                    e.preventDefault();
                    showValidationError('Item name must be at least 2 characters');
                    document.querySelector('[name="Asset.ItemName"]').focus();
                    return false;
                }
                
                if (!serialNumber) {
                    e.preventDefault();
                    showValidationError('Serial number is required');
                    document.querySelector('[name="Asset.SerialNumber"]').focus();
                    return false;
                }
                
                if (!actionType) {
                    e.preventDefault();
                    showValidationError('Please select an action type');
                    actionSelect.focus();
                    return false;
                }
                
                if (!condition) {
                    e.preventDefault();
                    showValidationError('Please select a condition');
                    conditionSelect.focus();
                    return false;
                }
                
                if (!issuedBy) {
                    e.preventDefault();
                    showValidationError('Issued by field is required');
                    document.querySelector('[name="Asset.IssuedBy"]').focus();
                    return false;
                }
                
                if (issuedBy.length < 2) {
                    e.preventDefault();
                    showValidationError('Issued by name must be at least 2 characters');
                    document.querySelector('[name="Asset.IssuedBy"]').focus();
                    return false;
                }
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving Asset Record...';
                
                return true;
            });
        }
        
        function showValidationError(message) {
            var errorDiv = document.querySelector('.validation-toast');
            if (errorDiv) errorDiv.remove();
            
            errorDiv = document.createElement('div');
            errorDiv.className = 'validation-toast';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
                animation: slideIn 0.3s ease;
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(errorDiv);
            
            setTimeout(function() {
                errorDiv.style.animation = 'slideOut 0.3s ease';
                setTimeout(function() { errorDiv.remove(); }, 300);
            }, 4000);
        }
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}