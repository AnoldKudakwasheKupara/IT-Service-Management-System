@model IT_Service_Management_System.ViewModels.AssetCreateViewModel

@{
    ViewData["Title"] = "Edit Asset Record";
}

<h2>Edit Asset Record</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Asset.Id" />

    <div class="form-group mb-3">
        <label>Date</label>
        <input asp-for="Asset.Date" type="date" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>User</label>
        <select asp-for="Asset.UserId" class="form-control">
            <option value="">-- Select User --</option>

            @foreach (var user in Model.Users)
            {
                <option value="@user.Id"
                        selected="@(user.Id == Model.Asset.UserId)">
                    @user.FirstName @user.LastName
                </option>
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Item Name</label>
        <input asp-for="Asset.ItemName" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Serial Number</label>
        <input asp-for="Asset.SerialNumber" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Action</label>
        <select asp-for="Asset.ActionType" class="form-control">
            <option value="Issued" selected="@(Model.Asset.ActionType == "Issued")">Issued</option>
            <option value="Returned" selected="@(Model.Asset.ActionType == "Returned")">Returned</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Condition</label>
        <select asp-for="Asset.Condition" class="form-control">
            <option value="New" selected="@(Model.Asset.Condition == "New")">New</option>
            <option value="Old" selected="@(Model.Asset.Condition == "Old")">Old</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Issued By</label>
        <input asp-for="Asset.IssuedBy" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Remarks</label>
        <input asp-for="Asset.Remarks" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Update</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}