@model IT_Service_Management_System.Models.Asset

@{
    ViewData["Title"] = "Edit Asset Record";
}

<h2>Edit Asset Record</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label>Date</label>
        <input asp-for="Date" type="date" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>User</label>
        <select asp-for="UserId" asp-items="ViewBag.Users" class="form-control">
            <option value="">-- Select User --</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Item Name</label>
        <input asp-for="ItemName" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Serial Number</label>
        <input asp-for="SerialNumber" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Action</label>
        <select asp-for="ActionType" class="form-control">
            <option value="Issued" selected="@(Model.ActionType == "Issued")">Issued</option>
            <option value="Returned" selected="@(Model.ActionType == "Returned")">Returned</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Condition</label>
        <select asp-for="Condition" class="form-control">
            <option value="New" selected="@(Model.Condition == "New")">New</option>
            <option value="Old" selected="@(Model.Condition == "Old")">Old</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Issued By</label>
        <input asp-for="IssuedBy" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Remarks</label>
        <input asp-for="Remarks" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Update</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}