@model IEnumerable<IT_Service_Management_System.Models.Asset>

@{
    ViewData["Title"] = "Asset Register - Axis IT Helpdesk";
    var searchTerm = Context.Request.Query["search"].ToString();
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title">
                    <i class="fas fa-boxes me-2" style="color: var(--primary);"></i>
                    Asset Register
                </h1>
                <p class="text-muted mt-2">Manage and track all IT assets and equipment</p>
            </div>
            <a asp-action="Create" class="btn-create-asset">
                <i class="fas fa-plus-circle me-2"></i>
                Add New Asset
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-cards mb-4">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-box"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count()</h3>
                <p>Total Assets</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon issued">
                <i class="fas fa-hand-holding"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(a => a.ActionType == "Issued")</h3>
                <p>Issued Assets</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon returned">
                <i class="fas fa-undo-alt"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(a => a.ActionType == "Returned")</h3>
                <p>Returned Assets</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon new">
                <i class="fas fa-star"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(a => a.Condition == "New")</h3>
                <p>New Condition</p>
            </div>
        </div>
    </div>

    <!-- Search Section -->
    <div class="search-card">
        <div class="search-header">
            <i class="fas fa-search"></i>
            <span>Search Assets</span>
        </div>
        <form method="get" class="search-body">
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" name="search" class="search-input" 
                       placeholder="Search by item name, serial number, user, or remarks..." 
                       value="@searchTerm" />
                <button type="submit" class="btn-search">
                    <i class="fas fa-search"></i>
                    Search
                </button>
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <a asp-action="Index" class="btn-clear-search">
                        <i class="fas fa-times"></i>
                        Clear
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Assets Table -->
    <div class="assets-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-list me-2"></i>
                <span>Asset Records</span>
            </div>
            <div class="asset-count">
                <i class="fas fa-chart-simple"></i>
                <span>@Model.Count()</span> assets found
            </div>
        </div>

        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="assets-table">
                    <thead>
                        <tr>
                            <th><i class="fas fa-calendar me-1"></i> Date</th>
                            <th><i class="fas fa-user me-1"></i> User</th>
                            <th><i class="fas fa-laptop me-1"></i> Item</th>
                            <th><i class="fas fa-barcode me-1"></i> Serial Number</th>
                            <th><i class="fas fa-exchange-alt me-1"></i> Action</th>
                            <th><i class="fas fa-chart-line me-1"></i> Condition</th>
                            <th><i class="fas fa-user-check me-1"></i> Issued By</th>
                            <th><i class="fas fa-comment me-1"></i> Remarks</th>
                            <th><i class="fas fa-cog me-1"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="date-cell">
                                    <i class="far fa-calendar-alt"></i>
                                    @item.Date.ToString("MMM dd, yyyy")
                                </td>
                                <td class="user-cell">
                                    <div class="user-info">
                                        <div class="user-avatar-small">
                                            @(item.User?.FirstName?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                        <span>@item.User?.FirstName @item.User?.LastName</span>
                                    </div>
                                </td>
                                <td class="item-cell">
                                    <div class="item-info">
                                        <i class="fas @(item.ItemName?.Contains("Laptop") == true ? "fa-laptop" : "fa-mouse")"></i>
                                        <span>@item.ItemName</span>
                                    </div>
                                </td>
                                <td class="serial-cell">
                                    <code>@item.SerialNumber</code>
                                </td>
                                <td>
                                    @if (item.ActionType == "Issued")
                                    {
                                        <span class="action-badge action-issued">
                                            <i class="fas fa-hand-holding"></i> Issued
                                        </span>
                                    }
                                    else if (item.ActionType == "Returned")
                                    {
                                        <span class="action-badge action-returned">
                                            <i class="fas fa-undo-alt"></i> Returned
                                        </span>
                                    }
                                    else if (item.ActionType == "Repair")
                                    {
                                        <span class="action-badge action-repair">
                                            <i class="fas fa-tools"></i> Repair
                                        </span>
                                    }
                                    else if (item.ActionType == "Upgrade")
                                    {
                                        <span class="action-badge action-upgrade">
                                            <i class="fas fa-arrow-up"></i> Upgrade
                                        </span>
                                    }
                                    else if (item.ActionType == "Stolen")
                                    {
                                        <span class="action-badge action-stolen">
                                            <i class="fas fa-exclamation-triangle"></i> Stolen
                                        </span>
                                    }
                                    else if (item.ActionType == "Retired")
                                    {
                                        <span class="action-badge action-retired">
                                            <i class="fas fa-archive"></i> Retired
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (item.Condition == "New")
                                    {
                                        <span class="condition-badge condition-new">
                                            <i class="fas fa-star"></i> New
                                        </span>
                                    }
                                    else if (item.Condition == "Good")
                                    {
                                        <span class="condition-badge condition-good">
                                            <i class="fas fa-check-circle"></i> Good
                                        </span>
                                    }
                                    else if (item.Condition == "Fair")
                                    {
                                        <span class="condition-badge condition-fair">
                                            <i class="fas fa-minus-circle"></i> Fair
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="condition-badge condition-poor">
                                            <i class="fas fa-exclamation-triangle"></i> Poor
                                        </span>
                                    }
                                </td>
                                <td class="issued-by-cell">
                                    <div class="user-info">
                                        <div class="user-avatar-small issued-by">
                                            @(item.IssuedBy?.Substring(0, 1).ToUpper() ?? "S")
                                        </div>
                                        <span>@item.IssuedBy</span>
                                    </div>
                                </td>
                                <td class="remarks-cell" title="@item.Remarks">
                                    @(item.Remarks?.Length > 40 ? item.Remarks.Substring(0, 40) + "..." : item.Remarks)
                                </td>
                                <td class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn btn-edit" title="Edit Asset">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn btn-delete" title="Delete Asset" onclick="return confirm('Are you sure you want to delete this asset record?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-box-open"></i>
                    <h3>No assets found</h3>
                    <p>@(string.IsNullOrEmpty(searchTerm) ? "Get started by adding your first asset record" : "No assets match your search criteria")</p>
                    @if (string.IsNullOrEmpty(searchTerm))
                    {
                        <a asp-action="Create" class="btn-create-asset-sm">
                            <i class="fas fa-plus-circle"></i> Add Asset
                        </a>
                    }
                    else
                    {
                        <a asp-action="Index" class="btn-clear-search-sm">
                            <i class="fas fa-undo-alt"></i> Clear Search
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Asset Register Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Create Asset Button */
    .btn-create-asset {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-sm);
    }

    .btn-create-asset:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        color: white;
        text-decoration: none;
    }

    /* Statistics Cards */
    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .stat-icon.total { background: linear-gradient(135deg, var(--info), #2563eb); color: white; }
    .stat-icon.issued { background: linear-gradient(135deg, var(--success), #059669); color: white; }
    .stat-icon.returned { background: linear-gradient(135deg, var(--warning), #e6a017); color: white; }
    .stat-icon.new { background: linear-gradient(135deg, var(--primary), var(--primary-light)); color: white; }

    .stat-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-800);
    }

    .stat-info p {
        margin: 0;
        color: var(--gray-500);
        font-size: 0.875rem;
    }

    /* Search Card */
    .search-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
        margin-bottom: 1.5rem;
    }

    .search-header {
        background: var(--gray-50);
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .search-body {
        padding: 1.5rem;
    }

    .search-wrapper {
        position: relative;
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .search-wrapper > i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 1rem;
        pointer-events: none;
    }

    .search-input {
        flex: 1;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        font-size: 0.875rem;
        transition: all 0.2s;
        font-family: 'Inter', sans-serif;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    .btn-search {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

    .btn-search:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
    }

    .btn-clear-search {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid var(--gray-300);
        transition: all 0.2s;
    }

    .btn-clear-search:hover {
        background: var(--gray-50);
        color: var(--gray-700);
        text-decoration: none;
    }

    /* Assets Card */
    .assets-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .asset-count {
        font-size: 0.875rem;
        font-weight: normal;
        color: var(--gray-500);
    }

    /* Table Styles */
    .assets-table {
        width: 100%;
        border-collapse: collapse;
    }

    .assets-table thead {
        background: var(--gray-50);
        border-bottom: 2px solid var(--gray-200);
    }

    .assets-table th {
        padding: 1rem 1.5rem;
        text-align: left;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .assets-table td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        vertical-align: middle;
        font-size: 0.875rem;
    }

    .assets-table tbody tr:hover {
        background-color: var(--gray-50);
    }

    /* User Info */
    .user-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .user-avatar-small {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.75rem;
        flex-shrink: 0;
    }

    .user-avatar-small.issued-by {
        background: linear-gradient(135deg, var(--gray-500), var(--gray-600));
    }

    /* Item Info */
    .item-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .item-info i {
        color: var(--primary);
        font-size: 1rem;
    }

    /* Serial Number */
    .serial-cell code {
        background: var(--gray-100);
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-family: monospace;
    }

    /* Action Badges */
    .action-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .action-issued {
        background: #e6f5e9;
        color: var(--success);
    }

    .action-returned {
        background: #fff5e6;
        color: var(--warning);
    }

    /* Condition Badges */
    .condition-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .condition-new {
        background: #e6f0ff;
        color: var(--info);
    }

    .condition-good {
        background: #e6f5e9;
        color: var(--success);
    }

    .condition-fair {
        background: #fff5e6;
        color: var(--warning);
    }

    .condition-poor {
        background: #fee;
        color: var(--danger);
    }

    /* Remarks Cell */
    .remarks-cell {
        max-width: 200px;
        color: var(--gray-600);
        cursor: help;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

    .btn-view {
        background: var(--gray-100);
        color: var(--info);
    }

    .btn-view:hover {
        background: var(--info);
        color: white;
        transform: translateY(-2px);
    }

    .btn-edit {
        background: var(--gray-100);
        color: var(--warning);
    }

    .btn-edit:hover {
        background: var(--warning);
        color: white;
        transform: translateY(-2px);
    }

    .btn-delete {
        background: var(--gray-100);
        color: var(--danger);
    }

    .btn-delete:hover {
        background: var(--danger);
        color: white;
        transform: translateY(-2px);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 3rem;
        color: var(--gray-500);
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
        color: var(--gray-600);
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    .btn-create-asset-sm {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-create-asset-sm:hover {
        transform: translateY(-2px);
        color: white;
        text-decoration: none;
    }

    .btn-clear-search-sm {
        background: white;
        color: var(--gray-600);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        border: 1px solid var(--gray-300);
        transition: all 0.2s;
    }

    .btn-clear-search-sm:hover {
        background: var(--gray-50);
        text-decoration: none;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add data-label attributes for responsive table
        const tableHeaders = document.querySelectorAll('.assets-table th');
        const tableRows = document.querySelectorAll('.assets-table tbody tr');
        
        tableRows.forEach(row => {
            const cells = row.querySelectorAll('td');
            cells.forEach((cell, index) => {
                if (tableHeaders[index]) {
                    const headerText = tableHeaders[index].innerText.replace(/[^\w\s]/g, '').trim();
                    cell.setAttribute('data-label', headerText);
                }
            });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">