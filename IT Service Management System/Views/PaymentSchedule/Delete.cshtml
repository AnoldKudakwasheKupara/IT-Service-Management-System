@model IT_Service_Management_System.Models.PaymentSchedule

@{
    ViewData["Title"] = "Delete Schedule";
}

<h2 class="text-danger">Delete Schedule</h2>

<div class="alert alert-warning">
    <strong>Warning!</strong> This action cannot be undone.
</div>

<div class="card">
    <div class="card-body">

        <h4>@Model.ServiceName</h4>
        <hr />

        <p><strong>Amount:</strong> @Model.Amount.ToString("C")</p>
        <p><strong>Frequency:</strong> @Model.Frequency</p>
        <p><strong>Next Run:</strong> @Model.NextRunDate.ToShortDateString()</p>
        <p><strong>Departments:</strong> @Model.Departments</p>

    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />

    <br />

    <button type="submit" class="btn btn-danger">
        Yes, Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>