@model IT_Service_Management_System.Models.PaymentSchedule

@{
    ViewData["Title"] = "Create Payment Schedule";
}

<h2>Create Payment Schedule</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- Service Name -->
    <div class="form-group">
        <label asp-for="ServiceName"></label>
        <input asp-for="ServiceName" class="form-control" />
        <span asp-validation-for="ServiceName" class="text-danger"></span>
    </div>

    <!-- Amount -->
    <div class="form-group">
        <label asp-for="Amount"></label>
        <input asp-for="Amount" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <!-- Frequency -->
    <div class="form-group">
        <label asp-for="Frequency"></label>
        <select asp-for="Frequency"
                class="form-control"
                id="frequencyDropdown"
                asp-items="Html.GetEnumSelectList<PaymentFrequency>()">
        </select>
        <span asp-validation-for="Frequency" class="text-danger"></span>
    </div>

    <!-- Monthly -->
    <div class="form-group" id="monthlyField">
        <label asp-for="DayOfMonth">Day of Month</label>
        <input asp-for="DayOfMonth" type="number" min="1" max="31" class="form-control" />
        <span asp-validation-for="DayOfMonth" class="text-danger"></span>
    </div>

    <!-- Annual -->
    <div class="form-group" id="annualField">
        <label asp-for="FixedDate">Fixed Date</label>
        <input asp-for="FixedDate" type="date" class="form-control" />
        <span asp-validation-for="FixedDate" class="text-danger"></span>
    </div>

    <!-- Departments -->
    <div class="form-group">
        <label asp-for="Departments"></label>
        <input asp-for="Departments" class="form-control" />
        <span asp-validation-for="Departments" class="text-danger"></span>
    </div>

    <br />

    <!-- Buttons -->
    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function toggleFields() {
            var freq = document.getElementById("frequencyDropdown").value;

            var monthly = document.getElementById("monthlyField");
            var annual = document.getElementById("annualField");

            if (freq === "Monthly") {
                monthly.style.display = "block";
                annual.style.display = "none";

                // Ensure value exists to avoid null
                let dayInput = document.querySelector('[name="DayOfMonth"]');
                if (!dayInput.value) {
                    dayInput.value = 1;
                }
            }
            else {
                monthly.style.display = "none";
                annual.style.display = "block";
            }
        }

        document.getElementById("frequencyDropdown").addEventListener("change", toggleFields);

        window.onload = function () {
            toggleFields();
        };
    </script>
}