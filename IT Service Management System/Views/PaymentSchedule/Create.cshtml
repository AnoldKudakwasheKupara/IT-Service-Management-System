@model IT_Service_Management_System.Models.PaymentSchedule

@{
    ViewData["Title"] = "Create Payment Schedule";
}

<h2>Create Payment Schedule</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- Service Name -->
    <div class="form-group">
        <label asp-for="ServiceName"></label>
        <input asp-for="ServiceName" class="form-control" />
        <span asp-validation-for="ServiceName" class="text-danger"></span>
    </div>

    <!-- Amount -->
    <div class="form-group">
        <label asp-for="Amount"></label>
        <input asp-for="Amount" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <!-- Frequency -->
    <div class="form-group">
        <label asp-for="Frequency"></label>
        <select asp-for="Frequency"
                class="form-control"
                asp-items="Html.GetEnumSelectList<PaymentFrequency>()">
        </select>
        <span asp-validation-for="Frequency" class="text-danger"></span>
    </div>

    <!-- Payment Date -->
    <div class="form-group">
        <label asp-for="PaymentDate">Payment Date</label>
        <input asp-for="PaymentDate" type="date" class="form-control" />
        <span asp-validation-for="PaymentDate" class="text-danger"></span>
    </div>

    <!-- Departments -->
    <div class="form-group">
        <label asp-for="Departments"></label>
        <input asp-for="Departments" class="form-control" />
        <span asp-validation-for="Departments" class="text-danger"></span>
    </div>

    <br />

    <!-- Buttons -->
    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}