@model IT_Service_Management_System.Models.PaymentSchedule

@{
    ViewData["Title"] = "Payment Schedule Details";
}

<h2>Payment Schedule Details</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <h4 class="mb-3">@Model.ServiceName</h4>
        <hr />

        <dl class="row">

            <!-- Amount -->
            <dt class="col-sm-3">Amount</dt>
            <dd class="col-sm-9">
                @Model.Amount.ToString("C", new System.Globalization.CultureInfo("en-US"))
            </dd>

            <!-- Frequency -->
            <dt class="col-sm-3">Frequency</dt>
            <dd class="col-sm-9">
                @Model.Frequency
            </dd>

            <!-- Payment Date -->
            <dt class="col-sm-3">Payment Date</dt>
            <dd class="col-sm-9">
                @Model.PaymentDate.ToString("dddd, dd MMM yyyy")
            </dd>

            <!-- Next Run -->
            <dt class="col-sm-3">Next Run Date</dt>
            <dd class="col-sm-9">
                <span class="badge bg-info text-dark">
                    @Model.NextRunDate.ToString("dddd, dd MMM yyyy")
                </span>
            </dd>

            <!-- Departments -->
            <dt class="col-sm-3">Departments</dt>
            <dd class="col-sm-9">
                @Model.Departments
            </dd>

            <!-- Status -->
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactive</span>
                }
            </dd>

        </dl>

    </div>
</div>

<br />

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>