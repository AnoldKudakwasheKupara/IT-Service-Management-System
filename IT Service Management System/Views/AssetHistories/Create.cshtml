@model IT_Service_Management_System.ViewModels.AssetHistoryViewModel

@{
    ViewData["Title"] = "Record Asset Action - Axis IT Operations";
    var currentHolder = ViewBag.CurrentHolder as string;
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-controller="Assets" asp-action="Details" asp-route-id="@Model.AssetId" class="btn-back" title="Back to asset">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-clock-rotate-left me-2" style="color: var(--primary);"></i>
                    Record Asset Action
                </h1>
                <p class="text-muted mt-2">Log a new event in this asset's history timeline</p>
            </div>
        </div>
    </div>

    <!-- Asset context -->
    <div class="context-card">
        <div class="context-icon"><i class="fas fa-laptop"></i></div>
        <div class="context-body">
            <span class="context-name">@ViewBag.AssetName</span>
            <span class="context-serial"><i class="fas fa-barcode"></i> @ViewBag.AssetSerial</span>
        </div>
        <div class="context-state">
            <span class="context-status">@ViewBag.AssetStatus</span>
            <span class="context-holder">
                <i class="fas fa-user"></i>
                @(string.IsNullOrEmpty(currentHolder) ? "In stock (no holder)" : currentHolder)
            </span>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post" id="recordActionForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AssetId" />

            <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

            <div class="form-grid">
                <div class="form-group-modern">
                    <label asp-for="EventType" class="form-label">
                        <i class="fas fa-bolt"></i> Action <span class="required">*</span>
                    </label>
                    <div class="select-wrapper">
                        <i class="fas fa-chevron-down select-icon"></i>
                        <select asp-for="EventType" class="form-control-modern" id="eventSelect">
                            <option value="">-- Select action --</option>
                            @foreach (var t in IT_Service_Management_System.Helpers.AssetWorkflow.EventTypes)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <span asp-validation-for="EventType" class="validation-message text-danger"></span>
                    <div class="form-hint" id="actionHint"><i class="fas fa-info-circle"></i> Choose what is happening to the asset.</div>
                </div>

                <div class="form-group-modern" id="userGroup">
                    <label asp-for="UserId" class="form-label">
                        <i class="fas fa-user"></i> User <span class="required" id="userRequired" style="display:none;">*</span>
                    </label>
                    <div class="select-wrapper">
                        <i class="fas fa-chevron-down select-icon"></i>
                        <select asp-for="UserId" class="form-control-modern" id="userSelect">
                            <option value="">-- No user (in stock) --</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Id">@user.FirstName @user.LastName</option>
                            }
                        </select>
                    </div>
                    <span asp-validation-for="UserId" class="validation-message text-danger"></span>
                    <div class="form-hint"><i class="fas fa-info-circle"></i> Only required when issuing the asset to someone.</div>
                </div>

                <div class="form-group-modern">
                    <label asp-for="Condition" class="form-label">
                        <i class="fas fa-chart-line"></i> Condition <span class="required">*</span>
                    </label>
                    <div class="select-wrapper">
                        <i class="fas fa-chevron-down select-icon"></i>
                        <select asp-for="Condition" class="form-control-modern">
                            <option value="">-- Select condition --</option>
                            <option value="New">New</option>
                            <option value="Good">Good</option>
                            <option value="Fair">Fair</option>
                            <option value="Poor">Poor</option>
                        </select>
                    </div>
                    <span asp-validation-for="Condition" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="Date" class="form-label">
                        <i class="fas fa-calendar"></i> Date &amp; Time <span class="required">*</span>
                    </label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-calendar-alt input-icon"></i>
                        <input asp-for="Date" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control-modern" />
                    </div>
                    <span asp-validation-for="Date" class="validation-message text-danger"></span>
                    <div class="form-hint"><i class="fas fa-info-circle"></i> Defaults to now; adjust if recording a past action.</div>
                </div>

                <div class="form-group-modern">
                    <label asp-for="PerformedBy" class="form-label">
                        <i class="fas fa-user-check"></i> Performed By <span class="required">*</span>
                    </label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-signature input-icon"></i>
                        <input asp-for="PerformedBy" class="form-control-modern" placeholder="Staff member processing this action" />
                    </div>
                    <span asp-validation-for="PerformedBy" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern full">
                    <label asp-for="Remarks" class="form-label">
                        <i class="fas fa-comment"></i> Remarks
                    </label>
                    <textarea asp-for="Remarks" class="form-control-modern" rows="3" placeholder="Optional notes about this action..."></textarea>
                    <span asp-validation-for="Remarks" class="validation-message text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <a asp-controller="Assets" asp-action="Details" asp-route-id="@Model.AssetId" class="btn-cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> Record Action
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .page-container { max-width: 920px; margin: 0 auto; }

    .page-title { font-size: 1.6rem; font-weight: 700; color: var(--gray-800); margin: 0; display: flex; align-items: center; }

    .btn-back {
        width: 42px; height: 42px; border-radius: var(--radius-sm);
        background: var(--bg-card); border: 1px solid var(--gray-200); color: var(--gray-600);
        display: flex; align-items: center; justify-content: center; text-decoration: none;
        transition: var(--transition-smooth); flex-shrink: 0;
    }
        .btn-back:hover { background: var(--primary); color: #fff; border-color: var(--primary); }

    .context-card {
        display: flex; align-items: center; gap: 1rem;
        background: var(--bg-card); border: 1px solid var(--gray-200);
        border-radius: var(--radius-md); padding: 1rem 1.25rem; margin-bottom: 1.25rem;
        box-shadow: var(--shadow-sm); flex-wrap: wrap;
    }
    .context-icon {
        width: 46px; height: 46px; border-radius: 0.75rem; flex-shrink: 0;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
    }
    .context-body { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 160px; }
    .context-name { font-weight: 700; color: var(--gray-800); }
    .context-serial { font-size: 0.75rem; color: var(--gray-500); }
    .context-state { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
    .context-status {
        font-size: 0.72rem; font-weight: 700; padding: 3px 12px; border-radius: 30px;
        background: var(--primary-light); color: var(--primary-dark);
    }
    .context-holder { font-size: 0.75rem; color: var(--gray-500); }

    .form-card {
        background: var(--bg-card); border: 1px solid var(--gray-200);
        border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 1.75rem;
    }

    .validation-summary:empty { display: none; }
    .validation-summary { margin-bottom: 1rem; font-size: 0.85rem; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem 1.5rem; }
    .form-group-modern { display: flex; flex-direction: column; gap: 0.5rem; }
    .form-group-modern.full { grid-column: 1 / -1; }

    .form-label { font-weight: 600; font-size: 0.85rem; color: var(--gray-700); display: flex; align-items: center; gap: 0.5rem; }
        .form-label i { color: var(--primary); }
    .required { color: var(--danger); }

    .input-icon-wrapper, .select-wrapper { position: relative; }
    .input-icon { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--gray-400); font-size: 0.85rem; pointer-events: none; }
    .select-icon { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: var(--gray-400); font-size: 0.7rem; pointer-events: none; }

    .form-control-modern {
        width: 100%; padding: 0.7rem 1rem; font-size: 0.88rem; font-family: inherit;
        border: 1.5px solid var(--gray-200); border-radius: var(--radius-sm); background: #fff;
        color: var(--gray-800); transition: var(--transition-smooth); resize: vertical;
    }
    .input-icon-wrapper .form-control-modern { padding-left: 2.5rem; }
    .select-wrapper select.form-control-modern { appearance: none; cursor: pointer; }
        .form-control-modern:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-glow); }

    .form-hint { font-size: 0.72rem; color: var(--gray-500); display: flex; align-items: center; gap: 0.4rem; }
    .validation-message { font-size: 0.75rem; }

    .form-actions { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--gray-200); }
    .btn-save, .btn-cancel {
        padding: 0.65rem 1.4rem; border-radius: 40px; font-weight: 600; font-size: 0.88rem;
        border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 0.5rem;
        transition: var(--transition-smooth); text-decoration: none;
    }
    .btn-save { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; }
        .btn-save:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .btn-cancel { background: var(--gray-100); color: var(--gray-700); }
        .btn-cancel:hover { background: var(--gray-200); }

    @@media (max-width: 640px) { .form-grid { grid-template-columns: 1fr; } }
</style>

<script>
    (function () {
        var eventSelect = document.getElementById('eventSelect');
        var userSelect = document.getElementById('userSelect');
        var userRequired = document.getElementById('userRequired');
        var actionHint = document.getElementById('actionHint');
        var form = document.getElementById('recordActionForm');

        var hints = {
            'In Stock': 'Asset is available in stock with no holder.',
            'Issued': 'Asset is being assigned to the selected user.',
            'Returned': 'Asset is returned and goes back to stock.',
            'In Repair': 'Asset is sent for repair (holder is kept).',
            'Retired': 'Asset is retired from service.',
            'Stolen': 'Asset is reported stolen/lost.'
        };

        function sync() {
            var v = eventSelect.value;
            var isIssue = v === 'Issued';
            userRequired.style.display = isIssue ? 'inline' : 'none';
            if (actionHint) {
                actionHint.querySelector('span') || actionHint;
                actionHint.innerHTML = '<i class="fas fa-info-circle"></i> ' + (hints[v] || 'Choose what is happening to the asset.');
            }
            if (!isIssue && (v === 'In Stock' || v === 'Returned' || v === 'Retired' || v === 'Stolen')) {
                userSelect.value = '';
            }
        }

        if (eventSelect) {
            eventSelect.addEventListener('change', sync);
            sync();
        }

        if (form) {
            form.addEventListener('submit', function (e) {
                if (eventSelect.value === 'Issued' && !userSelect.value) {
                    e.preventDefault();
                    userSelect.focus();
                    alert('Please select the user the asset is issued to.');
                }
            });
        }
    })();
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
