@functions {
    string GetRatingDisplay(EngagementRating? rating)
    {
        if (!rating.HasValue) return "Not rated";

        return rating.Value switch
        {
            EngagementRating.NotMeetingExpectations => "Not Meeting Expectations",
            EngagementRating.NeedsImprovement => "Needs Improvement",
            EngagementRating.MeetingMyExpectations => "Meeting My Expectations",
            _ => "Not rated"
        };
    }
}

