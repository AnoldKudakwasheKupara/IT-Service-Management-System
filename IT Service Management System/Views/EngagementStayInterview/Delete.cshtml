@model IT_Service_Management_System.Models.EngagementStayInterview

@{
    ViewData["Title"] = "Delete Stay Interview";
}

<div class="container">

    ```
    <div class="card border-danger mt-4">

        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">
                Delete Engagement Stay Interview
            </h3>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                <strong>Warning!</strong>

                Are you sure you want to delete this Engagement Stay Interview?

                This action cannot be undone.

            </div>

            <h5 class="mb-3">
                Employee Information
            </h5>

            <dl class="row">

                <dt class="col-sm-3">
                    Name & Surname
                </dt>

                <dd class="col-sm-9">
                    @Model.NameAndSurname
                </dd>

                <dt class="col-sm-3">
                    Job Title
                </dt>

                <dd class="col-sm-9">
                    @Model.JobTitle
                </dd>

                <dt class="col-sm-3">
                    Department
                </dt>

                <dd class="col-sm-9">
                    @Model.Department
                </dd>

                <dt class="col-sm-3">
                    Manager
                </dt>

                <dd class="col-sm-9">
                    @Model.ManagerName
                </dd>

                <dt class="col-sm-3">
                    Date Joined Axis
                </dt>

                <dd class="col-sm-9">
                    @Model.DateJoinedAxis?.ToString("dd-MMM-yyyy")
                </dd>

                <dt class="col-sm-3">
                    Discussion Date
                </dt>

                <dd class="col-sm-9">
                    @Model.DiscussionDate?.ToString("dd-MMM-yyyy")
                </dd>

                <dt class="col-sm-3">
                    Overall Status
                </dt>

                <dd class="col-sm-9">
                    @Model.OverallStatus
                </dd>

            </dl>

            <hr />

            <h5 class="mb-3">
                Interview Summary
            </h5>

            <div class="mb-3">

                <strong>
                    Motivation & Engagement Factors
                </strong>

                <div class="border rounded p-3 bg-light mt-2">
                    @Model.MotivationAndEngagementFactors
                </div>

            </div>

            <div class="mb-3">

                <strong>
                    Demotivating Factors
                </strong>

                <div class="border rounded p-3 bg-light mt-2">
                    @Model.DemotivatingFactors
                </div>

            </div>

            <div class="mb-4">

                <strong>
                    Improvement Ideas
                </strong>

                <div class="border rounded p-3 bg-light mt-2">
                    @Model.ImprovementIdeas
                </div>

            </div>

            <form asp-action="Delete">

                <input type="hidden"
                       asp-for="Id" />

                <button type="submit"
                        class="btn btn-danger">
                    <i class="fas fa-trash"></i>
                    Delete Interview
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>
    ```

</div>
