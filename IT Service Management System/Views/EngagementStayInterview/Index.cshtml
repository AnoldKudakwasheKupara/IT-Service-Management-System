@model IEnumerable<IT_Service_Management_System.Models.EngagementStayInterview>

@{
    ViewData["Title"] = "Engagement Stay Interviews - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title">
                    <i class="fas fa-comments me-2" style="color: var(--primary);"></i>
                    Engagement Stay Interviews
                </h1>
                <p class="text-muted mt-2">Track employee engagement and satisfaction</p>
            </div>
            <a asp-action="Create" class="btn-create-interview">
                <i class="fas fa-plus-circle me-2"></i>
                New Stay Interview
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-toast success">
            <i class="fas fa-check-circle"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="close-toast" onclick="this.parentElement.remove()">
                <i class="fas fa-times"></i>
            </button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="stats-cards mb-4">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-comments"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count()</h3>
                <p>Total Interviews</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon satisfied">
                <i class="fas fa-smile"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(i => i.OverallStatus == EngagementStatus.SatisfiedWithWorkingAtAxis || i.OverallStatus == EngagementStatus.HighlyMotivatedAndEngaged)</h3>
                <p>Satisfied/Engaged</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon at-risk">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(i => i.OverallStatus == EngagementStatus.ConsideringOpportunitiesOutsideAxis || i.OverallStatus == EngagementStatus.DissatisfiedWithWorkingAtAxis)</h3>
                <p>At Risk</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon this-month">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(i => i.DiscussionDate.HasValue && i.DiscussionDate.Value.Month == DateTime.Now.Month && i.DiscussionDate.Value.Year == DateTime.Now.Year)</h3>
                <p>This Month</p>
            </div>
        </div>
    </div>

    <!-- Interviews Table -->
    <div class="interviews-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-list me-2"></i>
                <span>Stay Interview Records</span>
            </div>
            <div class="record-count">
                <i class="fas fa-chart-simple"></i>
                <span>@Model.Count()</span> records found
            </div>
        </div>

        <div class="table-responsive">
            @if (Model.Any())
            {
                <table class="interviews-table">
                    <thead>
                        <tr>
                            <th style="width: 18%"><i class="fas fa-user me-1"></i> Name & Surname</th>
                            <th style="width: 15%"><i class="fas fa-briefcase me-1"></i> Job Title</th>
                            <th style="width: 15%"><i class="fas fa-building me-1"></i> Department</th>
                            <th style="width: 15%"><i class="fas fa-user-tie me-1"></i> Manager</th>
                            <th style="width: 12%"><i class="fas fa-calendar me-1"></i> Discussion Date</th>
                            <th style="width: 15%"><i class="fas fa-chart-line me-1"></i> Overall Status</th>
                            <th style="width: 10%"><i class="fas fa-cog me-1"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(i => i.DiscussionDate))
                        {
                            <tr>
                                <td class="employee-cell">
                                    <div class="employee-info">
                                        <div class="employee-avatar">
                                            @(item.NameAndSurname?.Substring(0, 1).ToUpper() ?? "E")
                                        </div>
                                        <div class="employee-name">
                                            <strong>@item.NameAndSurname</strong>
                                        </div>
                                    </div>
                                </td>
                                <td class="job-cell">
                                    <span class="job-badge">
                                        <i class="fas fa-briefcase"></i> @item.JobTitle
                                    </span>
                                </td>
                                <td class="department-cell">
                                    <span class="department-badge">
                                        <i class="fas fa-building"></i> @item.Department
                                    </span>
                                </td>
                                <td class="manager-cell">
                                    <div class="manager-info">
                                        <div class="manager-avatar">
                                            @(item.ManagerName?.Substring(0, 1).ToUpper() ?? "M")
                                        </div>
                                        <span>@item.ManagerName</span>
                                    </div>
                                </td>
                                <td class="date-cell">
                                    @if (item.DiscussionDate.HasValue)
                                    {
                                        <span>
                                            <i class="far fa-calendar-alt"></i>
                                            @item.DiscussionDate.Value.ToString("dd MMM yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="status-cell">
                                    @switch (item.OverallStatus)
                                    {
                                        case EngagementStatus.HighlyMotivatedAndEngaged:
                                            <span class="status-badge status-engaged">
                                                <i class="fas fa-star"></i> Highly Engaged
                                            </span>
                                            break;
                                        case EngagementStatus.SatisfiedWithWorkingAtAxis:
                                            <span class="status-badge status-satisfied">
                                                <i class="fas fa-smile"></i> Satisfied
                                            </span>
                                            break;
                                        case EngagementStatus.ConsideringOpportunitiesOutsideAxis:
                                            <span class="status-badge status-considering">
                                                <i class="fas fa-compass"></i> Considering Opportunities
                                            </span>
                                            break;
                                        case EngagementStatus.DissatisfiedWithWorkingAtAxis:
                                            <span class="status-badge status-dissatisfied">
                                                <i class="fas fa-frown"></i> Dissatisfied
                                            </span>
                                            break;
                                        default:
                                            <span class="status-badge status-unknown">
                                                <i class="fas fa-question"></i> Not Set
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn btn-edit" title="Edit Interview">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn btn-delete" title="Delete Interview" onclick="return confirm('Are you sure you want to delete this stay interview record?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-comments"></i>
                    <h3>No Stay Interviews Found</h3>
                    <p>Get started by creating your first engagement stay interview</p>
                    <a asp-action="Create" class="btn-create-interview-sm">
                        <i class="fas fa-plus-circle"></i> New Stay Interview
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Create Button */
    .btn-create-interview {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-sm);
    }

        .btn-create-interview:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    /* Alert Toast */
    .alert-toast {
        background: #e6f5e9;
        border-left: 4px solid var(--success);
        border-radius: 0.75rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--success);
        font-weight: 500;
        animation: slideIn 0.3s ease;
        box-shadow: var(--shadow-sm);
    }

        .alert-toast.success {
            background: #e6f5e9;
            border-left-color: var(--success);
            color: #1f6e4a;
        }

    .close-toast {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

        .close-toast:hover {
            opacity: 1;
        }

    /* Statistics Cards */
    .stats-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

        .stat-icon.total {
            background: linear-gradient(135deg, var(--info), #2563eb);
            color: white;
        }

        .stat-icon.satisfied {
            background: linear-gradient(135deg, var(--success), #059669);
            color: white;
        }

        .stat-icon.at-risk {
            background: linear-gradient(135deg, var(--danger), #c53030);
            color: white;
        }

        .stat-icon.this-month {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white;
        }

    .stat-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-800);
    }

    .stat-info p {
        margin: 0;
        color: var(--gray-500);
        font-size: 0.875rem;
    }

    /* Interviews Card */
    .interviews-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .record-count {
        font-size: 0.875rem;
        font-weight: normal;
        color: var(--gray-500);
    }

    /* Table Styles */
    .interviews-table {
        width: 100%;
        border-collapse: collapse;
    }

        .interviews-table thead {
            background: var(--gray-50);
            border-bottom: 2px solid var(--gray-200);
        }

        .interviews-table th {
            padding: 1rem 1.5rem;
            text-align: left;
            font-weight: 600;
            color: var(--gray-600);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .interviews-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            vertical-align: middle;
            font-size: 0.875rem;
        }

        .interviews-table tbody tr {
            transition: background-color 0.2s;
        }

            .interviews-table tbody tr:hover {
                background-color: var(--gray-50);
            }

    /* Employee Cell */
    .employee-cell {
        min-width: 160px;
    }

    .employee-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .employee-avatar {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.875rem;
        flex-shrink: 0;
    }

    .employee-name strong {
        color: var(--gray-800);
        font-size: 0.875rem;
    }

    /* Job & Department Badges */
    .job-badge, .department-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: var(--gray-100);
        color: var(--gray-600);
    }

    /* Manager Cell */
    .manager-cell {
        min-width: 130px;
    }

    .manager-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .manager-avatar {
        width: 28px;
        height: 28px;
        background: linear-gradient(135deg, var(--gray-500), var(--gray-600));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.7rem;
    }

    /* Date Cell */
    .date-cell {
        color: var(--gray-500);
        white-space: nowrap;
    }

    /* Status Badges */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-engaged {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
    }

    .status-satisfied {
        background: #e6f5e9;
        color: var(--success);
    }

    .status-considering {
        background: #fff5e6;
        color: var(--warning);
    }

    .status-dissatisfied {
        background: #fee;
        color: var(--danger);
    }

    .status-unknown {
        background: var(--gray-100);
        color: var(--gray-500);
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

    .btn-view {
        background: var(--gray-100);
        color: var(--info);
    }

        .btn-view:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: var(--gray-100);
        color: var(--warning);
    }

        .btn-edit:hover {
            background: var(--warning);
            color: white;
            transform: translateY(-2px);
        }

    .btn-delete {
        background: var(--gray-100);
        color: var(--danger);
    }

        .btn-delete:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 3rem;
        color: var(--gray-500);
    }

        .empty-state i {
            font-size: 4rem;
            color: var(--gray-300);
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
            color: var(--gray-600);
        }

        .empty-state p {
            margin-bottom: 1.5rem;
        }

    .btn-create-interview-sm {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

        .btn-create-interview-sm:hover {
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Auto-hide toast after 5 seconds
        const toast = document.querySelector('.alert-toast');
        if (toast) {
            setTimeout(() => {
                toast.style.transition = 'opacity 0.3s';
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        // Add data-label attributes for responsive table
        const tableHeaders = document.querySelectorAll('.interviews-table th');
        const tableRows = document.querySelectorAll('.interviews-table tbody tr');

        tableRows.forEach(row => {
            const cells = row.querySelectorAll('td');
            cells.forEach((cell, index) => {
                if (tableHeaders[index]) {
                    const headerText = tableHeaders[index].innerText.replace(/[^\w\s]/g, '').trim();
                    cell.setAttribute('data-label', headerText);
                }
            });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">