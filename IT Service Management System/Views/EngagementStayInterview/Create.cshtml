        color: var(--gray-700);
        line-height: 1.5;
    }

        .info-alert-content strong {
            color: var(--gray-800);
        }

    /* ============================================
       Sub Questions (for Q5)
       ============================================ */
    .sub-question {
        margin-bottom: 1rem;
    }

        .sub-question:last-child {
            margin-bottom: 0;
        }

    .sub-question-label {
        display: block;
        font-weight: 600;
        font-size: 0.8rem;
        color: var(--gray-700);
        margin-bottom: 0.4rem;
        letter-spacing: 0.01em;
    }

    /* ============================================
       Radio Groups
       ============================================ */
    .radio-group {
        margin-bottom: 1.25rem;
    }

        .radio-group:last-child {
            margin-bottom: 0;
        }

    .radio-question {
        display: block;
        font-weight: 600;
        font-size: 0.8rem;
        color: var(--gray-700);
        margin-bottom: 0.4rem;
        letter-spacing: 0.01em;
    }

    .radio-options {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .radio-label-inline {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-size: 0.85rem;
        color: var(--gray-600);
        transition: var(--transition);
        padding: 0.2rem 0;
    }

        .radio-label-inline input {
            position: absolute;
