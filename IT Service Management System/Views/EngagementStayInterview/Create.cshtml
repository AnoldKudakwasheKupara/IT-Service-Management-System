    }

    .radio-label {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        margin: 0;
        padding: 0.2rem;
    }

        .radio-label input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

    .radio-custom {
        display: inline-block;
        width: 16px;
        height: 16px;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        transition: var(--transition);
        position: relative;
