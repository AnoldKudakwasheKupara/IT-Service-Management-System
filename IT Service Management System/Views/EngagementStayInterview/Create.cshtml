            padding: 0.7rem 0.6rem;
            text-align: center;
            font-weight: 600;
            color: var(--gray-600);
            border: 1px solid var(--gray-200);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .ratings-matrix-table td {
            padding: 0.4rem 0.3rem;
            border: 1px solid var(--gray-200);
            vertical-align: middle;
        }

    .aspect-cell {
        font-weight: 600;
        color: var(--gray-700);
