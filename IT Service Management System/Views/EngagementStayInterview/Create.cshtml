        border-radius: 50%;
    }

    .radio-label-vertical:hover .radio-custom-vertical {
        border-color: var(--primary);
    }

    /* ============================================
       Ratings Matrix Table
       ============================================ */
    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .ratings-matrix-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.75rem;
        min-width: 600px;
    }

        .ratings-matrix-table th {
