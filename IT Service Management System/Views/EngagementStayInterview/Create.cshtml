@model IT_Service_Management_System.Models.EngagementStayInterview

@{
    ViewData["Title"] = "Create Engagement Stay Interview - Axis IT Helpdesk";
}

<div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <a asp-action="Index" class="btn-back" aria-label="Back to list">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div class="header-text">
                <h1 class="page-title">
                    <span class="title-icon">
                        <i class="fas fa-plus-circle"></i>
                    </span>
                    Engagement Stay Interview
                </h1>
                <p class="page-subtitle">Complete employee engagement and stay interview questionnaire</p>
            </div>
        </div>
        <div class="header-progress">
            <span class="progress-badge">Form</span>
        </div>
    </div>

    <form asp-action="Create" method="post" id="stayInterviewForm" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <!-- Employee Information Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-user-circle"></i>
                </div>
                <h3>Employee Information</h3>
                <span class="section-badge">Required</span>
            </div>
            <div class="section-body">
                <div class="form-row-grid">
                    <div class="form-group-modern">
                        <label asp-for="NameAndSurname" class="form-label">
                            <i class="fas fa-user"></i> Name and Surname
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-user input-icon"></i>
                            <input asp-for="NameAndSurname" class="form-control-modern" placeholder="Enter employee name" />
                        </div>
                        <span asp-validation-for="NameAndSurname" class="validation-message"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="JobTitle" class="form-label">
                            <i class="fas fa-briefcase"></i> Job Title
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-briefcase input-icon"></i>
                            <input asp-for="JobTitle" class="form-control-modern" placeholder="Enter job title" />
                        </div>
                        <span asp-validation-for="JobTitle" class="validation-message"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Department" class="form-label">
                            <i class="fas fa-building"></i> Department / Section
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-building input-icon"></i>
                            <input asp-for="Department" class="form-control-modern" placeholder="Enter department" />
                        </div>
                        <span asp-validation-for="Department" class="validation-message"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="DateJoinedAxis" class="form-label">
                            <i class="fas fa-calendar-alt"></i> Date Joined Axis
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-calendar-alt input-icon"></i>
                            <input asp-for="DateJoinedAxis" type="date" class="form-control-modern" />
                        </div>
                        <span asp-validation-for="DateJoinedAxis" class="validation-message"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="ManagerName" class="form-label">
                            <i class="fas fa-user-tie"></i> Manager Name
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-user-tie input-icon"></i>
                            <input asp-for="ManagerName" class="form-control-modern" placeholder="Enter manager name" />
                        </div>
                        <span asp-validation-for="ManagerName" class="validation-message"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="CurrentPositionStartDate" class="form-label">
                            <i class="fas fa-calendar-check"></i> Start Date For Current Position
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-calendar-check input-icon"></i>
                            <input asp-for="CurrentPositionStartDate" type="date" class="form-control-modern" />
                        </div>
                        <span asp-validation-for="CurrentPositionStartDate" class="validation-message"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="DiscussionDate" class="form-label">
                            <i class="fas fa-calendar-week"></i> Date of Discussion
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-calendar-week input-icon"></i>
                            <input asp-for="DiscussionDate" type="date" class="form-control-modern" />
                        </div>
                        <span asp-validation-for="DiscussionDate" class="validation-message"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Purpose Alert -->
        <div class="info-alert">
            <div class="info-alert-icon">
                <i class="fas fa-info-circle"></i>
            </div>
            <div class="info-alert-content">
                <strong>Purpose of this conversation:</strong> To gain insight into what motivates or frustrates you as an employee, understand what you value in Axis Solutions and discover how we can improve support, development, engagement and retention.
            </div>
        </div>

        <!-- Question 1 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-question-circle"></i>
                </div>
                <h3>1. Tell me a bit about some of your current priorities from a work perspective and how you are doing overall?</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="CurrentPrioritiesAndOverallWellbeing" class="form-control-textarea" rows="5" placeholder="Describe your current priorities and overall wellbeing..."></textarea>
                </div>
                <span asp-validation-for="CurrentPrioritiesAndOverallWellbeing" class="validation-message"></span>
            </div>
        </div>

        <!-- Question 2 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-rocket"></i>
                </div>
                <h3>2. What parts of your work keep you motivated and engaged?</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="MotivationAndEngagementFactors" class="form-control-textarea" rows="5" placeholder="What keeps you motivated and engaged?..."></textarea>
                </div>
                <span asp-validation-for="MotivationAndEngagementFactors" class="validation-message"></span>
            </div>
        </div>

        <!-- Question 3 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-frown"></i>
                </div>
                <h3>3. What parts of your work or work environment reduces your energy, demotivates you or places obstacles to your ability to perform at your best?</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="DemotivatingFactors" class="form-control-textarea" rows="5" placeholder="What demotivates you or creates obstacles?..."></textarea>
                </div>
                <span asp-validation-for="DemotivatingFactors" class="validation-message"></span>
            </div>
        </div>

        <!-- Question 4 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>4. Do you feel that your skills are being fully utilized in your current role?</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="SkillsUtilizationFeedback" class="form-control-textarea" rows="5" placeholder="Are your skills being fully utilized?..."></textarea>
                </div>
                <span asp-validation-for="SkillsUtilizationFeedback" class="validation-message"></span>
            </div>
        </div>

        <!-- Question 5 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-balance-scale"></i>
                </div>
                <h3>5. Similarly, what in your view exists in the Company that?</h3>
            </div>
            <div class="section-body">
                <div class="sub-question">
                    <label class="sub-question-label">Attracts people to stay:</label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-heart textarea-icon"></i>
                        <textarea asp-for="ReasonsPeopleStay" class="form-control-textarea" rows="4" placeholder="What attracts people to stay?..."></textarea>
                    </div>
                </div>
                <div class="sub-question">
                    <label class="sub-question-label">Results in them wanting to leave:</label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-door-open textarea-icon"></i>
                        <textarea asp-for="ReasonsPeopleLeave" class="form-control-textarea" rows="4" placeholder="What makes people want to leave?..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Question 6 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-lightbulb"></i>
                </div>
                <h3>6. What aspects would you change about working for Axis Solutions?</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="ChangesToWorkingAtAxis" class="form-control-textarea" rows="5" placeholder="What would you change?..."></textarea>
                </div>
                <span asp-validation-for="ChangesToWorkingAtAxis" class="validation-message"></span>
            </div>
        </div>

        <!-- Question 7 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-flag-checkered"></i>
                </div>
                <h3>7. What is your next career milestone or personal development milestone?</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="NextCareerMilestone" class="form-control-textarea" rows="5" placeholder="What is your next career milestone?..."></textarea>
                </div>
                <span asp-validation-for="NextCareerMilestone" class="validation-message"></span>
            </div>
        </div>

        <!-- Question 8 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-handshake"></i>
                </div>
                <h3>8. Do you feel that you have sufficient support and/or opportunities to achieve your personal and/or career milestones at Axis Solutions?</h3>
            </div>
            <div class="section-body">
                <div class="radio-group">
                    <label class="radio-question">Support Status</label>
                    <div class="radio-options">
                        <label class="radio-label-inline">
                            <input type="radio" asp-for="FeelsSupported" value="true" />
                            <span class="radio-custom-inline"></span>
                            <span>I do feel supported</span>
                        </label>
                        <label class="radio-label-inline">
                            <input type="radio" asp-for="FeelsSupported" value="false" />
                            <span class="radio-custom-inline"></span>
                            <span>I don't feel sufficiently supported</span>
                        </label>
                    </div>
                </div>
                <div class="radio-group">
                    <label class="radio-question">I have a Development Plan</label>
                    <div class="radio-options">
                        <label class="radio-label-inline">
                            <input type="radio" asp-for="HasDevelopmentPlan" value="true" />
                            <span class="radio-custom-inline"></span>
                            <span>Yes</span>
                        </label>
                        <label class="radio-label-inline">
                            <input type="radio" asp-for="HasDevelopmentPlan" value="false" />
                            <span class="radio-custom-inline"></span>
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Question 9 -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-lightbulb"></i>
                </div>
                <h3>9. What ideas would you love to see implemented in Axis Solutions in order for it to improve as an employer or make you stay employed and engaged with Axis Solutions?</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="ImprovementIdeas" class="form-control-textarea" rows="6" placeholder="Your improvement ideas..."></textarea>
                </div>
                <span asp-validation-for="ImprovementIdeas" class="validation-message"></span>
            </div>
        </div>

        <!-- Overall Status -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>Overall, I am:</h3>
            </div>
            <div class="section-body">
                <div class="radio-group-vertical">
                    <label class="radio-label-vertical">
                        <input type="radio" asp-for="OverallStatus" value="1" />
                        <span class="radio-custom-vertical"></span>
                        <span>Considering opportunities outside Axis</span>
                    </label>
                    <label class="radio-label-vertical">
                        <input type="radio" asp-for="OverallStatus" value="2" />
                        <span class="radio-custom-vertical"></span>
                        <span>Dissatisfied with working at Axis Solutions</span>
                    </label>
                    <label class="radio-label-vertical">
                        <input type="radio" asp-for="OverallStatus" value="3" />
                        <span class="radio-custom-vertical"></span>
                        <span>Satisfied with working for Axis Solutions</span>
                    </label>
                    <label class="radio-label-vertical">
                        <input type="radio" asp-for="OverallStatus" value="4" />
                        <span class="radio-custom-vertical"></span>
                        <span>Highly motivated and engaged</span>
                    </label>
                </div>
                <span asp-validation-for="OverallStatus" class="validation-message"></span>
            </div>
        </div>

        <!-- Rating Matrix -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-table"></i>
                </div>
                <h3>Currently how would you rate the following:</h3>
            </div>
            <div class="section-body">
                <div class="table-responsive">
                    <table class="ratings-matrix-table">
                        <thead>
                            <tr>
                                <th>Aspect</th>
                                <th>Not Meeting Expectations (1)</th>
                                <th>Needs Improvement (2)</th>
                                <th>Meeting My Expectations (3)</th>
                                <th>Comment</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td class="aspect-cell">My Wellbeing at Axis Solutions</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WellbeingRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WellbeingRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WellbeingRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="WellbeingComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Job Satisfaction Levels</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="JobSatisfactionRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="JobSatisfactionRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="JobSatisfactionRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="JobSatisfactionComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Career Opportunities</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CareerOpportunitiesRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CareerOpportunitiesRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CareerOpportunitiesRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="CareerOpportunitiesComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Quality of Leadership</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="LeadershipQualityRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="LeadershipQualityRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="LeadershipQualityRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="LeadershipQualityComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Relationship with my Manager</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ManagerRelationshipRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ManagerRelationshipRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ManagerRelationshipRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="ManagerRelationshipComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Relationship with Peers / Team</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="TeamRelationshipRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="TeamRelationshipRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="TeamRelationshipRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="TeamRelationshipComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">BSC System</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="BSCSystemRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="BSCSystemRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="BSCSystemRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="BSCSystemComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Reward for Performance</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="RewardForPerformanceRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="RewardForPerformanceRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="RewardForPerformanceRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="RewardForPerformanceComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Communication Channels</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CommunicationChannelsRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CommunicationChannelsRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CommunicationChannelsRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="CommunicationChannelsComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Opportunities to Develop</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="DevelopmentOpportunitiesRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="DevelopmentOpportunitiesRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="DevelopmentOpportunitiesRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="DevelopmentOpportunitiesComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Pay and Benefits</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="PayAndBenefitsRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="PayAndBenefitsRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="PayAndBenefitsRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="PayAndBenefitsComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Working Conditions</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WorkingConditionsRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WorkingConditionsRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WorkingConditionsRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="WorkingConditionsComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">The Organization in General</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OrganizationGeneralRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OrganizationGeneralRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OrganizationGeneralRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="OrganizationGeneralComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                            <tr><td class="aspect-cell">Other</td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OtherRating" value="1" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OtherRating" value="2" /><span class="radio-custom"></span></label></td><td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OtherRating" value="3" /><span class="radio-custom"></span></label></td><td><input asp-for="OtherComment" class="form-control-modern-sm" placeholder="Comment" /></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Interviewer Comments -->
        <div class="form-section">
            <div class="section-header">
                <div class="section-header-icon">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <h3>Interviewer Overall Comments from Discussion</h3>
            </div>
            <div class="section-body">
                <div class="textarea-wrapper">
                    <i class="fas fa-comment textarea-icon"></i>
                    <textarea asp-for="InterviewerOverallComments" class="form-control-textarea" rows="6" placeholder="Enter interviewer's overall comments..."></textarea>
                </div>
                <span asp-validation-for="InterviewerOverallComments" class="validation-message"></span>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
            <button type="submit" class="btn-save" id="submitBtn">
                <i class="fas fa-save"></i>
                Save Stay Interview
            </button>
            <a asp-action="Index" class="btn-cancel">
                <i class="fas fa-times"></i>
                Cancel
            </a>
        </div>
    </form>
</div>

<style>
    /* ============================================
       CSS Variables & Reset
       ============================================ */
    :root {
        --primary: #3b82f6;
        --primary-light: #eff6ff;
        --success: #2c9e6e;
        --success-light: #e8f5ef;
        --danger: #e53e3e;
        --warning: #f5b042;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f4f8;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --gray-900: #0f172a;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
        --shadow-lg: 0 8px 30px rgba(0,0,0,0.08);
        --radius: 12px;
        --radius-sm: 8px;
        --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ============================================
       Page Container
       ============================================ */
    .page-container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    /* ============================================
       Page Header
       ============================================ */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--gray-200);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: var(--radius-sm);
        color: var(--gray-500);
        text-decoration: none;
        transition: var(--transition);
        border: 1px solid var(--gray-200);
        flex-shrink: 0;
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
            border-color: var(--primary);
        }

    .header-text {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }

    .page-title {
        font-size: 1.625rem;
        font-weight: 700;
        color: var(--gray-900);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.625rem;
        letter-spacing: -0.02em;
    }

    .title-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--success);
        font-size: 1.25rem;
    }

    .page-subtitle {
        color: var(--gray-500);
        font-size: 0.875rem;
        margin: 0;
    }

    .header-progress {
        display: flex;
        align-items: center;
    }

    .progress-badge {
        background: var(--primary-light);
        color: var(--primary);
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.25rem 0.85rem;
        border-radius: 20px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    /* ============================================
       Form Sections
       ============================================ */
    .form-section {
        background: white;
        border-radius: var(--radius);
        margin-bottom: 1.5rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
        transition: var(--transition);
    }

        .form-section:hover {
            box-shadow: var(--shadow-md);
        }

    .section-header {
        background: var(--gray-50);
        padding: 0.9rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .section-header-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: var(--primary-light);
        border-radius: var(--radius-sm);
        color: var(--primary);
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .section-header h3 {
        margin: 0;
        font-size: 0.925rem;
        font-weight: 600;
        color: var(--gray-800);
        flex: 1;
        line-height: 1.4;
    }

    .section-badge {
        font-size: 0.6rem;
        font-weight: 600;
        color: var(--gray-500);
        background: var(--gray-200);
        padding: 0.15rem 0.6rem;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .section-body {
        padding: 1.5rem;
    }

    /* ============================================
       Form Grid
       ============================================ */
    .form-row-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.25rem;
    }

    /* ============================================
       Form Groups
       ============================================ */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.8rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.4rem;
        letter-spacing: 0.01em;
    }

        .form-label i {
            color: var(--gray-400);
            font-size: 0.75rem;
            width: 1rem;
        }

    .required {
        color: var(--danger);
        font-size: 1rem;
        margin-left: 0.1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper .input-icon {
