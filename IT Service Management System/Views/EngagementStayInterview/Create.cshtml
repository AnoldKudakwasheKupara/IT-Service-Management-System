            color: var(--primary);
        }

    .form-control-modern-sm {
        width: 100%;
        padding: 0.4rem 0.6rem;
        font-size: 0.75rem;
        border: 1.5px solid var(--gray-200);
        border-radius: var(--radius-sm);
        transition: var(--transition);
        font-family: 'Inter', sans-serif;
        background: white;
        color: var(--gray-800);
