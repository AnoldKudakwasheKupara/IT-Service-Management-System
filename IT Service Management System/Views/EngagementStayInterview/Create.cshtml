            width: 0;
            height: 0;
        }

    .radio-custom-inline {
        display: inline-block;
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        transition: var(--transition);
        position: relative;
    }

    .radio-label-inline input:checked ~ .radio-custom-inline {
        border-color: var(--primary);
        background: var(--primary);
    }

    .radio-label-inline input:checked ~ .radio-custom-inline::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 5px;
        height: 5px;
        background: white;
        border-radius: 50%;
    }

    .radio-label-inline:hover .radio-custom-inline {
        border-color: var(--primary);
    }

    /* ============================================
       Vertical Radio (Overall Status)
       ============================================ */
    .radio-group-vertical {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .radio-label-vertical {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        cursor: pointer;
        font-size: 0.85rem;
        color: var(--gray-600);
        transition: var(--transition);
        padding: 0.2rem 0;
    }

        .radio-label-vertical input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

    .radio-custom-vertical {
        display: inline-block;
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        transition: var(--transition);
