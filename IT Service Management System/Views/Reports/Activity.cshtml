@model IT_Service_Management_System.ViewModels.Reports.ActivityReportVM
@{
    ViewData["Title"] = "Activity Report - Axis IT Operations";
    decimal MaxA(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameAmount> l) => l.Any() ? l.Max(x => x.Amount) : 1m;
}

@await Html.PartialAsync("_ReportStyles")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-tasks"></i> Activity Report</h1>
            <p class="report-subtitle">Time logged across the team</p>
        </div>
        <div class="report-actions">
            <a class="report-btn" asp-action="Index"><i class="fas fa-arrow-left"></i> All Reports</a>
            <button class="report-btn primary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-list-check"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Total</div><div class="kpi-label">Total Activities</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-clock"></i></div><div class="kpi-body"><div class="kpi-value">@Model.TotalHours h</div><div class="kpi-label">Total Hours Logged</div></div></div>
        <div class="kpi-card"><div class="kpi-icon amber"><i class="fas fa-play-circle"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Ongoing</div><div class="kpi-label">Ongoing</div></div></div>
        <div class="kpi-card"><div class="kpi-icon slate"><i class="fas fa-check-circle"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Completed</div><div class="kpi-label">Completed</div></div></div>
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-tags"></i> Hours by Category</span></div>
            <div class="report-card-body">
                @if (Model.HoursByCategory.Any())
                {
                    var m1 = MaxA(Model.HoursByCategory);
                    <div class="bars">
                        @foreach (var s in Model.HoursByCategory)
                        {
                            <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(Math.Round(s.Amount * 100 / m1))%"></div></div><div class="bar-value">@s.Amount h</div></div>
                        }
                    </div>
                }
                else { <div class="empty-mini">No completed activities yet</div> }
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-folder"></i> Activities by Category</span></div>
            <div class="report-card-body">
                @if (Model.ByCategory.Any())
                {
                    <table class="report-table">
                        <thead><tr><th>Category</th><th style="text-align:right;">Count</th></tr></thead>
                        <tbody>@foreach (var c in Model.ByCategory) { <tr><td>@c.Name</td><td style="text-align:right;"><span class="pill">@c.Count</span></td></tr> }</tbody>
                    </table>
                }
                else { <div class="empty-mini">No data</div> }
            </div>
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-user-clock"></i> Hours by User (top 10)</span></div>
        <div class="report-card-body">
            @if (Model.HoursByUser.Any())
            {
                var m2 = MaxA(Model.HoursByUser);
                <div class="bars">
                    @foreach (var s in Model.HoursByUser)
                    {
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill green" style="width:@(Math.Round(s.Amount * 100 / m2))%"></div></div><div class="bar-value">@s.Amount h</div></div>
                    }
                </div>
            }
            else { <div class="empty-mini">No completed activities yet</div> }
        </div>
    </div>
</div>
