@model IT_Service_Management_System.ViewModels.Reports.UsersReportVM
@{
    ViewData["Title"] = "Users & Departments Report - Axis IT Operations";
    int Max(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameCount> l) => l.Any() ? l.Max(x => x.Count) : 1;
}

@await Html.PartialAsync("_ReportStyles")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-users"></i> Users &amp; Departments</h1>
            <p class="report-subtitle">Workforce composition and asset allocation</p>
        </div>
        <div class="report-actions">
            <a class="report-btn" asp-action="Index"><i class="fas fa-arrow-left"></i> All Reports</a>
            <button class="report-btn primary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-users"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Total</div><div class="kpi-label">Total Users</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-user-check"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Active</div><div class="kpi-label">Active</div></div></div>
        <div class="kpi-card"><div class="kpi-icon slate"><i class="fas fa-user-slash"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Inactive</div><div class="kpi-label">Inactive</div></div></div>
        <div class="kpi-card"><div class="kpi-icon violet"><i class="fas fa-building"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ByDepartment.Count</div><div class="kpi-label">Departments Represented</div></div></div>
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-user-tag"></i> By Role</span></div>
            <div class="report-card-body">
                @{ var m1 = Max(Model.ByRole); }
                <div class="bars">
                    @foreach (var s in Model.ByRole)
                    {
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(s.Count * 100 / m1)%"></div></div><div class="bar-value">@s.Count</div></div>
                    }
                </div>
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-building"></i> By Department</span></div>
            <div class="report-card-body">
                @{ var m2 = Max(Model.ByDepartment); }
                <div class="bars">
                    @foreach (var s in Model.ByDepartment)
                    {
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill green" style="width:@(s.Count * 100 / m2)%"></div></div><div class="bar-value">@s.Count</div></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-laptop"></i> Assets per User (top 10)</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.AssetsPerUser.Any())
            {
                <table class="report-table">
                    <thead><tr><th>User</th><th style="text-align:right;">Assets Held</th></tr></thead>
                    <tbody>@foreach (var u in Model.AssetsPerUser) { <tr><td>@u.Name</td><td style="text-align:right;"><span class="pill">@u.Count</span></td></tr> }</tbody>
                </table>
            }
            else { <div class="empty-mini">No assets currently assigned to users</div> }
        </div>
    </div>
</div>
