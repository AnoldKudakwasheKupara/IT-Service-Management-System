@model IT_Service_Management_System.ViewModels.Reports.AssetsReportVM
@{
    ViewData["Title"] = "Assets Report - Axis IT Operations";
    string Money(decimal v) => v.ToString("C0", new System.Globalization.CultureInfo("en-US"));
    int Max(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameCount> l) => l.Any() ? l.Max(x => x.Count) : 1;
}

@await Html.PartialAsync("_ReportStyles")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-laptop-code"></i> Assets Report</h1>
            <p class="report-subtitle">Inventory status, value and movement</p>
        </div>
        <div class="report-actions">
            <a class="report-btn" asp-action="Index"><i class="fas fa-arrow-left"></i> All Reports</a>
            <button class="report-btn primary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-boxes-stacked"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Total</div><div class="kpi-label">Total Assets</div></div></div>
        <div class="kpi-card"><div class="kpi-icon slate"><i class="fas fa-coins"></i></div><div class="kpi-body"><div class="kpi-value">@Money(Model.TotalValue)</div><div class="kpi-label">Total Purchase Value</div></div></div>
        @foreach (var s in Model.ByStatus.Take(3))
        {
            <div class="kpi-card"><div class="kpi-icon @(s.Name == "Issued" ? "amber" : s.Name == "In Repair" ? "violet" : "green")"><i class="fas fa-tag"></i></div><div class="kpi-body"><div class="kpi-value">@s.Count</div><div class="kpi-label">@s.Name</div></div></div>
        }
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-layer-group"></i> By Status</span></div>
            <div class="report-card-body">
                @{ var m1 = Max(Model.ByStatus); }
                <div class="bars">
                    @foreach (var s in Model.ByStatus)
                    {
                        var cls = s.Name == "Issued" ? "amber" : s.Name == "Stolen" || s.Name == "Retired" ? "red" : "green";
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill @cls" style="width:@(s.Count * 100 / m1)%"></div></div><div class="bar-value">@s.Count</div></div>
                    }
                </div>
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-chart-line"></i> By Condition</span></div>
            <div class="report-card-body">
                @{ var m2 = Max(Model.ByCondition); }
                <div class="bars">
                    @foreach (var s in Model.ByCondition)
                    {
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(s.Count * 100 / m2)%"></div></div><div class="bar-value">@s.Count</div></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-user-tag"></i> Assets by Holder</span></div>
            <div class="report-card-body">
                @if (Model.ByHolder.Any())
                {
                    <table class="report-table">
                        <thead><tr><th>Holder</th><th style="text-align:right;">Assets</th></tr></thead>
                        <tbody>@foreach (var h in Model.ByHolder) { <tr><td>@h.Name</td><td style="text-align:right;"><span class="pill">@h.Count</span></td></tr> }</tbody>
                    </table>
                }
                else { <div class="empty-mini">No assets currently assigned</div> }
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-bolt"></i> Actions Recorded (by type)</span></div>
            <div class="report-card-body">
                @if (Model.ByEventType.Any())
                {
                    var m3 = Max(Model.ByEventType);
                    <div class="bars">
                        @foreach (var s in Model.ByEventType)
                        {
                            <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(s.Count * 100 / m3)%"></div></div><div class="bar-value">@s.Count</div></div>
                        }
                    </div>
                }
                else { <div class="empty-mini">No actions recorded</div> }
            </div>
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-clock-rotate-left"></i> Recent Asset Activity</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.RecentActivity.Any())
            {
                <table class="report-table">
                    <thead><tr><th>Date &amp; Time</th><th>Asset</th><th>Action</th><th>User</th><th>Condition</th><th>By</th></tr></thead>
                    <tbody>
                        @foreach (var h in Model.RecentActivity)
                        {
                            <tr>
                                <td>@h.Date.ToString("MMM dd, yyyy 'at' h:mm tt")</td>
                                <td>@(h.Asset?.ItemName ?? "—")</td>
                                <td><span class="pill slate">@h.EventType</span></td>
                                <td>@(h.User != null ? $"{h.User.FirstName} {h.User.LastName}" : "—")</td>
                                <td>@h.Condition</td>
                                <td>@h.PerformedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No asset activity recorded yet</div> }
        </div>
    </div>
</div>
