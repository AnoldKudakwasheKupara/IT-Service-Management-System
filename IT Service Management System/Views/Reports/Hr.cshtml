@model IT_Service_Management_System.ViewModels.Reports.HrReportVM
@{
    ViewData["Title"] = "HR Report - Axis IT Operations";
    int Max(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameCount> l) => l.Any() ? l.Max(x => x.Count) : 1;
    var role = Context.Session.GetString("UserRole");
    var isFullAccess = role == "Admin" || role == "SystemsAdmin";
}

@await Html.PartialAsync("_ReportStyles")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-user-friends"></i> HR Report</h1>
            <p class="report-subtitle">Exit clearances, interviews &amp; talent analytics</p>
        </div>
        <div class="report-actions">
            @if (isFullAccess)
            {
                <a class="report-btn" asp-action="Index"><i class="fas fa-arrow-left"></i> All Reports</a>
            }
            <button class="report-btn primary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-file-signature"></i></div><div class="kpi-body"><div class="kpi-value">@Model.TotalClearances</div><div class="kpi-label">Exit Clearances</div></div></div>
        <div class="kpi-card"><div class="kpi-icon amber"><i class="fas fa-spinner"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ClearancesInProgress</div><div class="kpi-label">In Progress</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-check-circle"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ClearancesCompleted</div><div class="kpi-label">Completed</div></div></div>
        <div class="kpi-card"><div class="kpi-icon violet"><i class="fas fa-clipboard-list"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ExitInterviews</div><div class="kpi-label">Exit Interviews</div></div></div>
        <div class="kpi-card"><div class="kpi-icon slate"><i class="fas fa-user-friends"></i></div><div class="kpi-body"><div class="kpi-value">@Model.EngagementInterviews</div><div class="kpi-label">Engagement Interviews</div></div></div>
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-user-tie"></i></div><div class="kpi-body"><div class="kpi-value">@Model.TalentRecords</div><div class="kpi-label">Talent Records</div></div></div>
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-layer-group"></i> Clearances by Status</span></div>
            <div class="report-card-body">
                @if (Model.ClearancesByStatus.Any())
                {
                    var m1 = Max(Model.ClearancesByStatus);
                    <div class="bars">
                        @foreach (var s in Model.ClearancesByStatus)
                        {
                            var cls = s.Name == "Completed" ? "green" : s.Name == "Rejected" ? "red" : "amber";
                            <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill @cls" style="width:@(s.Count * 100 / m1)%"></div></div><div class="bar-value">@s.Count</div></div>
                        }
                    </div>
                }
                else { <div class="empty-mini">No clearances yet</div> }
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-stairs"></i> Clearances by Current Stage</span></div>
            <div class="report-card-body">
                @if (Model.ClearancesByStage.Any())
                {
                    var m2 = Max(Model.ClearancesByStage);
                    <div class="bars">
                        @foreach (var s in Model.ClearancesByStage)
                        {
                            <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(s.Count * 100 / m2)%"></div></div><div class="bar-value">@s.Count</div></div>
                        }
                    </div>
                }
                else { <div class="empty-mini">No clearances yet</div> }
            </div>
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-clock-rotate-left"></i> Recent Exit Clearances</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.RecentClearances.Any())
            {
                <table class="report-table">
                    <thead><tr><th>Employee</th><th>Current Stage</th><th>Status</th><th>Created</th></tr></thead>
                    <tbody>
                        @foreach (var c in Model.RecentClearances)
                        {
                            <tr>
                                <td>@(c.Employee != null ? $"{c.Employee.FirstName} {c.Employee.LastName}" : "—")</td>
                                <td><span class="pill">@c.CurrentStage</span></td>
                                <td><span class="pill @(c.Status.ToString() == "Completed" ? "green" : c.Status.ToString() == "Rejected" ? "red" : "amber")">@c.Status</span></td>
                                <td>@c.CreatedDate.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No exit clearances recorded yet</div> }
        </div>
    </div>
</div>
