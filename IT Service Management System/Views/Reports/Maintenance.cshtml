@model IT_Service_Management_System.ViewModels.Reports.MaintenanceReportVM
@{
    ViewData["Title"] = "Maintenance Report - Axis IT Operations";
    int Max(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameCount> l) => l.Any() ? l.Max(x => x.Count) : 1;
}

@await Html.PartialAsync("_ReportStyles")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-wrench"></i> Maintenance Report</h1>
            <p class="report-subtitle">Maintenance activity and upcoming schedule</p>
        </div>
        <div class="report-actions">
            <a class="report-btn" asp-action="Index"><i class="fas fa-arrow-left"></i> All Reports</a>
            <button class="report-btn primary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-clipboard-list"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Total</div><div class="kpi-label">Total Records</div></div></div>
        <div class="kpi-card"><div class="kpi-icon amber"><i class="fas fa-calendar-day"></i></div><div class="kpi-body"><div class="kpi-value">@Model.UpcomingCount</div><div class="kpi-label">Upcoming Scheduled</div></div></div>
        <div class="kpi-card"><div class="kpi-icon violet"><i class="fas fa-layer-group"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ByType.Count</div><div class="kpi-label">Maintenance Types</div></div></div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-layer-group"></i> By Type</span></div>
        <div class="report-card-body">
            @if (Model.ByType.Any())
            {
                var m1 = Max(Model.ByType);
                <div class="bars">
                    @foreach (var s in Model.ByType)
                    {
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(s.Count * 100 / m1)%"></div></div><div class="bar-value">@s.Count</div></div>
                    }
                </div>
            }
            else { <div class="empty-mini">No maintenance records yet</div> }
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-clock-rotate-left"></i> Recent Maintenance</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.Recent.Any())
            {
                <table class="report-table">
                    <thead><tr><th>Date</th><th>Asset</th><th>Type</th><th>Problem</th><th>By</th></tr></thead>
                    <tbody>
                        @foreach (var r in Model.Recent)
                        {
                            <tr>
                                <td>@r.MaintenanceDate.ToString("MMM dd, yyyy")</td>
                                <td>@(r.AssetName ?? "—")</td>
                                <td><span class="pill slate">@r.MaintenanceType</span></td>
                                <td style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(r.ProblemDescription ?? "—")</td>
                                <td>@(r.EmployeeName ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No maintenance records yet</div> }
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-calendar-day"></i> Upcoming Scheduled Maintenance</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.Upcoming.Any())
            {
                <table class="report-table">
                    <thead><tr><th>Next Date</th><th>Asset</th><th>Type</th><th>Notes</th></tr></thead>
                    <tbody>
                        @foreach (var r in Model.Upcoming)
                        {
                            <tr>
                                <td>@r.NextMaintenanceDate?.ToString("MMM dd, yyyy")</td>
                                <td>@(r.AssetName ?? "—")</td>
                                <td><span class="pill">@r.MaintenanceType</span></td>
                                <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(r.Comments ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No upcoming maintenance scheduled</div> }
        </div>
    </div>
</div>
