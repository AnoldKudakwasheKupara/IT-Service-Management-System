<style>
    .report-container { max-width: 1200px; margin: 0 auto; }

    .report-header { margin-bottom: 1.5rem; }
    .report-title {
        font-size: 1.6rem; font-weight: 700; color: var(--gray-800);
        letter-spacing: -0.4px; margin: 0; display: flex; align-items: center; gap: 0.5rem;
    }
    .report-title i { color: var(--primary); }
    .report-subtitle { color: var(--gray-500); margin-top: 0.35rem; font-size: 0.9rem; }

    .report-actions { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; }
    .report-btn {
        display: inline-flex; align-items: center; gap: 0.45rem; text-decoration: none;
        padding: 0.55rem 1.1rem; border-radius: 40px; font-size: 0.82rem; font-weight: 600;
        border: 1px solid var(--gray-200); background: var(--bg-card); color: var(--gray-700);
        transition: var(--transition-smooth); cursor: pointer;
    }
    .report-btn:hover { background: var(--gray-50); color: var(--primary); border-color: var(--primary); }
    .report-btn.primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; border: none; }
    .report-btn.primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); color: #fff; }

    /* KPI cards */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .kpi-card {
        background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: var(--radius-md);
        padding: 1.15rem 1.25rem; display: flex; align-items: center; gap: 1rem; box-shadow: var(--shadow-sm);
        transition: var(--transition-smooth);
    }
    .kpi-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .kpi-icon {
        width: 48px; height: 48px; border-radius: 0.85rem; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center; font-size: 1.25rem; color: #fff;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    }
    .kpi-icon.green { background: linear-gradient(135deg, #2c9e6e, #1f8a5c); }
    .kpi-icon.amber { background: linear-gradient(135deg, #f5b042, #e6a017); }
    .kpi-icon.red { background: linear-gradient(135deg, #e53e3e, #c53030); }
    .kpi-icon.slate { background: linear-gradient(135deg, #64748b, #475569); }
    .kpi-icon.violet { background: linear-gradient(135deg, #6366f1, #4f46e5); }
    .kpi-body { min-width: 0; }
    .kpi-value { font-size: 1.5rem; font-weight: 800; color: var(--gray-800); line-height: 1.1; }
    .kpi-label { font-size: 0.78rem; color: var(--gray-500); margin-top: 2px; }

    /* Section cards */
    .report-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .report-card {
        background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 1.25rem;
    }
    .report-card-header {
        padding: 0.95rem 1.25rem; border-bottom: 1px solid var(--gray-200); font-weight: 600;
        color: var(--gray-800); display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
    }
    .report-card-header i { color: var(--primary); margin-right: 0.4rem; }
    .report-card-body { padding: 1.1rem 1.25rem; }

    /* Horizontal bar distribution */
    .bars { display: flex; flex-direction: column; gap: 0.7rem; }
    .bar-row { display: grid; grid-template-columns: 140px 1fr 52px; align-items: center; gap: 0.6rem; }
    .bar-label { font-size: 0.82rem; color: var(--gray-700); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .bar-track { background: var(--gray-100); border-radius: 30px; height: 12px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 30px; background: linear-gradient(90deg, var(--primary-light), var(--primary)); min-width: 2px; }
    .bar-fill.green { background: linear-gradient(90deg, #6ee7b7, #2c9e6e); }
    .bar-fill.amber { background: linear-gradient(90deg, #fcd9a3, #f5b042); }
    .bar-fill.red { background: linear-gradient(90deg, #fca5a5, #e53e3e); }
    .bar-value { font-size: 0.82rem; font-weight: 700; color: var(--gray-700); text-align: right; }

    /* Tables */
    .report-table { width: 100%; border-collapse: collapse; }
    .report-table thead th {
        text-align: left; padding: 0.7rem 0.85rem; font-size: 0.7rem; text-transform: uppercase;
        letter-spacing: 0.5px; color: var(--gray-500); background: var(--gray-50); font-weight: 600;
    }
    .report-table tbody td { padding: 0.75rem 0.85rem; border-top: 1px solid var(--gray-100); color: var(--gray-700); font-size: 0.85rem; }
    .report-table tbody tr:hover { background: var(--gray-50); }

    .pill { display: inline-flex; align-items: center; gap: 5px; font-size: 0.72rem; font-weight: 600; padding: 3px 10px; border-radius: 30px; background: var(--primary-light); color: var(--primary-dark); }
    .pill.green { background: var(--success-light); color: var(--success); }
    .pill.amber { background: var(--warning-light); color: #b45309; }
    .pill.red { background: var(--danger-light); color: var(--danger); }
    .pill.slate { background: var(--gray-100); color: var(--gray-600); }

    .empty-mini { padding: 1.75rem; text-align: center; color: var(--gray-400); font-size: 0.85rem; }

    /* Reports hub link cards */
    .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }
    .hub-card {
        display: flex; align-items: flex-start; gap: 0.9rem; text-decoration: none;
        background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: var(--radius-md);
        padding: 1.15rem; transition: var(--transition-smooth); box-shadow: var(--shadow-sm);
    }
    .hub-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--primary); }
    .hub-icon { width: 46px; height: 46px; border-radius: 0.8rem; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: #fff; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); }
    .hub-text h3 { font-size: 0.98rem; font-weight: 700; color: var(--gray-800); margin: 0 0 0.2rem 0; }
    .hub-text p { font-size: 0.78rem; color: var(--gray-500); margin: 0; }

    @@media print {
        .report-actions, .sidebar, .topbar { display: none !important; }
        .kpi-card, .report-card, .hub-card { box-shadow: none !important; }
    }

    @@media (max-width: 820px) {
        .report-grid { grid-template-columns: 1fr; }
        .bar-row { grid-template-columns: 110px 1fr 44px; }
    }
</style>
