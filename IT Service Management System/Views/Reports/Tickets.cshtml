@model IT_Service_Management_System.ViewModels.Reports.TicketsReportVM
@{
    ViewData["Title"] = "Tickets Report - Axis IT Operations";
    int Max(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameCount> l) => l.Any() ? l.Max(x => x.Count) : 1;
}

@await Html.PartialAsync("_ReportStyles")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-ticket-alt"></i> Tickets Report</h1>
            <p class="report-subtitle">Helpdesk ticket breakdown and trends</p>
        </div>
        <div class="report-actions">
            <a class="report-btn" asp-action="Index"><i class="fas fa-arrow-left"></i> All Reports</a>
            <button class="report-btn primary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-ticket-alt"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Total</div><div class="kpi-label">Total Tickets</div></div></div>
        <div class="kpi-card"><div class="kpi-icon amber"><i class="fas fa-folder-open"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Open</div><div class="kpi-label">Open</div></div></div>
        <div class="kpi-card"><div class="kpi-icon violet"><i class="fas fa-spinner"></i></div><div class="kpi-body"><div class="kpi-value">@Model.InProgress</div><div class="kpi-label">In Progress</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-check-circle"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Resolved</div><div class="kpi-label">Resolved</div></div></div>
        <div class="kpi-card"><div class="kpi-icon slate"><i class="fas fa-lock"></i></div><div class="kpi-body"><div class="kpi-value">@Model.Closed</div><div class="kpi-label">Closed</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-percent"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ResolutionRate%</div><div class="kpi-label">Resolution Rate</div></div></div>
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-layer-group"></i> By Status</span></div>
            <div class="report-card-body">
                @{ var m1 = Max(Model.ByStatus); }
                <div class="bars">
                    @foreach (var s in Model.ByStatus)
                    {
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(s.Count * 100 / m1)%"></div></div><div class="bar-value">@s.Count</div></div>
                    }
                </div>
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-flag"></i> By Priority</span></div>
            <div class="report-card-body">
                @{ var m2 = Max(Model.ByPriority); }
                <div class="bars">
                    @foreach (var s in Model.ByPriority)
                    {
                        var cls = s.Name == "High" ? "red" : s.Name == "Medium" ? "amber" : "green";
                        <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill @cls" style="width:@(s.Count * 100 / m2)%"></div></div><div class="bar-value">@s.Count</div></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-tags"></i> By Category</span></div>
            <div class="report-card-body">
                @if (Model.ByCategory.Any())
                {
                    var m3 = Max(Model.ByCategory);
                    <div class="bars">
                        @foreach (var s in Model.ByCategory)
                        {
                            <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill" style="width:@(s.Count * 100 / m3)%"></div></div><div class="bar-value">@s.Count</div></div>
                        }
                    </div>
                }
                else { <div class="empty-mini">No data</div> }
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-user-friends"></i> Top Requesters</span></div>
            <div class="report-card-body">
                @if (Model.TopRequesters.Any())
                {
                    <table class="report-table">
                        <thead><tr><th>User</th><th style="text-align:right;">Tickets</th></tr></thead>
                        <tbody>
                            @foreach (var r in Model.TopRequesters)
                            {
                                <tr><td>@r.Name</td><td style="text-align:right;"><span class="pill">@r.Count</span></td></tr>
                            }
                        </tbody>
                    </table>
                }
                else { <div class="empty-mini">No data</div> }
            </div>
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-clock-rotate-left"></i> Recent Tickets</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.Recent.Any())
            {
                <table class="report-table">
                    <thead><tr><th>Title</th><th>Status</th><th>Priority</th><th>Requester</th><th>Created</th></tr></thead>
                    <tbody>
                        @foreach (var t in Model.Recent)
                        {
                            <tr>
                                <td>@t.Title</td>
                                <td><span class="pill slate">@t.Status</span></td>
                                <td><span class="pill @(t.Priority.ToString() == "High" ? "red" : t.Priority.ToString() == "Medium" ? "amber" : "green")">@t.Priority</span></td>
                                <td>@(t.CreatedBy != null ? $"{t.CreatedBy.FirstName} {t.CreatedBy.LastName}" : "—")</td>
                                <td>@t.CreatedAt.ToString("MMM dd, yyyy 'at' h:mm tt")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No tickets recorded yet</div> }
        </div>
    </div>
</div>
