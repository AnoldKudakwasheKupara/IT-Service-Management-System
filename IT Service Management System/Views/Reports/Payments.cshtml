@model IT_Service_Management_System.ViewModels.Reports.PaymentsReportVM
@{
    ViewData["Title"] = "Payments Report - Axis IT Operations";
    string Money(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("en-US"));
    decimal MaxA(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameAmount> l) => l.Any() ? l.Max(x => x.Amount) : 1m;
}

@await Html.PartialAsync("_ReportStyles")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-file-invoice-dollar"></i> Payments Report</h1>
            <p class="report-subtitle">Service payment obligations and status</p>
        </div>
        <div class="report-actions">
            <a class="report-btn" asp-action="Index"><i class="fas fa-arrow-left"></i> All Reports</a>
            <button class="report-btn primary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon slate"><i class="fas fa-coins"></i></div><div class="kpi-body"><div class="kpi-value">@Money(Model.TotalAmount)</div><div class="kpi-label">Total Billed</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-check-circle"></i></div><div class="kpi-body"><div class="kpi-value">@Money(Model.TotalPaid)</div><div class="kpi-label">Paid</div></div></div>
        <div class="kpi-card"><div class="kpi-icon amber"><i class="fas fa-hourglass-half"></i></div><div class="kpi-body"><div class="kpi-value">@Money(Model.TotalOutstanding)</div><div class="kpi-label">Outstanding</div></div></div>
        <div class="kpi-card"><div class="kpi-icon red"><i class="fas fa-triangle-exclamation"></i></div><div class="kpi-body"><div class="kpi-value">@Money(Model.TotalOverdue)</div><div class="kpi-label">Overdue</div></div></div>
    </div>

    <div class="report-grid">
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-chart-bar"></i> Amount by Status</span></div>
            <div class="report-card-body">
                @if (Model.AmountByStatus.Any())
                {
                    var m1 = MaxA(Model.AmountByStatus);
                    <div class="bars">
                        @foreach (var s in Model.AmountByStatus)
                        {
                            var cls = s.Name == "Paid" ? "green" : s.Name == "Overdue" ? "red" : "amber";
                            <div class="bar-row"><div class="bar-label">@s.Name</div><div class="bar-track"><div class="bar-fill @cls" style="width:@(Math.Round(s.Amount * 100 / m1))%"></div></div><div class="bar-value">@s.Amount.ToString("N0")</div></div>
                        }
                    </div>
                }
                else { <div class="empty-mini">No payments recorded</div> }
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-list-ol"></i> Count by Status</span></div>
            <div class="report-card-body">
                @if (Model.CountByStatus.Any())
                {
                    <table class="report-table">
                        <thead><tr><th>Status</th><th style="text-align:right;">Payments</th></tr></thead>
                        <tbody>@foreach (var c in Model.CountByStatus) { <tr><td>@c.Name</td><td style="text-align:right;"><span class="pill @(c.Name == "Paid" ? "green" : c.Name == "Overdue" ? "red" : "amber")">@c.Count</span></td></tr> }</tbody>
                    </table>
                }
                else { <div class="empty-mini">No data</div> }
            </div>
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span style="color:var(--danger);"><i class="fas fa-triangle-exclamation" style="color:var(--danger);"></i> Overdue Payments</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.Overdue.Any())
            {
                <table class="report-table">
                    <thead><tr><th>Service</th><th>Amount</th><th>Due Date</th><th>Status</th></tr></thead>
                    <tbody>@foreach (var p in Model.Overdue) { <tr><td>@p.ServiceName</td><td>@Money(p.Amount)</td><td>@p.DueDate.ToString("MMM dd, yyyy")</td><td><span class="pill red">@(string.IsNullOrEmpty(p.Status) ? "Pending" : p.Status)</span></td></tr> }</tbody>
                </table>
            }
            else { <div class="empty-mini">No overdue payments 🎉</div> }
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-calendar-day"></i> Upcoming (next 30 days)</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.Upcoming.Any())
            {
                <table class="report-table">
                    <thead><tr><th>Service</th><th>Amount</th><th>Due Date</th><th>Status</th></tr></thead>
                    <tbody>@foreach (var p in Model.Upcoming) { <tr><td>@p.ServiceName</td><td>@Money(p.Amount)</td><td>@p.DueDate.ToString("MMM dd, yyyy")</td><td><span class="pill amber">@(string.IsNullOrEmpty(p.Status) ? "Pending" : p.Status)</span></td></tr> }</tbody>
                </table>
            }
            else { <div class="empty-mini">No payments due in the next 30 days</div> }
        </div>
    </div>
</div>
