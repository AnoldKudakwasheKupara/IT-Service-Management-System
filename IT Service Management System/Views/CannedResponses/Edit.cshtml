@model IT_Service_Management_System.Models.CannedResponse

@{
    ViewData["Title"] = "Edit Canned Response - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-pencil-alt me-2" style="color: var(--warning);"></i>
                    Edit Canned Response
                </h1>
                <p class="text-muted mt-2">Update this reusable reply snippet</p>
            </div>
        </div>
    </div>

    <div class="data-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-reply-all me-2"></i>
                <span>Response Details</span>
            </div>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="card-body-custom">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="form-group">
                <label asp-for="Title" class="form-label">
                    <i class="fas fa-heading"></i> Title <span class="required">*</span>
                </label>
                <input asp-for="Title" class="form-control-modern" placeholder="e.g. Password reset instructions" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Body" class="form-label">
                    <i class="fas fa-align-left"></i> Body <span class="required">*</span>
                </label>
                <textarea asp-for="Body" class="form-control-textarea" rows="6" placeholder="Enter the reusable reply text..."></textarea>
                <span asp-validation-for="Body" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> Save
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
        }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    .data-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .card-body-custom {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-label i {
            color: var(--primary);
            font-size: 0.875rem;
        }

    .required {
        color: var(--danger);
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        background: white;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59,130,246, 0.1);
        }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        background: white;
        resize: vertical;
    }

        .form-control-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59,130,246, 0.1);
        }

    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-save {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
