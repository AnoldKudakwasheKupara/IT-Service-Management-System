@model TalentIdentification
@using IT_Service_Management_System.Enums

@{
    ViewData["Title"] = "Add Talent Identification - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-plus-circle me-2" style="color: var(--success);"></i>
                    Add Talent Identification
                </h1>
                <p class="text-muted mt-2">Complete the talent identification and assessment form</p>
            </div>
        </div>
    </div>

    <form asp-action="Create" method="post" id="talentForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <!-- Employee Information Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="header-icon-wrapper">
                    <i class="fas fa-user-circle"></i>
                </div>
                <h3>Employee Information</h3>
                <span class="section-badge">Personal Details</span>
            </div>
            <div class="section-body">
                <div class="form-row-grid">
                    <div class="form-group-modern">
                        <label asp-for="EmployeeName" class="form-label">
                            <i class="fas fa-user"></i> Employee Name
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-user input-icon"></i>
                            <input asp-for="EmployeeName" class="form-control-modern" placeholder="Enter employee name" />
                        </div>
                        <span asp-validation-for="EmployeeName" class="validation-message text-danger"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Department" class="form-label">
                            <i class="fas fa-building"></i> Department
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-building input-icon"></i>
                            <input asp-for="Department" class="form-control-modern" placeholder="Enter department" />
                        </div>
                        <span asp-validation-for="Department" class="validation-message text-danger"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="JobTitle" class="form-label">
                            <i class="fas fa-briefcase"></i> Job Title
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-briefcase input-icon"></i>
                            <input asp-for="JobTitle" class="form-control-modern" placeholder="Enter job title" />
                        </div>
                        <span asp-validation-for="JobTitle" class="validation-message text-danger"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Country" class="form-label">
                            <i class="fas fa-globe"></i> Country
                            <span class="required">*</span>
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-globe input-icon"></i>
                            <input asp-for="Country" class="form-control-modern" placeholder="Enter country" />
                        </div>
                        <span asp-validation-for="Country" class="validation-message text-danger"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="HireDate" class="form-label">
                            <i class="fas fa-calendar-alt"></i> Hire Date
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-calendar-alt input-icon"></i>
                            <input asp-for="HireDate" type="date" class="form-control-modern" />
                        </div>
                        <span asp-validation-for="HireDate" class="validation-message text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Track Record Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="header-icon-wrapper" style="background: linear-gradient(135deg, var(--success), #059669);">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>Performance Track Record</h3>
                <span class="section-badge">KPIs & Projects</span>
            </div>
            <div class="section-body">
                <div class="form-group-modern mb-3">
                    <label class="form-label">What KPI achievement scores has this person achieved over the past 24 to 36 months?</label>
                </div>
                <div class="form-row-grid-4">
                    <div class="form-group-modern">
                        <label class="form-label">2023</label>
                        <div class="textarea-wrapper-sm">
                            <i class="fas fa-calendar-alt textarea-icon"></i>
                            <textarea asp-for="KPI2023" class="form-control-textarea-sm" rows="4" placeholder="Enter KPI achievements for 2023..."></textarea>
                        </div>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label">2024</label>
                        <div class="textarea-wrapper-sm">
                            <i class="fas fa-calendar-alt textarea-icon"></i>
                            <textarea asp-for="KPI2024" class="form-control-textarea-sm" rows="4" placeholder="Enter KPI achievements for 2024..."></textarea>
                        </div>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label">2025</label>
                        <div class="textarea-wrapper-sm">
                            <i class="fas fa-calendar-alt textarea-icon"></i>
                            <textarea asp-for="KPI2025" class="form-control-textarea-sm" rows="4" placeholder="Enter KPI achievements for 2025..."></textarea>
                        </div>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label">Current Year - 2026</label>
                        <div class="textarea-wrapper-sm">
                            <i class="fas fa-calendar-alt textarea-icon"></i>
                            <textarea asp-for="KPI2026" class="form-control-textarea-sm" rows="4" placeholder="Enter KPI achievements for 2026..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="form-group-modern mt-3">
                    <label asp-for="KeyProjectsLed" class="form-label">
                        <i class="fas fa-project-diagram"></i> What key projects has the employee led that have brought value to and positively impacted the organization / department?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-tasks textarea-icon"></i>
                        <textarea asp-for="KeyProjectsLed" class="form-control-textarea" rows="5" placeholder="Enter key projects led..."></textarea>
                    </div>
                    <span asp-validation-for="KeyProjectsLed" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="DeliverySetbacks" class="form-label">
                        <i class="fas fa-exclamation-triangle"></i> What set-backs in delivery has this person encountered over the past 24 to 36 months?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-exclamation-triangle textarea-icon"></i>
                        <textarea asp-for="DeliverySetbacks" class="form-control-textarea" rows="5" placeholder="Enter delivery setbacks..."></textarea>
                    </div>
                    <span asp-validation-for="DeliverySetbacks" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="LongTermBusinessInitiatives" class="form-label">
                        <i class="fas fa-lightbulb"></i> What ideas/projects has this person independently initiated that focus on the long-term success of the business?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-lightbulb textarea-icon"></i>
                        <textarea asp-for="LongTermBusinessInitiatives" class="form-control-textarea" rows="5" placeholder="Enter long-term business initiatives..."></textarea>
                    </div>
                    <span asp-validation-for="LongTermBusinessInitiatives" class="validation-message text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Core Leadership Capability Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="header-icon-wrapper" style="background: linear-gradient(135deg, var(--info), #2563eb);">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Core Leadership Capability</h3>
                <span class="section-badge">Management</span>
            </div>
            <div class="section-body">
                <div class="info-alert">
                    <i class="fas fa-info-circle"></i>
                    <div>Only complete this section if the employee is in a supervisory or management role.</div>
                </div>

                <div class="form-group-modern mb-3">
                    <label class="form-label">How are the person's key direct reports performing?</label>
                    <p class="text-muted small">Rate using: CEE, EE, ME, PME or DNME</p>
                </div>

                <div class="table-responsive">
                    <table class="dynamic-table" id="directReportsTable">
                        <thead>
                            <tr>
                                <th style="width: 25%;">Employee Name</th>
                                <th style="width: 20%;">Performance Rating</th>
                                <th>Comments</th>
                                <th style="width: 120px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.DirectReports.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <div class="input-icon-wrapper-sm">
                                            <i class="fas fa-user input-icon-sm"></i>
                                            <input asp-for="DirectReports[i].EmployeeName" class="form-control-modern-sm" placeholder="Name" />
                                        </div>
                                    </td>
                                    <td>
                                        <select asp-for="DirectReports[i].PerformanceRating" class="form-control-modern-sm">
                                            <option value="">Select</option>
                                            <option value="1">CEE</option>
                                            <option value="2">EE</option>
                                            <option value="3">ME</option>
                                            <option value="4">PME</option>
                                            <option value="5">DNME</option>
                                        </select>
                                    </td>
                                    <td>
                                        <div class="input-icon-wrapper-sm">
                                            <i class="fas fa-comment input-icon-sm"></i>
                                            <input asp-for="DirectReports[i].Comments" class="form-control-modern-sm" placeholder="Comments" />
                                        </div>
                                    </td>
                                    <td>
                                        <button type="button" class="btn-remove-sm remove-direct-report">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <button type="button" id="addDirectReport" class="btn-add-row">
                    <i class="fas fa-plus-circle"></i> Add Direct Report
                </button>
            </div>
        </div>

        <!-- Leadership Assessment Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="header-icon-wrapper" style="background: linear-gradient(135deg, var(--info), #2563eb);">
                    <i class="fas fa-user-tie"></i>
                </div>
                <h3>Leadership Assessment</h3>
                <span class="section-badge">Evaluation</span>
            </div>
            <div class="section-body">
                <div class="form-group-modern">
                    <label asp-for="LeadershipOverallComments" class="form-label">
                        <i class="fas fa-comment"></i> Overall Comments
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-comment textarea-icon"></i>
                        <textarea asp-for="LeadershipOverallComments" class="form-control-textarea" rows="5" placeholder="Enter overall leadership comments..."></textarea>
                    </div>
                    <span asp-validation-for="LeadershipOverallComments" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="TeamCapabilityDevelopment" class="form-label">
                        <i class="fas fa-users-cog"></i> What has the person done in the past 24 months to develop the capability of his/her team?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-users-cog textarea-icon"></i>
                        <textarea asp-for="TeamCapabilityDevelopment" class="form-control-textarea" rows="5" placeholder="Enter team development activities..."></textarea>
                    </div>
                    <span asp-validation-for="TeamCapabilityDevelopment" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="StructuredOneOnOnes" class="form-label">
                        <i class="fas fa-handshake"></i> How many structured one-on-one meetings has the person had with his/her direct reports this year?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-handshake textarea-icon"></i>
                        <textarea asp-for="StructuredOneOnOnes" class="form-control-textarea" rows="3" placeholder="Enter number of one-on-one meetings..."></textarea>
                    </div>
                    <span asp-validation-for="StructuredOneOnOnes" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="TerminatedPoorPerformers" class="form-label">
                        <i class="fas fa-user-slash"></i> Has this person exercised the termination of poor and incapable performers?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-user-slash textarea-icon"></i>
                        <textarea asp-for="TerminatedPoorPerformers" class="form-control-textarea" rows="3" placeholder="Enter details of terminations..."></textarea>
                    </div>
                    <span asp-validation-for="TerminatedPoorPerformers" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="LeadershipDevelopmentAreas" class="form-label">
                        <i class="fas fa-chart-line"></i> What leadership development areas do they have?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-chart-line textarea-icon"></i>
                        <textarea asp-for="LeadershipDevelopmentAreas" class="form-control-textarea" rows="4" placeholder="Enter leadership development areas..."></textarea>
                    </div>
                    <span asp-validation-for="LeadershipDevelopmentAreas" class="validation-message text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Living The Axis Values Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="header-icon-wrapper" style="background: linear-gradient(135deg, var(--success), #059669);">
                    <i class="fas fa-heart"></i>
                </div>
                <h3>Living The Axis Values</h3>
                <span class="section-badge">Values</span>
            </div>
            <div class="section-body">
                <div class="form-group-modern">
                    <label asp-for="ChallengesApplyingAxisValues" class="form-label">
                        <i class="fas fa-question-circle"></i> Has this person experienced personal challenges in applying the Axis Values? If yes, give examples.
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-question-circle textarea-icon"></i>
                        <textarea asp-for="ChallengesApplyingAxisValues" class="form-control-textarea" rows="5" placeholder="Enter challenges and examples..."></textarea>
                    </div>
                    <span asp-validation-for="ChallengesApplyingAxisValues" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="SelfDevelopmentActions" class="form-label">
                        <i class="fas fa-user-graduate"></i> Has this person implemented actions to develop themselves?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-user-graduate textarea-icon"></i>
                        <textarea asp-for="SelfDevelopmentActions" class="form-control-textarea" rows="5" placeholder="Enter self-development actions..."></textarea>
                    </div>
                    <span asp-validation-for="SelfDevelopmentActions" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="SelfInitiatedLeadershipDevelopment" class="form-label">
                        <i class="fas fa-rocket"></i> Any evidence of self-initiated leadership development?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-rocket textarea-icon"></i>
                        <textarea asp-for="SelfInitiatedLeadershipDevelopment" class="form-control-textarea" rows="5" placeholder="Enter self-initiated leadership development..."></textarea>
                    </div>
                    <span asp-validation-for="SelfInitiatedLeadershipDevelopment" class="validation-message text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Potential Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="header-icon-wrapper" style="background: linear-gradient(135deg, var(--warning), #e6a017);">
                    <i class="fas fa-arrow-up"></i>
                </div>
                <h3>Potential To Take On Higher Or Increased Complexity</h3>
                <span class="section-badge">Assessment</span>
            </div>
            <div class="section-body">
                <div class="table-responsive">
                    <table class="assessment-table">
                        <thead>
                            <tr>
                                <th>Assessment Area</th>
                                <th style="width: 120px;">Yes</th>
                                <th style="width: 120px;">No</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="category-row">
                                <td colspan="3"><strong>Thinking</strong></td>
                            </tr>
                            <tr>
                                <td>Does this person cut through complex and ambiguous data to quickly see what is essential?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ThinkingComplexity" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ThinkingComplexity" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>
                            <tr>
                                <td>Does he/she use intuition and judgment?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ThinkingJudgement" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ThinkingJudgement" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>
                            <tr>
                                <td>Does he/she handle scale and manage complexity?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ThinkingScale" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="ThinkingScale" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>

                            <tr class="category-row">
                                <td colspan="3"><strong>Wisdom / Judgment</strong></td>
                            </tr>
                            <tr>
                                <td>Does this person size up situations fast and use sound judgment?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WisdomFastJudgement" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WisdomFastJudgement" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>
                            <tr>
                                <td>Does he/she know when and where to act?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WisdomWhenToAct" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WisdomWhenToAct" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>
                            <tr>
                                <td>Can this person combine short-term focus with long-term impact?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WisdomLongTermImpact" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WisdomLongTermImpact" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>

                            <tr class="category-row">
                                <td colspan="3"><strong>Courage</strong></td>
                            </tr>
                            <tr>
                                <td>Does this person have the ability to take risks?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CourageRiskTaking" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CourageRiskTaking" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>
                            <tr>
                                <td>Does he/she stand up for convictions with authenticity?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CourageConvictions" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="CourageConvictions" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>

                            <tr class="category-row">
                                <td colspan="3"><strong>Self Awareness</strong></td>
                            </tr>
                            <tr>
                                <td>Is the person conscious of strengths and improvement areas?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="SelfAwareness" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="SelfAwareness" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>

                            <tr class="category-row">
                                <td colspan="3"><strong>Receptive To Feedback</strong></td>
                            </tr>
                            <tr>
                                <td>Is the person open to feedback?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OpenToFeedback" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="OpenToFeedback" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>
                            <tr>
                                <td>Is he/she constantly willing to improve?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WillingToImprove" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="WillingToImprove" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>

                            <tr class="category-row">
                                <td colspan="3"><strong>Learning Agility</strong></td>
                            </tr>
                            <tr>
                                <td>Does this person adapt effectively and learn quickly?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="LearningAgility" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="LearningAgility" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>

                            <tr class="category-row">
                                <td colspan="3"><strong>Resilience</strong></td>
                            </tr>
                            <tr>
                                <td>Does this person maintain performance under pressure and uncertainty?</td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="Resilience" value="true" /><span class="radio-custom"></span></label></td>
                                <td class="radio-cell"><label class="radio-label"><input type="radio" asp-for="Resilience" value="false" /><span class="radio-custom"></span></label></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Career Development Section -->
        <div class="form-section">
            <div class="section-header">
                <div class="header-icon-wrapper">
                    <i class="fas fa-route"></i>
                </div>
                <h3>Career Development</h3>
                <span class="section-badge">Growth</span>
            </div>
            <div class="section-body">
                <div class="form-group-modern">
                    <label asp-for="CareerAspirations" class="form-label">
                        <i class="fas fa-flag"></i> What are the employee's career aspirations?
                    </label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-flag textarea-icon"></i>
                        <textarea asp-for="CareerAspirations" class="form-control-textarea" rows="5" placeholder="Enter career aspirations..."></textarea>
                    </div>
                    <span asp-validation-for="CareerAspirations" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label class="form-label">Mobility Preference</label>
                    <div class="radio-group-vertical">
                        <label class="radio-label-vertical"><input type="radio" asp-for="Mobility" value="1" /><span>Local Zimbabwe</span></label>
                        <label class="radio-label-vertical"><input type="radio" asp-for="Mobility" value="2" /><span>Regional</span></label>
                    </div>
                    <span asp-validation-for="Mobility" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label class="form-label">Risk Of Leaving</label>
                    <div class="radio-group-vertical">
                        <label class="radio-label-vertical"><input type="radio" asp-for="RiskOfLeaving" value="1" /><span>Low</span></label>
                        <label class="radio-label-vertical"><input type="radio" asp-for="RiskOfLeaving" value="2" /><span>Medium</span></label>
                        <label class="radio-label-vertical"><input type="radio" asp-for="RiskOfLeaving" value="3" /><span>High</span></label>
                    </div>
                    <span asp-validation-for="RiskOfLeaving" class="validation-message text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label class="form-label">Can this employee occupy a higher grade role?</label>
                    <div class="radio-options">
