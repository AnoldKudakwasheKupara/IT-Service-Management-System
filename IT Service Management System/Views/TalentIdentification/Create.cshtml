                                            <input asp-for="DevelopmentActions[i].DevelopmentAction" class="form-control-modern-sm" placeholder="Action" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="input-icon-wrapper-sm">
                                            <i class="fas fa-bullseye input-icon-sm"></i>
                                            <input asp-for="DevelopmentActions[i].Objective" class="form-control-modern-sm" placeholder="Objective" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="input-icon-wrapper-sm">
                                            <i class="fas fa-calendar input-icon-sm"></i>
                                            <input asp-for="DevelopmentActions[i].Timeline" class="form-control-modern-sm" placeholder="Timeline" />
                                        </div>
                                    </td>
                                    <td>
                                        <select asp-for="DevelopmentActions[i].Status" class="form-control-modern-sm">
                                            <option value="">Select</option>
                                            <option value="1">Completed</option>
                                            <option value="2">Delayed</option>
                                            <option value="3">In Progress</option>
                                            <option value="4">Not Started</option>
                                        </select>
                                    </td>
                                    <td>
                                        <button type="button" class="btn-remove-sm remove-development-action">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <button type="button" id="addDevelopmentAction" class="btn-add-row success">
                    <i class="fas fa-plus-circle"></i> Add Development Action
                </button>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
            <button type="submit" class="btn-save" id="submitBtn">
                <i class="fas fa-save"></i>
                Save Talent Assessment
            </button>
            <a asp-action="Index" class="btn-cancel">
                <i class="fas fa-times"></i>
                Cancel
            </a>
        </div>
    </form>
</div>

