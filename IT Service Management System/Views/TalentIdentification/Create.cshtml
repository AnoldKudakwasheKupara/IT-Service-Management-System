<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add Direct Report
        document.getElementById('addDirectReport').addEventListener('click', function() {
            let table = document.querySelector('#directReportsTable tbody');
            let index = table.querySelectorAll('tr').length;
            let template = document.getElementById('directReportTemplate').innerHTML.replace(/INDEX/g, index);
            table.insertAdjacentHTML('beforeend', template);
        });

        // Remove Direct Report
        document.addEventListener('click', function(e) {
            if (e.target.closest('.remove-direct-report')) {
                let row = e.target.closest('tr');
                if (document.querySelectorAll('#directReportsTable tbody tr').length > 1) {
                    row.remove();
                } else {
                    showAlert('At least one direct report is required.', 'warning');
                }
            }
        });

        // Add Development Action
        document.getElementById('addDevelopmentAction').addEventListener('click', function() {
            let table = document.querySelector('#developmentActionsTable tbody');
            let index = table.querySelectorAll('tr').length;
            let template = document.getElementById('developmentActionTemplate').innerHTML.replace(/INDEX/g, index);
            table.insertAdjacentHTML('beforeend', template);
        });

        // Remove Development Action
        document.addEventListener('click', function(e) {
            if (e.target.closest('.remove-development-action')) {
                e.target.closest('tr').remove();
            }
        });

        // Form Submit
        const form = document.getElementById('talentForm');
        const submitBtn = document.getElementById('submitBtn');

        if (form) {
            form.addEventListener('submit', function(e) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
            });
        }

        // Helper function for alerts
        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert-toast ${type}`;
            alertDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                padding: 1rem 1.25rem;
                border-radius: 0.75rem;
                background: ${type === 'warning' ? '#fff5e6' : '#fee'};
                border-left: 4px solid ${type === 'warning' ? 'var(--warning)' : 'var(--danger)'};
                color: ${type === 'warning' ? 'var(--warning)' : 'var(--danger)'};
                font-weight: 500;
                z-index: 1050;
                animation: slideIn 0.3s ease;
                box-shadow: var(--shadow-lg);
                display: flex;
                align-items: center;
                gap: 0.75rem;
            `;
            alertDiv.innerHTML = `
                <i class="fas ${type === 'warning' ? 'fa-exclamation-triangle' : 'fa-exclamation-circle'}"></i>
                <span>${message}</span>
                <button type="button" style="margin-left: auto; background: none; border: none; cursor: pointer; color: inherit;" onclick="this.parentElement.remove()">
                    <i class="fas fa-times"></i>
                </button>
            `;
            document.body.appendChild(alertDiv);

            setTimeout(() => {
                alertDiv.style.opacity = '0';
                setTimeout(() => alertDiv.remove(), 300);
            }, 4000);
        }
    });
</script>

