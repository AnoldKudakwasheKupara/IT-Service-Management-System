@functions {
    string GetPerformanceRatingDisplay(PerformanceRating? rating)
    {
        if (!rating.HasValue) return "Not rated";

        return rating.Value switch
        {
            PerformanceRating.CEE => "CEE",
            PerformanceRating.EE => "EE",
            PerformanceRating.ME => "ME",
            PerformanceRating.PME => "PME",
            PerformanceRating.DNME => "DNME",
            _ => "Not rated"
        };
    }

    string GetMobilityDisplay(MobilityType? mobility)
    {
        if (!mobility.HasValue) return "Not specified";

        return mobility.Value switch
        {
            MobilityType.LocalZimbabwe => "Local Zimbabwe",
            MobilityType.Regional => "Regional",
            _ => "Not specified"
        };
    }

    string GetRiskLevelDisplay(RiskLevel? risk)
    {
        if (!risk.HasValue) return "Not specified";

        return risk.Value switch
        {
            RiskLevel.Low => "Low",
            RiskLevel.Medium => "Medium",
            RiskLevel.High => "High",
            _ => "Not specified"
        };
    }

    string GetReadinessDisplay(ReadinessLevel? readiness)
    {
        if (!readiness.HasValue) return "Not specified";

        return readiness.Value switch
        {
            ReadinessLevel.ReadyNow => "Ready Now",
            ReadinessLevel.ShortTerm => "Short Term",
            ReadinessLevel.MidTerm => "Mid Term",
            ReadinessLevel.LongTerm => "Long Term",
            _ => "Not specified"
        };
    }

    string GetStatusDisplay(DevelopmentStatus? status)
    {
        if (!status.HasValue) return "Not specified";

        return status.Value switch
        {
            DevelopmentStatus.Completed => "<span class='status-badge status-completed'>Completed</span>",
            DevelopmentStatus.Delayed => "<span class='status-badge status-delayed'>Delayed</span>",
            DevelopmentStatus.InProgress => "<span class='status-badge status-in-progress'>In Progress</span>",
            DevelopmentStatus.NotStarted => "<span class='status-badge status-not-started'>Not Started</span>",
            _ => "Not specified"
        };
    }
}

