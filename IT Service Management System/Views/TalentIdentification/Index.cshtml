@using IT_Service_Management_System.Enums
@model IEnumerable<IT_Service_Management_System.Models.TalentIdentification>

@{
    ViewData["Title"] = "Talent Identification - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title">
                    <i class="fas fa-user-tie me-2" style="color: var(--primary);"></i>
                    Talent Identification
                </h1>
                <p class="text-muted mt-2">Identify and assess high-potential talent within the organization</p>
            </div>
            <a asp-action="Create" class="btn-create-talent">
                <i class="fas fa-plus-circle me-2"></i>
                New Talent Assessment
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-toast success">
            <i class="fas fa-check-circle"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="close-toast" onclick="this.parentElement.remove()">
                <i class="fas fa-times"></i>
            </button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="stats-cards mb-4">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count()</h3>
                <p>Total Records</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon ready-now">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(m => m.Readiness == ReadinessLevel.ReadyNow)</h3>
                <p>Ready Now</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon high-risk">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(m => m.RiskOfLeaving == RiskLevel.High)</h3>
                <p>High Risk of Leaving</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon this-month">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(m => m.CreatedDate.Month == DateTime.Now.Month && m.CreatedDate.Year == DateTime.Now.Year)</h3>
                <p>This Month</p>
            </div>
        </div>
    </div>

    <!-- Talent Table -->
    <div class="talent-table-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-list me-2"></i>
                <span>Talent Assessment Records</span>
            </div>
            <div class="record-count">
                <i class="fas fa-chart-simple"></i>
                <span>@Model.Count()</span> records found
            </div>
        </div>

        <div class="table-responsive">
            @if (Model.Any())
            {
                <table class="talent-table">
                    <thead>
                        <tr>
                            <th><i class="fas fa-user me-1"></i> Employee Name</th>
                            <th><i class="fas fa-building me-1"></i> Department</th>
                            <th><i class="fas fa-briefcase me-1"></i> Job Title</th>
                            <th><i class="fas fa-globe me-1"></i> Country</th>
                            <th><i class="fas fa-exclamation-triangle me-1"></i> Risk of Leaving</th>
                            <th><i class="fas fa-chart-line me-1"></i> Readiness</th>
                            <th><i class="fas fa-calendar me-1"></i> Created Date</th>
                            <th><i class="fas fa-cog me-1"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(m => m.CreatedDate))
                        {
                            <tr>
                                <td class="employee-cell">
                                    <div class="employee-info">
                                        <div class="employee-avatar">
                                            @(item.EmployeeName?.Substring(0, 1).ToUpper() ?? "E")
                                        </div>
                                        <div class="employee-name">
                                            <strong>@item.EmployeeName</strong>
                                        </div>
                                    </div>
                                </td>
                                <td class="department-cell">
                                    <span class="department-badge">
                                        <i class="fas fa-building"></i> @item.Department
                                    </span>
                                </td>
                                <td class="job-cell">
                                    <span class="job-badge">
                                        <i class="fas fa-briefcase"></i> @item.JobTitle
                                    </span>
                                </td>
                                <td class="country-cell">
                                    <span class="country-badge">
                                        <i class="fas fa-globe"></i> @item.Country
                                    </span>
                                </td>
                                <td class="risk-cell">
                                    @switch (item.RiskOfLeaving)
                                    {
                                        case RiskLevel.Low:
                                            <span class="risk-badge risk-low">
                                                <i class="fas fa-check-circle"></i> Low
                                            </span>
                                            break;
                                        case RiskLevel.Medium:
                                            <span class="risk-badge risk-medium">
                                                <i class="fas fa-minus-circle"></i> Medium
                                            </span>
                                            break;
                                        case RiskLevel.High:
                                            <span class="risk-badge risk-high">
                                                <i class="fas fa-exclamation-circle"></i> High
                                            </span>
                                            break;
                                        default:
                                            <span class="risk-badge risk-unknown">
                                                <i class="fas fa-question-circle"></i> Not Set
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="readiness-cell">
                                    @switch (item.Readiness)
                                    {
                                        case ReadinessLevel.ReadyNow:
                                            <span class="readiness-badge readiness-ready">
                                                <i class="fas fa-check-circle"></i> Ready Now
                                            </span>
                                            break;
                                        case ReadinessLevel.ShortTerm:
                                            <span class="readiness-badge readiness-short">
                                                <i class="fas fa-clock"></i> Short Term
                                            </span>
                                            break;
                                        case ReadinessLevel.MidTerm:
                                            <span class="readiness-badge readiness-mid">
                                                <i class="fas fa-calendar-alt"></i> Mid Term
                                            </span>
                                            break;
                                        case ReadinessLevel.LongTerm:
                                            <span class="readiness-badge readiness-long">
                                                <i class="fas fa-calendar-week"></i> Long Term
                                            </span>
                                            break;
                                        default:
                                            <span class="readiness-badge readiness-unknown">
                                                <i class="fas fa-question-circle"></i> Not Set
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="date-cell">
                                    <i class="far fa-calendar-alt"></i>
                                    @item.CreatedDate.ToString("dd MMM yyyy")
                                </td>
                                <td class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn btn-edit" title="Edit Record">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn btn-delete" title="Delete Record" onclick="return confirm('Are you sure you want to delete this talent identification record?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-user-tie"></i>
                    <h3>No Talent Records Found</h3>
                    <p>Get started by creating your first talent identification assessment</p>
                    <a asp-action="Create" class="btn-create-talent-sm">
                        <i class="fas fa-plus-circle"></i> New Talent Assessment
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Create Button */
    .btn-create-talent {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-sm);
    }

        .btn-create-talent:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    /* Alert Toast */
    .alert-toast {
        background: #e6f5e9;
        border-left: 4px solid var(--success);
        border-radius: 0.75rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--success);
        font-weight: 500;
        animation: slideIn 0.3s ease;
        box-shadow: var(--shadow-sm);
    }

        .alert-toast.success {
            background: #e6f5e9;
            border-left-color: var(--success);
            color: #1f6e4a;
        }

    .close-toast {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

        .close-toast:hover {
            opacity: 1;
        }

    /* Statistics Cards */
    .stats-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 1024px) {
        .stats-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .stats-cards {
            grid-template-columns: 1fr;
        }
    }

    .stat-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

        .stat-icon.total {
            background: linear-gradient(135deg, var(--info), #2563eb);
            color: white;
        }

        .stat-icon.ready-now {
            background: linear-gradient(135deg, var(--success), #059669);
            color: white;
        }

        .stat-icon.high-risk {
            background: linear-gradient(135deg, var(--danger), #c53030);
            color: white;
        }

        .stat-icon.this-month {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white;
        }

    .stat-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-800);
    }

    .stat-info p {
        margin: 0;
        color: var(--gray-500);
        font-size: 0.875rem;
    }

    /* Talent Table Card */
    .talent-table-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .record-count {
        font-size: 0.875rem;
        font-weight: normal;
        color: var(--gray-500);
    }

    /* Table Styles */
    .talent-table {
        width: 100%;
        border-collapse: collapse;
    }

        .talent-table thead {
            background: var(--gray-50);
            border-bottom: 2px solid var(--gray-200);
        }

        .talent-table th {
            padding: 1rem 1.5rem;
            text-align: left;
            font-weight: 600;
            color: var(--gray-600);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .talent-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            vertical-align: middle;
            font-size: 0.875rem;
        }

        .talent-table tbody tr {
            transition: background-color 0.2s;
        }

            .talent-table tbody tr:hover {
                background-color: var(--gray-50);
            }

    /* Employee Cell */
    .employee-cell {
        min-width: 160px;
    }

    .employee-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .employee-avatar {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.875rem;
        flex-shrink: 0;
    }

    .employee-name strong {
        color: var(--gray-800);
        font-size: 0.875rem;
    }

    /* Badges */
    .department-badge, .job-badge, .country-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: var(--gray-100);
        color: var(--gray-600);
    }

    /* Risk Badges */
    .risk-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .risk-low {
        background: #e6f5e9;
        color: var(--success);
    }

    .risk-medium {
        background: #fff5e6;
        color: var(--warning);
    }

    .risk-high {
        background: #fee;
        color: var(--danger);
    }

    .risk-unknown {
        background: var(--gray-100);
        color: var(--gray-500);
    }

    /* Readiness Badges */
    .readiness-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .readiness-ready {
        background: #e6f5e9;
        color: var(--success);
    }

    .readiness-short {
        background: #e6f0ff;
        color: var(--info);
    }

    .readiness-mid {
        background: #e6e6ff;
        color: #6366f1;
    }

    .readiness-long {
        background: var(--gray-100);
        color: var(--gray-600);
    }

    .readiness-unknown {
        background: var(--gray-100);
        color: var(--gray-500);
    }

    /* Date Cell */
    .date-cell {
        color: var(--gray-500);
        white-space: nowrap;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .action-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

    .btn-view {
        background: var(--gray-100);
        color: var(--info);
    }

        .btn-view:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: var(--gray-100);
        color: var(--warning);
    }

        .btn-edit:hover {
            background: var(--warning);
            color: white;
            transform: translateY(-2px);
        }

    .btn-delete {
        background: var(--gray-100);
        color: var(--danger);
    }

        .btn-delete:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 3rem;
        color: var(--gray-500);
    }

        .empty-state i {
            font-size: 4rem;
            color: var(--gray-300);
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
            color: var(--gray-600);
        }

        .empty-state p {
            margin-bottom: 1.5rem;
        }

    .btn-create-talent-sm {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

        .btn-create-talent-sm:hover {
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    /* Responsive Table */
    @@media (max-width: 768px) {
        .talent-table thead {
            display: none;
        }

        .talent-table tbody tr {
            display: block;
            margin-bottom: 1rem;
            border: 1px solid var(--gray-200);
            border-radius: 0.5rem;
            padding: 0.5rem;
        }

        .talent-table td {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem;
            border: none;
            border-bottom: 1px solid var(--gray-100);
        }

            .talent-table td:last-child {
                border-bottom: none;
            }

            .talent-table td:before {
                content: attr(data-label);
                font-weight: 600;
                color: var(--gray-600);
                margin-right: 1rem;
                font-size: 0.75rem;
                text-transform: uppercase;
            }

        .action-buttons {
            justify-content: flex-end;
        }

        .action-btn {
            width: 36px;
            height: 36px;
        }
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Auto-hide toast after 5 seconds
        const toast = document.querySelector('.alert-toast');
        if (toast) {
            setTimeout(() => {
                toast.style.transition = 'opacity 0.3s';
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        // Add data-label attributes for responsive table
        const tableHeaders = document.querySelectorAll('.talent-table th');
        const tableRows = document.querySelectorAll('.talent-table tbody tr');

        tableRows.forEach(row => {
            const cells = row.querySelectorAll('td');
            cells.forEach((cell, index) => {
                if (tableHeaders[index]) {
                    const headerText = tableHeaders[index].innerText.replace(/[^\w\s]/g, '').trim();
                    cell.setAttribute('data-label', headerText);
                }
            });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">