@model TalentIdentification
@using IT_Service_Management_System.Enums

@{
    ViewData["Title"] = "Delete Talent Identification - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-trash-alt me-2" style="color: var(--danger);"></i>
                    Delete Talent Identification
                </h1>
                <p class="text-muted mt-2">This action cannot be undone</p>
            </div>
        </div>
    </div>

    <div class="delete-warning-card">
        <div class="warning-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h3 class="warning-title">Are you absolutely sure?</h3>
        <p class="warning-message">This action will permanently delete this talent identification record from the system.</p>
    </div>

    <div class="talent-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-user-tie me-2"></i>
                <span>Talent Record to Delete</span>
            </div>
            <div class="talent-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- Employee Summary -->
            <div class="talent-summary">
                <div class="talent-icon">
                    <i class="fas fa-user-circle"></i>
                </div>
                <div class="talent-summary-info">
                    <h2 class="talent-name">@Model.EmployeeName</h2>
                    <div class="talent-meta">
                        <span class="meta-badge">
                            <i class="fas fa-building"></i>
                            @Model.Department
                        </span>
                        <span class="meta-badge">
                            <i class="fas fa-briefcase"></i>
                            @Model.JobTitle
                        </span>
                        <span class="meta-badge">
                            <i class="fas fa-globe"></i>
                            @Model.Country
                        </span>
                    </div>
                </div>
            </div>

            <!-- Talent Details -->
            <div class="talent-details">
                <div class="detail-row">
                    <div class="detail-label">
                        <i class="fas fa-calendar-alt"></i>
                        Hire Date
                    </div>
                    <div class="detail-value">
                        @(Model.HireDate?.ToString("dd MMM yyyy") ?? "—")
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">
                        <i class="fas fa-route"></i>
                        Mobility Preference
                    </div>
                    <div class="detail-value">
                        @GetMobilityDisplay(Model.Mobility)
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">
                        <i class="fas fa-exclamation-triangle"></i>
                        Risk of Leaving
                    </div>
                    <div class="detail-value">
                        <span class="risk-badge @(Model.RiskOfLeaving == RiskLevel.High ? "high" : Model.RiskOfLeaving == RiskLevel.Medium ? "medium" : "low")">
                            @GetRiskLevelDisplay(Model.RiskOfLeaving)
                        </span>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">
                        <i class="fas fa-rocket"></i>
                        Readiness
                    </div>
                    <div class="detail-value">
                        @GetReadinessDisplay(Model.Readiness)
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">
                        <i class="fas fa-flag"></i>
                        Career Aspirations
                    </div>
                    <div class="detail-value aspiration-value">
                        @(string.IsNullOrEmpty(Model.CareerAspirations) ? "No information provided" : Model.CareerAspirations)
                    </div>
                </div>
            </div>

            <!-- Associated Data -->
            <div class="associated-data">
                <h4 class="associated-title">
                    <i class="fas fa-link"></i>
                    Associated Data
                </h4>
                <div class="associated-grid">
                    <div class="associated-item">
                        <span class="associated-label">Direct Reports</span>
                        <span class="associated-count">@(Model.DirectReports?.Count ?? 0)</span>
                    </div>
                    <div class="associated-item">
                        <span class="associated-label">Development Actions</span>
                        <span class="associated-count">@(Model.DevelopmentActions?.Count ?? 0)</span>
                    </div>
                    <div class="associated-item">
                        <span class="associated-label">Performance Records</span>
                        <span class="associated-count">4 Years</span>
                    </div>
                </div>
            </div>

            <!-- Warning Details -->
            <div class="warning-details">
                <div class="warning-detail-item">
                    <i class="fas fa-database"></i>
                    <div>
                        <strong>Data Loss Warning</strong>
                        <span>This talent identification record will be permanently deleted from the system.</span>
                    </div>
                </div>
                <div class="warning-detail-item">
                    <i class="fas fa-clock"></i>
                    <div>
                        <strong>Irreversible Action</strong>
                        <span>This action cannot be undone. You will not be able to recover this talent record.</span>
                    </div>
                </div>
                <div class="warning-detail-item">
                    <i class="fas fa-chart-line"></i>
                    <div>
                        <strong>Assessment Impact</strong>
                        <span>All associated talent assessment data will be permanently removed.</span>
                    </div>
                </div>
                @if ((Model.DirectReports != null && Model.DirectReports.Any()) || (Model.DevelopmentActions != null && Model.DevelopmentActions.Any()))
                {
                    <div class="warning-detail-item">
                        <i class="fas fa-users"></i>
                        <div>
                            <strong>Associated Records</strong>
                            <span>This record has @(Model.DirectReports?.Count ?? 0) direct report(s) and @(Model.DevelopmentActions?.Count ?? 0) development action(s) that will also be deleted.</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Confirmation Form -->
            <form asp-action="Delete" method="post" id="deleteForm" class="delete-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="confirmation-checkbox">
                    <input type="checkbox" id="confirmDelete" required>
                    <label for="confirmDelete">
                        I understand that this action is permanent and cannot be undone
                    </label>
                </div>

                <div class="action-buttons-container">
                    <button type="submit" class="btn-delete" id="deleteButton" disabled>
                        <i class="fas fa-trash-alt"></i>
                        Permanently Delete Record
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --danger-dark: #c53030;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

