@model IT_Service_Management_System.ViewModels.Security.SecurityDashboardVM
@{
    ViewData["Title"] = "Security Dashboard - Axis IT Operations";
    int Max(IEnumerable<IT_Service_Management_System.ViewModels.Reports.NameCount> l) => l.Any() ? l.Max(x => x.Count) : 1;
}

@await Html.PartialAsync("~/Views/Reports/_ReportStyles.cshtml")

<div class="report-container">
    <div class="report-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="report-title"><i class="fas fa-shield-halved"></i> Security Dashboard</h1>
            <p class="report-subtitle">Account protection, sessions &amp; security events &middot; @Model.GeneratedAt.ToString("dddd, MMM dd yyyy 'at' h:mm tt")</p>
        </div>
        <div class="report-actions">
            <a class="report-btn" asp-controller="Configuration" asp-action="Index"><i class="fas fa-sliders"></i> Configuration</a>
            <a class="report-btn" asp-controller="AuditLogs" asp-action="Index"><i class="fas fa-clipboard-list"></i> Audit Logs</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="report-card" style="border-left:4px solid var(--success,#22c55e);margin-bottom:1rem;">
            <div class="report-card-body" style="color:#166534;"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        </div>
    }

    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-icon red"><i class="fas fa-user-xmark"></i></div><div class="kpi-body"><div class="kpi-value">@Model.FailedLogins24h</div><div class="kpi-label">Failed Logins (24h)</div></div></div>
        <div class="kpi-card"><div class="kpi-icon amber"><i class="fas fa-clock-rotate-left"></i></div><div class="kpi-body"><div class="kpi-value">@Model.FailedLogins7d</div><div class="kpi-label">Failed Logins (7d)</div></div></div>
        <div class="kpi-card"><div class="kpi-icon red"><i class="fas fa-lock"></i></div><div class="kpi-body"><div class="kpi-value">@Model.LockedUsersCount</div><div class="kpi-label">Locked Accounts</div></div></div>
        <div class="kpi-card"><div class="kpi-icon"><i class="fas fa-desktop"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ActiveSessionsCount</div><div class="kpi-label">Active Sessions</div></div></div>
        <div class="kpi-card"><div class="kpi-icon amber"><i class="fas fa-key"></i></div><div class="kpi-body"><div class="kpi-value">@Model.ExpiredPasswordsCount</div><div class="kpi-label">Expired Passwords</div></div></div>
        <div class="kpi-card"><div class="kpi-icon slate"><i class="fas fa-user-slash"></i></div><div class="kpi-body"><div class="kpi-value">@Model.DisabledAccountsCount</div><div class="kpi-label">Disabled Accounts</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-mobile-screen-button"></i></div><div class="kpi-body"><div class="kpi-value">@Model.MfaEnabledCount</div><div class="kpi-label">MFA Enabled</div></div></div>
        <div class="kpi-card"><div class="kpi-icon violet"><i class="fas fa-users"></i></div><div class="kpi-body"><div class="kpi-value">@Model.TotalUsers</div><div class="kpi-label">Total Users</div></div></div>
    </div>

    <!-- Locked accounts -->
    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-lock"></i> Locked Accounts</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.LockedUsers.Any())
            {
                <table class="report-table">
                    <thead><tr><th>User</th><th>Email</th><th>Role</th><th>Locked Until</th><th style="text-align:right;">Action</th></tr></thead>
                    <tbody>
                        @foreach (var u in Model.LockedUsers)
                        {
                            <tr>
                                <td>@u.FullName</td>
                                <td>@u.Email</td>
                                <td><span class="pill slate">@u.Role</span></td>
                                <td><span class="pill red">@u.LockoutEnd?.ToString("MMM dd, h:mm tt")</span></td>
                                <td style="text-align:right;">
                                    <form asp-action="UnlockUser" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button type="submit" class="report-btn" style="padding:0.3rem 0.7rem;"><i class="fas fa-unlock"></i> Unlock</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No locked accounts 🎉</div> }
        </div>
    </div>

    <!-- Active sessions -->
    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-desktop"></i> Active Sessions</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.ActiveSessions.Any())
            {
                <table class="report-table">
                    <thead><tr><th>User</th><th>Device</th><th>IP</th><th>Signed In</th><th>Last Active</th><th style="text-align:right;">Action</th></tr></thead>
                    <tbody>
                        @foreach (var s in Model.ActiveSessions)
                        {
                            <tr>
                                <td>@(s.User != null ? s.User.FullName : $"User #{s.UserId}")</td>
                                <td>@(string.IsNullOrEmpty(s.Device) ? "—" : s.Device)</td>
                                <td>@s.IpAddress</td>
                                <td>@s.CreatedAt.ToString("MMM dd, h:mm tt")</td>
                                <td>@s.LastSeenAt.ToString("MMM dd, h:mm tt")</td>
                                <td style="text-align:right;">
                                    <form asp-action="RevokeSession" method="post" style="display:inline;"
                                          onsubmit="return confirm('Revoke this session?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <button type="submit" class="report-btn" style="padding:0.3rem 0.7rem;color:var(--danger,#dc2626);"><i class="fas fa-ban"></i> Revoke</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No active sessions</div> }
        </div>
    </div>

    <div class="report-grid">
        <!-- Failed login targets -->
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-crosshairs"></i> Most-Targeted Accounts (7d failed logins)</span></div>
            <div class="report-card-body">
                @if (Model.TopFailedLoginTargets.Any())
                {
                    var m1 = Max(Model.TopFailedLoginTargets);
                    <div class="bars">
                        @foreach (var t in Model.TopFailedLoginTargets)
                        {
                            <div class="bar-row"><div class="bar-label" title="@t.Name">@t.Name</div><div class="bar-track"><div class="bar-fill red" style="width:@(t.Count * 100 / m1)%"></div></div><div class="bar-value">@t.Count</div></div>
                        }
                    </div>
                }
                else { <div class="empty-mini">No failed logins in the last 7 days</div> }
            </div>
        </div>

        <!-- Disabled accounts -->
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-user-slash"></i> Disabled / Inactive Accounts</span></div>
            <div class="report-card-body" style="padding:0;">
                @if (Model.DisabledAccounts.Any())
                {
                    <table class="report-table">
                        <thead><tr><th>User</th><th>Email</th><th>Role</th></tr></thead>
                        <tbody>
                            @foreach (var u in Model.DisabledAccounts)
                            {
                                <tr><td>@u.FullName</td><td>@u.Email</td><td><span class="pill slate">@u.Role</span></td></tr>
                            }
                        </tbody>
                    </table>
                }
                else { <div class="empty-mini">All accounts are active</div> }
            </div>
        </div>
    </div>

    <!-- Expired passwords (only when a policy is configured) -->
    @if (Model.PasswordExpiryDays > 0)
    {
        <div class="report-card">
            <div class="report-card-header"><span><i class="fas fa-key"></i> Expired Passwords (policy: @Model.PasswordExpiryDays days)</span></div>
            <div class="report-card-body" style="padding:0;">
                @if (Model.ExpiredPasswordUsers.Any())
                {
                    <table class="report-table">
                        <thead><tr><th>User</th><th>Email</th><th>Last Changed</th></tr></thead>
                        <tbody>
                            @foreach (var u in Model.ExpiredPasswordUsers)
                            {
                                <tr><td>@u.FullName</td><td>@u.Email</td><td>@((u.PasswordChangedAt ?? u.CreatedAt).ToString("MMM dd, yyyy"))</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else { <div class="empty-mini">No expired passwords</div> }
            </div>
        </div>
    }
    else
    {
        <div class="report-card">
            <div class="report-card-body" style="font-size:0.85rem;color:var(--gray-500,#64748b);">
                <i class="fas fa-info-circle"></i> Password expiry is currently disabled.
                Set an expiry window in <a asp-controller="Configuration" asp-action="Index">Configuration</a> to track expired passwords.
            </div>
        </div>
    }

    <!-- Recent security events -->
    <div class="report-card">
        <div class="report-card-header"><span><i class="fas fa-clock-rotate-left"></i> Recent Security Events</span></div>
        <div class="report-card-body" style="padding:0;">
            @if (Model.RecentSecurityEvents.Any())
            {
                <table class="report-table">
                    <thead><tr><th>When</th><th>Action</th><th>By</th><th>Details</th><th>IP / Location</th></tr></thead>
                    <tbody>
                        @foreach (var e in Model.RecentSecurityEvents)
                        {
                            var cls = e.Action.Contains("Failed") || e.Action.Contains("Locked") || e.Action.Contains("Blocked") ? "red"
                                : e.Action.Contains("Login") || e.Action.Contains("Set Password") ? "green" : "slate";
                            <tr>
                                <td>@e.Timestamp.ToString("MMM dd, h:mm tt")</td>
                                <td><span class="pill @cls">@e.Action</span></td>
                                <td>@e.UserName</td>
                                <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@e.Details">@e.Details</td>
                                <td>@e.IpAddress @(string.IsNullOrEmpty(e.Location) ? "" : $"· {e.Location}")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else { <div class="empty-mini">No security events recorded yet</div> }
        </div>
    </div>
</div>
