@model IT_Service_Management_System.Models.Ticket

@{
    ViewData["Title"] = $"{Model.Reference} - Axis IT Helpdesk";
    var isClosed = Model.Status.ToString() == "Closed";
    var isStaff = (bool)(ViewBag.IsStaff ?? false);
    var agents = ViewBag.Agents as List<IT_Service_Management_System.Models.User> ?? new List<IT_Service_Management_System.Models.User>();
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-ticket-alt me-2" style="color: var(--primary);"></i>
                    Ticket Details
                </h1>
                <p class="text-muted mt-2">View and manage ticket information</p>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="ticket-flash"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
    }

    <!-- Main Ticket Card -->
    <div class="ticket-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-ticket-alt me-2"></i>
                <span>@Model.Reference</span>
            </div>
            <div class="ticket-status-badge @(isClosed ? "closed" : "active")">
                @if (isClosed)
                {
                    <i class="fas fa-ban"></i>
                    <span>Closed</span>
                }
                else
                {
                    <i class="fas fa-circle"></i>
                    <span>Active</span>
                }
            </div>
        </div>

        <div class="card-body-custom">
            <!-- Ticket Header with Title and Status -->
            <div class="ticket-header">
                <div class="ticket-title-section">
                    <h2 class="ticket-title">@Model.Title</h2>
                    <div class="ticket-badges">
                        @{
                            var status = Model.Status.ToString();
                            if (status == "Open")
                            {
                                <span class="status-badge status-open">
                                    <i class="fas fa-circle"></i> Open
                                </span>
                            }
                            else if (status == "InProgress")
                            {
                                <span class="status-badge status-progress">
                                    <i class="fas fa-spinner fa-pulse"></i> In Progress
                                </span>
                            }
                            else if (status == "Resolved")
                            {
                                <span class="status-badge status-resolved">
                                    <i class="fas fa-check-circle"></i> Resolved
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-closed">
                                    <i class="fas fa-ban"></i> Closed
                                </span>
                            }
                        }
                        
                        @{
                            var priority = Model.Priority.ToString();
                            if (priority == "Critical")
                            {
                                <span class="priority-badge priority-critical">
                                    <i class="fas fa-exclamation-circle"></i> Critical
                                </span>
                            }
                            else if (priority == "High")
                            {
                                <span class="priority-badge priority-high">
                                    <i class="fas fa-arrow-up"></i> High
                                </span>
                            }
                            else if (priority == "Medium")
                            {
                                <span class="priority-badge priority-medium">
                                    <i class="fas fa-minus"></i> Medium
                                </span>
                            }
                            else
                            {
                                <span class="priority-badge priority-low">
                                    <i class="fas fa-arrow-down"></i> Low
                                </span>
                            }
                        }
                    </div>
                </div>
                <div class="ticket-meta">
                    <div class="meta-item">
                        <i class="fas fa-user"></i>
                        <div>
                            <label>Created by</label>
                            <span>@Model.CreatedBy?.FirstName @Model.CreatedBy?.LastName</span>
                        </div>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-calendar"></i>
                        <div>
                            <label>Created</label>
                            <span>@Model.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</span>
                        </div>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-user-gear"></i>
                        <div>
                            <label>Assigned to</label>
                            <span>@(Model.AssignedTo != null ? $"{Model.AssignedTo.FirstName} {Model.AssignedTo.LastName}" : "Unassigned")</span>
                        </div>
                    </div>
                    @if (Model.DueAt != null)
                    {
                        <div class="meta-item">
                            <i class="fas @(Model.IsSlaBreached ? "fa-triangle-exclamation" : "fa-stopwatch")" style="color:@(Model.IsSlaBreached ? "var(--danger)" : "var(--primary)");"></i>
                            <div>
                                <label>SLA (@Model.Priority)</label>
                                <span style="color:@(Model.IsSlaBreached ? "var(--danger)" : "inherit");font-weight:@(Model.IsSlaBreached ? "700" : "500");">
                                    @IT_Service_Management_System.Helpers.TicketSla.Describe(Model.DueAt, Model.IsOpen)
                                </span>
                            </div>
                        </div>
                    }
                    @if (Model.UpdatedAt != null)
                    {
                        <div class="meta-item">
                            <i class="fas fa-clock-rotate-left"></i>
                            <div>
                                <label>Last updated</label>
                                <span>@Model.UpdatedAt.Value.ToString("MMM dd, yyyy 'at' HH:mm")</span>
                            </div>
                        </div>
                    }
            </div>

            <!-- Description Section -->
            <div class="description-section">
                <h3 class="section-title">
                    <i class="fas fa-align-left"></i>
                    Description
                </h3>
                <div class="description-content">
                    @Model.Description
                </div>
            </div>

            <!-- Staff toolbar -->
            @if (isStaff && !isClosed)
            {
                <div class="staff-toolbar">
                    <div class="staff-toolbar-row">
                        <span class="toolbar-label"><i class="fas fa-bolt"></i> Set status</span>
                        <form asp-action="ChangeStatus" method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button name="status" value="InProgress" class="status-btn progress"><i class="fas fa-spinner"></i> In Progress</button>
                        </form>
                        <form asp-action="ChangeStatus" method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button name="status" value="Resolved" class="status-btn resolved"><i class="fas fa-check-circle"></i> Resolved</button>
                        </form>
                        <a asp-action="Close" asp-route-id="@Model.Id" class="status-btn closed"><i class="fas fa-lock"></i> Close</a>
                    </div>
                    <div class="staff-toolbar-row">
                        <span class="toolbar-label"><i class="fas fa-user-gear"></i> Assign</span>
                        <form asp-action="Assign" method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <select name="assignedToId" class="assign-select">
                                <option value="">— Unassigned —</option>
                                @foreach (var ag in agents)
                                {
                                    <option value="@ag.Id" selected="@(Model.AssignedToId == ag.Id)">@ag.FirstName @ag.LastName</option>
                                }
                            </select>
                            <button type="submit" class="status-btn assign"><i class="fas fa-paper-plane"></i> Update</button>
                        </form>
                    </div>
                </div>
            }
            else if (isClosed)
            {
                <div class="closed-alert">
                    <i class="fas fa-lock"></i>
                    <div style="flex:1;">
                        <strong>This ticket is closed</strong>
                        <p>Reopen it to continue the conversation.</p>
                    </div>
                    <form asp-action="Reopen" method="post" class="inline-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="status-btn progress"><i class="fas fa-rotate-left"></i> Reopen</button>
                    </form>
                </div>
            }
        </div>
    </div>

    <!-- Attachments Section -->
    @{
        var viewerId = Context.Session.GetInt32("UserId");
        var isOwnerView = Model.CreatedById == viewerId;
    }
    @if (isOwnerView && !Model.IsOpen)
    {
        <div class="csat-card">
            <div class="card-header-custom">
                <i class="fas fa-star me-2"></i>
                <span>Your Feedback</span>
            </div>
            <div class="card-body-custom">
                @if (Model.SatisfactionRating == null)
                {
                    <p style="margin-bottom:0.75rem;color:var(--gray-600);">How satisfied were you with how this ticket was handled?</p>
                    <form asp-action="RateSatisfaction" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="csat-stars" id="csatStars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <button type="button" class="csat-star" data-v="@i" aria-label="@i stars"><i class="fas fa-star"></i></button>
                            }
                        </div>
                        <input type="hidden" name="rating" id="csatRating" value="" required />
                        <textarea name="comment" class="reply-textarea" rows="2" placeholder="Any comments? (optional)" style="margin-top:0.75rem;"></textarea>
                        <button type="submit" class="btn-send-reply" style="margin-top:0.6rem;">
                            <i class="fas fa-paper-plane"></i> Submit Feedback
                        </button>
                    </form>
                }
                else
                {
                    <div class="csat-result">
                        <div class="csat-stars-static">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star @(i <= Model.SatisfactionRating ? "filled" : "")"></i>
                            }
                        </div>
                        <span style="font-weight:600;color:var(--gray-700);">You rated this @Model.SatisfactionRating / 5</span>
                        @if (!string.IsNullOrEmpty(Model.SatisfactionComment))
                        {
                            <p class="csat-comment">“@Model.SatisfactionComment”</p>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <style>
        /* Internal notes */
        .internal-message .message-content { background:#fffbeb !important; border-left:3px solid var(--warning,#f59e0b) !important; }
        .internal-badge { margin-left:auto; font-size:0.62rem; font-weight:700; text-transform:uppercase; letter-spacing:0.4px;
            color:#92400e; background:#fef3c7; border:1px solid #fde68a; padding:0.1rem 0.5rem; border-radius:1rem; display:inline-flex; align-items:center; gap:0.3rem; }
        .internal-note-toggle { display:inline-flex; align-items:center; gap:0.35rem; margin-left:0.75rem; font-size:0.78rem; color:#92400e; cursor:pointer; }
        .internal-note-toggle input { accent-color:var(--warning,#f59e0b); }
        /* CSAT */
        .csat-card { background:#fff; border-radius:1rem; overflow:hidden; box-shadow:var(--shadow-sm); border:1px solid var(--gray-200); margin-bottom:1.5rem; }
        .csat-stars { display:flex; gap:0.25rem; }
        .csat-star { background:none; border:none; cursor:pointer; font-size:1.6rem; color:var(--gray-300,#cbd5e1); transition:color 0.15s; padding:0; }
        .csat-star.on, .csat-star:hover, .csat-star.on ~ .csat-star { color:#f59e0b; }
        .csat-stars:hover .csat-star { color:var(--gray-300,#cbd5e1); }
        .csat-stars .csat-star:hover, .csat-stars .csat-star:hover ~ .csat-star { color:#f59e0b; }
        .csat-stars-static .fa-star { color:var(--gray-300,#cbd5e1); font-size:1.3rem; }
        .csat-stars-static .fa-star.filled { color:#f59e0b; }
        .csat-result { display:flex; flex-direction:column; gap:0.4rem; }
        .csat-comment { font-style:italic; color:var(--gray-500); margin:0.25rem 0 0; }
    </style>
    <script>
        (function () {
            var stars = document.querySelectorAll('#csatStars .csat-star');
            var input = document.getElementById('csatRating');
            stars.forEach(function (s) {
                s.addEventListener('click', function () {
                    var v = parseInt(this.getAttribute('data-v'));
                    if (input) input.value = v;
                    stars.forEach(function (x) {
                        x.classList.toggle('on', parseInt(x.getAttribute('data-v')) <= v);
                    });
                });
            });
        })();
    </script>

    <div class="attachments-card">
        <div class="card-header-custom">
            <i class="fas fa-paperclip me-2"></i>
            <span>Attachments</span>
            <span class="attachment-count">@(Model.Attachments?.Count() ?? 0) files</span>
        </div>
        <div class="card-body-custom">
            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <div class="attachments-grid">
                    @foreach (var file in Model.Attachments)
                    {
                        <div class="attachment-item">
                            <i class="fas fa-file-alt"></i>
                            <div class="attachment-info">
                                <a href="@file.FilePath" target="_blank" class="attachment-link">@file.FileName</a>
                                <span class="attachment-meta">Uploaded @file.UploadedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-attachments">
                    <i class="fas fa-paperclip"></i>
                    <p>No attachments</p>
                </div>
            }
        </div>
    </div>

    <!-- Conversation Section -->
    <div class="conversation-card">
        <div class="card-header-custom">
            <i class="fas fa-comments me-2"></i>
            <span>Conversation History</span>
            <span class="message-count">@(Model.Messages?.Count() ?? 0) messages</span>
        </div>
        
        <div class="chat-container" id="chatBox">
            @if (Model.Messages != null && Model.Messages.Any())
            {
                foreach (var msg in Model.Messages.OrderBy(m => m.SentAt))
                {
                    var sideClass = msg.IsInternal ? "internal-message" : (msg.SenderId == Model.CreatedBy?.Id ? "user-message" : "support-message");
                    <div class="message-item @sideClass">
                        <div class="message-header">
                            <div class="message-sender">
                                <div class="sender-avatar">
                                    @((msg.Sender?.FirstName?.Substring(0, 1) ?? "U") + (msg.Sender?.LastName?.Substring(0, 1) ?? "S"))
                                </div>
                                <div>
                                    <strong>@msg.Sender?.FirstName @msg.Sender?.LastName</strong>
                                    <span class="message-time">@msg.SentAt.ToString("MMM dd, yyyy HH:mm")</span>
                                </div>
                            </div>
                            @if (msg.IsInternal)
                            {
                                <span class="internal-badge"><i class="fas fa-user-shield"></i> Internal</span>
                            }
                        </div>
                        <div class="message-content">
                            @msg.Message
                        </div>
                        @if (msg.Attachments != null && msg.Attachments.Any())
                        {
                            <div class="message-attachments">
                                @foreach (var file in msg.Attachments)
                                {
                                    <a href="@file.FilePath" target="_blank" class="attachment-link-sm">
                                        <i class="fas fa-paperclip"></i> @file.FileName
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-conversation">
                    <i class="fas fa-comments"></i>
                    <p>No messages yet</p>
                    <span>Be the first to reply to this ticket</span>
                </div>
            }
        </div>

        <!-- Reply Section -->
        @if (!isClosed)
        {
            <div class="reply-section">
                <h3 class="reply-title">
                    <i class="fas fa-reply"></i>
                    Reply to Ticket
                </h3>
                <form id="chatForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="ticketId" value="@Model.Id" />

                    @{
                        var isStaffView = (bool?)ViewBag.IsStaff ?? false;
                        var canned = ViewBag.CannedResponses as List<IT_Service_Management_System.Models.CannedResponse>
                            ?? new List<IT_Service_Management_System.Models.CannedResponse>();
                    }
                    @if (isStaffView && canned.Any())
                    {
                        <select id="cannedSelect" class="reply-textarea" style="margin-bottom:0.5rem;cursor:pointer;">
                            <option value="">＋ Insert a canned reply…</option>
                            @foreach (var c in canned)
                            {
                                <option value="@c.Body">@c.Title</option>
                            }
                        </select>
                    }

                    <div class="reply-input-wrapper">
                        <textarea id="messageInput" class="reply-textarea" placeholder="Type your reply here..." rows="3"></textarea>
                        <div class="reply-actions">
                            <div class="file-upload-wrapper">
                                <label for="fileInput" class="file-upload-btn">
                                    <i class="fas fa-paperclip"></i>
                                    Attach files
                                </label>
                                <input type="file" id="fileInput" multiple style="display: none;" />
                                <span id="fileNameDisplay" class="file-name-display"></span>
                                @if (isStaffView)
                                {
                                    <label class="internal-note-toggle" title="Visible to staff only — not shown to the requester and not emailed">
                                        <input type="checkbox" id="isInternalCheck" />
                                        <i class="fas fa-user-shield"></i> Internal note
                                    </label>
                                }
                            </div>
                            <button type="button" onclick="sendMessage()" class="btn-send-reply">
                                <i class="fas fa-paper-plane"></i>
                                Send Reply
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

<style>
    /* Ticket Details Page Styles */
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Cards */
    .ticket-details-card, .attachments-card, .conversation-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
        margin-bottom: 1.5rem;
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .card-body-custom {
        padding: 1.5rem;
    }

    /* Ticket Status Badge */
    .ticket-status-badge {
        margin-left: auto;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .ticket-status-badge.active {
        background: #e6f5e9;
        color: var(--success);
    }

    .ticket-status-badge.closed {
        background: var(--gray-100);
        color: var(--gray-500);
    }

    /* Ticket Header */
    .ticket-header {
        border-bottom: 1px solid var(--gray-200);
        padding-bottom: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .ticket-title-section {
        margin-bottom: 1rem;
    }

    .ticket-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 0.75rem 0;
    }

    .ticket-badges {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .status-badge, .priority-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-open { background: #fff5e6; color: var(--warning); border: 1px solid #ffe0b3; }
    .status-progress { background: #e6f0ff; color: var(--info); border: 1px solid #cce4ff; }
    .status-resolved { background: #e6f5e9; color: var(--success); border: 1px solid #c6e0c9; }
    .status-closed { background: var(--gray-100); color: var(--gray-500); border: 1px solid var(--gray-300); }
    .priority-critical { background: #fee; color: var(--danger); border: 1px solid #fed7d7; }
    .priority-high { background: #fff5f5; color: #e67e22; border: 1px solid #ffe0d4; }
    .priority-medium { background: var(--gray-100); color: var(--warning); border: 1px solid var(--gray-300); }
    .priority-low { background: var(--gray-100); color: var(--gray-500); border: 1px solid var(--gray-300); }

    /* Meta Items */
    .ticket-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.75rem;
    }

    .meta-item i {
        width: 24px;
        color: var(--primary);
    }

    .meta-item label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--gray-500);
        display: block;
        margin-bottom: 0.125rem;
    }

    .meta-item span {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--gray-700);
    }

    /* Description Section */
    .description-section {
        margin-bottom: 1.5rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .description-content {
        background: var(--gray-50);
        padding: 1rem;
        border-radius: 0.75rem;
        line-height: 1.6;
        color: var(--gray-700);
    }

    /* Close Ticket Section */
    .close-ticket-section {
        background: #fff5f5;
        border: 1px solid #fed7d7;
        border-radius: 0.75rem;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .btn-close-ticket {
        background: linear-gradient(100deg, var(--danger), #c53030);
        color: white;
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

    .btn-close-ticket:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
    }

    .close-hint {
        font-size: 0.75rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .closed-alert {
        background: var(--gray-50);
        border-left: 3px solid var(--gray-500);
        padding: 1rem;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .closed-alert i {
        font-size: 1.5rem;
        color: var(--gray-500);
    }

    /* Attachments */
    .attachments-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
    }

    .attachment-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        background: var(--gray-50);
        border-radius: 0.5rem;
        transition: all 0.2s;
    }

    .attachment-item:hover {
        background: var(--gray-100);
    }

    .attachment-item i {
        font-size: 1.25rem;
        color: var(--primary);
    }

    .attachment-info {
        flex: 1;
    }

    .attachment-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 500;
        display: block;
        font-size: 0.875rem;
    }

    .attachment-link:hover {
        text-decoration: underline;
    }

    .attachment-meta {
        font-size: 0.7rem;
        color: var(--gray-500);
    }

    .empty-attachments {
        text-align: center;
        padding: 2rem;
        color: var(--gray-400);
    }

    /* Chat Container */
    .chat-container {
        max-height: 500px;
        overflow-y: auto;
        padding: 1rem;
        background: var(--gray-50);
    }

    .message-item {
        margin-bottom: 1rem;
        animation: fadeIn 0.3s ease;
    }

    .user-message .message-content {
        background: white;
        border-left: 3px solid var(--primary);
    }

    .support-message .message-content {
        background: #e6f0ff;
        border-left: 3px solid var(--info);
    }

    .message-header {
        margin-bottom: 0.5rem;
    }

    .message-sender {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .sender-avatar {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.75rem;
    }

    .message-time {
        font-size: 0.7rem;
        color: var(--gray-500);
        margin-left: 0.5rem;
    }

    .message-content {
        padding: 0.75rem;
        border-radius: 0.5rem;
        margin-left: 2.5rem;
        background: white;
        line-height: 1.5;
    }

    .message-attachments {
        margin-left: 2.5rem;
        margin-top: 0.5rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .attachment-link-sm {
        font-size: 0.7rem;
        color: var(--primary);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .empty-conversation {
        text-align: center;
        padding: 3rem;
        color: var(--gray-400);
    }

    /* Reply Section */
    .reply-section {
        border-top: 1px solid var(--gray-200);
        padding: 1.5rem;
    }

    .reply-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .reply-textarea {
        width: 100%;
        padding: 0.75rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-family: 'Inter', sans-serif;
        resize: vertical;
        transition: all 0.2s;
    }

    .reply-textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59,130,246, 0.1);
    }

    .reply-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.75rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .file-upload-wrapper {
        flex: 1;
    }

    .file-upload-btn {
        background: var(--gray-100);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .file-upload-btn:hover {
        background: var(--gray-200);
    }

    .file-name-display {
        margin-left: 0.5rem;
        font-size: 0.75rem;
        color: var(--gray-500);
    }

    .btn-send-reply {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.5rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

    .btn-send-reply:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
    }

    /* Flash banner */
    .ticket-flash {
        background: #f0fdf4; border-left: 4px solid var(--success); color: #166534;
        padding: 0.8rem 1rem; border-radius: 0.6rem; margin-bottom: 1rem;
        display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 500;
    }

    /* Staff toolbar */
    .staff-toolbar {
        background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 0.75rem;
        padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem;
    }
    .staff-toolbar-row { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
    .toolbar-label { font-size: 0.75rem; font-weight: 700; color: var(--gray-600); min-width: 90px; }
    .toolbar-label i { color: var(--primary); margin-right: 0.25rem; }
    .inline-form { display: inline; margin: 0; }
    .status-btn {
        border: none; cursor: pointer; padding: 0.45rem 0.9rem; border-radius: 0.5rem;
        font-size: 0.8rem; font-weight: 600; color: white; display: inline-flex; align-items: center;
        gap: 0.4rem; text-decoration: none; transition: all 0.15s;
    }
    .status-btn:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); color: white; }
    .status-btn.progress { background: var(--info); }
    .status-btn.resolved { background: var(--success); }
    .status-btn.closed { background: var(--gray-600); }
    .status-btn.assign { background: var(--primary-dark); }
    .assign-select {
        padding: 0.45rem 0.7rem; border: 1.5px solid var(--gray-200); border-radius: 0.5rem;
        font-size: 0.8rem; font-family: inherit; background: white; min-width: 180px;
    }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const ticketId = document.getElementById("ticketId")?.value;
    let connection;

    // Initialize SignalR
    if (ticketId) {
        connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .withAutomaticReconnect()
            .build();

        connection.start()
            .then(function() {
                console.log("SignalR connected");
                connection.invoke("JoinTicketGroup", ticketId);
            })
            .catch(function(err) {
                console.error("SignalR connection error: ", err);
            });

        connection.on("ReceiveMessage", function(user, message, time) {
            const chatBox = document.getElementById("chatBox");
            const msgDiv = document.createElement("div");
            msgDiv.classList.add("message-item", "support-message");
            msgDiv.innerHTML = `
                <div class="message-header">
                    <div class="message-sender">
                        <div class="sender-avatar">${user.charAt(0)}</div>
                        <div>
                            <strong>${user}</strong>
                            <span class="message-time">${time}</span>
                        </div>
                    </div>
                </div>
                <div class="message-content">${escapeHtml(message)}</div>
            `;
            chatBox.appendChild(msgDiv);
            chatBox.scrollTop = chatBox.scrollHeight;
        });
    }

    // File input display
    const fileInput = document.getElementById('fileInput');
    const fileNameDisplay = document.getElementById('fileNameDisplay');
    
    if (fileInput) {
        fileInput.addEventListener('change', function() {
            if (this.files.length > 0) {
                fileNameDisplay.textContent = `${this.files.length} file(s) selected`;
            } else {
                fileNameDisplay.textContent = '';
            }
        });
    }

    // Insert a canned reply into the message box.
    const cannedSelect = document.getElementById('cannedSelect');
    if (cannedSelect) {
        cannedSelect.addEventListener('change', function () {
            if (!this.value) return;
            const box = document.getElementById('messageInput');
            box.value = box.value ? (box.value.trimEnd() + "\n\n" + this.value) : this.value;
            box.focus();
            this.value = "";
        });
    }

    function sendMessage() {
        const message = document.getElementById("messageInput").value.trim();
        if (!message) {
            showNotification('Please enter a message', 'warning');
            return;
        }

        const internalCheck = document.getElementById("isInternalCheck");
        const isInternal = internalCheck ? internalCheck.checked : false;

        const formData = new FormData();
        formData.append("ticketId", ticketId);
        formData.append("message", message);
        formData.append("isInternal", isInternal);

        const files = document.getElementById("fileInput").files;
        for (let i = 0; i < files.length; i++) {
            formData.append("files", files[i]);
        }

        const sendBtn = document.querySelector('.btn-send-reply');
        sendBtn.disabled = true;
        sendBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';

        fetch("/Tickets/AddReply", {
            method: "POST",
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
            }
        })
        .then(response => {
            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            return response.json();
        })
        .then(data => {
            if (data.success) {
                const senderName = data.senderName || "You";
                const when = data.time || "Just now";
                const sideClass = data.isInternal ? "internal-message" : (data.isStaff ? "support-message" : "user-message");
                const internalBadge = data.isInternal
                    ? '<span class="internal-badge"><i class="fas fa-user-shield"></i> Internal</span>' : '';

                // Internal notes are staff-only, so don't broadcast them over SignalR.
                if (connection && !data.isInternal) {
                    connection.invoke("SendMessage", ticketId, senderName, message, when);
                }

                // Add message to chat immediately
                const chatBox = document.getElementById("chatBox");
                const msgDiv = document.createElement("div");
                msgDiv.classList.add("message-item", sideClass);
                const initials = senderName.split(' ').map(p => p.charAt(0)).join('').substring(0,2).toUpperCase();
                msgDiv.innerHTML = `
                    <div class="message-header">
                        <div class="message-sender">
                            <div class="sender-avatar">${initials}</div>
                            <div>
                                <strong>${escapeHtml(senderName)}</strong>
                                <span class="message-time">${when}</span>
                            </div>
                        </div>
                        ${internalBadge}
                    </div>
                    <div class="message-content">${escapeHtml(message)}</div>
                `;
                chatBox.appendChild(msgDiv);
                chatBox.scrollTop = chatBox.scrollHeight;

                // Clear form
                document.getElementById("messageInput").value = "";
                document.getElementById("fileInput").value = "";
                fileNameDisplay.textContent = "";
                if (internalCheck) internalCheck.checked = false;
                showNotification(data.isInternal ? 'Internal note saved (staff only).' : 'Reply sent — the other party has been emailed.', 'success');
            } else {
                showNotification(data.message || 'Failed to send message', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showNotification('Failed to send message. Please try again.', 'error');
        })
        .finally(() => {
            sendBtn.disabled = false;
            sendBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Reply';
        });
    }

    function confirmCloseTicket() {
        if (confirm('Are you sure you want to close this ticket?\n\nClosing the ticket will prevent any further replies.')) {
            document.getElementById('closeTicketForm').submit();
        }
    }

    function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.className = 'notification-toast';
        const colors = {
            success: '#2c9e6e',
            error: '#e53e3e',
            warning: '#f5b042'
        };
        notification.style.cssText = `
            position: fixed;
            top: 1rem;
            right: 1rem;
            background: ${colors[type] || colors.success};
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 0.75rem;
            box-shadow: var(--shadow-lg);
            z-index: 1050;
            animation: slideIn 0.3s ease;
            font-size: 0.875rem;
        `;
        notification.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i> ${message}`;
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.style.animation = 'slideOut 0.3s ease';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // Auto-scroll to bottom of chat
    const chatBox = document.getElementById('chatBox');
    if (chatBox) {
        chatBox.scrollTop = chatBox.scrollHeight;
    }
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}