@model IT_Service_Management_System.Models.Ticket

<h2>Ticket Details</h2>

<div class="card mb-3">
    <div class="card-body">

        <h4>
            @Model.Title

            @if (Model.Status == IT_Service_Management_System.Models.Ticket.TicketStatus.Closed)
            {
                <span class="badge bg-secondary">Closed</span>
            }
            else if (Model.Status == IT_Service_Management_System.Models.Ticket.TicketStatus.Open)
            {
                <span class="badge bg-warning">Open</span>
            }
            else if (Model.Status == IT_Service_Management_System.Models.Ticket.TicketStatus.InProgress)
            {
                <span class="badge bg-info">In Progress</span>
            }
        </h4>

        <p>@Model.Description</p>

        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Priority:</strong> @Model.Priority</p>

        <!-- ✅ CLOSE BUTTON -->
        @if (Model.Status != IT_Service_Management_System.Models.Ticket.TicketStatus.Closed)
        {
            <form asp-action="CloseTicket" method="post" class="mt-2">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger">
                    Close Ticket
                </button>
            </form>
        }
        else
        {
            <div class="mt-2">
                <span class="badge bg-secondary">This ticket is closed</span>
            </div>
        }

    </div>
</div>

<h4>Attachments</h4>

@if (Model.Attachments != null && Model.Attachments.Any())
{
    foreach (var file in Model.Attachments)
    {
        <div>
            <a href="@file.FilePath" target="_blank">@file.FileName</a>
        </div>
    }
}
else
{
    <p>No attachments</p>
}

<hr />

<h4>Conversation</h4>

<div id="chatBox" class="border p-3 mb-3" style="max-height:400px; overflow-y:auto;">

    @if (Model.Messages != null && Model.Messages.Any())
    {
        foreach (var msg in Model.Messages.OrderBy(m => m.SentAt))
        {
            <div class="mb-3">
                <strong>@msg.Sender?.FirstName</strong>
                <small class="text-muted">(@msg.SentAt.ToString("g"))</small>

                <div class="p-2 border rounded mt-1">
                    @msg.Message
                </div>

                @if (msg.Attachments != null && msg.Attachments.Any())
                {
                    foreach (var file in msg.Attachments)
                    {
                        <div>
                            <a href="@file.FilePath" target="_blank">@file.FileName</a>
                        </div>
                    }
                }
            </div>
        }
    }
    else
    {
        <p>No messages yet</p>
    }

</div>

<hr />

<!-- ✅ CONDITIONAL REPLY -->
@if (Model.Status != IT_Service_Management_System.Models.Ticket.TicketStatus.Closed)
{
    <h4>Reply</h4>

    <form id="chatForm" enctype="multipart/form-data">
        <input type="hidden" id="ticketId" value="@Model.Id" />

        <div>
            <textarea id="messageInput" class="form-control" placeholder="Type your message..." required></textarea>
        </div>

        <div class="mt-2">
            <input type="file" id="fileInput" multiple class="form-control" />
        </div>

        <br />

        <button type="button" onclick="sendMessage()" class="btn btn-primary">
            Send Reply
        </button>
    </form>
}
else
{
    <div class="alert alert-warning">
        This ticket is closed. No further replies allowed.
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const ticketId = document.getElementById("ticketId")?.value;

        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .build();

        connection.start().then(function () {
        if (ticketId)
        connection.invoke("JoinTicketGroup", ticketId);
        });

        connection.on("ReceiveMessage", function (user, message, time) {

        const chatBox = document.getElementById("chatBox");

        const msgDiv = document.createElement("div");
        msgDiv.classList.add("mb-3");

        msgDiv.innerHTML = `
        <strong>${user}</strong>
        <small class="text-muted">(${time})</small>
        <div class="p-2 border rounded mt-1">${message}</div>
        `;

        chatBox.appendChild(msgDiv);
        chatBox.scrollTop = chatBox.scrollHeight;
        });

        function sendMessage() {
        const message = document.getElementById("messageInput").value;

        if (!message) return;

        const formData = new FormData();
        formData.append("ticketId", ticketId);
        formData.append("message", message);

        const files = document.getElementById("fileInput").files;
        for (let i = 0; i < files.length; i++) {
        formData.append("files", files[i]);
        }

        fetch("/Tickets/AddReply", {
        method: "POST",
        body: formData
        })
        .then(() => {
        connection.invoke("SendMessage", ticketId, "Admin", message, new Date().toLocaleString());

        document.getElementById("messageInput").value = "";
        document.getElementById("fileInput").value = "";
        });
        }
    </script>
}