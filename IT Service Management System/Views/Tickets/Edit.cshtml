@model IT_Service_Management_System.Models.Ticket

@{
    ViewData["Title"] = "Edit Ticket - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-edit me-2" style="color: var(--warning);"></i>
                    Edit Ticket
                </h1>
                <p class="text-muted mt-2">Update ticket information and track progress</p>
            </div>
        </div>
    </div>

    <div class="edit-ticket-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-ticket-alt me-2"></i>
                <span>Ticket Information</span>
            </div>
            <div class="ticket-id-badge">
                <i class="fas fa-hashtag"></i>
                Ticket #@Model.Id
            </div>
        </div>

        <form asp-action="Edit" method="post" id="editTicketForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="card-body-custom">
                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Title" class="form-label">
                                <i class="fas fa-heading"></i>
                                Ticket Title
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-ticket-alt input-icon"></i>
                                <input asp-for="Title" class="form-control-modern" placeholder="Enter ticket title" autocomplete="off" />
                            </div>
                            <span asp-validation-for="Title" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Brief summary of the issue
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Description" class="form-label">
                                <i class="fas fa-align-left"></i>
                                Description
                                <span class="required">*</span>
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-file-alt textarea-icon"></i>
                                <textarea asp-for="Description" class="form-control-textarea" rows="6" placeholder="Provide detailed information about the issue..."></textarea>
                            </div>
                            <span asp-validation-for="Description" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Include steps to reproduce, expected behavior, and any relevant details
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Status" class="form-label">
                                <i class="fas fa-chart-simple"></i>
                                Status
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="Status" class="form-control-modern" id="statusSelect">
                                    @foreach (var status in Enum.GetValues(typeof(IT_Service_Management_System.Models.Ticket.TicketStatus)))
                                    {
                                        var statusValue = status.ToString();
                                        <option value="@statusValue" selected="@(Model.Status.ToString() == statusValue)">
                                            @statusValue
                                        </option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="Status" class="validation-message text-danger"></span>
                            <div class="status-info" id="statusInfo">
                                <i class="fas fa-info-circle"></i>
                                <span id="statusDescription"></span>
                            </div>
                        </div>

                        <p>
    @(Model.CreatedBy != null 
        ? Model.CreatedBy.FirstName + " " + Model.CreatedBy.LastName 
        : "N/A")
</p>

                        <div class="form-group-modern">
                            <label asp-for="Priority" class="form-label">
                                <i class="fas fa-flag"></i>
                                Priority
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="Priority" class="form-control-modern" id="prioritySelect">
                                    @foreach (var priority in Enum.GetValues(typeof(IT_Service_Management_System.Models.Ticket.TicketPriority)))
                                    {
                                        var priorityValue = priority.ToString();
                                        <option value="@priorityValue" selected="@(Model.Priority.ToString() == priorityValue)">
                                            @priorityValue
                                        </option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="Priority" class="validation-message text-danger"></span>
                            <div class="priority-info" id="priorityInfo">
                                <i class="fas fa-clock"></i>
                                <span id="priorityDescription"></span>
                            </div>
                        </div>

                        <!-- Metadata Section -->
                        <div class="metadata-section">
                            <div class="metadata-item">
                                <i class="fas fa-user"></i>
                                <div>
                                    <label>Created By</label>
                                    <p>
                                        @(Model.CreatedBy != null 
                                            ? Model.CreatedBy.FirstName + " " + Model.CreatedBy.LastName 
                                            : "N/A")
                                    </p>
                                </div>
                            </div>
                            <div class="metadata-item">
                                <i class="fas fa-calendar"></i>
                                <div>
                                    <label>Created Date</label>
                                    <p>@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                                </div>
                            </div>
                                            </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-save" id="submitBtn">
                        <i class="fas fa-save"></i>
                        Save Changes
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Edit Ticket Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Edit Ticket Card */
    .edit-ticket-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .ticket-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label i {
        color: var(--primary);
        font-size: 0.875rem;
    }

    .required {
        color: var(--danger);
        font-size: 1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .input-icon-wrapper i.input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

    .form-control-modern:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    /* Textarea Styling */
    .textarea-wrapper {
        position: relative;
    }

    .textarea-icon {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
        resize: vertical;
    }

    .form-control-textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    /* Select Styling */
    .select-wrapper {
        position: relative;
    }

    .select-wrapper select {
        appearance: none;
        cursor: pointer;
        background: white;
    }

    .select-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        pointer-events: none;
        font-size: 0.75rem;
    }

    /* Status & Priority Info */
    .status-info, .priority-info {
        background: var(--gray-50);
        padding: 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-left: 3px solid var(--primary);
    }

    .status-info i, .priority-info i {
        color: var(--primary);
    }

    /* Metadata Section */
    .metadata-section {
        background: var(--gray-50);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-top: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .metadata-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.75rem;
    }

    .metadata-item i {
        width: 24px;
        color: var(--primary);
        font-size: 0.875rem;
    }

    .metadata-item div {
        flex: 1;
    }

    .metadata-item label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--gray-500);
        display: block;
        margin-bottom: 0.125rem;
    }

    .metadata-item p {
        margin: 0;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--gray-700);
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-hint i {
        font-size: 0.7rem;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-save {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-cancel:hover {
        background: var(--gray-50);
        color: var(--gray-700);
        text-decoration: none;
    }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Status descriptions
        const statusSelect = document.getElementById('statusSelect');
        const statusDescription = document.getElementById('statusDescription');
        
        const statusDescriptions = {
            'Open': 'Ticket has been created and is waiting for assignment',
            'InProgress': 'Ticket is currently being worked on by support team',
            'Resolved': 'Issue has been resolved and awaiting confirmation',
            'Closed': 'Ticket is completed and closed'
        };
        
        function updateStatusDescription() {
            var selectedStatus = statusSelect.value;
            if (selectedStatus && statusDescriptions[selectedStatus]) {
                statusDescription.textContent = statusDescriptions[selectedStatus];
            } else {
                statusDescription.textContent = 'Select a status to see description';
            }
        }
        
        if (statusSelect) {
            updateStatusDescription();
            statusSelect.addEventListener('change', updateStatusDescription);
        }
        
        // Priority descriptions
        const prioritySelect = document.getElementById('prioritySelect');
        const priorityDescription = document.getElementById('priorityDescription');
        
        const priorityDescriptions = {
            'Low': 'Minor issue with minimal impact, can be addressed when time permits',
            'Medium': 'Moderate impact, should be addressed in a timely manner',
            'High': 'Significant impact requiring immediate attention',
            'Critical': 'System-wide impact requiring urgent resolution'
        };
        
        function updatePriorityDescription() {
            var selectedPriority = prioritySelect.value;
            if (selectedPriority && priorityDescriptions[selectedPriority]) {
                priorityDescription.textContent = priorityDescriptions[selectedPriority];
                
                // Add visual indication based on priority
                var priorityInfo = document.getElementById('priorityInfo');
                if (selectedPriority === 'Critical') {
                    priorityInfo.style.borderLeftColor = 'var(--danger)';
                    priorityInfo.querySelector('i').style.color = 'var(--danger)';
                } else if (selectedPriority === 'High') {
                    priorityInfo.style.borderLeftColor = '#e67e22';
                    priorityInfo.querySelector('i').style.color = '#e67e22';
                } else if (selectedPriority === 'Medium') {
                    priorityInfo.style.borderLeftColor = 'var(--warning)';
                    priorityInfo.querySelector('i').style.color = 'var(--warning)';
                } else {
                    priorityInfo.style.borderLeftColor = 'var(--gray-500)';
                    priorityInfo.querySelector('i').style.color = 'var(--gray-500)';
                }
            } else {
                priorityDescription.textContent = 'Select a priority to see description';
            }
        }
        
        if (prioritySelect) {
            updatePriorityDescription();
            prioritySelect.addEventListener('change', updatePriorityDescription);
        }
        
        // Form validation
        const form = document.getElementById('editTicketForm');
        const submitBtn = document.getElementById('submitBtn');
        
        if (form) {
            form.addEventListener('submit', function(e) {
                var title = document.querySelector('[name="Title"]').value.trim();
                var description = document.querySelector('[name="Description"]').value.trim();
                var status = statusSelect.value;
                var priority = prioritySelect.value;
                
                if (!title) {
                    e.preventDefault();
                    showValidationError('Ticket title is required');
                    document.querySelector('[name="Title"]').focus();
                    return false;
                }
                
                if (title.length < 5) {
                    e.preventDefault();
                    showValidationError('Title must be at least 5 characters');
                    document.querySelector('[name="Title"]').focus();
                    return false;
                }
                
                if (!description) {
                    e.preventDefault();
                    showValidationError('Description is required');
                    document.querySelector('[name="Description"]').focus();
                    return false;
                }
                
                if (description.length < 10) {
                    e.preventDefault();
                    showValidationError('Description must be at least 10 characters');
                    document.querySelector('[name="Description"]').focus();
                    return false;
                }
                
                if (!status) {
                    e.preventDefault();
                    showValidationError('Please select a status');
                    statusSelect.focus();
                    return false;
                }
                
                if (!priority) {
                    e.preventDefault();
                    showValidationError('Please select a priority');
                    prioritySelect.focus();
                    return false;
                }
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving Changes...';
                
                return true;
            });
        }
        
        function showValidationError(message) {
            var errorDiv = document.querySelector('.validation-toast');
            if (errorDiv) errorDiv.remove();
            
            errorDiv = document.createElement('div');
            errorDiv.className = 'validation-toast';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
                animation: slideIn 0.3s ease;
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(errorDiv);
            
            setTimeout(function() {
                errorDiv.style.animation = 'slideOut 0.3s ease';
                setTimeout(function() { errorDiv.remove(); }, 300);
            }, 4000);
        }
    });
</script>

<style>
    /* Additional animations */
    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }
        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}