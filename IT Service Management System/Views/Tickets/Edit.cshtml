@model IT_Service_Management_System.Models.Ticket

<h2>Edit Ticket</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div>
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div>
        <label>Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div>
        <label>Status</label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<IT_Service_Management_System.Models.Ticket.TicketStatus>()" class="form-control"></select>
    </div>

    <div>
        <label>Priority</label>
        <select asp-for="Priority" asp-items="Html.GetEnumSelectList<IT_Service_Management_System.Models.Ticket.TicketPriority>()" class="form-control"></select>
    </div>

    <br />

    <button type="submit" class="btn btn-success">Save</button>
</form>