@model IT_Service_Management_System.Models.ExitInterview

@{
    ViewData["Title"] = "Exit Interview Details - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-file-alt me-2" style="color: var(--info);"></i>
                    Exit Interview Questionnaire
                </h1>
                <p class="text-muted mt-2">View complete exit interview responses</p>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons-top mb-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit-top">
            <i class="fas fa-pencil-alt"></i> Edit
        </a>
        <a asp-action="Index" class="btn-back-top">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
        <button type="button" class="btn-print-top" onclick="window.print()">
            <i class="fas fa-print"></i> Print
        </button>
    </div>

    <!-- Employee Information Section -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-user-circle me-2"></i>
            <span>Employee Information</span>
        </div>
        <div class="card-body-custom">
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Employee Name</span>
                    <span class="info-value">@Model.EmployeeName</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Position</span>
                    <span class="info-value">@Model.Position</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Client</span>
                    <span class="info-value">@Model.Client</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Date of Resignation</span>
                    <span class="info-value">@(Model.DateOfResignation?.ToString("dd MMM yyyy") ?? "—")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Last Working Day</span>
                    <span class="info-value">@(Model.LastWorkingDay?.ToString("dd MMM yyyy") ?? "—")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Interview Conducted By</span>
                    <span class="info-value">@(string.IsNullOrEmpty(Model.InterviewConductedBy) ? "—" : Model.InterviewConductedBy)</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Date of Interview</span>
                    <span class="info-value">@(Model.InterviewDate?.ToString("dd MMM yyyy") ?? "—")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Primary Reason for Departure -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-question-circle me-2"></i>
            <span>Primary Reason for Departure</span>
        </div>
        <div class="card-body-custom">
            <div class="content-box">
                @(string.IsNullOrEmpty(Model.PrimaryReasonForDeparture) ? "No information provided" : Model.PrimaryReasonForDeparture)
            </div>
        </div>
    </div>

    <!-- Section 1: Overall Views -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-chart-line me-2"></i>
            <span>1. Overall Views</span>
        </div>
        <div class="card-body-custom">
            <p class="section-description">We value your feedback to help us improve. Below are the responses to the overall views section.</p>

            <div class="ratings-grid">
                <div class="rating-item">
                    <span class="rating-label">Career Growth Opportunities</span>
                    <span class="rating-value rating-@((int)Model.CareerGrowthOpportunities)">
                        @GetRatingText(Model.CareerGrowthOpportunities)
                    </span>
                </div>
                <div class="rating-item">
                    <span class="rating-label">Compensation and Benefits</span>
                    <span class="rating-value rating-@((int)Model.CompensationAndBenefits)">
                        @GetRatingText(Model.CompensationAndBenefits)
                    </span>
                </div>
                <div class="rating-item">
                    <span class="rating-label">Work-Life Balance</span>
                    <span class="rating-value rating-@((int)Model.WorkLifeBalanceRating)">
                        @GetRatingText(Model.WorkLifeBalanceRating)
                    </span>
                </div>
                <div class="rating-item">
                    <span class="rating-label">Management / Leadership Style</span>
                    <span class="rating-value rating-@((int)Model.ManagementLeadershipStyle)">
                        @GetRatingText(Model.ManagementLeadershipStyle)
                    </span>
                </div>
                <div class="rating-item">
                    <span class="rating-label">Company Culture / Work Environment</span>
                    <span class="rating-value rating-@((int)Model.CompanyCultureWorkEnvironment)">
                        @GetRatingText(Model.CompanyCultureWorkEnvironment)
                    </span>
                </div>
                <div class="rating-item">
                    <span class="rating-label">Job Responsibilities</span>
                    <span class="rating-value rating-@((int)Model.JobResponsibilities)">
                        @GetRatingText(Model.JobResponsibilities)
                    </span>
                </div>
                <div class="rating-item">
                    <span class="rating-label">Relationship with Your Manager</span>
                    <span class="rating-value rating-@((int)Model.RelationshipWithManagerRating)">
                        @GetRatingText(Model.RelationshipWithManagerRating)
                    </span>
                </div>
                <div class="rating-item">
                    <span class="rating-label">Other</span>
                    <span class="rating-value rating-@((int)(Model.OtherRating ?? Rating.MetExpectations))">
                        @GetRatingText(Model.OtherRating ?? Rating.MetExpectations)
                    </span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.OtherReasonDescription))
            {
                <div class="content-box mt-3">
                    <strong>Other (Please Specify):</strong>
                    <p class="mt-1">@Model.OtherReasonDescription</p>
                </div>
            }
        </div>
    </div>

    <!-- Section 2: Job Satisfaction & Role Clarity -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-smile me-2"></i>
            <span>2. Job Satisfaction & Role Clarity</span>
        </div>
        <div class="card-body-custom">
            <div class="info-grid-2col">
                <div class="info-item">
                    <span class="info-label">Role Met Expectations</span>
                    <span class="info-value @(Model.RoleMetExpectations == true ? "status-yes" : "status-no")">
                        <i class="fas @(Model.RoleMetExpectations == true ? "fa-check-circle" : "fa-times-circle")"></i>
                        @(Model.RoleMetExpectations == true ? "Yes" : "No")
                    </span>
                </div>
                <div class="info-item">
                    <span class="info-label">Responsibilities Clearly Defined</span>
                    <span class="info-value @(Model.ResponsibilitiesClearlyDefined == true ? "status-yes" : "status-no")">
                        <i class="fas @(Model.ResponsibilitiesClearlyDefined == true ? "fa-check-circle" : "fa-times-circle")"></i>
                        @(Model.ResponsibilitiesClearlyDefined == true ? "Yes" : "No")
                    </span>
                </div>
                <div class="info-item">
                    <span class="info-label">Adequate Training & Resources</span>
                    <span class="info-value @(Model.AdequateTrainingAndResources == true ? "status-yes" : "status-no")">
                        <i class="fas @(Model.AdequateTrainingAndResources == true ? "fa-check-circle" : "fa-times-circle")"></i>
                        @(Model.AdequateTrainingAndResources == true ? "Yes" : "No")
                    </span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.JobSatisfactionComments))
            {
                <div class="content-box mt-3">
                    <strong>Additional Comments:</strong>
                    <p class="mt-1">@Model.JobSatisfactionComments</p>
                </div>
            }
        </div>
    </div>

    <!-- Section 3: Feedback on Management & Team Dynamics -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-users me-2"></i>
            <span>3. Feedback on Management & Team Dynamics</span>
        </div>
        <div class="card-body-custom">
            @if (!string.IsNullOrEmpty(Model.RelationshipWithManagerDescription))
            {
                <div class="content-box mb-3">
                    <strong>How would you describe your relationship with your manager?</strong>
                    <p class="mt-1">@Model.RelationshipWithManagerDescription</p>
                </div>
            }
            <div class="info-item mb-3">
                <span class="info-label">Supported by Team & Leadership</span>
                <span class="info-value @(Model.SupportedByTeamAndLeadership == true ? "status-yes" : "status-no")">
                    <i class="fas @(Model.SupportedByTeamAndLeadership == true ? "fa-check-circle" : "fa-times-circle")"></i>
                    @(Model.SupportedByTeamAndLeadership == true ? "Yes" : "No")
                </span>
            </div>
            @if (!string.IsNullOrEmpty(Model.CommunicationCollaborationSuggestions))
            {
                <div class="content-box">
                    <strong>Suggestions for improving communication or collaboration:</strong>
                    <p class="mt-1">@Model.CommunicationCollaborationSuggestions</p>
                </div>
            }
        </div>
    </div>

    <!-- Section 4: Compensation & Benefits -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-dollar-sign me-2"></i>
            <span>4. Compensation & Benefits</span>
        </div>
        <div class="card-body-custom">
            <div class="info-item mb-3">
                <span class="info-label">Satisfied with Salary & Benefits</span>
                <span class="info-value @(Model.SatisfiedWithSalaryAndBenefits == true ? "status-yes" : "status-no")">
                    <i class="fas @(Model.SatisfiedWithSalaryAndBenefits == true ? "fa-check-circle" : "fa-times-circle")"></i>
                    @(Model.SatisfiedWithSalaryAndBenefits == true ? "Yes" : "No")
                </span>
            </div>
            @if (!string.IsNullOrEmpty(Model.CompensationMarketCompetitiveness))
            {
                <div class="content-box">
                    <strong>How competitive do you believe our compensation is compared to the market?</strong>
                    <p class="mt-1">@Model.CompensationMarketCompetitiveness</p>
                </div>
            }
        </div>
    </div>

    <!-- Section 5: Work Environment & Culture -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-building me-2"></i>
            <span>5. Work Environment & Culture</span>
        </div>
        <div class="card-body-custom">
            <div class="info-item mb-3">
                <span class="info-label">Felt Valued & Recognized</span>
                <span class="info-value @(Model.FeltValuedAndRecognized == true ? "status-yes" : "status-no")">
                    <i class="fas @(Model.FeltValuedAndRecognized == true ? "fa-check-circle" : "fa-times-circle")"></i>
                    @(Model.FeltValuedAndRecognized == true ? "Yes" : "No")
                </span>
            </div>
            @if (!string.IsNullOrEmpty(Model.MostLikedAboutCompany))
            {
                <div class="content-box mb-3">
                    <strong>What did you like most about working here?</strong>
                    <p class="mt-1">@Model.MostLikedAboutCompany</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.CultureImprovementSuggestions))
            {
                <div class="content-box">
                    <strong>What could be improved about the company culture?</strong>
                    <p class="mt-1">@Model.CultureImprovementSuggestions</p>
                </div>
            }
        </div>
    </div>

    <!-- Section 6: Suggestions for Improvement -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-lightbulb me-2"></i>
            <span>6. Suggestions for Improvement</span>
        </div>
        <div class="card-body-custom">
            @if (!string.IsNullOrEmpty(Model.EmployeeRetentionRecommendations))
            {
                <div class="content-box mb-3">
                    <strong>What changes would you recommend to enhance employee retention?</strong>
                    <p class="mt-1">@Model.EmployeeRetentionRecommendations</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ResignationPreventionSuggestions))
            {
                <div class="content-box">
                    <strong>Is there anything the company could have done to prevent your resignation?</strong>
                    <p class="mt-1">@Model.ResignationPreventionSuggestions</p>
                </div>
            }
        </div>
    </div>

    <!-- Section 7: Future Engagement -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-handshake me-2"></i>
            <span>7. Future Engagement</span>
        </div>
        <div class="card-body-custom">
            <div class="info-grid-2col">
                <div class="info-item">
                    <span class="info-label">Would Return to Company</span>
                    <span class="info-value @(Model.WouldReturnToCompany == true ? "status-yes" : "status-no")">
                        <i class="fas @(Model.WouldReturnToCompany == true ? "fa-check-circle" : "fa-times-circle")"></i>
                        @(Model.WouldReturnToCompany == true ? "Yes" : "No")
                    </span>
                </div>
                <div class="info-item">
                    <span class="info-label">Would Recommend Company</span>
                    <span class="info-value @(Model.WouldRecommendCompany == true ? "status-yes" : "status-no")">
                        <i class="fas @(Model.WouldRecommendCompany == true ? "fa-check-circle" : "fa-times-circle")"></i>
                        @(Model.WouldRecommendCompany == true ? "Yes" : "No")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 8: Work-Life Balance -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-balance-scale me-2"></i>
            <span>8. Work-Life Balance</span>
        </div>
        <div class="card-body-custom">
            <div class="content-box">
                @(string.IsNullOrEmpty(Model.WorkLifeBalanceComments) ? "No information provided" : Model.WorkLifeBalanceComments)
            </div>
        </div>
    </div>

    <!-- Section 9: Additional Comments -->
    @if (!string.IsNullOrEmpty(Model.AdditionalComments))
    {
        <div class="details-card">
            <div class="card-header-custom">
                <i class="fas fa-comment-dots me-2"></i>
                <span>9. Additional Comments</span>
            </div>
            <div class="card-body-custom">
                <div class="content-box">
                    @Model.AdditionalComments
                </div>
            </div>
        </div>
    }

    <!-- Sign Off Section -->
    <div class="details-card">
        <div class="card-header-custom">
            <i class="fas fa-signature me-2"></i>
            <span>Sign Off</span>
        </div>
        <div class="card-body-custom">
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Employee</span>
                    <span class="info-value">@(string.IsNullOrEmpty(Model.EmployeeSignature) ? "—" : Model.EmployeeSignature)</span>
                </div>
                <div class="info-item">
                    <span class="info-label">HR Representative</span>
                    <span class="info-value">@(string.IsNullOrEmpty(Model.HRRepresentativeSignature) ? "—" : Model.HRRepresentativeSignature)</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Date</span>
                    <span class="info-value">@(Model.SignOffDate?.ToString("dd MMM yyyy") ?? "—")</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 1rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
        }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Top Action Buttons */
    .action-buttons-top {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .btn-edit-top {
        background: linear-gradient(100deg, var(--warning), #e6a017);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

        .btn-edit-top:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    .btn-back-top {
        background: white;
        color: var(--gray-600);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
    }

        .btn-back-top:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

    .btn-print-top {
        background: white;
        color: var(--info);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--info);
        font-size: 0.875rem;
        cursor: pointer;
    }

        .btn-print-top:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

    /* Details Cards */
    .details-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
        margin-bottom: 1.5rem;
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .card-body-custom {
        padding: 1.5rem;
    }

    .section-description {
        color: var(--gray-600);
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
    }

    /* Info Grids */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
    }

    .info-grid-2col {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem;
        background: var(--gray-50);
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
    }

    .info-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--gray-500);
        text-transform: uppercase;
    }

    .info-value {
        font-size: 0.875rem;
        color: var(--gray-700);
        font-weight: 500;
    }

    /* Ratings Grid */
    .ratings-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
    }

    .rating-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem;
        background: var(--gray-50);
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
    }

    .rating-label {
        font-size: 0.75rem;
        color: var(--gray-600);
    }

    .rating-value {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.125rem 0.5rem;
        border-radius: 2rem;
    }

        .rating-value.rating-1 {
            background: #e6f5e9;
            color: var(--success);
        }

        .rating-value.rating-2 {
            background: #fff5e6;
            color: var(--warning);
        }

        .rating-value.rating-3 {
            background: #fee;
            color: var(--danger);
        }

    /* Content Box */
    .content-box {
        background: var(--gray-50);
        padding: 1rem;
        border-radius: 0.75rem;
        border: 1px solid var(--gray-200);
        line-height: 1.5;
        color: var(--gray-700);
    }

        .content-box p {
            margin: 0;
        }

    /* Status Indicators */
    .status-yes {
        color: var(--success);
    }

    .status-no {
        color: var(--danger);
    }


</style>

@functions {
    string GetRatingText(Rating rating)
    {
        return rating switch
        {
            Rating.MetExpectations => "Met Expectations",
            Rating.NeedsImprovement => "Needs Improvement",
            Rating.DidNotMeetExpectations => "Did Not Meet Expectations",
            _ => "Not rated"
        };
    }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">