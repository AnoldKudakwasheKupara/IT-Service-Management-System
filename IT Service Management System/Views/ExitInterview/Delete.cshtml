@model IT_Service_Management_System.Models.ExitInterview

@{
    ViewData["Title"] = "Delete Exit Interview";
}

<div class="container">

    ```
    <div class="card border-danger mt-4">

        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Exit Interview</h3>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                <strong>Warning!</strong>
                Are you sure you want to delete this Exit Interview record?
                This action cannot be undone.
            </div>

            <dl class="row">

                <dt class="col-sm-3">
                    Employee Name
                </dt>
                <dd class="col-sm-9">
                    @Model.EmployeeName
                </dd>

                <dt class="col-sm-3">
                    Position
                </dt>
                <dd class="col-sm-9">
                    @Model.Position
                </dd>

                <dt class="col-sm-3">
                    Client
                </dt>
                <dd class="col-sm-9">
                    @Model.Client
                </dd>

                <dt class="col-sm-3">
                    Date of Resignation
                </dt>
                <dd class="col-sm-9">
                    @Model.DateOfResignation?.ToString("dd-MMM-yyyy")
                </dd>

                <dt class="col-sm-3">
                    Last Working Day
                </dt>
                <dd class="col-sm-9">
                    @Model.LastWorkingDay?.ToString("dd-MMM-yyyy")
                </dd>

                <dt class="col-sm-3">
                    Interview Date
                </dt>
                <dd class="col-sm-9">
                    @Model.InterviewDate?.ToString("dd-MMM-yyyy")
                </dd>

                <dt class="col-sm-3">
                    Interview Conducted By
                </dt>
                <dd class="col-sm-9">
                    @Model.InterviewConductedBy
                </dd>

                <dt class="col-sm-3">
                    Primary Reason For Departure
                </dt>
                <dd class="col-sm-9">
                    @Model.PrimaryReasonForDeparture
                </dd>

            </dl>

            <form asp-action="Delete">

                <input type="hidden" asp-for="Id" />

                <button type="submit"
                        class="btn btn-danger">
                    <i class="fas fa-trash"></i>
                    Delete
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>
    ```

</div>