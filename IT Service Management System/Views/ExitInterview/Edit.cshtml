@model IT_Service_Management_System.Models.ExitInterview

@{
    ViewData["Title"] = "Exit Interview";
}

<div class="container">

    <h2 class="mb-4">Edit Exit Interview Questionnaire</h2>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- Employee Information -->
        <div class="card mb-4">
            <div class="card-header">
                Employee Information
            </div>

            <div class="card-body row">

                <div class="col-md-4 mb-3">
                    <label class="form-label">Employee Name</label>
                    <input asp-for="EmployeeName" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Position</label>
                    <input asp-for="Position" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Client</label>
                    <input asp-for="Client" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Date of Resignation</label>
                    <input asp-for="DateOfResignation" type="date" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Last Working Day</label>
                    <input asp-for="LastWorkingDay" type="date" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Interview Conducted By</label>
                    <input asp-for="InterviewConductedBy" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Date of Interview</label>
                    <input asp-for="InterviewDate" type="date" class="form-control" />
                </div>

            </div>
        </div>

        <!-- Primary Reason -->
        <h4>What is the primary reason for your departure?</h4>

        <div class="mb-4">
            <label>Answer:</label>
            <textarea asp-for="PrimaryReasonForDeparture"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <!-- Section 1 -->
        <h4>1. Overall Views</h4>

        <p>
            We value your feedback to help us improve.
            Could you provide your overall views related to your resignation?
            Answer all and tick appropriate.
        </p>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Area</th>
                    <th>Met Expectations</th>
                    <th>Needs Improvement</th>
                    <th>Did Not Meet Expectations</th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td>Career Growth Opportunities</td>
                    <td><input type="radio" asp-for="CareerGrowthOpportunities" value="1" /></td>
                    <td><input type="radio" asp-for="CareerGrowthOpportunities" value="2" /></td>
                    <td><input type="radio" asp-for="CareerGrowthOpportunities" value="3" /></td>
                </tr>

                <tr>
                    <td>Compensation and Benefits</td>
                    <td><input type="radio" asp-for="CompensationAndBenefits" value="1" /></td>
                    <td><input type="radio" asp-for="CompensationAndBenefits" value="2" /></td>
                    <td><input type="radio" asp-for="CompensationAndBenefits" value="3" /></td>
                </tr>

                <tr>
                    <td>Work-Life Balance</td>
                    <td><input type="radio" asp-for="WorkLifeBalanceRating" value="1" /></td>
                    <td><input type="radio" asp-for="WorkLifeBalanceRating" value="2" /></td>
                    <td><input type="radio" asp-for="WorkLifeBalanceRating" value="3" /></td>
                </tr>

                <tr>
                    <td>Management / Leadership Style</td>
                    <td><input type="radio" asp-for="ManagementLeadershipStyle" value="1" /></td>
                    <td><input type="radio" asp-for="ManagementLeadershipStyle" value="2" /></td>
                    <td><input type="radio" asp-for="ManagementLeadershipStyle" value="3" /></td>
                </tr>

                <tr>
                    <td>Company Culture / Work Environment</td>
                    <td><input type="radio" asp-for="CompanyCultureWorkEnvironment" value="1" /></td>
                    <td><input type="radio" asp-for="CompanyCultureWorkEnvironment" value="2" /></td>
                    <td><input type="radio" asp-for="CompanyCultureWorkEnvironment" value="3" /></td>
                </tr>

                <tr>
                    <td>Job Responsibilities</td>
                    <td><input type="radio" asp-for="JobResponsibilities" value="1" /></td>
                    <td><input type="radio" asp-for="JobResponsibilities" value="2" /></td>
                    <td><input type="radio" asp-for="JobResponsibilities" value="3" /></td>
                </tr>

                <tr>
                    <td>Relationship with Your Manager</td>
                    <td><input type="radio" asp-for="RelationshipWithManagerRating" value="1" /></td>
                    <td><input type="radio" asp-for="RelationshipWithManagerRating" value="2" /></td>
                    <td><input type="radio" asp-for="RelationshipWithManagerRating" value="3" /></td>
                </tr>

            </tbody>
        </table>

        <div class="mb-4">
            <label>Other (Please Specify)</label>
            <textarea asp-for="OtherReasonDescription"
                      class="form-control"
                      rows="3"></textarea>
        </div>

        <!-- Section 2 -->
        <h4>2. Job Satisfaction & Role Clarity</h4>

        <div class="mb-3">
            <label>Did your role meet your expectations?</label><br />

            <input type="radio" asp-for="RoleMetExpectations" value="true" /> Yes

            <input type="radio"
                   asp-for="RoleMetExpectations"
                   value="false"
                   class="ms-3" /> No
        </div>

        <div class="mb-3">
            <label>Were your responsibilities clearly defined?</label><br />

            <input type="radio" asp-for="ResponsibilitiesClearlyDefined" value="true" /> Yes

            <input type="radio"
                   asp-for="ResponsibilitiesClearlyDefined"
                   value="false"
                   class="ms-3" /> No
        </div>

        <div class="mb-3">
            <label>
                Did you receive adequate training and resources
                to perform your job effectively?
            </label><br />

            <input type="radio" asp-for="AdequateTrainingAndResources" value="true" /> Yes

            <input type="radio"
                   asp-for="AdequateTrainingAndResources"
                   value="false"
                   class="ms-3" /> No
        </div>

        <div class="mb-4">
            <label>Additional Comments</label>

            <textarea asp-for="JobSatisfactionComments"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <!-- Section 3 -->
        <h4>3. Feedback on Management & Team Dynamics</h4>

        <div class="mb-3">
            <label>How would you describe your relationship with your manager?</label>

            <textarea asp-for="RelationshipWithManagerDescription"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <div class="mb-3">
            <label>Did you feel supported by your team and leadership?</label><br />

            <input type="radio" asp-for="SupportedByTeamAndLeadership" value="true" /> Yes

            <input type="radio"
                   asp-for="SupportedByTeamAndLeadership"
                   value="false"
                   class="ms-3" /> No
        </div>

        <div class="mb-4">
            <label>Suggestions</label>

            <textarea asp-for="CommunicationCollaborationSuggestions"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <!-- Section 4 -->
        <h4>4. Compensation & Benefits</h4>

        <div class="mb-3">
            <label>Were you satisfied with your salary and benefits package?</label><br />

            <input type="radio" asp-for="SatisfiedWithSalaryAndBenefits" value="true" /> Yes

            <input type="radio"
                   asp-for="SatisfiedWithSalaryAndBenefits"
                   value="false"
                   class="ms-3" /> No
        </div>

        <div class="mb-4">
            <label>
                How competitive do you believe our compensation is compared to the market?
            </label>

            <textarea asp-for="CompensationMarketCompetitiveness"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <!-- Section 5 -->
        <h4>5. Work Environment & Culture</h4>

        <div class="mb-3">
            <label>
                Did you feel valued and recognized for your contributions?
            </label><br />

            <input type="radio" asp-for="FeltValuedAndRecognized" value="true" /> Yes

            <input type="radio"
                   asp-for="FeltValuedAndRecognized"
                   value="false"
                   class="ms-3" /> No
        </div>

        <div class="mb-3">
            <label>What did you like most about working here?</label>

            <textarea asp-for="MostLikedAboutCompany"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <div class="mb-4">
            <label>What could be improved about the company culture?</label>

            <textarea asp-for="CultureImprovementSuggestions"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <!-- Section 6 -->
        <h4>6. Suggestions for Improvement</h4>

        <div class="mb-3">
            <label>
                What changes would you recommend to enhance employee retention?
            </label>

            <textarea asp-for="EmployeeRetentionRecommendations"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <div class="mb-4">
            <label>
                Is there anything the company could have done to prevent your resignation?
            </label>

            <textarea asp-for="ResignationPreventionSuggestions"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <!-- Section 7 -->
        <h4>7. Future Engagement</h4>

        <div class="mb-3">
            <label>
                Would you consider returning to the company in the future?
            </label><br />

            <input type="radio" asp-for="WouldReturnToCompany" value="true" /> Yes

            <input type="radio"
                   asp-for="WouldReturnToCompany"
                   value="false"
                   class="ms-3" /> No
        </div>

        <div class="mb-4">
            <label>
                Would you recommend this company to other professionals in your network?
            </label><br />

            <input type="radio" asp-for="WouldRecommendCompany" value="true" /> Yes

            <input type="radio"
                   asp-for="WouldRecommendCompany"
                   value="false"
                   class="ms-3" /> No
        </div>

        <!-- Section 8 -->
        <h4>8. How was your work-life balance during your tenure?</h4>

        <div class="mb-4">
            <textarea asp-for="WorkLifeBalanceComments"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <!-- Section 9 -->
        <h4>9. Additional Comments</h4>

        <div class="mb-4">
            <textarea asp-for="AdditionalComments"
                      class="form-control"
                      rows="5"></textarea>
        </div>

        <!-- Sign Off -->
        <h4>Sign Off</h4>

        <div class="row">

            <div class="col-md-4 mb-3">
                <label>Employee</label>
                <input asp-for="EmployeeSignature" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label>HR</label>
                <input asp-for="HRRepresentativeSignature" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label>Date</label>
                <input asp-for="SignOffDate"
                       type="date"
                       class="form-control" />
            </div>

        </div>

        <div class="mt-4 mb-5">


            <button type="submit" class="btn btn-primary">
                Update Exit Interview
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}