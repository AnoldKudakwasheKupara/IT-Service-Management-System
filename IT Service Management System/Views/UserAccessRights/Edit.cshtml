<script>
    document.addEventListener('DOMContentLoaded', function() {
        // ===== Update User Count =====
        function updateUserCount() {
            const rowCount = document.querySelectorAll('#usersTable tbody tr').length;
            const badge = document.getElementById('userCount');
            if (badge) badge.textContent = rowCount;
        }

        // ===== Add Row =====
        document.getElementById('addRow')?.addEventListener('click', function() {
            const table = document.getElementById('usersTable');
            const tbody = table.querySelector('tbody');
            const rows = tbody.querySelectorAll('tr');
            const newIndex = rows.length;

            const newRow = document.createElement('tr');
            newRow.innerHTML = `
                <td>
                    <input name="Users[${newIndex}].UserName" class="form-control-modern-sm" placeholder="Username" />
                    <input type="hidden" name="Users[${newIndex}].Id" value="0" />
                    <span class="validation-message text-danger"></span>
                </td>
                <td class="text-center">
                    <input type="checkbox" name="Users[${newIndex}].UserManagement" class="checkbox-modern" value="true" />
                    <input type="hidden" name="Users[${newIndex}].UserManagement" value="false" />
                </td>
                <td class="text-center">
                    <input type="checkbox" name="Users[${newIndex}].Initiate" class="checkbox-modern" value="true" />
                    <input type="hidden" name="Users[${newIndex}].Initiate" value="false" />
                </td>
                <td class="text-center">
                    <input type="checkbox" name="Users[${newIndex}].Confirmation" class="checkbox-modern" value="true" />
                    <input type="hidden" name="Users[${newIndex}].Confirmation" value="false" />
                </td>
                <td class="text-center">
                    <input type="checkbox" name="Users[${newIndex}].Approval" class="checkbox-modern" value="true" />
                    <input type="hidden" name="Users[${newIndex}].Approval" value="false" />
                </td>
                <td class="text-center">
                    <input type="checkbox" name="Users[${newIndex}].AccountManagement" class="checkbox-modern" value="true" />
                    <input type="hidden" name="Users[${newIndex}].AccountManagement" value="false" />
                </td>
                <td class="text-center">
                    <input type="checkbox" name="Users[${newIndex}].Reports" class="checkbox-modern" value="true" />
                    <input type="hidden" name="Users[${newIndex}].Reports" value="false" />
                </td>
                <td class="text-center">
                    <button type="button" class="btn-remove-row" title="Remove user">
                        <i class="fas fa-times"></i>
                    </button>
                </td>
            `;

            tbody.appendChild(newRow);
            updateUserCount();

            // Attach remove handler
            newRow.querySelector('.btn-remove-row').addEventListener('click', function() {
                if (tbody.querySelectorAll('tr').length > 1) {
                    newRow.remove();
                    updateUserCount();
                    reindexRows();
                } else {
                    showAlert('You need at least one user row.', 'warning');
                }
            });
        });

        // ===== Remove Row =====
        document.querySelectorAll('.btn-remove-row').forEach(btn => {
            btn.addEventListener('click', function() {
                const row = this.closest('tr');
                const tbody = row.closest('tbody');
                if (tbody.querySelectorAll('tr').length > 1) {
                    row.remove();
                    updateUserCount();
                    reindexRows();
                } else {
                    showAlert('You need at least one user row.', 'warning');
                }
            });
        });

        // ===== Re-index Rows =====
        function reindexRows() {
            const rows = document.querySelectorAll('#usersTable tbody tr');
            rows.forEach((row, index) => {
                const inputs = row.querySelectorAll('input, select');
                inputs.forEach(input => {
                    const name = input.getAttribute('name');
                    if (name) {
                        const newName = name.replace(/Users\[\d+\]/, `Users[${index}]`);
                        input.setAttribute('name', newName);
                    }
                });
            });
        }

        // ===== Form Submit =====
        const form = document.getElementById('editAccessRightsForm');
        const submitBtn = document.getElementById('submitBtn');

        if (form) {
            form.addEventListener('submit', function(e) {
                // Validate required fields
                const solution = document.querySelector('[name="SolutionSoftware"]');
                const serverId = document.querySelector('[name="ProductionServerId"]');
                const client = document.querySelector('[name="ClientName"]');
                const admin = document.querySelector('[name="SystemsAdmin"]');
                const date = document.querySelector('[name="Date"]');

                const requiredFields = [
                    { element: solution, name: 'Solution / Software' },
                    { element: serverId, name: 'Production Server ID' },
                    { element: client, name: 'Client Name' },
                    { element: admin, name: 'Systems Administrator' },
                    { element: date, name: 'Date' }
                ];

                for (let field of requiredFields) {
                    if (!field.element || !field.element.value.trim()) {
                        e.preventDefault();
                        if (field.element) field.element.focus();
                        showAlert(`Please enter ${field.name}`, 'error');
                        return false;
                    }
                }

                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';

                return true;
            });
        }

        // ===== Alert System =====
        function showAlert(message, type) {
            const existing = document.querySelector('.alert-toast');
            if (existing) existing.remove();

            const colors = {
                error: { bg: '#fee', border: '#e53e3e', text: '#c53030', icon: 'fa-exclamation-circle' },
                warning: { bg: '#fffbeb', border: '#f5b042', text: '#92400e', icon: 'fa-exclamation-triangle' },
                success: { bg: '#e6fffa', border: '#2c9e6e', text: '#1f6e4a', icon: 'fa-check-circle' }
            };

            const style = colors[type] || colors.error;

            const toast = document.createElement('div');
            toast.className = 'alert-toast';
            toast.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: ${style.bg};
                border-left: 4px solid ${style.border};
                border-radius: 0.75rem;
                padding: 1rem 1.25rem;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                color: ${style.text};
                font-weight: 500;
                z-index: 1050;
                animation: slideIn 0.3s ease;
                box-shadow: var(--shadow-lg);
                max-width: 400px;
            `;
            toast.innerHTML = `
                <i class="fas ${style.icon}"></i>
                <span>${message}</span>
                <button type="button" style="margin-left: auto; background: none; border: none; cursor: pointer; color: inherit;" onclick="this.parentElement.remove()">
                    <i class="fas fa-times"></i>
                </button>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        // Initialize count
        updateUserCount();
    });
</script>

