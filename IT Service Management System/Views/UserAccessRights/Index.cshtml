@model IEnumerable<IT_Service_Management_System.Models.UserAccessRight>

@{
    ViewData["Title"] = "User Access Rights";
}

<div class="container-fluid mt-3">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <div class="d-flex justify-content-between align-items-center">

                <h4 class="mb-0">
                    <i class="fas fa-user-shield"></i>
                    User Access Rights
                </h4>

                <a asp-action="Create" class="btn btn-light">
                    <i class="fas fa-plus-circle"></i>
                    New Access Form
                </a>

            </div>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover table-striped align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>Solution / Software</th>

                            <th>Production Server</th>

                            <th>Client</th>

                            <th>Version</th>

                            <th>Systems Admin</th>

                            <th>Date</th>

                            <th width="220">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.SolutionSoftware</td>

                                    <td>@item.ProductionServerId</td>

                                    <td>@item.ClientName</td>

                                    <td>@item.VersionReleaseNo</td>

                                    <td>@item.SystemsAdmin</td>

                                    <td>@item.Date.ToString("dd MMM yyyy")</td>

                                    <td>

                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-info btn-sm">

                                            <i class="fas fa-eye"></i>

                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-warning btn-sm">

                                            <i class="fas fa-edit"></i>

                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm">

                                            <i class="fas fa-trash"></i>

                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="7" class="text-center text-muted">

                                    No User Access Rights Forms Found.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>