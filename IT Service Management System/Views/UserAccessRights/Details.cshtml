@model IT_Service_Management_System.Models.UserAccessRight

@{
    ViewData["Title"] = "User Access Rights Details - Axis IT Helpdesk";
}

<div class="page-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-icon">
                <i class="fas fa-user-shield"></i>
            </div>
            <div>
                <h1 class="hero-title">Access Rights Details</h1>
                <p class="hero-subtitle">View complete access rights configuration</p>
            </div>
        </div>
        <div class="hero-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="hero-btn hero-btn-edit">
                <i class="fas fa-edit"></i>
                Edit
            </a>
            <a asp-action="Index" class="hero-btn hero-btn-back">
                <i class="fas fa-arrow-left"></i>
                Back
            </a>
        </div>
    </div>

    <!-- Details Card -->
    <div class="details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-info-circle me-2"></i>
                <span>Configuration Details</span>
                <span class="badge-status" id="statusBadge">
                    <i class="fas fa-check-circle"></i>
                    Active
                </span>
            </div>
            <div class="record-id">
                <i class="fas fa-hashtag"></i>
                Record #@Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- System Information Section -->
            <div class="section-header">
                <i class="fas fa-server"></i>
                System Information
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <label class="info-label">
                        <i class="fas fa-code"></i>
                        Solution / Software
                    </label>
                    <div class="info-value">
                        <span class="value-text">@Model.SolutionSoftware</span>
                    </div>
                </div>

                <div class="info-item">
                    <label class="info-label">
                        <i class="fas fa-server"></i>
                        Production Server ID
                    </label>
                    <div class="info-value">
                        <span class="value-text">@Model.ProductionServerId</span>
                    </div>
                </div>

                <div class="info-item">
                    <label class="info-label">
                        <i class="fas fa-user"></i>
                        Client Name
                    </label>
                    <div class="info-value">
                        <span class="value-text">@Model.ClientName</span>
                    </div>
                </div>

                <div class="info-item">
                    <label class="info-label">
                        <i class="fas fa-tag"></i>
                        Version / Release
                    </label>
                    <div class="info-value">
                        <span class="badge-version">@Model.VersionReleaseNo</span>
                    </div>
                </div>

                <div class="info-item">
                    <label class="info-label">
                        <i class="fas fa-user-cog"></i>
                        Systems Administrator
                    </label>
                    <div class="info-value">
                        <span class="value-text">@Model.SystemsAdmin</span>
                    </div>
                </div>

                <div class="info-item">
                    <label class="info-label">
                        <i class="far fa-calendar-alt"></i>
                        Date
                    </label>
                    <div class="info-value">
                        <span class="badge-date">
                            <i class="far fa-calendar-alt"></i>
                            @Model.Date.ToString("dd MMM yyyy")
                        </span>
                    </div>
                </div>
            </div>

            <hr class="section-divider" />

            <!-- User Access Rights Section -->
            <div class="section-header">
                <i class="fas fa-users-cog"></i>
                User Access Rights
                <span class="badge-count">@Model.Users.Count</span>
            </div>

            <div class="table-responsive">
                <table class="table-modern" id="usersTable">
                    <thead>
                        <tr>
                            <th class="user-col">User</th>
                            <th class="text-center">User Mgmt</th>
                            <th class="text-center">Initiate</th>
                            <th class="text-center">Confirm</th>
                            <th class="text-center">Approve</th>
                            <th class="text-center">Account</th>
                            <th class="text-center">Reports</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Users)
                        {
                            <tr>
                                <td>
                                    <div class="cell-content">
                                        <i class="fas fa-user-circle cell-icon"></i>
                                        <span>@item.UserName</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (item.UserManagement)
                                    {
                                        <span class="permission-badge granted">
                                            <i class="fas fa-check-circle"></i> Granted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="permission-badge denied">
                                            <i class="fas fa-times-circle"></i> Denied
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Initiate)
                                    {
                                        <span class="permission-badge granted">
                                            <i class="fas fa-check-circle"></i> Granted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="permission-badge denied">
                                            <i class="fas fa-times-circle"></i> Denied
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Confirmation)
                                    {
                                        <span class="permission-badge granted">
                                            <i class="fas fa-check-circle"></i> Granted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="permission-badge denied">
                                            <i class="fas fa-times-circle"></i> Denied
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Approval)
                                    {
                                        <span class="permission-badge granted">
                                            <i class="fas fa-check-circle"></i> Granted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="permission-badge denied">
                                            <i class="fas fa-times-circle"></i> Denied
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.AccountManagement)
                                    {
                                        <span class="permission-badge granted">
                                            <i class="fas fa-check-circle"></i> Granted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="permission-badge denied">
                                            <i class="fas fa-times-circle"></i> Denied
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Reports)
                                    {
                                        <span class="permission-badge granted">
                                            <i class="fas fa-check-circle"></i> Granted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="permission-badge denied">
                                            <i class="fas fa-times-circle"></i> Denied
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <hr class="section-divider" />

            <!-- Authorization Section -->
            <div class="section-header">
                <i class="fas fa-gavel"></i>
                Authorization
            </div>

            <div class="authorization-grid">
                <!-- Assigned -->
                <div class="auth-card auth-card-assigned">
                    <div class="auth-card-header">
                        <i class="fas fa-pen-fancy"></i>
                        Assigned By
                    </div>
                    <div class="auth-card-body">
                        <div class="auth-field">
                            <label>Name</label>
                            <div class="auth-value">
                                <i class="fas fa-user"></i>
                                <span>@Model.AssignedBy</span>
                            </div>
                        </div>
                        <div class="auth-field">
                            <label>Signature</label>
                            <div class="auth-value">
                                <i class="fas fa-signature"></i>
                                <span>@Model.AssignedSignature</span>
                            </div>
                        </div>
                        <div class="auth-field">
                            <label>Date</label>
                            <div class="auth-value">
                                <i class="far fa-calendar-alt"></i>
                                <span>@(Model.AssignedDate?.ToString("dd MMM yyyy") ?? "Not assigned")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reviewed -->
                <div class="auth-card auth-card-reviewed">
                    <div class="auth-card-header">
                        <i class="fas fa-search"></i>
                        Reviewed By
                    </div>
                    <div class="auth-card-body">
                        <div class="auth-field">
                            <label>Name</label>
                            <div class="auth-value">
                                <i class="fas fa-user"></i>
                                <span>@Model.ReviewedBy</span>
                            </div>
                        </div>
                        <div class="auth-field">
                            <label>Signature</label>
                            <div class="auth-value">
                                <i class="fas fa-signature"></i>
                                <span>@Model.ReviewedSignature</span>
                            </div>
                        </div>
                        <div class="auth-field">
                            <label>Date</label>
                            <div class="auth-value">
                                <i class="far fa-calendar-alt"></i>
                                <span>@(Model.ReviewedDate?.ToString("dd MMM yyyy") ?? "Not reviewed")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Approved -->
                <div class="auth-card auth-card-approved">
                    <div class="auth-card-header">
                        <i class="fas fa-check-circle"></i>
                        Approved By
                    </div>
                    <div class="auth-card-body">
                        <div class="auth-field">
                            <label>Name</label>
                            <div class="auth-value">
                                <i class="fas fa-user"></i>
                                <span>@Model.ApprovedBy</span>
                            </div>
                        </div>
                        <div class="auth-field">
                            <label>Signature</label>
                            <div class="auth-value">
                                <i class="fas fa-signature"></i>
                                <span>@Model.ApprovedSignature</span>
                            </div>
                        </div>
                        <div class="auth-field">
                            <label>Date</label>
                            <div class="auth-value">
                                <i class="far fa-calendar-alt"></i>
                                <span>@(Model.ApprovedDate?.ToString("dd MMM yyyy") ?? "Not approved")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit-main">
                    <i class="fas fa-edit"></i>
                    Edit Access Rights
                </a>
                <a asp-action="Index" class="btn-cancel-main">
                    <i class="fas fa-arrow-left"></i>
                    Back to List
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* ===== Base Variables ===== */
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --success-dark: #1f8a5c;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    /* ===== Page Container ===== */
    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    /* ===== Hero Section ===== */
    .hero-section {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        border-radius: 1.5rem;
        padding: 2rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        box-shadow: var(--shadow-lg);
    }

    .hero-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hero-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
    }

    .hero-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.25rem 0;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .hero-btn {
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }

    .hero-btn-edit {
        background: white;
        color: var(--warning);
    }

        .hero-btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: var(--warning);
            text-decoration: none;
        }

    .hero-btn-back {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

        .hero-btn-back:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    /* ===== Main Card ===== */
    .details-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .badge-status {
        background: var(--success);
        color: white;
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        border-radius: 1rem;
        font-weight: 500;
        margin-left: 0.5rem;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .badge-status i {
            font-size: 0.65rem;
        }

    .record-id {
        font-size: 0.8rem;
        color: var(--gray-500);
        background: white;
        padding: 0.2rem 0.8rem;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
    }

        .record-id i {
            color: var(--primary-light);
            margin-right: 0.3rem;
        }

    .card-body-custom {
        padding: 2rem;
    }

    /* ===== Sections ===== */
    .section-header {
        font-weight: 700;
        font-size: 1rem;
        color: var(--gray-700);
        margin: 1.5rem 0 1.25rem 0;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--gray-200);
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

        .section-header i {
            color: var(--primary);
            font-size: 1.1rem;
        }

    .badge-count {
        background: var(--primary);
        color: white;
        font-size: 0.7rem;
        padding: 0.1rem 0.6rem;
        border-radius: 1rem;
        font-weight: 600;
        margin-left: 0.5rem;
    }

    .section-divider {
        border: 0;
        border-top: 2px dashed var(--gray-200);
        margin: 2rem 0;
    }

    /* ===== Info Grid ===== */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    @@media (max-width: 992px) {
        .info-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }
    }

    @@media (max-width: 576px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }

    .info-item {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .info-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--gray-500);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

        .info-label i {
            color: var(--primary-light);
            font-size: 0.7rem;
        }

    .info-value {
        padding: 0.6rem 0.8rem;
        background: var(--gray-50);
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
        min-height: 42px;
        display: flex;
        align-items: center;
    }

    .value-text {
        font-size: 0.9rem;
        color: var(--gray-700);
        font-weight: 500;
    }

    .badge-version {
        background: var(--gray-200);
        color: var(--gray-700);
        padding: 0.2rem 0.6rem;
        border-radius: 0.25rem;
        font-size: 0.8rem;
        font-weight: 600;
        font-family: monospace;
        border: 1px solid var(--gray-300);
    }

    .badge-date {
        background: white;
        padding: 0.2rem 0.6rem;
        border-radius: 0.25rem;
        font-size: 0.8rem;
        color: var(--gray-600);
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        border: 1px solid var(--gray-200);
    }

        .badge-date i {
            font-size: 0.7rem;
            color: var(--gray-400);
        }

    /* ===== Table Styles ===== */
    .table-responsive {
        overflow-x: auto;
    }

    .table-modern {
        width: 100%;
        border-collapse: collapse;
        border-radius: 0.75rem;
        overflow: hidden;
        border: 1px solid var(--gray-200);
        min-width: 700px;
    }

        .table-modern thead {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            color: white;
        }

            .table-modern thead th {
                padding: 0.6rem 0.5rem;
                font-size: 0.7rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.3px;
                border: none;
                text-align: center;
                vertical-align: middle;
                white-space: nowrap;
            }

                .table-modern thead th.user-col {
                    text-align: left;
                }

        .table-modern tbody td {
            padding: 0.6rem 0.5rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--gray-200);
            background: white;
        }

        .table-modern tbody tr:hover td {
            background-color: var(--gray-50);
        }

        .table-modern tbody tr:last-child td {
            border-bottom: none;
        }

    .cell-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .cell-icon {
        color: var(--primary-light);
        font-size: 1.1rem;
        width: 20px;
        text-align: center;
    }

    /* ===== Permission Badges ===== */
    .permission-badge {
        padding: 0.2rem 0.6rem;
        border-radius: 0.25rem;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .permission-badge.granted {
            background: #e6fffa;
            color: var(--success);
            border: 1px solid var(--success);
        }

        .permission-badge.denied {
            background: #fee;
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        .permission-badge i {
            font-size: 0.65rem;
        }

    /* ===== Authorization Cards ===== */
    .authorization-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-top: 0.5rem;
    }

    @@media (max-width: 992px) {
        .authorization-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 576px) {
        .authorization-grid {
            grid-template-columns: 1fr;
        }
    }

    .auth-card {
        border: 1px solid var(--gray-200);
        border-radius: 0.75rem;
        overflow: hidden;
        background: white;
        transition: box-shadow 0.2s ease;
    }

        .auth-card:hover {
            box-shadow: var(--shadow-sm);
        }

    .auth-card-assigned .auth-card-header {
        background: var(--primary);
        color: white;
    }

    .auth-card-reviewed .auth-card-header {
        background: var(--warning);
        color: white;
    }

    .auth-card-approved .auth-card-header {
        background: var(--success);
        color: white;
    }

    .auth-card-header {
        padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .auth-card-body {
        padding: 1rem;
    }

    .auth-field {
        margin-bottom: 0.75rem;
    }

        .auth-field:last-child {
            margin-bottom: 0;
        }

        .auth-field label {
            font-size: 0.7rem;
            font-weight: 500;
            color: var(--gray-500);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 0.2rem;
            display: block;
        }

    .auth-value {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.6rem;
        background: var(--gray-50);
        border-radius: 0.4rem;
        font-size: 0.85rem;
        color: var(--gray-700);
        border: 1px solid var(--gray-200);
    }

        .auth-value i {
            color: var(--gray-400);
            font-size: 0.8rem;
            width: 16px;
        }

    /* ===== Form Actions ===== */
    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-edit-main {
        background: linear-gradient(100deg, var(--warning), #e6a020);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-edit-main:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    .btn-cancel-main {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
