@model IT_Service_Management_System.Models.User

@{
    ViewData["Title"] = "Add User - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-user-plus me-2" style="color: var(--success);"></i>
                    Add New User
                </h1>
                <p class="text-muted mt-2">Create a new user account for the helpdesk system</p>
            </div>
        </div>
    </div>

    <div class="add-user-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-user-circle me-2"></i>
                <span>User Information</span>
            </div>
        </div>

        <form asp-action="Create" method="post" id="createUserForm">
            @Html.AntiForgeryToken()
            
            <div class="card-body-custom">
                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="FirstName" class="form-label">
                                <i class="fas fa-user"></i>
                                First Name
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-user input-icon"></i>
                                <input asp-for="FirstName" class="form-control-modern" placeholder="Enter first name" autocomplete="off" />
                            </div>
                            <span asp-validation-for="FirstName" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> User's given name
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="LastName" class="form-label">
                                <i class="fas fa-user-tag"></i>
                                Last Name
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-user input-icon"></i>
                                <input asp-for="LastName" class="form-control-modern" placeholder="Enter last name" autocomplete="off" />
                            </div>
                            <span asp-validation-for="LastName" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> User's family name
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Email" class="form-label">
                                <i class="fas fa-envelope"></i>
                                Email Address
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-at input-icon"></i>
                                <input asp-for="Email" class="form-control-modern" placeholder="name@company.com" type="email" autocomplete="off" />
                            </div>
                            <span asp-validation-for="Email" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> User will use this email to login
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="PasswordHash" class="form-label">
                                <i class="fas fa-lock"></i>
                                Password
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-key input-icon"></i>
                                <input asp-for="PasswordHash" type="password" class="form-control-modern" placeholder="Enter password" autocomplete="off" />
                                <button type="button" class="password-toggle" id="togglePassword">
                                    <i class="far fa-eye-slash"></i>
                                </button>
                            </div>
                            <span asp-validation-for="PasswordHash" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Password must be at least 8 characters
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label class="form-label">
                                <i class="fas fa-check-circle"></i>
                                Confirm Password
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-redo-alt input-icon"></i>
                                <input type="password" id="confirmPassword" class="form-control-modern" placeholder="Confirm password" />
                                <button type="button" class="password-toggle" id="toggleConfirmPassword">
                                    <i class="far fa-eye-slash"></i>
                                </button>
                            </div>
                            <div id="passwordMatchError" class="validation-message text-danger" style="display: none;">
                                <i class="fas fa-times-circle"></i> Passwords do not match
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Role" class="form-label">
                                <i class="fas fa-tag"></i>
                                User Role
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="Role" class="form-control-modern" id="roleSelect">
                                    <option value="">Select a role</option>
                                    @foreach (var role in Enum.GetValues(typeof(IT_Service_Management_System.Models.Ticket.UserRole)))
                                    {
                                        var roleValue = role.ToString();
                                        <option value="@roleValue">
                                            @roleValue
                                        </option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="Role" class="validation-message text-danger"></span>
                            <div class="role-info" id="roleInfo" style="display: none;">
                                <i class="fas fa-shield-alt"></i>
                                <span id="roleDescription"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-create" id="submitBtn">
                        <i class="fas fa-save"></i>
                        Create User Account
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Add User Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Add User Card */
    .add-user-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label i {
        color: var(--primary);
        font-size: 0.875rem;
    }

    .required {
        color: var(--danger);
        font-size: 1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .input-icon-wrapper i.input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

    .form-control-modern:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    /* Password Toggle */
    .password-toggle {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--gray-400);
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .password-toggle:hover {
        color: var(--primary);
    }

    /* Select Styling */
    .select-wrapper {
        position: relative;
    }

    .select-wrapper select {
        appearance: none;
        cursor: pointer;
        background: white;
    }

    .select-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        pointer-events: none;
        font-size: 0.75rem;
    }

    /* Role Info */
    .role-info {
        background: var(--gray-50);
        padding: 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-left: 3px solid var(--primary);
    }

    .role-info i {
        color: var(--primary);
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-hint i {
        font-size: 0.7rem;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-create {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-cancel:hover {
        background: var(--gray-50);
        color: var(--gray-700);
        text-decoration: none;
    }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Password visibility toggles
        const passwordInput = document.querySelector('[asp-for="PasswordHash"]');
        const confirmPasswordInput = document.getElementById('confirmPassword');
        const togglePassword = document.getElementById('togglePassword');
        const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');
        const passwordMatchError = document.getElementById('passwordMatchError');
        
        // Get the actual password input
        const actualPasswordInput = document.querySelector('input[name="PasswordHash"]');
        
        // Password visibility toggle for main password
        if (togglePassword && actualPasswordInput) {
            togglePassword.addEventListener('click', function() {
                const type = actualPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                actualPasswordInput.setAttribute('type', type);
                
                const icon = this.querySelector('i');
                if (type === 'text') {
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                } else {
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                }
            });
        }
        
        // Password visibility toggle for confirm password
        if (toggleConfirmPassword && confirmPasswordInput) {
            toggleConfirmPassword.addEventListener('click', function() {
                const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                confirmPasswordInput.setAttribute('type', type);
                
                const icon = this.querySelector('i');
                if (type === 'text') {
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                } else {
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                }
            });
        }
        
        // Password match validation
        function checkPasswordMatch() {
            if (actualPasswordInput && confirmPasswordInput) {
                const password = actualPasswordInput.value;
                const confirmPassword = confirmPasswordInput.value;
                
                if (confirmPassword.length > 0 && password !== confirmPassword) {
                    passwordMatchError.style.display = 'flex';
                    return false;
                } else {
                    passwordMatchError.style.display = 'none';
                    return true;
                }
            }
            return true;
        }
        
        if (confirmPasswordInput) {
            confirmPasswordInput.addEventListener('input', checkPasswordMatch);
        }
        
        if (actualPasswordInput) {
            actualPasswordInput.addEventListener('input', function() {
                if (confirmPasswordInput && confirmPasswordInput.value.length > 0) {
                    checkPasswordMatch();
                }
            });
        }
        
        // Role description
        const roleSelect = document.getElementById('roleSelect');
        const roleInfo = document.getElementById('roleInfo');
        const roleDescription = document.getElementById('roleDescription');
        
        var roleDescriptions = {
            'Admin': 'Full system access. Can manage users, tickets, and system settings.',
            'User': 'Standard user access. Can create and manage their own tickets.',
            'Guest': 'Limited access. Can only view assigned tickets.'
        };
        
        function updateRoleDescription() {
            var selectedRole = roleSelect.value;
            if (selectedRole && roleDescriptions[selectedRole]) {
                roleDescription.textContent = roleDescriptions[selectedRole];
                roleInfo.style.display = 'flex';
            } else if (selectedRole) {
                roleDescription.textContent = 'Custom role with specific permissions';
                roleInfo.style.display = 'flex';
            } else {
                roleInfo.style.display = 'none';
            }
        }
        
        if (roleSelect) {
            roleSelect.addEventListener('change', updateRoleDescription);
            // Initialize role description if a role is pre-selected
            updateRoleDescription();
        }
        
        // Form validation
        const form = document.getElementById('createUserForm');
        const submitBtn = document.getElementById('submitBtn');
        
        if (form) {
            form.addEventListener('submit', function(e) {
                var firstName = document.querySelector('[name="FirstName"]').value.trim();
                var lastName = document.querySelector('[name="LastName"]').value.trim();
                var email = document.querySelector('[name="Email"]').value.trim();
                var password = actualPasswordInput ? actualPasswordInput.value : '';
                var confirmPassword = confirmPasswordInput ? confirmPasswordInput.value : '';
                var role = roleSelect ? roleSelect.value : '';
                
                if (!firstName) {
                    e.preventDefault();
                    showValidationError('First Name is required');
                    document.querySelector('[name="FirstName"]').focus();
                    return false;
                }
                
                if (!lastName) {
                    e.preventDefault();
                    showValidationError('Last Name is required');
                    document.querySelector('[name="LastName"]').focus();
                    return false;
                }
                
                if (!email) {
                    e.preventDefault();
                    showValidationError('Email is required');
                    document.querySelector('[name="Email"]').focus();
                    return false;
                }
                
                // Email format validation
                var emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                if (!emailRegex.test(email)) {
                    e.preventDefault();
                    showValidationError('Please enter a valid email address');
                    document.querySelector('[name="Email"]').focus();
                    return false;
                }
                
                if (!password) {
                    e.preventDefault();
                    showValidationError('Password is required');
                    actualPasswordInput.focus();
                    return false;
                }
                
                if (password.length < 8) {
                    e.preventDefault();
                    showValidationError('Password must be at least 8 characters');
                    actualPasswordInput.focus();
                    return false;
                }
                
                if (!confirmPassword) {
                    e.preventDefault();
                    showValidationError('Please confirm your password');
                    confirmPasswordInput.focus();
                    return false;
                }
                
                if (password !== confirmPassword) {
                    e.preventDefault();
                    showValidationError('Passwords do not match');
                    confirmPasswordInput.focus();
                    return false;
                }
                
                if (!role) {
                    e.preventDefault();
                    showValidationError('Please select a user role');
                    roleSelect.focus();
                    return false;
                }
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating Account...';
                
                return true;
            });
        }
        
        function showValidationError(message) {
            var errorDiv = document.querySelector('.validation-toast');
            if (errorDiv) errorDiv.remove();
            
            errorDiv = document.createElement('div');
            errorDiv.className = 'validation-toast';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
                animation: slideIn 0.3s ease;
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(errorDiv);
            
            setTimeout(function() {
                errorDiv.style.animation = 'slideOut 0.3s ease';
                setTimeout(function() { errorDiv.remove(); }, 300);
            }, 4000);
        }
    });
</script>

<style>
    /* Additional animations */
    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }
        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}