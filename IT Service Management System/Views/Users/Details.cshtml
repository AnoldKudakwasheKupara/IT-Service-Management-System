@model IT_Service_Management_System.Models.User

@{
    ViewData["Title"] = "User Details - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-user-circle me-2" style="color: var(--primary);"></i>
                    User Details
                </h1>
                <p class="text-muted mt-2">View and manage user information</p>
            </div>
        </div>
    </div>

    <div class="user-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-id-card me-2"></i>
                <span>User Information</span>
            </div>
            <div class="user-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- User Profile Header -->
            <div class="user-profile-header">
                <div class="user-avatar-large">
                    @((Model.FirstName?.Substring(0, 1) ?? "U") + (Model.LastName?.Substring(0, 1) ?? "S"))
                </div>
                <div class="user-header-info">
                    <h2 class="user-fullname">@Model.FirstName @Model.LastName</h2>
                    <div class="user-meta">
                        <span class="user-role-badge @(Model.Role.ToString().ToLower())">
                            <i class="fas @(Model.Role.ToString() == "Admin" ? "fa-shield-alt" : "fa-user")"></i>
                            @Model.Role
                        </span>
                        <span class="user-status active">
                            <i class="fas fa-circle"></i>
                            Active
                        </span>
                    </div>
                </div>
            </div>

            <!-- Details Grid -->
            <div class="details-grid">
                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div class="detail-content">
                        <label>Email Address</label>
                        <p>@Model.Email</p>
                        <a href="mailto:@Model.Email" class="detail-action">
                            <i class="fas fa-paper-plane"></i> Send email
                        </a>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="detail-content">
                        <label>Member Since</label>
                        <p>@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                        <span class="detail-sub">@GetTimeAgo(Model.CreatedAt)</span>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-tag"></i>
                    </div>
                    <div class="detail-content">
                        <label>User Role</label>
                        <p>@Model.Role</p>
                        <span class="detail-sub">@GetRoleDescription(Model.Role.ToString())</span>
                    </div>
                </div>
            </div>

            <!-- Additional Information Section -->
            <div class="additional-info">
                <h3 class="section-title">
                    <i class="fas fa-info-circle"></i>
                    Additional Information
                </h3>
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">User ID:</span>
                        <span class="info-value">@Model.Id</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Full Name:</span>
                        <span class="info-value">@Model.FirstName @Model.LastName</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Role Type:</span>
                        <span class="info-value">@(Model.Role.ToString() == "Admin" ? "Administrator" : "Standard User")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Account Status:</span>
                        <span class="info-value status-active">
                            <i class="fas fa-check-circle"></i> Active
                        </span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons-container">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">
                    <i class="fas fa-pencil-alt"></i>
                    Edit User
                </a>
                <a asp-action="Index" class="btn-back-to-list">
                    <i class="fas fa-arrow-left"></i>
                    Back to List
                </a>
                <button type="button" class="btn-reset-password" onclick="showResetPasswordModal(@Model.Id)">
                    <i class="fas fa-key"></i>
                    Reset Password
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-labelledby="resetPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content-modern">
            <div class="modal-header-modern">
                <h5 class="modal-title">
                    <i class="fas fa-key"></i>
                    Reset Password
                </h5>
                <button type="button" class="btn-close-modern" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body-modern">
                <p>Are you sure you want to reset the password for <strong>@Model.FirstName @Model.LastName</strong>?</p>
                <p class="text-muted small">A password reset link will be sent to their email address.</p>
                <form id="resetPasswordForm" asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                </form>
            </div>
            <div class="modal-footer-modern">
                <button type="button" class="btn-cancel-modal" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="resetPasswordForm" class="btn-confirm-modal">
                    <i class="fas fa-paper-plane"></i>
                    Send Reset Link
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* User Details Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
        }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* User Details Card */
    .user-details-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .user-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* User Profile Header */
    .user-profile-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid var(--gray-100);
    }

    .user-avatar-large {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 2rem;
        flex-shrink: 0;
    }

    .user-header-info {
        flex: 1;
    }

    .user-fullname {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 0.5rem 0;
    }

    .user-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .user-role-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

        .user-role-badge.admin {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .user-role-badge.user {
            background: var(--gray-100);
            color: var(--gray-700);
            border: 1px solid var(--gray-300);
        }

    .user-status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        color: var(--success);
    }

        .user-status i {
            font-size: 0.5rem;
        }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .detail-card {
        background: var(--gray-50);
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        gap: 1rem;
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

        .detail-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            background: white;
        }

    .detail-icon {
        width: 48px;
        height: 48px;
        background: white;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.25rem;
        flex-shrink: 0;
        border: 1px solid var(--gray-200);
    }

    .detail-content {
        flex: 1;
    }

        .detail-content label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray-500);
            font-weight: 600;
            display: block;
            margin-bottom: 0.25rem;
        }

        .detail-content p {
            font-size: 1rem;
            font-weight: 600;
            color: var(--gray-800);
            margin: 0 0 0.5rem 0;
        }

    .detail-action {
        font-size: 0.75rem;
        color: var(--primary);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

        .detail-action:hover {
            text-decoration: underline;
        }

    .detail-sub {
        font-size: 0.7rem;
        color: var(--gray-500);
    }

    /* Additional Information */
    .additional-info {
        margin-bottom: 2rem;
        padding-top: 1rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-grid {
        background: var(--gray-50);
        border-radius: 0.75rem;
        padding: 1rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem;
        background: white;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
    }

    .info-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

    .info-value {
        font-size: 0.875rem;
        color: var(--gray-700);
        font-weight: 500;
    }

        .info-value.status-active {
            color: var(--success);
        }

            .info-value.status-active i {
                font-size: 0.75rem;
            }

    /* Action Buttons */
    .action-buttons-container {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
        flex-wrap: wrap;
    }

    .btn-edit {
        background: linear-gradient(100deg, var(--warning), #e6a017);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
    }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    .btn-back-to-list {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
    }

        .btn-back-to-list:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

    .btn-reset-password {
        background: white;
        color: var(--info);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--info);
        font-size: 0.875rem;
        cursor: pointer;
        background: none;
    }

        .btn-reset-password:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

    /* Modal Styles */
    .modal-content-modern {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        border: none;
    }

    .modal-header-modern {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header-modern .modal-title {
            font-weight: 600;
            color: var(--gray-800);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .btn-close-modern {
        background: none;
        border: none;
        color: var(--gray-500);
        cursor: pointer;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .btn-close-modern:hover {
            color: var(--danger);
        }

    .modal-body-modern {
        padding: 1.5rem;
    }

    .modal-footer-modern {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
    }

    .btn-cancel-modal {
        background: white;
        color: var(--gray-600);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-300);
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-cancel-modal:hover {
            background: var(--gray-50);
        }

    .btn-confirm-modal {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

        .btn-confirm-modal:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow-sm);
        }
</style>

<script>
function showResetPasswordModal(userId) {
    const modal = new bootstrap.Modal(document.getElementById('resetPasswordModal'));
    modal.show();
}

@functions {
        string GetTimeAgo(DateTime date)
        {
                var timeSpan = DateTime.Now - date;
                if (timeSpan.TotalDays > 365)
                        return $"{(int)(timeSpan.TotalDays / 365)} year(s) ago";
                if (timeSpan.TotalDays > 30)
                        return $"{(int)(timeSpan.TotalDays / 30)} month(s) ago";
                if (timeSpan.TotalDays > 7)
                        return $"{(int)(timeSpan.TotalDays / 7)} week(s) ago";
                if (timeSpan.TotalDays > 1)
                        return $"{(int)timeSpan.TotalDays} day(s) ago";
                if (timeSpan.TotalHours > 1)
                        return $"{(int)timeSpan.TotalHours} hour(s) ago";
                if (timeSpan.TotalMinutes > 1)
                        return $"{(int)timeSpan.TotalMinutes} minute(s) ago";
                return "Just now";
        }

        string GetRoleDescription(string role)
        {
                return role == "Admin" ? "Full system access" : "Standard user permissions";
        }
}
</script>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
}