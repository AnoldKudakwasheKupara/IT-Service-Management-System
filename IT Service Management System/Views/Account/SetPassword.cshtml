@{
    Layout = null;
    ViewData["Title"] = "Set Password - Axis IT Helpdesk";
    var token = Context.Request.Query["token"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Axis IT Helpdesk | Set Password</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
            /* Modern Set Password Page Styles */
            :root {
                --primary-dark: #1e4c6b;
                --primary: #2c7da0;
                --primary-light: #61a5c2;
                --success: #2c9e6e;
                --success-dark: #227a55;
                --danger: #e53e3e;
                --secondary: #2c3e4e;
                --gray-light: #f8fafc;
                --gray-border: #e2e8f0;
            }

            /* Full height container */
            .set-password-container {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, #0f2b3d 0%, #1b4f6e 50%, #208aae 100%);
                padding: 1.5rem;
                position: relative;
            }

            /* Animated background blobs */
            .bg-blob {
                position: fixed;
                width: 40vw;
                height: 40vw;
                background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 70%);
                border-radius: 50%;
                z-index: 0;
                pointer-events: none;
            }
        
            .blob-1 {
                top: -15vw;
                left: -10vw;
                animation: floatBlob 22s infinite ease-in-out;
            }
        
            .blob-2 {
                bottom: -20vw;
                right: -5vw;
                width: 55vw;
                height: 55vw;
                background: radial-gradient(circle, rgba(255,215,150,0.1) 0%, rgba(255,215,150,0) 70%);
                animation: floatBlob 28s infinite reverse;
            }

            /* Main Card */
            .password-card {
                background: rgba(255, 255, 255, 0.98);
                border-radius: 1.5rem;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
                overflow: hidden;
                width: 100%;
                max-width: 460px;
                z-index: 2;
                transition: transform 0.25s ease, box-shadow 0.3s;
            }

                .password-card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 30px 55px -12px rgba(0, 0, 0, 0.4);
                }

            /* Card Header */
            .password-header {
                background: linear-gradient(115deg, var(--primary-dark) 0%, var(--primary) 100%);
                padding: 2rem 1.5rem;
                text-align: center;
                border-bottom: 1px solid rgba(255,255,255,0.2);
            }

            .brand-icon {
                font-size: 3rem;
                color: white;
                background: rgba(255,255,255,0.15);
                width: 70px;
                height: 70px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 1.2rem;
                margin-bottom: 1rem;
            }

            .password-header h2 {
                font-weight: 700;
                font-size: 1.8rem;
                color: white;
                margin: 0;
                letter-spacing: -0.3px;
            }

            .password-subtitle {
                color: rgba(255,255,255,0.85);
                font-size: 0.85rem;
                margin-top: 0.5rem;
            }

            /* Card Body */
            .password-body {
                padding: 2rem;
                background: white;
            }

            /* Form Groups */
            .form-group-modern {
                margin-bottom: 1.5rem;
            }

                .form-group-modern label {
                    font-weight: 600;
                    font-size: 0.85rem;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    color: var(--secondary);
                    margin-bottom: 0.5rem;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                }

                    .form-group-modern label i {
                        color: var(--primary);
                        font-size: 0.9rem;
                    }

            .input-icon-wrapper {
                position: relative;
            }

                .input-icon-wrapper i.input-icon {
                    position: absolute;
                    left: 1rem;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: 1rem;
                    pointer-events: none;
                    z-index: 1;
                }

                .input-icon-wrapper input {
                    width: 100%;
                    padding: 0.8rem 1rem 0.8rem 2.5rem;
                    font-size: 0.95rem;
                    border: 1.5px solid var(--gray-border);
                    border-radius: 0.75rem;
                    transition: all 0.2s ease;
                    font-family: 'Inter', sans-serif;
                }

                    .input-icon-wrapper input:focus {
                        outline: none;
                        border-color: var(--primary);
                        box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
                    }

            /* Password Strength Indicator */
            .password-strength {
                margin-top: 0.5rem;
                font-size: 0.75rem;
            }

            .strength-bar {
                height: 4px;
                background: #e2e8f0;
                border-radius: 2px;
                margin-top: 0.5rem;
                overflow: hidden;
            }

            .strength-bar-fill {
                height: 100%;
                width: 0%;
                transition: all 0.3s ease;
                border-radius: 2px;
            }

            .strength-text {
                font-size: 0.7rem;
                color: #64748b;
                margin-top: 0.25rem;
                display: inline-block;
            }

            /* Password Requirements */
            .password-requirements {
                background: var(--gray-light);
                border-radius: 0.75rem;
                padding: 0.75rem;
                margin-top: 0.75rem;
                font-size: 0.7rem;
            }

                .password-requirements p {
                    margin: 0 0 0.5rem 0;
                    font-weight: 600;
                    color: var(--secondary);
                }

                .password-requirements ul {
                    margin: 0;
                    padding-left: 1.25rem;
                }

                .password-requirements li {
                    color: #64748b;
                    margin-bottom: 0.25rem;
                }

                    .password-requirements li.valid {
                        color: var(--success);
                        text-decoration: line-through;
                        opacity: 0.7;
                    }

            /* Password Toggle */
            .password-toggle {
                position: absolute;
                right: 0.75rem;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                color: #94a3b8;
                cursor: pointer;
                padding: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 2;
            }

                .password-toggle:hover {
                    color: var(--primary);
                }

            /* Alert Styles */
            .alert-modern {
                border-radius: 0.75rem;
                border: none;
                padding: 0.85rem 1rem;
                margin-bottom: 1.5rem;
                font-size: 0.85rem;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }

                .alert-modern.alert-danger {
                    background: #fee;
                    border-left: 4px solid var(--danger);
                    color: #c53030;
                }

                .alert-modern.alert-success {
                    background: #e8f5e9;
                    border-left: 4px solid var(--success);
                    color: #1f6e4a;
                }

                .alert-modern i {
                    font-size: 1.1rem;
                }

            /* Set Password Button */
            .btn-set-password {
                background: linear-gradient(100deg, var(--success-dark), var(--success));
                border: none;
                padding: 0.85rem;
                font-weight: 600;
                font-size: 0.95rem;
                border-radius: 0.75rem;
                width: 100%;
                color: white;
                transition: all 0.25s;
                box-shadow: 0 4px 12px rgba(44, 158, 110, 0.25);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.75rem;
            }

                .btn-set-password:hover {
                    background: linear-gradient(100deg, #1a6345, #227a55);
                    transform: translateY(-1px);
                    box-shadow: 0 6px 16px rgba(44, 158, 110, 0.3);
                }

                .btn-set-password:active {
                    transform: translateY(0);
                }

            /* Back to Login Link */
            .back-to-login {
                text-align: center;
                margin-top: 1.25rem;
            }

                .back-to-login a {
                    color: var(--primary);
                    text-decoration: none;
                    font-size: 0.85rem;
                    font-weight: 500;
                    transition: color 0.2s;
                    display: inline-flex;
                    align-items: center;
                    gap: 0.5rem;
                }

                    .back-to-login a:hover {
                        color: var(--primary-dark);
                        text-decoration: underline;
                    }

            /* Footer Info */
            .password-footer {
                background: var(--gray-light);
                padding: 1rem;
                text-align: center;
                border-top: 1px solid var(--gray-border);
                font-size: 0.7rem;
                color: #5c6f87;
                display: flex;
                justify-content: center;
                gap: 1.5rem;
            }

                .password-footer span i {
                    margin-right: 0.25rem;
                    font-size: 0.7rem;
                }

            /* Responsive */
            @@media (max-width: 576px) {
                .password-body {
                    padding: 1.5rem;
                }
            
                .password-header {
                    padding: 1.5rem;
                }
            
                    .password-header h2 {
                        font-size: 1.5rem;
                    }
            
                .brand-icon {
                    width: 55px;
                    height: 55px;
                    font-size: 2.2rem;
                }
            }
    </style>
</head>
<body>
    <div class="set-password-container">
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>
        
        <div class="password-card">
            <div class="password-header">
                <div class="brand-icon">
                    <i class="fas fa-key"></i>
                </div>
                <h2>Set New Password</h2>
                <div class="password-subtitle">Create a secure password for your account</div>
            </div>
            
            <div class="password-body">
                <!-- Error Messages -->
                @if (ViewBag.Error != null)
                {
                    <div class="alert-modern alert-danger">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }
                
                <!-- Set Password Form -->
                <form method="post" id="setPasswordForm">
                    @Html.AntiForgeryToken()
                    
                    <!-- Hidden Token Field -->
                    <input type="hidden" name="token" value="@token" />
                    
                    <div class="form-group-modern">
                        <label for="password">
                            <i class="fas fa-lock"></i>
                            New Password
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-key input-icon"></i>
                            <input type="password"
                                   id="password"
                                   name="password"
                                   class="form-control"
                                   placeholder="Create a strong password"
                                   required
                                   autocomplete="new-password" />
                            <button type="button" class="password-toggle" id="togglePassword">
                                <i class="far fa-eye-slash"></i>
                            </button>
                        </div>
                        
                        <!-- Password Strength Indicator -->
                        <div class="password-strength" id="passwordStrength">
                            <div class="strength-bar">
                                <div class="strength-bar-fill" id="strengthBarFill"></div>
                            </div>
                            <span class="strength-text" id="strengthText"></span>
                        </div>
                        
                        <!-- Password Requirements -->
                        <div class="password-requirements">
                            <p><i class="fas fa-shield-alt"></i> Password Requirements:</p>
                            <ul id="passwordRequirements">
                                <li id="reqLength"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> At least 8 characters</li>
                                <li id="reqUpper"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> At least one uppercase letter</li>
                                <li id="reqLower"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> At least one lowercase letter</li>
                                <li id="reqNumber"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> At least one number</li>
                                <li id="reqSpecial"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> At least one special character (!@@#$%^&*)</li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="form-group-modern">
                        <label for="confirmPassword">
                            <i class="fas fa-check-circle"></i>
                            Confirm Password
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-redo-alt input-icon"></i>
                            <input type="password"
                                   id="confirmPassword"
                                   name="confirmPassword"
                                   class="form-control"
                                   placeholder="Confirm your new password"
                                   required
                                   autocomplete="new-password" />
                            <button type="button" class="password-toggle" id="toggleConfirmPassword">
                                <i class="far fa-eye-slash"></i>
                            </button>
                        </div>
                        <div id="passwordMatchError" class="text-danger" style="font-size: 0.75rem; margin-top: 0.25rem; display: none;">
                            <i class="fas fa-times-circle"></i> Passwords do not match
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-set-password" id="submitBtn">
                        <i class="fas fa-check-circle"></i>
                        Set Password
                    </button>
                    
                    <div class="back-to-login">
                        <a asp-controller="Account" asp-action="Login">
                            <i class="fas fa-arrow-left"></i>
                            Back to Login
                        </a>
                    </div>
                </form>
            </div>
            
            <div class="password-footer">
                <span><i class="fas fa-shield-alt"></i> Secure Encryption</span>
                <span><i class="fas fa-clock"></i> Link expires in 24h</span>
                <span><i class="fas fa-headset"></i> Need Help?</span>
            </div>
        </div>
    </div>
    
    <script>
            document.addEventListener('DOMContentLoaded', function() {
                const passwordInput = document.getElementById('password');
                const confirmPasswordInput = document.getElementById('confirmPassword');
                const togglePassword = document.getElementById('togglePassword');
                const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');
                const submitBtn = document.getElementById('submitBtn');
                const passwordMatchError = document.getElementById('passwordMatchError');
            
                // Password visibility toggle for main password field
                if (togglePassword && passwordInput) {
                    togglePassword.addEventListener('click', function() {
                        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                        passwordInput.setAttribute('type', type);
                    
                        const icon = this.querySelector('i');
                        if (type === 'text') {
                            icon.classList.remove('fa-eye-slash');
                            icon.classList.add('fa-eye');
                        } else {
                            icon.classList.remove('fa-eye');
                            icon.classList.add('fa-eye-slash');
                        }
                    });
                }
            
                // Password visibility toggle for confirm password field
                if (toggleConfirmPassword && confirmPasswordInput) {
                    toggleConfirmPassword.addEventListener('click', function() {
                        const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                        confirmPasswordInput.setAttribute('type', type);
                    
                        const icon = this.querySelector('i');
                        if (type === 'text') {
                            icon.classList.remove('fa-eye-slash');
                            icon.classList.add('fa-eye');
                        } else {
                            icon.classList.remove('fa-eye');
                            icon.classList.add('fa-eye-slash');
                        }
                    });
                }
            
                // Password strength checker
                function checkPasswordStrength(password) {
                    let strength = 0;
                    const requirements = {
                        length: password.length >= 8,
                        upper: /[A-Z]/.test(password),
                        lower: /[a-z]/.test(password),
                        number: /[0-9]/.test(password),
                        special: /[!@@#$%^&*(),.?":{}|<>]/.test(password)
                    };
                
                    // Update requirement indicators
                    document.getElementById('reqLength').style.color = requirements.length ? '#2c9e6e' : '#64748b';
                    document.getElementById('reqUpper').style.color = requirements.upper ? '#2c9e6e' : '#64748b';
                    document.getElementById('reqLower').style.color = requirements.lower ? '#2c9e6e' : '#64748b';
                    document.getElementById('reqNumber').style.color = requirements.number ? '#2c9e6e' : '#64748b';
                    document.getElementById('reqSpecial').style.color = requirements.special ? '#2c9e6e' : '#64748b';
                
                    // Calculate strength
                    if (requirements.length) strength++;
                    if (requirements.upper) strength++;
                    if (requirements.lower) strength++;
                    if (requirements.number) strength++;
                    if (requirements.special) strength++;
                
                    // Update strength bar and text
                    const strengthBar = document.getElementById('strengthBarFill');
                    const strengthText = document.getElementById('strengthText');
                
                    let width = (strength / 5) * 100;
                    let color = '';
                    let text = '';
                
                    if (strength === 0) {
                        color = '#e2e8f0';
                        text = 'No password';
                    } else if (strength <= 2) {
                        color = '#e53e3e';
                        text = 'Weak';
                    } else if (strength <= 3) {
                        color = '#f5b042';
                        text = 'Fair';
                    } else if (strength <= 4) {
                        color = '#2c7da0';
                        text = 'Good';
                    } else {
                        color = '#2c9e6e';
                        text = 'Strong';
                    }
                
                    strengthBar.style.width = width + '%';
                    strengthBar.style.backgroundColor = color;
                    strengthText.textContent = text;
                    strengthText.style.color = color;
                
                    return requirements;
                }
            
                // Check password match
                function checkPasswordMatch() {
                    const password = passwordInput.value;
                    const confirmPassword = confirmPasswordInput.value;
                
                    if (confirmPassword.length > 0 && password !== confirmPassword) {
                        passwordMatchError.style.display = 'block';
                        return false;
                    } else {
                        passwordMatchError.style.display = 'none';
                        return true;
                    }
                }
            
                // Real-time password validation
                if (passwordInput) {
                    passwordInput.addEventListener('input', function() {
                        checkPasswordStrength(this.value);
                        checkPasswordMatch();
                    });
                }
            
                if (confirmPasswordInput) {
                    confirmPasswordInput.addEventListener('input', function() {
                        checkPasswordMatch();
                    });
                }
            
                // Form submission validation
                const form = document.getElementById('setPasswordForm');
                if (form) {
                    form.addEventListener('submit', function(e) {
                        const password = passwordInput.value;
                        const confirmPassword = confirmPasswordInput.value;
                    
                        // Validate password strength
                        const requirements = checkPasswordStrength(password);
                        const isStrong = Object.values(requirements).every(req => req === true);
                    
                        if (!isStrong) {
                            e.preventDefault();
                            showAlert('Please ensure your password meets all requirements', 'danger');
                            passwordInput.focus();
                            return false;
                        }
                    
                        // Validate password match
                        if (password !== confirmPassword) {
                            e.preventDefault();
                            showAlert('Passwords do not match', 'danger');
                            confirmPasswordInput.focus();
                            return false;
                        }
                    
                        // Validate token
                        const token = document.querySelector('input[name="token"]').value;
                        if (!token) {
                            e.preventDefault();
                            showAlert('Invalid password reset token', 'danger');
                            return false;
                        }
                    
                        return true;
                    });
                }
            
                // Helper function to show alerts
                function showAlert(message, type) {
                    const existingAlert = document.querySelector('.alert-modern.dynamic-alert');
                    if (existingAlert) existingAlert.remove();
                
                    const alertDiv = document.createElement('div');
                    alertDiv.className = `alert-modern alert-${type} dynamic-alert`;
                    alertDiv.style.marginBottom = '1rem';
                
                    const icon = type === 'danger' ? 'fa-exclamation-circle' : 'fa-info-circle';
                    alertDiv.innerHTML = `
                        <i class="fas ${icon}"></i>
                        <span>${message}</span>
                    `;
                
                    const formContainer = document.querySelector('.password-body');
                    const formElement = formContainer.querySelector('form');
                    formContainer.insertBefore(alertDiv, formElement);
                
                    setTimeout(() => {
                        alertDiv.style.opacity = '0';
                        setTimeout(() => alertDiv.remove(), 300);
                    }, 5000);
                }
            
                // Initial password strength check (if any value pre-filled)
                if (passwordInput && passwordInput.value) {
                    checkPasswordStrength(passwordInput.value);
                }
            });
    </script>
</body>
</html>