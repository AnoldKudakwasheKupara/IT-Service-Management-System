@{
    Layout = null; // Optional: Set to null for full-page login, or remove to use your main layout
    ViewData["Title"] = "Login - Axis IT Helpdesk";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Axis IT Helpdesk | Login</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        /* Modern Login Page Styles - Layout Compatible */
        :root {
            --primary-dark: #1e4c6b;
            --primary: #2c7da0;
            --primary-light: #61a5c2;
            --secondary: #2c3e4e;
            --success: #2c9e6e;
            --danger: #e53e3e;
            --warning: #f5b042;
            --gray-light: #f8fafc;
            --gray-border: #e2e8f0;
        }

        /* Full height login container */
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0f2b3d 0%, #1b4f6e 50%, #208aae 100%);
            padding: 1.5rem;
            position: relative;
        }

        /* Animated background blobs */
        .bg-blob {
            position: fixed;
            width: 40vw;
            height: 40vw;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 70%);
            border-radius: 50%;
            z-index: 0;
            pointer-events: none;
        }
        
        .blob-1 {
            top: -15vw;
            left: -10vw;
            animation: floatBlob 22s infinite ease-in-out;
        }
        
        .blob-2 {
            bottom: -20vw;
            right: -5vw;
            width: 55vw;
            height: 55vw;
            background: radial-gradient(circle, rgba(255,215,150,0.1) 0%, rgba(255,215,150,0) 70%);
            animation: floatBlob 28s infinite reverse;
        }
      

        /* Login Card */
        .login-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 1.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
            overflow: hidden;
            width: 100%;
            max-width: 460px;
            z-index: 2;
            transition: transform 0.25s ease, box-shadow 0.3s;
        }

        .login-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 30px 55px -12px rgba(0, 0, 0, 0.4);
        }

        /* Card Header */
        .login-header {
            background: linear-gradient(115deg, var(--primary-dark) 0%, var(--primary) 100%);
            padding: 2rem 1.5rem;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.2);
        }

        .brand-icon {
            font-size: 3rem;
            color: white;
            background: rgba(255,255,255,0.15);
            width: 70px;
            height: 70px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 1.2rem;
            margin-bottom: 1rem;
        }

        .login-header h2 {
            font-weight: 700;
            font-size: 1.8rem;
            color: white;
            margin: 0;
            letter-spacing: -0.3px;
        }

        .login-subtitle {
            color: rgba(255,255,255,0.85);
            font-size: 0.85rem;
            margin-top: 0.5rem;
        }

        /* Card Body */
        .login-body {
            padding: 2rem;
            background: white;
        }

        /* Form Groups */
        .form-group-modern {
            margin-bottom: 1.5rem;
        }

        .form-group-modern label {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--secondary);
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-group-modern label i {
            color: var(--primary);
            font-size: 0.9rem;
        }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon-wrapper i.input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1rem;
            pointer-events: none;
        }

        .input-icon-wrapper input {
            width: 100%;
            padding: 0.8rem 1rem 0.8rem 2.5rem;
            font-size: 0.95rem;
            border: 1.5px solid var(--gray-border);
            border-radius: 0.75rem;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }

        .input-icon-wrapper input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
        }

        /* Password Toggle */
        .password-toggle {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2;
        }

        .password-toggle:hover {
            color: var(--primary);
        }

        /* Alert Styles */
        .alert-modern {
            border-radius: 0.75rem;
            border: none;
            padding: 0.85rem 1rem;
            margin-bottom: 1.5rem;
            font-size: 0.85rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-modern.alert-danger {
            background: #fee;
            border-left: 4px solid var(--danger);
            color: #c53030;
        }

        .alert-modern.alert-success {
            background: #e8f5e9;
            border-left: 4px solid var(--success);
            color: #1f6e4a;
        }

        .alert-modern i {
            font-size: 1.1rem;
        }

        /* Login Button */
        .btn-login {
            background: linear-gradient(100deg, var(--primary-dark), var(--primary));
            border: none;
            padding: 0.85rem;
            font-weight: 600;
            font-size: 0.95rem;
            border-radius: 0.75rem;
            width: 100%;
            color: white;
            transition: all 0.25s;
            box-shadow: 0 4px 12px rgba(28, 108, 138, 0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }

        .btn-login:hover {
            background: linear-gradient(100deg, #195e7a, #226f8f);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(28, 108, 138, 0.3);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        /* Forgot Password Link */
        .forgot-password {
            text-align: center;
            margin-top: 1.25rem;
        }

        .forgot-password a {
            color: var(--primary);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: color 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .forgot-password a:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        /* Footer Info */
        .login-footer {
            background: var(--gray-light);
            padding: 1rem;
            text-align: center;
            border-top: 1px solid var(--gray-border);
            font-size: 0.7rem;
            color: #5c6f87;
            display: flex;
            justify-content: center;
            gap: 1.5rem;
        }

        .login-footer span i {
            margin-right: 0.25rem;
            font-size: 0.7rem;
        }

        /* Responsive */
        @@media (max-width: 576px) {
            .login-body {
                padding: 1.5rem;
            }
            
            .login-header {
                padding: 1.5rem;
            }
            
            .login-header h2 {
                font-size: 1.5rem;
            }
            
            .brand-icon {
                width: 55px;
                height: 55px;
                font-size: 2.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>
        
        <div class="login-card">
            <div class="login-header">
                <div class="brand-icon">
                    <i class="fas fa-headset"></i>
                </div>
                <h2>Axis IT Helpdesk</h2>
                <div class="login-subtitle">Secure Access Portal</div>
            </div>
            
            <div class="login-body">
                <!-- Error Messages -->
                @if (ViewBag.Error != null)
                {
                    <div class="alert-modern alert-danger">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }
                
                @if (TempData["Success"] != null)
                {
                    <div class="alert-modern alert-success">
                        <i class="fas fa-check-circle"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }
                
                <!-- Login Form -->
                <form method="post" id="loginForm">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group-modern">
                        <label for="email">
                            <i class="fas fa-envelope"></i>
                            Email Address
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-at input-icon"></i>
                            <input type="email" 
                                   id="email" 
                                   name="email" 
                                   class="form-control" 
                                   placeholder="name@company.com" 
                                   required 
                                   autocomplete="email" />
                        </div>
                    </div>
                    
                    <div class="form-group-modern">
                        <label for="password">
                            <i class="fas fa-lock"></i>
                            Password
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-key input-icon"></i>
                            <input type="password" 
                                   id="password" 
                                   name="password" 
                                   class="form-control" 
                                   placeholder="Enter your password" 
                                   required 
                                   autocomplete="current-password" />
                            <button type="button" class="password-toggle" id="togglePassword">
                                <i class="far fa-eye-slash"></i>
                            </button>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-login">
                        <i class="fas fa-sign-in-alt"></i>
                        Sign In
                    </button>
                    
                    <div class="forgot-password">
                        <a asp-controller="Account" asp-action="ForgotPassword">
                            <i class="fas fa-question-circle"></i>
                            Forgot Password?
                        </a>
                    </div>
                </form>
            </div>
            
            <div class="login-footer">
                <span><i class="fas fa-shield-alt"></i> SSL Secured</span>
                <span><i class="fas fa-headset"></i> 24/7 Support</span>
                <span><i class="fas fa-chart-line"></i> v2.0</span>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Password visibility toggle
            const togglePassword = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('password');
            
            if (togglePassword && passwordInput) {
                togglePassword.addEventListener('click', function() {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    
                    const icon = this.querySelector('i');
                    if (type === 'text') {
                        icon.classList.remove('fa-eye-slash');
                        icon.classList.add('fa-eye');
                    } else {
                        icon.classList.remove('fa-eye');
                        icon.classList.add('fa-eye-slash');
                    }
                });
            }
            
            // Client-side validation
            const form = document.getElementById('loginForm');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const email = document.getElementById('email');
                    const password = document.getElementById('password');
                    
                    if (!email.value.trim()) {
                        e.preventDefault();
                        showAlert('Please enter your email address', 'danger');
                        email.focus();
                        return false;
                    }
                    
                    if (!password.value.trim()) {
                        e.preventDefault();
                        showAlert('Please enter your password', 'danger');
                        password.focus();
                        return false;
                    }
                    
                    // Basic email validation
                    const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                    if (!emailRegex.test(email.value.trim())) {
                        e.preventDefault();
                        showAlert('Please enter a valid email address', 'danger');
                        email.focus();
                        return false;
                    }
                    
                    return true;
                });
            }
            
            // Helper function to show alerts
            function showAlert(message, type) {
                const existingAlert = document.querySelector('.alert-modern.dynamic-alert');
                if (existingAlert) existingAlert.remove();
                
                const alertDiv = document.createElement('div');
                alertDiv.className = `alert-modern alert-${type} dynamic-alert`;
                alertDiv.style.marginBottom = '1rem';
                
                const icon = type === 'danger' ? 'fa-exclamation-circle' : 'fa-info-circle';
                alertDiv.innerHTML = `
                    <i class="fas ${icon}"></i>
                    <span>${message}</span>
                `;
                
                const formContainer = document.querySelector('.login-body');
                const formElement = formContainer.querySelector('form');
                formContainer.insertBefore(alertDiv, formElement);
                
                setTimeout(() => {
                    alertDiv.style.opacity = '0';
                    setTimeout(() => alertDiv.remove(), 300);
                }, 4000);
            }
        });
    </script>
</body>
</html>