@{
    Layout = null;
    ViewData["Title"] = "Forgot Password - Axis IT Helpdesk";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Axis IT Helpdesk | Forgot Password</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        /* Modern Forgot Password Page Styles */
        :root {
            --primary-dark: #1e4c6b;
            --primary: #2c7da0;
            --primary-light: #61a5c2;
            --info: #3b82f6;
            --info-dark: #2563eb;
            --success: #2c9e6e;
            --danger: #e53e3e;
            --warning: #f5b042;
            --secondary: #2c3e4e;
            --gray-light: #f8fafc;
            --gray-border: #e2e8f0;
        }

        /* Full height container */
        .forgot-password-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0f2b3d 0%, #1b4f6e 50%, #208aae 100%);
            padding: 1.5rem;
            position: relative;
        }

        /* Animated background blobs */
        .bg-blob {
            position: fixed;
            width: 40vw;
            height: 40vw;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 70%);
            border-radius: 50%;
            z-index: 0;
            pointer-events: none;
        }
        
        .blob-1 {
            top: -15vw;
            left: -10vw;
            animation: floatBlob 22s infinite ease-in-out;
        }
        
        .blob-2 {
            bottom: -20vw;
            right: -5vw;
            width: 55vw;
            height: 55vw;
            background: radial-gradient(circle, rgba(255,215,150,0.1) 0%, rgba(255,215,150,0) 70%);
            animation: floatBlob 28s infinite reverse;
        }
       

        /* Main Card */
        .forgot-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 1.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
            overflow: hidden;
            width: 100%;
            max-width: 460px;
            z-index: 2;
            transition: transform 0.25s ease, box-shadow 0.3s;
        }

        .forgot-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 30px 55px -12px rgba(0, 0, 0, 0.4);
        }

        /* Card Header */
        .forgot-header {
            background: linear-gradient(115deg, var(--primary-dark) 0%, var(--primary) 100%);
            padding: 2rem 1.5rem;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.2);
        }

        .brand-icon {
            font-size: 3rem;
            color: white;
            background: rgba(255,255,255,0.15);
            width: 70px;
            height: 70px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 1.2rem;
            margin-bottom: 1rem;
        }

        .forgot-header h2 {
            font-weight: 700;
            font-size: 1.8rem;
            color: white;
            margin: 0;
            letter-spacing: -0.3px;
        }

        .forgot-subtitle {
            color: rgba(255,255,255,0.85);
            font-size: 0.85rem;
            margin-top: 0.5rem;
        }

        /* Card Body */
        .forgot-body {
            padding: 2rem;
            background: white;
        }

        /* Info Message */
        .info-message {
            background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%);
            border-radius: 0.75rem;
            padding: 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            border-left: 4px solid var(--info);
        }

        .info-message i {
            color: var(--info);
            font-size: 1.25rem;
            margin-top: 0.125rem;
        }

        .info-message-content {
            flex: 1;
        }

        .info-message-content p {
            margin: 0;
            font-size: 0.85rem;
            color: #1e40af;
            line-height: 1.4;
        }

        /* Form Groups */
        .form-group-modern {
            margin-bottom: 1.5rem;
        }

        .form-group-modern label {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--secondary);
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-group-modern label i {
            color: var(--primary);
            font-size: 0.9rem;
        }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon-wrapper i.input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1rem;
            pointer-events: none;
            z-index: 1;
        }

        .input-icon-wrapper input {
            width: 100%;
            padding: 0.8rem 1rem 0.8rem 2.5rem;
            font-size: 0.95rem;
            border: 1.5px solid var(--gray-border);
            border-radius: 0.75rem;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }

        .input-icon-wrapper input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
        }

        /* Alert Styles */
        .alert-modern {
            border-radius: 0.75rem;
            border: none;
            padding: 0.85rem 1rem;
            margin-bottom: 1.5rem;
            font-size: 0.85rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-modern.alert-info {
            background: #eff6ff;
            border-left: 4px solid var(--info);
            color: #1e40af;
        }

        .alert-modern.alert-success {
            background: #e8f5e9;
            border-left: 4px solid var(--success);
            color: #1f6e4a;
        }

        .alert-modern.alert-danger {
            background: #fee;
            border-left: 4px solid var(--danger);
            color: #c53030;
        }

        .alert-modern i {
            font-size: 1.1rem;
        }

        /* Send Reset Button */
        .btn-send-reset {
            background: linear-gradient(100deg, var(--info-dark), var(--info));
            border: none;
            padding: 0.85rem;
            font-weight: 600;
            font-size: 0.95rem;
            border-radius: 0.75rem;
            width: 100%;
            color: white;
            transition: all 0.25s;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }

        .btn-send-reset:hover:not(:disabled) {
            background: linear-gradient(100deg, #1d4ed8, #2563eb);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(59, 130, 246, 0.3);
        }

        .btn-send-reset:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn-send-reset:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        /* Back to Login Link */
        .back-to-login {
            text-align: center;
            margin-top: 1.25rem;
        }

        .back-to-login a {
            color: var(--primary);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: color 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .back-to-login a:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        /* Footer Info */
        .forgot-footer {
            background: var(--gray-light);
            padding: 1rem;
            text-align: center;
            border-top: 1px solid var(--gray-border);
            font-size: 0.7rem;
            color: #5c6f87;
            display: flex;
            justify-content: center;
            gap: 1.5rem;
        }

        .forgot-footer span i {
            margin-right: 0.25rem;
            font-size: 0.7rem;
        }

        /* Responsive */
        @@media (max-width: 576px) {
            .forgot-body {
                padding: 1.5rem;
            }
            
            .forgot-header {
                padding: 1.5rem;
            }
            
            .forgot-header h2 {
                font-size: 1.5rem;
            }
            
            .brand-icon {
                width: 55px;
                height: 55px;
                font-size: 2.2rem;
            }
            
            .info-message {
                padding: 0.75rem;
            }
        }
    </style>
</head>
<body>
    <div class="forgot-password-container">
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>
        
        <div class="forgot-card">
            <div class="forgot-header">
                <div class="brand-icon">
                    <i class="fas fa-question-circle"></i>
                </div>
                <h2>Forgot Password</h2>
                <div class="forgot-subtitle">We'll help you reset your password</div>
            </div>
            
            <div class="forgot-body">
                <!-- Info Message -->
                <div class="info-message">
                    <i class="fas fa-info-circle"></i>
                    <div class="info-message-content">
                        <p>Enter your email address and we'll send you a link to reset your password. The link will expire in 24 hours.</p>
                    </div>
                </div>
                
                <!-- Alert Messages -->
                @if (ViewBag.Message != null)
                {
                    <div class="alert-modern alert-info">
                        <i class="fas fa-envelope"></i>
                        <span>@ViewBag.Message</span>
                    </div>
                }
                
                @if (TempData["Error"] != null)
                {
                    <div class="alert-modern alert-danger">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>@TempData["Error"]</span>
                    </div>
                }
                
                @if (TempData["Success"] != null)
                {
                    <div class="alert-modern alert-success">
                        <i class="fas fa-check-circle"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }
                
                <!-- Forgot Password Form -->
                <form method="post" id="forgotPasswordForm">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group-modern">
                        <label for="email">
                            <i class="fas fa-envelope"></i>
                            Email Address
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-at input-icon"></i>
                            <input type="email" 
                                   id="email" 
                                   name="email" 
                                   class="form-control" 
                                   placeholder="name@company.com" 
                                   required 
                                   autocomplete="email" />
                        </div>
                        <div id="emailHelp" class="form-text" style="font-size: 0.7rem; color: #64748b; margin-top: 0.25rem;">
                            <i class="fas fa-info-circle"></i> We'll send the reset link to this email address
                        </div>
                    </div>
                    
                    <button type="submit" class="btn-send-reset" id="submitBtn">
                        <i class="fas fa-paper-plane"></i>
                        Send Reset Link
                    </button>
                    
                    <div class="back-to-login">
                        <a asp-controller="Account" asp-action="Login">
                            <i class="fas fa-arrow-left"></i>
                            Back to Login
                        </a>
                    </div>
                </form>
            </div>
            
            <div class="forgot-footer">
                <span><i class="fas fa-shield-alt"></i> Secure Process</span>
                <span><i class="fas fa-clock"></i> Link expires in 24h</span>
                <span><i class="fas fa-headset"></i> Need Help?</span>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const emailInput = document.getElementById('email');
            const submitBtn = document.getElementById('submitBtn');
            const form = document.getElementById('forgotPasswordForm');
            
            // Email validation function
            function validateEmail(email) {
                const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                return emailRegex.test(email);
            }
            
            // Real-time email validation
            if (emailInput) {
                emailInput.addEventListener('input', function() {
                    const email = this.value.trim();
                    if (email.length > 0 && !validateEmail(email)) {
                        this.style.borderColor = '#e53e3e';
                        showInlineError('Please enter a valid email address');
                    } else {
                        this.style.borderColor = '#e2e8f0';
                        hideInlineError();
                    }
                });
                
                emailInput.addEventListener('blur', function() {
                    const email = this.value.trim();
                    if (email.length > 0 && !validateEmail(email)) {
                        this.style.borderColor = '#e53e3e';
                        showInlineError('Please enter a valid email address');
                    }
                });
            }
            
            function showInlineError(message) {
                let errorDiv = document.getElementById('inlineEmailError');
                if (!errorDiv) {
                    errorDiv = document.createElement('div');
                    errorDiv.id = 'inlineEmailError';
                    errorDiv.className = 'text-danger';
                    errorDiv.style.fontSize = '0.75rem';
                    errorDiv.style.marginTop = '0.25rem';
                    emailInput.parentElement.parentElement.appendChild(errorDiv);
                }
                errorDiv.innerHTML = `<i class="fas fa-times-circle"></i> ${message}`;
                errorDiv.style.display = 'block';
            }
            
            function hideInlineError() {
                const errorDiv = document.getElementById('inlineEmailError');
                if (errorDiv) {
                    errorDiv.style.display = 'none';
                }
            }
            
            // Rate limiting protection (prevent multiple rapid submissions)
            let lastSubmitTime = 0;
            const SUBMIT_COOLDOWN = 30000; // 30 seconds cooldown
            
            // Form submission validation
            if (form) {
                form.addEventListener('submit', function(e) {
                    const email = emailInput.value.trim();
                    
                    // Check if email is empty
                    if (!email) {
                        e.preventDefault();
                        showAlert('Please enter your email address', 'danger');
                        emailInput.focus();
                        return false;
                    }
                    
                    // Validate email format
                    if (!validateEmail(email)) {
                        e.preventDefault();
                        showAlert('Please enter a valid email address (e.g., name@domain.com)', 'danger');
                        emailInput.focus();
                        return false;
                    }
                    
                    // Rate limiting check
                    const now = Date.now();
                    if (now - lastSubmitTime < SUBMIT_COOLDOWN) {
                        e.preventDefault();
                        const remainingSeconds = Math.ceil((SUBMIT_COOLDOWN - (now - lastSubmitTime)) / 1000);
                        showAlert(`Please wait ${remainingSeconds} seconds before requesting another reset link`, 'warning');
                        return false;
                    }
                    
                    // Disable button during submission
                    submitBtn.disabled = true;
                    const originalButtonText = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
                    
                    // Re-enable button after 5 seconds if form doesn't submit immediately
                    setTimeout(() => {
                        if (submitBtn.disabled) {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalButtonText;
                        }
                    }, 5000);
                    
                    lastSubmitTime = now;
                    return true;
                });
            }
            
            // Helper function to show alerts
            function showAlert(message, type) {
                const existingAlert = document.querySelector('.alert-modern.dynamic-alert');
                if (existingAlert) existingAlert.remove();
                
                const alertDiv = document.createElement('div');
                alertDiv.className = `alert-modern alert-${type} dynamic-alert`;
                alertDiv.style.marginBottom = '1rem';
                
                let icon = '';
                switch(type) {
                    case 'danger':
                        icon = 'fa-exclamation-circle';
                        break;
                    case 'success':
                        icon = 'fa-check-circle';
                        break;
                    case 'warning':
                        icon = 'fa-exclamation-triangle';
                        break;
                    default:
                        icon = 'fa-info-circle';
                }
                
                alertDiv.innerHTML = `
                    <i class="fas ${icon}"></i>
                    <span>${message}</span>
                `;
                
                const formContainer = document.querySelector('.forgot-body');
                const formElement = formContainer.querySelector('form');
                const infoMessage = formContainer.querySelector('.info-message');
                
                if (infoMessage) {
                    formContainer.insertBefore(alertDiv, infoMessage.nextSibling);
                } else {
                    formContainer.insertBefore(alertDiv, formElement);
                }
                
                setTimeout(() => {
                    alertDiv.style.opacity = '0';
                    setTimeout(() => alertDiv.remove(), 300);
                }, 5000);
            }
            
            // Optional: Add email domain suggestions (helpful for enterprise)
            const commonDomains = ['company.com', 'gmail.com', 'outlook.com', 'yahoo.com'];
            
            // Smooth focus effect
            if (emailInput) {
                emailInput.addEventListener('focus', function() {
                    this.parentElement.style.transform = 'scale(1.01)';
                    this.parentElement.style.transition = 'transform 0.2s';
                });
                
                emailInput.addEventListener('blur', function() {
                    this.parentElement.style.transform = 'scale(1)';
                });
            }
            
            // Check if there's a success message and optionally auto-redirect
            const successAlert = document.querySelector('.alert-modern.alert-success');
            if (successAlert && successAlert.innerText.includes('sent')) {
                // Auto-redirect to login after 5 seconds if needed
                setTimeout(() => {
                    const loginLink = document.querySelector('.back-to-login a');
                    if (loginLink) {
                        window.location.href = loginLink.href;
                    }
                }, 5000);
            }
        });
    </script>
</body>
</html>