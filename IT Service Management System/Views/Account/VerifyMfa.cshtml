@{
    Layout = null;
    ViewData["Title"] = "Verify Sign-In - Axis IT Helpdesk";
    var masked = ViewBag.MaskedEmail as string ?? "your email";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Axis IT Helpdesk | Verify Sign-In</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root { --primary-dark:#2563eb; --primary:#3b82f6; --success:#2c9e6e; --danger:#e53e3e; --gray-border:#e2e8f0; }
        * { box-sizing:border-box; }
        body { margin:0; font-family:'Inter',sans-serif; }
        .mfa-container {
            min-height:100vh; display:flex; align-items:center; justify-content:center;
            background:linear-gradient(135deg,#0f2b3d 0%,#1b4f6e 50%,#208aae 100%); padding:1.5rem;
        }
        .mfa-card { background:#fff; border-radius:1.5rem; box-shadow:0 25px 50px -12px rgba(0,0,0,0.35);
            overflow:hidden; width:100%; max-width:440px; }
        .mfa-header { background:linear-gradient(115deg,var(--primary-dark),var(--primary));
            padding:2rem 1.5rem; text-align:center; }
        .brand-icon { font-size:2.5rem; color:#fff; background:rgba(255,255,255,0.15); width:70px; height:70px;
            display:inline-flex; align-items:center; justify-content:center; border-radius:1.2rem; margin-bottom:1rem; }
        .mfa-header h2 { font-weight:700; font-size:1.6rem; color:#fff; margin:0; }
        .mfa-sub { color:rgba(255,255,255,0.85); font-size:0.85rem; margin-top:0.5rem; }
        .mfa-body { padding:2rem; }
        .mfa-body p.lead { font-size:0.9rem; color:#475569; text-align:center; margin:0 0 1.5rem; }
        .mfa-body p.lead strong { color:#1e293b; }
        .code-input { width:100%; text-align:center; font-size:2rem; font-weight:700; letter-spacing:0.7rem;
            padding:0.85rem; border:1.5px solid var(--gray-border); border-radius:0.85rem; font-family:'Inter',sans-serif; }
        .code-input:focus { outline:none; border-color:var(--primary); box-shadow:0 0 0 3px rgba(59,130,246,0.1); }
        .btn-verify { width:100%; margin-top:1.25rem; padding:0.85rem; border:none; border-radius:0.85rem;
            background:linear-gradient(100deg,var(--primary-dark),var(--primary)); color:#fff; font-weight:600;
            font-size:0.95rem; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; }
        .btn-verify:hover { transform:translateY(-1px); box-shadow:0 6px 16px rgba(59,130,246,0.3); }
        .alert { border-radius:0.75rem; padding:0.8rem 1rem; margin-bottom:1.25rem; font-size:0.85rem;
            display:flex; align-items:center; gap:0.6rem; }
        .alert.danger { background:#fee; border-left:4px solid var(--danger); color:#c53030; }
        .alert.success { background:#e8f5e9; border-left:4px solid var(--success); color:#1f6e4a; }
        .mfa-foot { text-align:center; margin-top:1.25rem; font-size:0.82rem; }
        .mfa-foot a { color:var(--primary); text-decoration:none; font-weight:500; }
        .mfa-foot a:hover { text-decoration:underline; }
        .resend-form { display:inline; }
        .resend-btn { background:none; border:none; color:var(--primary); font-weight:500; cursor:pointer;
            font-size:0.82rem; padding:0; }
        .resend-btn:hover { text-decoration:underline; }
    </style>
</head>
<body>
    <div class="mfa-container">
        <div class="mfa-card">
            <div class="mfa-header">
                <div class="brand-icon"><i class="fas fa-shield-halved"></i></div>
                <h2>Verify It's You</h2>
                <div class="mfa-sub">Two-factor authentication</div>
            </div>
            <div class="mfa-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert danger"><i class="fas fa-exclamation-circle"></i><span>@ViewBag.Error</span></div>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="alert success"><i class="fas fa-check-circle"></i><span>@TempData["Success"]</span></div>
                }

                <p class="lead">We sent a 6-digit verification code to <strong>@masked</strong>. Enter it below to finish signing in.</p>

                <form method="post" asp-action="VerifyMfa">
                    @Html.AntiForgeryToken()
                    <input type="text" name="code" class="code-input" maxlength="6" inputmode="numeric"
                           pattern="[0-9]*" autocomplete="one-time-code" placeholder="••••••" autofocus required />
                    <button type="submit" class="btn-verify"><i class="fas fa-check"></i> Verify &amp; Sign In</button>
                </form>

                <div class="mfa-foot">
                    Didn't get a code?
                    <form method="post" asp-action="ResendMfa" class="resend-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="resend-btn">Resend code</button>
                    </form>
                    &middot; <a asp-action="Login">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
