@model IT_Service_Management_System.Models.MaintenanceRecord

@{
    ViewData["Title"] = "Edit Maintenance Record - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-edit me-2" style="color: var(--warning);"></i>
                    Edit Maintenance Record
                </h1>
                <p class="text-muted mt-2">Update equipment maintenance information</p>
            </div>
        </div>
    </div>

    <div class="edit-maintenance-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-tools me-2"></i>
                <span>Maintenance Information</span>
            </div>
            <div class="maintenance-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <form asp-action="Edit" method="post" id="editMaintenanceForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="AssetName" class="form-label">
                                <i class="fas fa-laptop"></i>
                                Asset Name
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-server input-icon"></i>
                                <input asp-for="AssetName" class="form-control-modern" placeholder="Enter asset name" />
                            </div>
                            <span asp-validation-for="AssetName" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Name of the equipment or asset being maintained
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="EmployeeName" class="form-label">
                                <i class="fas fa-user"></i>
                                Employee Name
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-user input-icon"></i>
                                <input asp-for="EmployeeName" class="form-control-modern" placeholder="Enter employee name" />
                            </div>
                            <span asp-validation-for="EmployeeName" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Employee who performed the maintenance
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="MaintenanceDate" class="form-label">
                                <i class="fas fa-calendar-alt"></i>
                                Maintenance Date
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-alt input-icon"></i>
                                <input asp-for="MaintenanceDate" type="date" class="form-control-modern" />
                            </div>
                            <span asp-validation-for="MaintenanceDate" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Date when the maintenance was performed
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="MaintenanceType" class="form-label">
                                <i class="fas fa-tag"></i>
                                Maintenance Type
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="MaintenanceType" class="form-control-modern">
                                    <option value="">Select maintenance type</option>
                                    @foreach (var type in Enum.GetValues(typeof(IT_Service_Management_System.Enums.MaintenanceType)))
                                    {
                                        var typeValue = type.ToString();
                                        <option value="@typeValue" selected="@(Model.MaintenanceType.ToString() == typeValue)">
                                            @typeValue
                                        </option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="MaintenanceType" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Type of maintenance performed
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="ProblemDescription" class="form-label">
                                <i class="fas fa-exclamation-circle"></i>
                                Problem Description
                                <span class="required">*</span>
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-exclamation-circle textarea-icon"></i>
                                <textarea asp-for="ProblemDescription" class="form-control-textarea" rows="3" placeholder="Describe the problem that was reported..."></textarea>
                            </div>
                            <span asp-validation-for="ProblemDescription" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Detailed description of the issue or problem
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="WorkDone" class="form-label">
                                <i class="fas fa-tasks"></i>
                                Work Done
                                <span class="required">*</span>
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-tasks textarea-icon"></i>
                                <textarea asp-for="WorkDone" class="form-control-textarea" rows="4" placeholder="Describe the work that was performed..."></textarea>
                            </div>
                            <span asp-validation-for="WorkDone" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Detailed description of the work performed
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="PartsReplaced" class="form-label">
                                <i class="fas fa-microchip"></i>
                                Parts Replaced
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-microchip textarea-icon"></i>
                                <textarea asp-for="PartsReplaced" class="form-control-textarea" rows="2" placeholder="List any parts that were replaced..."></textarea>
                            </div>
                            <span asp-validation-for="PartsReplaced" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> List of parts or components that were replaced
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="SoftwareInstalled" class="form-label">
                                <i class="fas fa-code"></i>
                                Software Installed
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-code textarea-icon"></i>
                                <textarea asp-for="SoftwareInstalled" class="form-control-textarea" rows="2" placeholder="List any software that was installed..."></textarea>
                            </div>
                            <span asp-validation-for="SoftwareInstalled" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Software or updates that were installed
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Comments" class="form-label">
                                <i class="fas fa-comment"></i>
                                Additional Comments
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-comment textarea-icon"></i>
                                <textarea asp-for="Comments" class="form-control-textarea" rows="3" placeholder="Any additional comments or notes..."></textarea>
                            </div>
                            <span asp-validation-for="Comments" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Any additional information about the maintenance
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="NextMaintenanceDate" class="form-label">
                                <i class="fas fa-calendar-week"></i>
                                Next Maintenance Date
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-week input-icon"></i>
                                <input asp-for="NextMaintenanceDate" type="date" class="form-control-modern" />
                            </div>
                            <span asp-validation-for="NextMaintenanceDate" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Scheduled date for the next maintenance
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-update" id="submitBtn">
                        <i class="fas fa-save"></i>
                        Update Record
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
        }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Edit Maintenance Card */
    .edit-maintenance-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .maintenance-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Validation Summary */
    .validation-summary {
        background: #fee;
        border-left: 3px solid var(--danger);
        padding: 1rem;
        border-radius: 0.75rem;
        margin-bottom: 1.5rem;
        color: var(--danger);
        font-size: 0.875rem;
    }

        .validation-summary ul {
            margin: 0.5rem 0 0 1.5rem;
        }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-label i {
            color: var(--primary);
            font-size: 0.875rem;
        }

    .required {
        color: var(--danger);
        font-size: 1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i.input-icon {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray-400);
            font-size: 0.875rem;
            pointer-events: none;
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 0.75rem 0.75rem 2.25rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
        }

    /* Select Styling */
    .select-wrapper {
        position: relative;
    }

        .select-wrapper select {
            appearance: none;
            width: 100%;
            padding: 0.75rem 2.25rem 0.75rem 1rem;
            font-size: 0.875rem;
            border: 1.5px solid var(--gray-200);
            border-radius: 0.75rem;
            cursor: pointer;
            background: white;
        }

            .select-wrapper select:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
            }

    .select-icon {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        pointer-events: none;
        font-size: 0.75rem;
    }

    /* Textarea Styling */
    .textarea-wrapper {
        position: relative;
    }

    .textarea-icon {
        position: absolute;
        left: 0.75rem;
        top: 0.75rem;
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 0.75rem 0.75rem 2.25rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
        resize: vertical;
    }

        .form-control-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
        }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-hint i {
            font-size: 0.7rem;
        }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-update {
        background: linear-gradient(100deg, var(--warning), #e6a017);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

    /* Animations */
    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }

        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .card-body-custom {
            padding: 1.5rem;
        }

        .form-actions {
            flex-direction: column;
        }

        .card-header-custom {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media print {
        .btn-back, .form-actions, .btn-print {
            display: none;
        }

        .edit-maintenance-card {
            box-shadow: none;
            border: 1px solid var(--gray-200);
        }

        .card-header-custom {
            background: var(--gray-100);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('editMaintenanceForm');
        const submitBtn = document.getElementById('submitBtn');

        if (form) {
            form.addEventListener('submit', function(e) {
                const assetName = document.querySelector('[name="AssetName"]').value.trim();
                const employeeName = document.querySelector('[name="EmployeeName"]').value.trim();
                const maintenanceDate = document.querySelector('[name="MaintenanceDate"]').value;
                const maintenanceType = document.querySelector('[name="MaintenanceType"]').value;
                const problemDescription = document.querySelector('[name="ProblemDescription"]').value.trim();
                const workDone = document.querySelector('[name="WorkDone"]').value.trim();

                if (!assetName) {
                    e.preventDefault();
                    showValidationError('Asset name is required');
                    document.querySelector('[name="AssetName"]').focus();
                    return false;
                }

                if (assetName.length < 2) {
                    e.preventDefault();
                    showValidationError('Asset name must be at least 2 characters');
                    document.querySelector('[name="AssetName"]').focus();
                    return false;
                }

                if (!employeeName) {
                    e.preventDefault();
                    showValidationError('Employee name is required');
                    document.querySelector('[name="EmployeeName"]').focus();
                    return false;
                }

                if (!maintenanceDate) {
                    e.preventDefault();
                    showValidationError('Maintenance date is required');
                    document.querySelector('[name="MaintenanceDate"]').focus();
                    return false;
                }

                if (!maintenanceType) {
                    e.preventDefault();
                    showValidationError('Please select a maintenance type');
                    document.querySelector('[name="MaintenanceType"]').focus();
                    return false;
                }

                if (!problemDescription) {
                    e.preventDefault();
                    showValidationError('Problem description is required');
                    document.querySelector('[name="ProblemDescription"]').focus();
                    return false;
                }

                if (problemDescription.length < 5) {
                    e.preventDefault();
                    showValidationError('Problem description must be at least 5 characters');
                    document.querySelector('[name="ProblemDescription"]').focus();
                    return false;
                }

                if (!workDone) {
                    e.preventDefault();
                    showValidationError('Work done description is required');
                    document.querySelector('[name="WorkDone"]').focus();
                    return false;
                }

                if (workDone.length < 5) {
                    e.preventDefault();
                    showValidationError('Work done description must be at least 5 characters');
                    document.querySelector('[name="WorkDone"]').focus();
                    return false;
                }

                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating Record...';
            });
        }

        function showValidationError(message) {
            const errorDiv = document.createElement('div');
            errorDiv.className = 'validation-toast';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
                animation: slideIn 0.3s ease;
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
                <button type="button" style="margin-left: auto; background: none; border: none; cursor: pointer; color: inherit;" onclick="this.parentElement.remove()">
                    <i class="fas fa-times"></i>
                </button>
            `;
            document.body.appendChild(errorDiv);

            setTimeout(() => {
                errorDiv.style.opacity = '0';
                setTimeout(() => errorDiv.remove(), 300);
            }, 4000);
        }
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}