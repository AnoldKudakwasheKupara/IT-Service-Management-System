@model IT_Service_Management_System.Models.MaintenanceRecord

@{
    ViewData["Title"] = "Delete Maintenance Record - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-trash-alt me-2" style="color: var(--danger);"></i>
                    Delete Maintenance Record
                </h1>
                <p class="text-muted mt-2">This action cannot be undone</p>
            </div>
        </div>
    </div>

    <div class="delete-warning-card">
        <div class="warning-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h3 class="warning-title">Are you absolutely sure?</h3>
        <p class="warning-message">This action will permanently delete this maintenance record from the system.</p>
    </div>

    <div class="maintenance-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-tools me-2"></i>
                <span>Maintenance Record to Delete</span>
            </div>
            <div class="maintenance-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- Maintenance Summary -->
            <div class="maintenance-summary">
                <div class="summary-icon">
                    <i class="fas fa-tools"></i>
                </div>
                <div class="summary-info">
                    <h2 class="summary-title">@Model.AssetName</h2>
                    <div class="summary-meta">
                        <span class="meta-badge">
                            <i class="fas fa-user"></i>
                            @Model.EmployeeName
                        </span>
                        <span class="meta-badge">
                            <i class="fas fa-calendar-alt"></i>
                            @Model.MaintenanceDate.ToString("dd MMM yyyy")
                        </span>
                        @{
                            var type = Model.MaintenanceType.ToString();
                            if (type == "Preventive")
                            {
                                <span class="meta-badge type-preventive">
                                    <i class="fas fa-shield-alt"></i> Preventive
                                </span>
                            }
                            else if (type == "Corrective")
                            {
                                <span class="meta-badge type-corrective">
                                    <i class="fas fa-wrench"></i> Corrective
                                </span>
                            }
                            else if (type == "Emergency")
                            {
                                <span class="meta-badge type-emergency">
                                    <i class="fas fa-exclamation-triangle"></i> Emergency
                                </span>
                            }
                            else if (type == "Scheduled")
                            {
                                <span class="meta-badge type-scheduled">
                                    <i class="fas fa-calendar-alt"></i> Scheduled
                                </span>
                            }
                            else
                            {
                                <span class="meta-badge type-other">
                                    <i class="fas fa-circle"></i> @type
                                </span>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Details Grid -->
            <div class="details-grid">
                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="detail-content">
                        <label>Maintenance Date</label>
                        <p>@Model.MaintenanceDate.ToString("dddd, MMMM dd, yyyy")</p>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-tag"></i>
                    </div>
                    <div class="detail-content">
                        <label>Maintenance Type</label>
                        <p>@Model.MaintenanceType</p>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-calendar-week"></i>
                    </div>
                    <div class="detail-content">
                        <label>Next Maintenance</label>
                        <p>@(Model.NextMaintenanceDate.HasValue ? Model.NextMaintenanceDate.Value.ToString("dd MMM yyyy") : "Not Scheduled")</p>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="detail-content">
                        <label>Created At</label>
                        <p>@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</p>
                    </div>
                </div>
            </div>

            <!-- Description Sections -->
            <div class="description-sections">
                <div class="desc-section">
                    <h4 class="desc-title">
                        <i class="fas fa-exclamation-circle"></i>
                        Problem / Reason
                    </h4>
                    <div class="desc-content">
                        @(string.IsNullOrWhiteSpace(Model.ProblemDescription) ? "No problem description provided." : Model.ProblemDescription)
                    </div>
                </div>

                <div class="desc-section">
                    <h4 class="desc-title">
                        <i class="fas fa-tasks"></i>
                        Work Done
                    </h4>
                    <div class="desc-content">
                        @(string.IsNullOrWhiteSpace(Model.WorkDone) ? "No work details provided." : Model.WorkDone)
                    </div>
                </div>

                <div class="desc-section">
                    <h4 class="desc-title">
                        <i class="fas fa-comment"></i>
                        Additional Comments
                    </h4>
                    <div class="desc-content">
                        @(string.IsNullOrWhiteSpace(Model.Comments) ? "No additional comments." : Model.Comments)
                    </div>
                </div>
            </div>

            <!-- Warning Details -->
            <div class="warning-details">
                <div class="warning-detail-item">
                    <i class="fas fa-database"></i>
                    <div>
                        <strong>Data Loss Warning</strong>
                        <span>This maintenance record will be permanently deleted from the system.</span>
                    </div>
                </div>
                <div class="warning-detail-item">
                    <i class="fas fa-clock"></i>
                    <div>
                        <strong>Irreversible Action</strong>
                        <span>This action cannot be undone. You will not be able to recover this record.</span>
                    </div>
                </div>
                <div class="warning-detail-item">
                    <i class="fas fa-chart-line"></i>
                    <div>
                        <strong>Maintenance History Impact</strong>
                        <span>This record will be removed from maintenance history and reports.</span>
                    </div>
                </div>
            </div>

            <!-- Confirmation Form -->
            <form asp-action="Delete" method="post" id="deleteForm" class="delete-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="confirmation-checkbox">
                    <input type="checkbox" id="confirmDelete" required>
                    <label for="confirmDelete">
                        I understand that this action is permanent and cannot be undone
                    </label>
                </div>

                <div class="action-buttons-container">
                    <button type="submit" class="btn-delete" id="deleteButton" disabled>
                        <i class="fas fa-trash-alt"></i>
                        Permanently Delete Record
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --danger-dark: #c53030;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
        }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Warning Card */
    .delete-warning-card {
        background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);
        border: 1px solid #fed7d7;
        border-radius: 1rem;
        padding: 2rem;
        text-align: center;
        margin-bottom: 2rem;
    }

    .warning-icon {
        width: 80px;
        height: 80px;
        background: var(--danger);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

        .warning-icon i {
            font-size: 3rem;
            color: white;
        }

    .warning-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--danger-dark);
        margin: 0 0 0.5rem 0;
    }

    .warning-message {
        color: var(--gray-600);
        margin: 0;
    }

    /* Maintenance Details Card */
    .maintenance-details-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .maintenance-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Maintenance Summary */
    .maintenance-summary {
        display: flex;
        gap: 1.5rem;
        padding-bottom: 1.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--gray-200);
    }

    .summary-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--gray-400), var(--gray-500));
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.75rem;
        flex-shrink: 0;
    }

    .summary-info {
        flex: 1;
    }

    .summary-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 0.5rem 0;
    }

    .summary-meta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .meta-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 600;
        background: var(--gray-100);
        color: var(--gray-600);
    }

        .meta-badge.type-preventive {
            background: #e6f5e9;
            color: var(--success);
        }

        .meta-badge.type-corrective {
            background: #fff5e6;
            color: var(--warning);
        }

        .meta-badge.type-emergency {
            background: #fee;
            color: var(--danger);
        }

        .meta-badge.type-scheduled {
            background: #e6f0ff;
            color: var(--info);
        }

        .meta-badge.type-other {
            background: var(--gray-100);
            color: var(--gray-600);
        }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .detail-card {
        background: var(--gray-50);
        border-radius: 0.75rem;
        padding: 0.75rem;
        display: flex;
        gap: 0.75rem;
        border: 1px solid var(--gray-200);
    }

    .detail-icon {
        width: 36px;
        height: 36px;
        background: white;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 0.875rem;
        flex-shrink: 0;
        border: 1px solid var(--gray-200);
    }

    .detail-content {
        flex: 1;
    }

        .detail-content label {
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray-500);
            font-weight: 600;
            display: block;
            margin-bottom: 0.125rem;
        }

        .detail-content p {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--gray-800);
            margin: 0;
        }

    /* Description Sections */
    .description-sections {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .desc-section {
        background: var(--gray-50);
        border-radius: 0.75rem;
        overflow: hidden;
        border: 1px solid var(--gray-200);
    }

    .desc-title {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-700);
        margin: 0;
        padding: 0.5rem 0.75rem;
        background: var(--gray-100);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .desc-title i {
            color: var(--primary);
        }

    .desc-content {
        padding: 0.75rem;
        font-size: 0.8rem;
        color: var(--gray-700);
        line-height: 1.5;
        white-space: pre-wrap;
    }

    /* Warning Details */
    .warning-details {
        background: #fff5f5;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        border-left: 3px solid var(--danger);
    }

    .warning-detail-item {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
    }

        .warning-detail-item i {
            font-size: 1rem;
            color: var(--danger);
            margin-top: 0.125rem;
        }

        .warning-detail-item div {
            flex: 1;
        }

        .warning-detail-item strong {
            display: block;
            font-size: 0.875rem;
            color: var(--gray-700);
            margin-bottom: 0.25rem;
        }

        .warning-detail-item span {
            font-size: 0.75rem;
            color: var(--gray-500);
            line-height: 1.4;
        }

    /* Confirmation Checkbox */
    .confirmation-checkbox {
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: var(--gray-50);
        border-radius: 0.75rem;
        border-left: 3px solid var(--danger);
    }

        .confirmation-checkbox input[type="checkbox"] {
            margin-right: 0.75rem;
            cursor: pointer;
            width: 18px;
            height: 18px;
        }

        .confirmation-checkbox label {
            color: var(--gray-700);
            font-size: 0.875rem;
            cursor: pointer;
            user-select: none;
        }

    /* Action Buttons */
    .action-buttons-container {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-delete {
        background: linear-gradient(100deg, var(--danger-dark), var(--danger));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-delete:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            filter: brightness(1.05);
        }

        .btn-delete:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

    /* Animations */
    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }

        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }

    @@keyframes shake {
        0%, 100% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-5px);
        }

        75% {
            transform: translateX(5px);
        }
    }

    .btn-delete:active:not(:disabled) {
        transform: scale(0.98);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .card-body-custom {
            padding: 1.5rem;
        }

        .maintenance-summary {
            flex-direction: column;
            text-align: center;
        }

        .summary-icon {
            margin: 0 auto;
        }

        .summary-meta {
            justify-content: center;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .action-buttons-container {
            flex-direction: column;
        }

        .btn-delete, .btn-cancel {
            width: 100%;
        }
    }

    @@media print {
        .btn-back, .action-buttons-container, .btn-print, .page-header a:not(.page-title) {
            display: none;
        }

        .maintenance-details-card {
            box-shadow: none;
            border: 1px solid var(--gray-200);
        }

        .card-header-custom {
            background: var(--gray-100);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const confirmCheckbox = document.getElementById('confirmDelete');
        const deleteButton = document.getElementById('deleteButton');
        const deleteForm = document.getElementById('deleteForm');

        // Enable/disable delete button based on checkbox
        if (confirmCheckbox && deleteButton) {
            confirmCheckbox.addEventListener('change', function() {
                deleteButton.disabled = !this.checked;
            });
        }

        // Form submission with additional confirmation
        if (deleteForm) {
            deleteForm.addEventListener('submit', function(e) {
                if (!confirmCheckbox.checked) {
                    e.preventDefault();
                    showWarningToast('Please confirm that you understand this action is permanent');
                    confirmCheckbox.focus();
                    return false;
                }

                // Final confirmation dialog with maintenance details
                const assetName = '@(Model.AssetName)';
                const employeeName = '@(Model.EmployeeName)';
                const confirmed = confirm(
                    '⚠️ WARNING: This action is permanent and cannot be undone.\n\n' +
                    `Are you absolutely sure you want to delete the maintenance record for "${assetName}"?\n\n` +
                    'This will permanently delete:\n' +
                    '• All maintenance information\n' +
                    '• Problem description and work done\n' +
                    '• Parts replaced and software installed\n' +
                    '• Comments and notes\n' +
                    `• Record for ${employeeName}\n\n` +
                    'This action cannot be reversed.'
                );

                if (!confirmed) {
                    e.preventDefault();
                    return false;
                }

                // Disable button to prevent double submission
                deleteButton.disabled = true;
                deleteButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting Record...';
            });
        }

        // Helper function to show toast notifications
        function showWarningToast(message) {
            const existingToast = document.querySelector('.warning-toast');
            if (existingToast) existingToast.remove();

            const toast = document.createElement('div');
            toast.className = 'warning-toast';
            toast.style.cssText = `
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                animation: slideIn 0.3s ease;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
            `;
            toast.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.animation = 'slideOut 0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // Add hover effect to delete button when checkbox is checked
        if (confirmCheckbox && deleteButton) {
            confirmCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    deleteButton.style.animation = 'shake 0.5s ease';
                    setTimeout(() => {
                        deleteButton.style.animation = '';
                    }, 500);
                }
            });
        }
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">