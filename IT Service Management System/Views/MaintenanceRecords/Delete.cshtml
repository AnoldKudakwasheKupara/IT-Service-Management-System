@model IT_Service_Management_System.Models.MaintenanceRecord

@{
    ViewData["Title"] = "Delete Maintenance Record";
}

<div class="container mt-4">

    <div class="card shadow-sm border-danger">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="bi bi-trash"></i> Delete Maintenance Record
            </h4>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <strong>Warning!</strong> Are you sure you want to delete this maintenance record? This action cannot be undone.
            </div>

            <div class="row mb-3">

                <div class="col-md-6">
                    <strong>Asset Name</strong>
                    <div>@Model.AssetName</div>
                </div>

                <div class="col-md-6">
                    <strong>Employee Name</strong>
                    <div>@Model.EmployeeName</div>
                </div>

            </div>

            <div class="row mb-3">

                <div class="col-md-6">
                    <strong>Maintenance Date</strong>
                    <div>@Model.MaintenanceDate.ToString("dd MMM yyyy")</div>
                </div>

                <div class="col-md-6">
                    <strong>Maintenance Type</strong>
                    <div>@Model.MaintenanceType</div>
                </div>

            </div>

            <div class="mb-3">
                <strong>Problem / Reason</strong>

                <div class="border rounded p-3 bg-light">
                    @(string.IsNullOrWhiteSpace(Model.ProblemDescription)
                        ? "N/A"
                        : Model.ProblemDescription)
                </div>
            </div>

            <div class="mb-3">
                <strong>Work Done</strong>

                <div class="border rounded p-3 bg-light">
                    @(string.IsNullOrWhiteSpace(Model.WorkDone)
                        ? "N/A"
                        : Model.WorkDone)
                </div>
            </div>

            <div class="mb-3">
                <strong>Comments</strong>

                <div class="border rounded p-3 bg-light">
                    @(string.IsNullOrWhiteSpace(Model.Comments)
                        ? "No comments."
                        : Model.Comments)
                </div>
            </div>

            <div class="row">

                <div class="col-md-6">
                    <strong>Next Maintenance Date</strong>
                    <div>
                        @(Model.NextMaintenanceDate.HasValue
                            ? Model.NextMaintenanceDate.Value.ToString("dd MMM yyyy")
                            : "Not Scheduled")
                    </div>
                </div>

                <div class="col-md-6">
                    <strong>Created At</strong>
                    <div>@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                </div>

            </div>

        </div>

        <div class="card-footer">

            <form asp-action="Delete">

                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>

                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete Record
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>