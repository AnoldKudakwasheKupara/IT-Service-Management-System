@model IT_Service_Management_System.Models.MaintenanceRecord

@{
    ViewData["Title"] = "Maintenance Record Details - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-tools me-2" style="color: var(--info);"></i>
                    Maintenance Record Details
                </h1>
                <p class="text-muted mt-2">View complete maintenance information</p>
            </div>
        </div>
    </div>

    <div class="maintenance-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-clipboard-list me-2"></i>
                <span>Maintenance Information</span>
            </div>
            <div class="maintenance-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- Summary Header -->
            <div class="maintenance-summary">
                <div class="summary-icon">
                    <i class="fas fa-tools"></i>
                </div>
                <div class="summary-info">
                    <h2 class="summary-title">@Model.AssetName</h2>
                    <div class="summary-meta">
                        <span class="meta-badge">
                            <i class="fas fa-user"></i>
                            @Model.EmployeeName
                        </span>
                        <span class="meta-badge">
                            <i class="fas fa-calendar-alt"></i>
                            @Model.MaintenanceDate.ToString("dd MMM yyyy")
                        </span>
                        @{
                            var type = Model.MaintenanceType.ToString();
                            if (type == "Preventive")
                            {
                                <span class="meta-badge type-preventive">
                                    <i class="fas fa-shield-alt"></i> Preventive
                                </span>
                            }
                            else if (type == "Corrective")
                            {
                                <span class="meta-badge type-corrective">
                                    <i class="fas fa-wrench"></i> Corrective
                                </span>
                            }
                            else if (type == "Emergency")
                            {
                                <span class="meta-badge type-emergency">
                                    <i class="fas fa-exclamation-triangle"></i> Emergency
                                </span>
                            }
                            else if (type == "Scheduled")
                            {
                                <span class="meta-badge type-scheduled">
                                    <i class="fas fa-calendar-alt"></i> Scheduled
                                </span>
                            }
                            else
                            {
                                <span class="meta-badge type-other">
                                    <i class="fas fa-circle"></i> @type
                                </span>
                            }
                        }
                    </span>
                </div>
            </div>
        </div>

        <!-- Details Grid -->
        <div class="details-grid">
            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="detail-content">
                    <label>Maintenance Date</label>
                    <p>@Model.MaintenanceDate.ToString("dddd, MMMM dd, yyyy")</p>
                    <span class="detail-sub">@Model.MaintenanceDate.ToString("hh:mm tt")</span>
                </div>
            </div>

            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-tag"></i>
                </div>
                <div class="detail-content">
                    <label>Maintenance Type</label>
                    <p>@Model.MaintenanceType</p>
                    <span class="detail-sub">Type of maintenance performed</span>
                </div>
            </div>

            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-calendar-week"></i>
                </div>
                <div class="detail-content">
                    <label>Next Maintenance</label>
                    <p>@(Model.NextMaintenanceDate.HasValue ? Model.NextMaintenanceDate.Value.ToString("dddd, MMMM dd, yyyy") : "Not Scheduled")</p>
                    <span class="detail-sub">@(Model.NextMaintenanceDate.HasValue ? "Scheduled for future" : "No date set")</span>
                </div>
            </div>

            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="detail-content">
                    <label>Record Created</label>
                    <p>@Model.CreatedAt.ToString("dddd, MMMM dd, yyyy")</p>
                    <span class="detail-sub">@Model.CreatedAt.ToString("hh:mm tt")</span>
                </div>
            </div>
        </div>

        <!-- Description Sections -->
        <div class="description-sections">
            <div class="desc-section">
                <h4 class="desc-title">
                    <i class="fas fa-exclamation-circle"></i>
                    Problem / Reason
                </h4>
                <div class="desc-content">
                    @(string.IsNullOrWhiteSpace(Model.ProblemDescription) ? "No problem description provided." : Model.ProblemDescription)
                </div>
            </div>

            <div class="desc-section">
                <h4 class="desc-title">
                    <i class="fas fa-tasks"></i>
                    Work Done
                </h4>
                <div class="desc-content">
                    @(string.IsNullOrWhiteSpace(Model.WorkDone) ? "No work details provided." : Model.WorkDone)
                </div>
            </div>

            <div class="desc-section">
                <h4 class="desc-title">
                    <i class="fas fa-microchip"></i>
                    Parts Replaced
                </h4>
                <div class="desc-content">
                    @(string.IsNullOrWhiteSpace(Model.PartsReplaced) ? "No parts were replaced." : Model.PartsReplaced)
                </div>
            </div>

            <div class="desc-section">
                <h4 class="desc-title">
                    <i class="fas fa-code"></i>
                    Software Installed
                </h4>
                <div class="desc-content">
                    @(string.IsNullOrWhiteSpace(Model.SoftwareInstalled) ? "No software was installed." : Model.SoftwareInstalled)
                </div>
            </div>

            <div class="desc-section">
                <h4 class="desc-title">
                    <i class="fas fa-comment"></i>
                    Additional Comments
                </h4>
                <div class="desc-content">
                    @(string.IsNullOrWhiteSpace(Model.Comments) ? "No additional comments." : Model.Comments)
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons-container">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">
                <i class="fas fa-pencil-alt"></i>
                Edit Record
            </a>
            <a asp-action="Index" class="btn-back-to-list">
                <i class="fas fa-arrow-left"></i>
                Back to List
            </a>
            <button type="button" class="btn-print" onclick="window.print()">
                <i class="fas fa-print"></i>
                Print Details
            </button>
        </div>
    </div>
</div>

<style>
        :root {
            --primary-dark: #1e4c6b;
            --primary: #2c7da0;
            --primary-light: #61a5c2;
            --success: #2c9e6e;
            --warning: #f5b042;
            --danger: #e53e3e;
            --info: #3b82f6;
            --gray-50: #f8fafc;
            --gray-100: #f1f5f9;
            --gray-200: #e2e8f0;
            --gray-300: #cbd5e1;
            --gray-400: #94a3b8;
            --gray-500: #64748b;
            --gray-600: #475569;
            --gray-700: #334155;
            --gray-800: #1e293b;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        .page-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .page-header {
            margin-bottom: 2rem;
        }

        .btn-back {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border-radius: 0.75rem;
            color: var(--gray-600);
            text-decoration: none;
            transition: all 0.2s;
            border: 1px solid var(--gray-200);
        }

            .btn-back:hover {
                background: var(--gray-50);
                color: var(--primary);
                transform: translateX(-2px);
            }

        .page-title {
            font-size: 1.875rem;
            font-weight: 700;
            color: var(--gray-800);
            margin: 0;
        }

        /* Maintenance Details Card */
        .maintenance-details-card {
            background: white;
            border-radius: 1rem;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
        }

        .card-header-custom {
            background: var(--gray-50);
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            font-weight: 600;
            color: var(--gray-700);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .maintenance-id-badge {
            background: white;
            padding: 0.25rem 0.75rem;
            border-radius: 2rem;
            font-size: 0.75rem;
            color: var(--gray-600);
            border: 1px solid var(--gray-200);
        }

        .card-body-custom {
            padding: 2rem;
        }

        /* Summary Header */
        .maintenance-summary {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding-bottom: 1.5rem;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid var(--gray-100);
        }

        .summary-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            border-radius: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.75rem;
            flex-shrink: 0;
        }

        .summary-info {
            flex: 1;
        }

        .summary-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--gray-800);
            margin: 0 0 0.5rem 0;
        }

        .summary-meta {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .meta-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.25rem 0.75rem;
            border-radius: 2rem;
            font-size: 0.7rem;
            font-weight: 600;
            background: var(--gray-100);
            color: var(--gray-600);
        }

            .meta-badge.type-preventive {
                background: #e6f5e9;
                color: var(--success);
            }

            .meta-badge.type-corrective {
                background: #fff5e6;
                color: var(--warning);
            }

            .meta-badge.type-emergency {
                background: #fee;
                color: var(--danger);
            }

            .meta-badge.type-scheduled {
                background: #e6f0ff;
                color: var(--info);
            }

            .meta-badge.type-other {
                background: var(--gray-100);
                color: var(--gray-600);
            }

        /* Details Grid */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .detail-card {
            background: var(--gray-50);
            border-radius: 0.75rem;
            padding: 1rem;
            display: flex;
            gap: 0.75rem;
            transition: all 0.2s;
            border: 1px solid var(--gray-200);
        }

            .detail-card:hover {
                background: white;
                border-color: var(--primary-light);
            }

        .detail-icon {
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 1rem;
            flex-shrink: 0;
            border: 1px solid var(--gray-200);
        }

        .detail-content {
            flex: 1;
        }

            .detail-content label {
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: var(--gray-500);
                font-weight: 600;
                display: block;
                margin-bottom: 0.125rem;
            }

            .detail-content p {
                font-size: 0.9rem;
                font-weight: 600;
                color: var(--gray-800);
                margin: 0 0 0.25rem 0;
            }

        .detail-sub {
            font-size: 0.65rem;
            color: var(--gray-500);
        }

        /* Description Sections */
        .description-sections {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .desc-section {
            background: var(--gray-50);
            border-radius: 0.75rem;
            overflow: hidden;
            border: 1px solid var(--gray-200);
        }

        .desc-title {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--gray-700);
            margin: 0;
            padding: 0.75rem 1rem;
            background: var(--gray-100);
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .desc-title i {
                color: var(--primary);
            }

        .desc-content {
            padding: 1rem;
            font-size: 0.875rem;
            color: var(--gray-700);
            line-height: 1.6;
            white-space: pre-wrap;
        }

        /* Action Buttons */
        .action-buttons-container {
            display: flex;
            gap: 1rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--gray-200);
            flex-wrap: wrap;
        }

        .btn-edit {
            background: linear-gradient(100deg, var(--warning), #e6a017);
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
            font-size: 0.875rem;
            flex: 1;
            justify-content: center;
        }

            .btn-edit:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
                color: white;
                text-decoration: none;
            }

        .btn-back-to-list {
            background: white;
            color: var(--gray-600);
            padding: 0.75rem 1.5rem;
            border-radius: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
            border: 1px solid var(--gray-300);
            font-size: 0.875rem;
            flex: 1;
            justify-content: center;
        }

            .btn-back-to-list:hover {
                background: var(--gray-50);
                color: var(--gray-700);
                text-decoration: none;
            }

        .btn-print {
            background: white;
            color: var(--info);
            padding: 0.75rem 1.5rem;
            border-radius: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
            border: 1px solid var(--info);
            font-size: 0.875rem;
            cursor: pointer;
            flex: 1;
            justify-content: center;
        }

            .btn-print:hover {
                background: var(--info);
                color: white;
                transform: translateY(-2px);
            }

        /* Print Styles */
        @@media print {
            .btn-back, .action-buttons-container, .btn-print, .page-header a:not(.page-title) {
                display: none;
            }

            .maintenance-details-card {
                box-shadow: none;
                border: 1px solid var(--gray-200);
            }

            .card-header-custom {
                background: var(--gray-100);
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .detail-card, .desc-section {
                break-inside: avoid;
            }
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .card-body-custom {
                padding: 1.5rem;
            }

            .maintenance-summary {
                flex-direction: column;
                text-align: center;
            }

            .summary-icon {
                margin: 0 auto;
            }

            .summary-meta {
                justify-content: center;
            }

            .details-grid {
                grid-template-columns: 1fr;
            }

            .action-buttons-container {
                flex-direction: column;
            }

            .btn-edit, .btn-back-to-list, .btn-print {
                width: 100%;
            }
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">