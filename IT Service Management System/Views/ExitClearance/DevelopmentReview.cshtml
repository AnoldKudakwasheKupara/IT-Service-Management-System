@model DevelopmentClearance

<div class="card">
    <div class="card-header">
        <h4>Development Clearance</h4>
    </div>

    <div class="card-body">

        <form asp-action="DevelopmentReview" method="post">

            <input asp-for="ExitClearanceId" type="hidden" />

            <div class="form-check mb-3">
                <input asp-for="BitbucketRemoved"
                       class="form-check-input" />

                <label class="form-check-label">
                    Bitbucket Credentials Removed
                </label>
            </div>

            <div class="form-check mb-3">
                <input asp-for="ProjectManagementRemoved"
                       class="form-check-input" />

                <label class="form-check-label">
                    Project Management Credentials Removed
                </label>
            </div>

            <div class="form-check mb-3">
                <input asp-for="ManageEngineRemoved"
                       class="form-check-input" />

                <label class="form-check-label">
                    ManageEngine Credentials Removed
                </label>
            </div>

            <div class="mb-3">
                <label>Comments</label>

                <textarea asp-for="Comments"
                          class="form-control">
                </textarea>
            </div>

            <button class="btn btn-success">
                Approve & Forward
            </button>

        </form>

    </div>
</div>