@model List<ExitClearance>

<div class="card">
    <div class="card-header">
        <h4>Pending Finance Clearances</h4>
    </div>

    <div class="card-body">

        <table class="table">

            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @item.Employee.FirstName
                            @item.Employee.LastName
                        </td>

                        <td>
                            @item.CurrentStage
                        </td>

                        <td>
                            <a asp-action="FinanceReview"
                               asp-route-id="@item.Id"
                               class="btn btn-primary btn-sm">

                                Review
                            </a>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>