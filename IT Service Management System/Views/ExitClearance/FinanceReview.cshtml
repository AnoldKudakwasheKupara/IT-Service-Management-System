@model FinanceClearance

<div class="card">
    <div class="card-header">
        <h4>Finance Clearance</h4>
    </div>

    ```
    <div class="card-body">

        <form asp-action="FinanceReview" method="post">

            <input asp-for="ExitClearanceId" type="hidden" />

            <table class="table table-bordered align-middle">

                <thead class="table-light">
                    <tr>
                        <th style="width:35%">
                            Finance
                        </th>

                        <th style="width:25%">
                            Asset / Serial Number
                        </th>

                        <th style="width:20%">
                            Received By (Sign)
                        </th>

                        <th style="width:20%">
                            Date
                        </th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>
                            Staff Advance and Other Liabilities (if any)
                        </td>

                        <td>
                            <input asp-for="StaffAdvanceReference"
                                   class="form-control" />
                        </td>

                        <td>
                            <input asp-for="StaffAdvanceReceivedBy"
                                   class="form-control" />
                        </td>

                        <td>
                            <input asp-for="StaffAdvanceDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>
                            Receipts handed over to finance (if any)
                        </td>

                        <td>
                            <input asp-for="ReceiptsReference"
                                   class="form-control" />
                        </td>

                        <td>
                            <input asp-for="ReceiptsReceivedBy"
                                   class="form-control" />
                        </td>

                        <td>
                            <input asp-for="ReceiptsDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>
                            Final dues to be paid to the employee
                        </td>

                        <td>
                            <input asp-for="FinalDuesReference"
                                   class="form-control" />
                        </td>

                        <td>
                            <input asp-for="FinalDuesReceivedBy"
                                   class="form-control" />
                        </td>

                        <td>
                            <input asp-for="FinalDuesDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                </tbody>

            </table>

            <div class="mb-3">
                <label class="form-label">
                    Comments
                </label>

                <textarea asp-for="Comments"
                          class="form-control"
                          rows="4"></textarea>
            </div>

            <button type="submit"
                    class="btn btn-success">
                Approve & Forward
            </button>

        </form>

    </div>
    ```

</div>