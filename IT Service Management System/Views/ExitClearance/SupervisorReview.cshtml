@model SupervisorApproval

@{
    ViewData["Title"] = "Supervisor Approval - Axis IT Helpdesk";
}

<div class="page-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-icon">
                <i class="fas fa-user-check"></i>
            </div>
            <div>
                <h1 class="hero-title">Supervisor Approval</h1>
                <p class="hero-subtitle">Review and approve employee handover completion</p>
            </div>
        </div>
        <div class="hero-actions">
            <a asp-action="PendingSupervisor" class="hero-btn hero-btn-back">
                <i class="fas fa-arrow-left"></i> Back to Pending
            </a>
        </div>
    </div>

    <!-- Approval Form Card -->
    <div class="approval-form-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-user-check me-2"></i>
                <span>Supervisor Approval</span>
            </div>
            <div class="form-steps">
                <span class="step active">1</span>
                <span class="step-line"></span>
                <span class="step">2</span>
                <span class="step-line"></span>
                <span class="step">3</span>
            </div>
        </div>

        <div class="card-body-custom">
            <form asp-action="SupervisorReview" method="post" id="supervisorForm">
                @Html.AntiForgeryToken()
                <input asp-for="ExitClearanceId" type="hidden" />

                <!-- Approval Checkbox -->
                <div class="approval-section">
                    <div class="checkbox-group">
                        <label class="checkbox-wrapper">
                            <input asp-for="Approved" type="checkbox" id="approvedCheckbox" />
                            <span class="checkmark"></span>
                            <span class="checkbox-label">Handover Completed</span>
                        </label>
                    </div>
                    <div class="form-hint">
                        <i class="fas fa-info-circle"></i> Check this box to confirm that the handover has been completed successfully
                    </div>
                </div>

                <!-- Comments Section -->
                <div class="comments-section">
                    <div class="comments-header">
                        <i class="fas fa-comment-dots"></i>
                        <span>Comments</span>
                    </div>
                    <div class="textarea-wrapper">
                        <i class="fas fa-pen textarea-icon"></i>
                        <textarea asp-for="Comments" class="form-control-textarea" rows="4" placeholder="Enter any additional comments or notes..."></textarea>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-approve" id="submitBtn">
                        <i class="fas fa-check-circle"></i>
                        Approve & Forward
                    </button>
                    <a asp-action="PendingSupervisor" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, #11998e, #38ef7d);
        border-radius: 1.5rem;
        padding: 2rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        box-shadow: var(--shadow-lg);
    }

    .hero-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hero-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
    }

    .hero-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.25rem 0;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .hero-btn {
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }

    .hero-btn-back {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

        .hero-btn-back:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    /* Approval Form Card */
    .approval-form-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .form-steps {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .step {
        width: 30px;
        height: 30px;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

        .step.active {
            background: var(--success);
            border-color: var(--success);
            color: white;
        }

    .step-line {
        width: 40px;
        height: 2px;
        background: var(--gray-300);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Approval Section */
    .approval-section {
        margin-bottom: 2rem;
    }

    .checkbox-group {
        margin-bottom: 0.5rem;
    }

    .checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        user-select: none;
    }

        .checkbox-wrapper input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
            height: 0;
            width: 0;
        }

    .checkmark {
        position: relative;
        display: inline-block;
        height: 22px;
        width: 22px;
        background-color: white;
        border: 2px solid var(--gray-300);
        border-radius: 0.375rem;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .checkbox-wrapper input:checked ~ .checkmark {
        background-color: var(--success);
        border-color: var(--success);
    }

    .checkmark:after {
        content: "";
        position: absolute;
        display: none;
    }

    .checkbox-wrapper input:checked ~ .checkmark:after {
        display: block;
    }

    .checkbox-wrapper .checkmark:after {
        left: 6px;
        top: 2px;
        width: 6px;
        height: 11px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }

    .checkbox-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        cursor: pointer;
    }

    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-left: 2rem;
    }

        .form-hint i {
            font-size: 0.7rem;
        }

    /* Comments Section */
    .comments-section {
        margin-bottom: 2rem;
    }

    .comments-header {
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .comments-header i {
            color: var(--primary);
        }

    .textarea-wrapper {
        position: relative;
    }

    .textarea-icon {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
        resize: vertical;
    }

        .form-control-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59,130,246, 0.1);
        }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1rem;
    }

    .btn-approve {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-approve:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('supervisorForm');
        const submitBtn = document.getElementById('submitBtn');
        const approvedCheckbox = document.getElementById('approvedCheckbox');

        if (form) {
            form.addEventListener('submit', function(e) {
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
            });
        }
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}