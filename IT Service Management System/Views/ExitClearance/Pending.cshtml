@model List<ExitClearance>

<div class="card">

    <div class="card-header">
        <h4>Pending Clearances</h4>
    </div>

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                No pending clearances as of now.
            </div>
        }
        else
        {
            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Status</th>
                        <th>Current Stage</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.Employee.FirstName
                                @item.Employee.LastName
                            </td>

                            <td>@item.Status</td>

                            <td>@item.CurrentStage</td>

                            <td>

                                <a asp-action="Open"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm">
                                    Open
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        }

    </div>

</div>