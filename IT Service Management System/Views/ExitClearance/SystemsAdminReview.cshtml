@model SystemsAdminClearance

<div class="card">

    <div class="card-header">
        <h4>Systems Administration Clearance</h4>
    </div>

    <div class="card-body">

        <form asp-action="SystemsAdminReview">

            <input asp-for="ExitClearanceId" type="hidden" />

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>Systems Admin</th>
                        <th>Asset / Serial Number</th>
                        <th>Received By (Sign)</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>Laptop</td>
                        <td>
                            <input asp-for="LaptopAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="LaptopReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="LaptopDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>Laptop Bags</td>
                        <td>
                            <input asp-for="LaptopBagAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="LaptopBagReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="LaptopBagDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>Accessories (if any)</td>
                        <td>
                            <input asp-for="AccessoriesAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="AccessoriesReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="AccessoriesDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>Laptop Locker (if any)</td>
                        <td>
                            <input asp-for="LockerAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="LockerReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="LockerDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>Endpoint Security</td>
                        <td>
                            <input asp-for="EndpointSecurityAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="EndpointSecurityReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="EndpointSecurityDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>Login Credentials For Sophos</td>
                        <td>
                            <input asp-for="SophosAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="SophosReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="SophosDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>
                            Confirm deletion of employee from systems access and passwords
                        </td>
                        <td>
                            <input asp-for="AccessRemovalAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="AccessRemovalReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="AccessRemovalDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>
                            Confirm deletion / suspension of email and redirection
                        </td>
                        <td>
                            <input asp-for="EmailAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="EmailReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="EmailDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                    <tr>
                        <td>
                            Confirm deletion from social media groups
                        </td>
                        <td>
                            <input asp-for="SocialMediaAsset"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="SocialMediaReceivedBy"
                                   class="form-control" />
                        </td>
                        <td>
                            <input asp-for="SocialMediaDate"
                                   type="date"
                                   class="form-control" />
                        </td>
                    </tr>

                </tbody>

            </table>

            <div class="mb-3">

                <label>Comments</label>

                <textarea asp-for="Comments"
                          class="form-control"
                          rows="4"></textarea>

            </div>

            <button type="submit"
                    class="btn btn-success">
                Approve & Forward
            </button>

        </form>

    </div>

</div>