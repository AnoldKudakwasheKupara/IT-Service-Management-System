@model HrApproval

<div class="card">

    <div class="card-header">
        <h4>Human Resources Final Clearance</h4>
    </div>

    <div class="card-body">

        <form asp-action="HrReview" method="post">

            <input asp-for="ExitClearanceId" type="hidden" />

            <table class="table table-bordered">

                <thead class="table-light">

                    <tr>
                        <th style="width:45%">Human Resources</th>
                        <th style="width:15%">Tick If Done</th>
                        <th style="width:25%">Received By (Sign)</th>
                        <th style="width:15%">Date</th>
                    </tr>

                </thead>

                <tbody>

                    <tr>
                        <td>Acknowledge receiving resignation letter</td>
                        <td><input asp-for="ResignationLetterReceived" /></td>
                        <td><input asp-for="ResignationLetterReceivedBy" class="form-control" /></td>
                        <td><input asp-for="ResignationLetterDate" type="date" class="form-control" /></td>
                    </tr>

                    <tr>
                        <td>Staff ID Card</td>
                        <td><input asp-for="StaffIdReturned" /></td>
                        <td><input asp-for="StaffIdReceivedBy" class="form-control" /></td>
                        <td><input asp-for="StaffIdDate" type="date" class="form-control" /></td>
                    </tr>

                    <tr>
                        <td>Cancellation of benefits - Medical Aid</td>
                        <td><input asp-for="MedicalAidCancelled" /></td>
                        <td><input asp-for="MedicalAidReceivedBy" class="form-control" /></td>
                        <td><input asp-for="MedicalAidDate" type="date" class="form-control" /></td>
                    </tr>

                    <tr>
                        <td>Cancellation of Pension - NSSA</td>
                        <td><input asp-for="NSSACancelled" /></td>
                        <td><input asp-for="NSSAReceivedBy" class="form-control" /></td>
                        <td><input asp-for="NSSADate" type="date" class="form-control" /></td>
                    </tr>

                    <tr>
                        <td>Cancellation of Funeral Policy</td>
                        <td><input asp-for="FuneralPolicyCancelled" /></td>
                        <td><input asp-for="FuneralPolicyReceivedBy" class="form-control" /></td>
                        <td><input asp-for="FuneralPolicyDate" type="date" class="form-control" /></td>
                    </tr>

                    <tr>
                        <td>Exit Interviews Done</td>
                        <td><input asp-for="ExitInterviewCompleted" /></td>
                        <td><input asp-for="ExitInterviewReceivedBy" class="form-control" /></td>
                        <td><input asp-for="ExitInterviewDate" type="date" class="form-control" /></td>
                    </tr>

                    <tr>
                        <td>Handover Report Submitted</td>
                        <td><input asp-for="HandoverReportSubmitted" /></td>
                        <td><input asp-for="HandoverReportReceivedBy" class="form-control" /></td>
                        <td><input asp-for="HandoverReportDate" type="date" class="form-control" /></td>
                    </tr>

                </tbody>

            </table>

            <div class="mb-3">

                <label>Comments</label>

                <textarea asp-for="Comments"
                          rows="4"
                          class="form-control"></textarea>

            </div>

            <button type="submit"
                    class="btn btn-success">
                Complete Clearance
            </button>

        </form>

    </div>

</div>