@if (Model.FinanceClearance != null)
{
    <div class="card mb-3">

        <div class="card-header bg-success text-white">
            Finance Clearance
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>Finance Item</th>
                        <th>Asset / Serial Number</th>
                        <th>Received By</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>
                            Staff Advance and Other Liabilities (if any)
                        </td>

                        <td>
                            @Model.FinanceClearance.StaffAdvanceReference
                        </td>

                        <td>
                            @Model.FinanceClearance.StaffAdvanceReceivedBy
                        </td>

                        <td>
                            @Model.FinanceClearance.StaffAdvanceDate?.ToString("dd-MMM-yyyy")
                        </td>
                    </tr>

                    <tr>
                        <td>
                            Receipts Handed Over To Finance (if any)
                        </td>

                        <td>
                            @Model.FinanceClearance.ReceiptsReference
                        </td>

                        <td>
                            @Model.FinanceClearance.ReceiptsReceivedBy
                        </td>

                        <td>
                            @Model.FinanceClearance.ReceiptsDate?.ToString("dd-MMM-yyyy")
                        </td>
                    </tr>

                    <tr>
                        <td>
                            Final Dues To Be Paid To Employee
                        </td>

                        <td>
                            @Model.FinanceClearance.FinalDuesReference
                        </td>

                        <td>
                            @Model.FinanceClearance.FinalDuesReceivedBy
                        </td>

                        <td>
                            @Model.FinanceClearance.FinalDuesDate?.ToString("dd-MMM-yyyy")
                        </td>
                    </tr>

                </tbody>

            </table>

            @if (!string.IsNullOrWhiteSpace(Model.FinanceClearance.Comments))
            {
                <div class="mt-3">

                    <strong>Comments:</strong>

                    <p class="mt-2">
                        @Model.FinanceClearance.Comments
                    </p>

                </div>
            }

        </div>

    </div>
}