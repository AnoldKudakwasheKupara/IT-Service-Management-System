@using IT_Service_Management_System.ViewModels
@model ExitClearanceDetailsVM

@{
    ViewData["Title"] = "Exit Clearance Details - Axis IT Helpdesk";
}

<div class="page-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-icon">
                <i class="fas fa-sign-out-alt"></i>
            </div>
            <div>
                <h1 class="hero-title">Exit Clearance Details</h1>
                <p class="hero-subtitle">Complete employee clearance and offboarding management</p>
            </div>
        </div>
        <div class="hero-actions">
            <a asp-action="Index" class="hero-btn hero-btn-back">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
            <button type="button" class="hero-btn hero-btn-print" onclick="window.print()">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </div>

    <!-- Employee Profile Card -->
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                @((Model.ExitClearance.Employee?.FirstName?.Substring(0, 1) ?? "E") + (Model.ExitClearance.Employee?.LastName?.Substring(0, 1) ?? "M"))
            </div>
            <div class="profile-info">
                <h2 class="profile-name">@Model.ExitClearance.Employee?.FirstName @Model.ExitClearance.Employee?.LastName</h2>
                <div class="profile-badges">
                    <span class="badge badge-primary">
                        <i class="fas fa-building"></i> @Model.EmployeeDetails?.Department
                    </span>
                    <span class="badge badge-info">
                        <i class="fas fa-user-tie"></i> @Model.EmployeeDetails?.PositionHeld
                    </span>
                </div>
            </div>
        </div>

        <div class="profile-details">
            <!-- 3x3 Grid for Employee Details -->
            <div class="detail-group">
                <div class="detail-item">
                    <i class="fas fa-calendar-alt"></i>
                    <div>
                        <label>Date of Notice</label>
                        <span>@(Model.EmployeeDetails?.DateOfNotice?.ToString("dd MMM yyyy") ?? "-")</span>
                    </div>
                </div>
                <div class="detail-item">
                    <i class="fas fa-calendar-check"></i>
                    <div>
                        <label>Last Day of Work</label>
                        <span>@(Model.EmployeeDetails?.LastDayOfWork?.ToString("dd MMM yyyy") ?? "-")</span>
                    </div>
                </div>
                <div class="detail-item">
                    <i class="fas fa-chart-line"></i>
                    <div>
                        <label>Length of Service</label>
                        <span>@Model.EmployeeDetails?.LengthOfService</span>
                    </div>
                </div>
                <div class="detail-item">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <label>Email</label>
                        <span>@Model.EmployeeDetails?.Email</span>
                    </div>
                </div>
                <div class="detail-item">
                    <i class="fas fa-user-tie"></i>
                    <div>
                        <label>Supervisor</label>
                        <span>@Model.EmployeeDetails?.Supervisor</span>
                    </div>
                </div>
                <div class="detail-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <div>
                        <label>Forwarding Address</label>
                        <span>@Model.EmployeeDetails?.ForwardingAddress</span>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <!-- Clearance Sections - 2x2 Grid -->
    <div class="clearance-grid">
        <!-- Finance Clearance -->
        <div class="clearance-card finance">
            <div class="clearance-header">
                <div class="header-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>Finance Clearance</h3>
                <a asp-action="FinanceReview"
                   asp-route-id="@Model.ExitClearance.Id"
                   class="btn btn-sm btn-light">
                    <i class="fas fa-edit"></i> Edit
                </a>
                <span class="section-badge">Financial</span>
            </div>
            <div class="clearance-body">
                <div class="clearance-item">
                    <div class="item-title">Staff Advance and Other Liabilities</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.FinanceClearance?.StaffAdvanceReference ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.FinanceClearance?.StaffAdvanceReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.FinanceClearance?.StaffAdvanceDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Receipts Handed Over To Finance</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.FinanceClearance?.ReceiptsReference ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.FinanceClearance?.ReceiptsReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.FinanceClearance?.ReceiptsDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Final Dues To Be Paid To Employee</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.FinanceClearance?.FinalDuesReference ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.FinanceClearance?.FinalDuesReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.FinanceClearance?.FinalDuesDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.FinanceClearance?.Comments))
                {
                    <div class="comment-box">
                        <i class="fas fa-comment-dots"></i>
                        <p>@Model.FinanceClearance.Comments</p>
                    </div>
                }
            </div>
        </div>

        <!-- Systems Administration Clearance -->
        <div class="clearance-card systems">
            <div class="clearance-header">
                <div class="header-icon">
                    <i class="fas fa-server"></i>
                </div>
                <h3>Systems Administration</h3>
                <a asp-action="SystemsAdminReview"
                   asp-route-id="@Model.ExitClearance.Id"
                   class="btn btn-sm btn-light">
                    Edit
                </a>
                <span class="section-badge">IT Assets</span>
            </div>
            <div class="clearance-body">
                <div class="clearance-item">
                    <div class="item-title">Laptop</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.LaptopAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.LaptopReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.LaptopDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Laptop Bags</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.LaptopBagAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.LaptopBagReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.LaptopBagDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Accessories</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.AccessoriesAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.AccessoriesReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.AccessoriesDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Laptop Locker</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.LockerAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.LockerReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.LockerDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Endpoint Security</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.EndpointSecurityAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.EndpointSecurityReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.EndpointSecurityDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">System Access Removed</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.AccessRemovalAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.AccessRemovalReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.AccessRemovalDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Email Disabled / Redirected</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.EmailAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.EmailReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.EmailDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Removed From Social Media Groups</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.SystemsAdminClearance?.SocialMediaAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.SystemsAdminClearance?.SocialMediaReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.SystemsAdminClearance?.SocialMediaDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.SystemsAdminClearance?.Comments))
                {
                    <div class="comment-box">
                        <i class="fas fa-comment-dots"></i>
                        <p>@Model.SystemsAdminClearance.Comments</p>
                    </div>
                }
            </div>
        </div>

        <!-- Human Resources Clearance -->
        <div class="clearance-card hr">
            <div class="clearance-header">
                <div class="header-icon">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Human Resources</h3>
                <a asp-action="HrReview"
                   asp-route-id="@Model.ExitClearance.Id"
                   class="btn btn-sm btn-light">
                    Edit
                </a>
                <span class="section-badge">HR Process</span>
            </div>
            <div class="clearance-body">
                <div class="clearance-item">
                    <div class="item-title">Resignation Letter</div>
                    <div class="item-details">
                        <span><i class="fas fa-user-check"></i> @(Model.HrApproval?.ResignationLetterReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.HrApproval?.ResignationLetterDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        <span class="status-badge @(Model.HrApproval?.ResignationLetterReceived == true ? "status-completed" : "status-pending")">
                            @(Model.HrApproval?.ResignationLetterReceived == true ? "Completed" : "Pending")
                        </span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Staff ID Card</div>
                    <div class="item-details">
                        <span><i class="fas fa-user-check"></i> @(Model.HrApproval?.StaffIdReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.HrApproval?.StaffIdDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        <span class="status-badge @(Model.HrApproval?.StaffIdReturned == true ? "status-completed" : "status-pending")">
                            @(Model.HrApproval?.StaffIdReturned == true ? "Completed" : "Pending")
                        </span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Medical Aid Cancellation</div>
                    <div class="item-details">
                        <span><i class="fas fa-user-check"></i> @(Model.HrApproval?.MedicalAidReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.HrApproval?.MedicalAidDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        <span class="status-badge @(Model.HrApproval?.MedicalAidCancelled == true ? "status-completed" : "status-pending")">
                            @(Model.HrApproval?.MedicalAidCancelled == true ? "Completed" : "Pending")
                        </span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">NSSA Cancellation</div>
                    <div class="item-details">
                        <span><i class="fas fa-user-check"></i> @(Model.HrApproval?.NSSAReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.HrApproval?.NSSADate?.ToString("dd MMM yyyy") ?? "—")</span>
                        <span class="status-badge @(Model.HrApproval?.NSSACancelled == true ? "status-completed" : "status-pending")">
                            @(Model.HrApproval?.NSSACancelled == true ? "Completed" : "Pending")
                        </span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Funeral Policy Cancellation</div>
                    <div class="item-details">
                        <span><i class="fas fa-user-check"></i> @(Model.HrApproval?.FuneralPolicyReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.HrApproval?.FuneralPolicyDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        <span class="status-badge @(Model.HrApproval?.FuneralPolicyCancelled == true ? "status-completed" : "status-pending")">
                            @(Model.HrApproval?.FuneralPolicyCancelled == true ? "Completed" : "Pending")
                        </span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Exit Interview</div>
                    <div class="item-details">
                        <span><i class="fas fa-user-check"></i> @(Model.HrApproval?.ExitInterviewReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.HrApproval?.ExitInterviewDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        <span class="status-badge @(Model.HrApproval?.ExitInterviewCompleted == true ? "status-completed" : "status-pending")">
                            @(Model.HrApproval?.ExitInterviewCompleted == true ? "Completed" : "Pending")
                        </span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Handover Report</div>
                    <div class="item-details">
                        <span><i class="fas fa-user-check"></i> @(Model.HrApproval?.HandoverReportReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.HrApproval?.HandoverReportDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        <span class="status-badge @(Model.HrApproval?.HandoverReportSubmitted == true ? "status-completed" : "status-pending")">
                            @(Model.HrApproval?.HandoverReportSubmitted == true ? "Completed" : "Pending")
                        </span>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.HrApproval?.Comments))
                {
                    <div class="comment-box">
                        <i class="fas fa-comment-dots"></i>
                        <p>@Model.HrApproval.Comments</p>
                    </div>
                }
            </div>
        </div>

        <!-- Development Clearance -->
        <div class="clearance-card development">
            <div class="clearance-header">
                <div class="header-icon">
                    <i class="fas fa-code"></i>
                </div>
                <h3>Development</h3>
                <a asp-action="DevelopmentReview"
                   asp-route-id="@Model.ExitClearance.Id"
                   class="btn btn-sm btn-light">
                    Edit
                </a>
                <span class="section-badge">Dev Access</span>
            </div>
            <div class="clearance-body">
                <div class="clearance-item">
                    <div class="item-title">Bitbucket Administration Credentials</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.DevelopmentClearance?.BitbucketAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.DevelopmentClearance?.BitbucketReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.DevelopmentClearance?.BitbucketDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Project Management Credentials</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.DevelopmentClearance?.ProjectManagementAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.DevelopmentClearance?.ProjectManagementReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.DevelopmentClearance?.ProjectManagementDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                <div class="clearance-item">
                    <div class="item-title">Manage Engine Credentials</div>
                    <div class="item-details">
                        <span><i class="fas fa-hashtag"></i> @(Model.DevelopmentClearance?.ManageEngineAsset ?? "—")</span>
                        <span><i class="fas fa-user-check"></i> @(Model.DevelopmentClearance?.ManageEngineReceivedBy ?? "—")</span>
                        <span><i class="fas fa-calendar"></i> @(Model.DevelopmentClearance?.ManageEngineDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.DevelopmentClearance?.Comments))
                {
                    <div class="comment-box">
                        <i class="fas fa-comment-dots"></i>
                        <p>@Model.DevelopmentClearance.Comments</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 1.5rem;
        padding: 2rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        box-shadow: var(--shadow-lg);
    }

    .hero-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hero-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
    }

    .hero-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.25rem 0;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .hero-btn {
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }

    .hero-btn-edit {
        background: white;
        color: #667eea;
    }

        .hero-btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: #667eea;
            text-decoration: none;
        }

    .hero-btn-back {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

        .hero-btn-back:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    .hero-btn-print {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

        .hero-btn-print:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            color: white;
        }

    /* Profile Card */
    .profile-card {
        background: white;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-md);
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .profile-header {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        color: white;
    }

    .profile-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.5rem 0;
    }

    .profile-badges {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-primary {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

    .badge-info {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    .profile-details {
        padding: 1.5rem;
    }

    /* 3x3 Grid for Employee Details */
    .detail-group {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .detail-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        background: var(--gray-50);
        border-radius: 0.75rem;
        transition: all 0.2s;
    }

        .detail-item:hover {
            background: var(--gray-100);
            transform: translateY(-2px);
        }

        .detail-item i {
            width: 32px;
            height: 32px;
            background: white;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 0.875rem;
