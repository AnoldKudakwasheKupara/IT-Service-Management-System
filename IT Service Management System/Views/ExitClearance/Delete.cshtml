@model ExitClearance

@{
    ViewData["Title"] = "Delete Clearance - Axis IT Helpdesk";
}

<div class="page-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-icon">
                <i class="fas fa-trash-alt"></i>
            </div>
            <div>
                <h1 class="hero-title">Delete Clearance</h1>
                <p class="hero-subtitle">This action cannot be undone</p>
            </div>
        </div>
        <div class="hero-actions">
            <a asp-action="Index" class="hero-btn hero-btn-back">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Warning Card -->
    <div class="warning-card">
        <div class="warning-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div class="warning-content">
            <h3 class="warning-title">Are you absolutely sure?</h3>
            <p class="warning-message">This action will permanently delete this clearance record from the system.</p>
        </div>
    </div>

    <!-- Clearance Details Card -->
    <div class="clearance-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-sign-out-alt me-2"></i>
                <span>Clearance to Delete</span>
            </div>
            <div class="clearance-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- Employee Info Summary -->
            <div class="employee-summary">
                <div class="employee-avatar">
                    @{
                        var firstName = Model.Employee?.FirstName ?? "E";
                        var lastName = Model.Employee?.LastName ?? "M";
                    }
                    @((firstName.Substring(0, 1)) + (lastName.Substring(0, 1)))
                </div>
                <div class="employee-info">
                    <h4 class="employee-name">@Model.Employee?.FirstName @Model.Employee?.LastName</h4>
                    <span class="employee-id">Employee ID: @Model.EmployeeId</span>
                </div>
                <div class="clearance-stage">
                    <span class="stage-badge @(Model.CurrentStage.ToString().ToLower())">
                        <i class="fas fa-chart-line"></i>
                        @Model.CurrentStage
                    </span>
                </div>
            </div>

            <!-- Warning Details -->
            <div class="warning-details">
                <div class="warning-detail-item">
                    <i class="fas fa-database"></i>
                    <div>
                        <strong>Data Loss Warning</strong>
                        <span>This clearance record will be permanently deleted from the system.</span>
                    </div>
                </div>
                <div class="warning-detail-item">
                    <i class="fas fa-clock"></i>
                    <div>
                        <strong>Irreversible Action</strong>
                        <span>This action cannot be undone. You will not be able to recover this clearance.</span>
                    </div>
                </div>
                <div class="warning-detail-item">
                    <i class="fas fa-chart-line"></i>
                    <div>
                        <strong>Workflow Impact</strong>
                        <span>All associated workflow history will also be deleted.</span>
                    </div>
                </div>
            </div>

            <!-- Confirmation Checkbox -->
            <div class="confirmation-checkbox">
                <input type="checkbox" id="confirmDelete" required>
                <label for="confirmDelete">
                    I understand that this action is permanent and cannot be undone
                </label>
            </div>

            <!-- Form Actions -->
            <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" id="deleteForm" class="delete-form">
                @Html.AntiForgeryToken()

                <div class="form-actions">
                    <button type="submit" class="btn-delete" id="deleteButton" disabled>
                        <i class="fas fa-trash-alt"></i>
                        Permanently Delete Clearance
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --danger-dark: #c53030;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, var(--danger-dark), var(--danger));
        border-radius: 1.5rem;
        padding: 2rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        box-shadow: var(--shadow-lg);
    }

    .hero-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hero-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
    }

    .hero-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.25rem 0;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .hero-btn {
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }

    .hero-btn-back {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

        .hero-btn-back:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    /* Warning Card */
    .warning-card {
        background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);
        border: 1px solid #fed7d7;
        border-radius: 1rem;
        padding: 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .warning-icon {
        width: 60px;
        height: 60px;
        background: var(--danger);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .warning-icon i {
            font-size: 1.75rem;
            color: white;
        }

    .warning-content {
        flex: 1;
    }

    .warning-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--danger-dark);
        margin: 0 0 0.25rem 0;
    }

    .warning-message {
        color: var(--gray-600);
        margin: 0;
        font-size: 0.875rem;
    }

    /* Clearance Details Card */
    .clearance-details-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .clearance-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Employee Summary */
    .employee-summary {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--gray-200);
    }

    .employee-avatar {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .employee-info {
        flex: 1;
    }

    .employee-name {
        font-size: 1rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 0.25rem 0;
    }

    .employee-id {
        font-size: 0.75rem;
        color: var(--gray-500);
    }

    .clearance-stage {
        flex-shrink: 0;
    }

    .stage-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 600;
    }

        .stage-badge.employee {
            background: #e6f0ff;
            color: var(--info);
        }

        .stage-badge.finance {
            background: #e6f5e9;
            color: var(--success);
        }

        .stage-badge.systemsadmin {
            background: #e6e6ff;
            color: #6366f1;
        }

        .stage-badge.development {
            background: #ffe6e6;
            color: #f5576c;
        }

        .stage-badge.supervisor {
            background: #fff5e6;
            color: var(--warning);
        }

        .stage-badge.hod {
            background: #e6e6ff;
            color: #8e2de2;
        }

        .stage-badge.hr {
            background: #e6f0ff;
            color: var(--info);
        }

        .stage-badge.completed {
            background: #e6f5e9;
            color: var(--success);
        }

    /* Warning Details */
    .warning-details {
        background: #fff5f5;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        border-left: 3px solid var(--danger);
    }

    .warning-detail-item {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
    }

        .warning-detail-item i {
            font-size: 1rem;
            color: var(--danger);
            margin-top: 0.125rem;
        }

        .warning-detail-item div {
            flex: 1;
        }

        .warning-detail-item strong {
            display: block;
            font-size: 0.875rem;
            color: var(--gray-700);
            margin-bottom: 0.25rem;
        }

        .warning-detail-item span {
            font-size: 0.75rem;
            color: var(--gray-500);
            line-height: 1.4;
        }

    /* Confirmation Checkbox */
    .confirmation-checkbox {
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: var(--gray-50);
        border-radius: 0.75rem;
        border-left: 3px solid var(--danger);
    }

        .confirmation-checkbox input[type="checkbox"] {
            margin-right: 0.75rem;
            cursor: pointer;
            width: 18px;
            height: 18px;
        }

        .confirmation-checkbox label {
            color: var(--gray-700);
            font-size: 0.875rem;
            cursor: pointer;
            user-select: none;
        }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-delete {
        background: linear-gradient(100deg, var(--danger-dark), var(--danger));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-delete:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            filter: brightness(1.05);
        }

        .btn-delete:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const confirmCheckbox = document.getElementById('confirmDelete');
        const deleteButton = document.getElementById('deleteButton');
        const deleteForm = document.getElementById('deleteForm');

        // Enable/disable delete button based on checkbox
        if (confirmCheckbox && deleteButton) {
            confirmCheckbox.addEventListener('change', function() {
                deleteButton.disabled = !this.checked;
            });
        }

        // Form submission with additional confirmation
        if (deleteForm) {
            deleteForm.addEventListener('submit', function(e) {
                if (!confirmCheckbox.checked) {
                    e.preventDefault();
                    showWarningToast('Please confirm that you understand this action is permanent');
                    confirmCheckbox.focus();
                    return false;
                }

                // Final confirmation dialog
                const employeeName = '@(Model.Employee?.FirstName ?? "this employee") @(Model.Employee?.LastName ?? "")';
                const confirmed = confirm(
                    '⚠️ WARNING: This action is permanent and cannot be undone.\n\n' +
                    `Are you absolutely sure you want to delete clearance for ${employeeName}?\n\n` +
                    'This will permanently delete:\n' +
                    '• All clearance information\n' +
                    '• Workflow history\n' +
                    '• Associated approval records\n\n' +
                    'This action cannot be reversed.'
                );

                if (!confirmed) {
                    e.preventDefault();
                    return false;
                }

                // Disable button to prevent double submission
                deleteButton.disabled = true;
                deleteButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';
            });
        }

        function showWarningToast(message) {
            const existingToast = document.querySelector('.warning-toast');
            if (existingToast) existingToast.remove();

            const toast = document.createElement('div');
            toast.className = 'warning-toast';
            toast.style.cssText = `
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                animation: slideIn 0.3s ease;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
            `;
            toast.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.animation = 'slideOut 0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // Add hover effect to delete button when checkbox is checked
        if (confirmCheckbox && deleteButton) {
            confirmCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    deleteButton.style.animation = 'shake 0.5s ease';
                    setTimeout(() => {
                        deleteButton.style.animation = '';
                    }, 500);
                }
            });
        }
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">