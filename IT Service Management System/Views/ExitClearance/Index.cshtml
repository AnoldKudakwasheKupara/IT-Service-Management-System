@model List<ExitClearance>

<div class="d-flex justify-content-between align-items-center mb-3">

    <h3>Exit Clearances</h3>

    @if (User.IsInRole("SystemsAdmin"))
    {
        <a asp-action="Create"
           class="btn btn-primary">
            Create Clearance
        </a>
    }

</div>

<div class="card">

    <div class="card-body">

        <table class="table table-striped">

            <thead>

                <tr>
                    <th>Employee</th>
                    <th>Status</th>
                    <th>Current Stage</th>
                    <th width="250">Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @item.Employee.FirstName
                            @item.Employee.LastName
                        </td>

                        <td>
                            @item.Status
                        </td>

                        <td>
                            @item.CurrentStage
                        </td>

                        <td>

                            <a asp-action="Open"
                               asp-route-id="@item.Id"
                               class="btn btn-success btn-sm">
                                Open
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm">
                                View
                            </a>

                            @if (item.CurrentStage == ClearanceStage.Employee
                                && item.EmployeeSubmittedDate == null)
                            {
                                <a asp-action="Send"
                                   asp-route-id="@item.Id"
                                   class="btn btn-success btn-sm">

                                    Send
                                </a>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>