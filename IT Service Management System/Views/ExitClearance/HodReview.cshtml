@model HodApproval

@{
    ViewData["Title"] = "HOD Handover Confirmation - Axis IT Helpdesk";
}

<div class="page-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-icon">
                <i class="fas fa-user-tie"></i>
            </div>
            <div>
                <h1 class="hero-title">Head of Department Handover Confirmation</h1>
                <p class="hero-subtitle">Confirm handover and forward to HR for final processing</p>
            </div>
        </div>
        <div class="hero-actions">
            <a asp-action="PendingHod" class="hero-btn hero-btn-back">
                <i class="fas fa-arrow-left"></i> Back to Pending
            </a>
        </div>
    </div>

    <!-- Confirmation Form Card -->
    <div class="confirmation-form-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-user-tie me-2"></i>
                <span>HOD Handover Confirmation</span>
            </div>
            <div class="form-steps">
                <span class="step active">1</span>
                <span class="step-line"></span>
                <span class="step">2</span>
                <span class="step-line"></span>
                <span class="step">3</span>
            </div>
        </div>

        <div class="card-body-custom">
            <form asp-action="HodReview" method="post" id="hodForm">
                @Html.AntiForgeryToken()
                <input asp-for="ExitClearanceId" type="hidden" />

                <!-- Confirmation Section -->
                <div class="confirmation-section">
                    <div class="confirmation-text">
                        <label class="form-label">I,</label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-signature input-icon"></i>
                            <input asp-for="ConfirmedBy" class="form-control-modern" placeholder="Enter your full name" />
                        </div>
                        <span class="confirmation-suffix">confirm the handover of the above-listed items.</span>
                    </div>
                    <span asp-validation-for="ConfirmedBy" class="validation-message text-danger"></span>
                    <div class="form-hint">
                        <i class="fas fa-info-circle"></i> Type your full name as confirmation
                    </div>
                </div>

                <!-- Handover Details Row -->
                <div class="form-row">
                    <div class="form-group-modern">
                        <label asp-for="HandoverSignature" class="form-label">
                            <i class="fas fa-signature"></i>
                            Handover Signature
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-pen input-icon"></i>
                            <input asp-for="HandoverSignature" class="form-control-modern" placeholder="Type your signature" />
                        </div>
                        <span asp-validation-for="HandoverSignature" class="validation-message text-danger"></span>
                        <div class="form-hint">
                            <i class="fas fa-info-circle"></i> Electronic signature for handover confirmation
                        </div>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="HandoverDate" class="form-label">
                            <i class="fas fa-calendar-alt"></i>
                            Date
                        </label>
                        <div class="input-icon-wrapper">
                            <i class="fas fa-calendar-alt input-icon"></i>
                            <input asp-for="HandoverDate" type="date" class="form-control-modern" />
                        </div>
                        <span asp-validation-for="HandoverDate" class="validation-message text-danger"></span>
                        <div class="form-hint">
                            <i class="fas fa-info-circle"></i> Date of handover confirmation
                        </div>
                    </div>
                </div>

                <!-- Comments Section -->
                <div class="comments-section">
                    <div class="comments-header">
                        <i class="fas fa-comment-dots"></i>
                        <span>Comments</span>
                    </div>
                    <div class="textarea-wrapper">
                        <i class="fas fa-pen textarea-icon"></i>
                        <textarea asp-for="Comments" class="form-control-textarea" rows="4" placeholder="Enter any additional comments or notes..."></textarea>
                    </div>
                    <span asp-validation-for="Comments" class="validation-message text-danger"></span>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-confirm" id="submitBtn">
                        <i class="fas fa-check-circle"></i>
                        Confirm & Forward To HR
                    </button>
                    <a asp-action="PendingHod" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #2563eb;
        --primary: #3b82f6;
        --primary-light: #60a5fa;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, #8e2de2, #4a00e0);
        border-radius: 1.5rem;
        padding: 2rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        box-shadow: var(--shadow-lg);
    }

    .hero-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hero-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
    }

    .hero-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.25rem 0;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
        font-size: 0.875rem;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .hero-btn {
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }

    .hero-btn-back {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

        .hero-btn-back:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

    /* Confirmation Form Card */
    .confirmation-form-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .form-steps {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .step {
        width: 30px;
        height: 30px;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

        .step.active {
            background: var(--success);
            border-color: var(--success);
            color: white;
        }

    .step-line {
        width: 40px;
        height: 2px;
        background: var(--gray-300);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Confirmation Section */
    .confirmation-section {
        margin-bottom: 2rem;
    }

    .confirmation-text {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

        .confirmation-text .form-label {
            margin: 0;
            font-weight: 600;
            color: var(--gray-700);
        }

        .confirmation-text .input-icon-wrapper {
            flex: 1;
            min-width: 200px;
        }

    .confirmation-suffix {
        color: var(--gray-600);
        font-size: 0.875rem;
    }

    /* Form Row */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-label i {
            color: var(--primary);
            font-size: 0.875rem;
        }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i.input-icon {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray-400);
            font-size: 0.875rem;
            pointer-events: none;
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59,130,246, 0.1);
        }

    input[type="date"].form-control-modern {
        padding-right: 0.75rem;
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-hint i {
            font-size: 0.7rem;
        }

    /* Comments Section */
    .comments-section {
        margin-bottom: 2rem;
    }

    .comments-header {
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .comments-header i {
            color: var(--primary);
        }

    .textarea-wrapper {
        position: relative;
    }

    .textarea-icon {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
        resize: vertical;
    }

        .form-control-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59,130,246, 0.1);
        }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1rem;
    }

    .btn-confirm {
        background: linear-gradient(100deg, #8e2de2, #4a00e0);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-confirm:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('hodForm');
        const submitBtn = document.getElementById('submitBtn');

        if (form) {
            form.addEventListener('submit', function(e) {
                const confirmedBy = document.querySelector('[name="ConfirmedBy"]')?.value.trim();
                const handoverSignature = document.querySelector('[name="HandoverSignature"]')?.value.trim();
                const handoverDate = document.querySelector('[name="HandoverDate"]')?.value;

                if (!confirmedBy) {
                    e.preventDefault();
                    showValidationError('Confirmed by name is required');
                    document.querySelector('[name="ConfirmedBy"]').focus();
                    return false;
                }

                if (confirmedBy.length < 2) {
                    e.preventDefault();
                    showValidationError('Please enter a valid name');
                    document.querySelector('[name="ConfirmedBy"]').focus();
                    return false;
                }

                if (!handoverSignature) {
                    e.preventDefault();
                    showValidationError('Handover signature is required');
                    document.querySelector('[name="HandoverSignature"]').focus();
                    return false;
                }

                if (!handoverDate) {
                    e.preventDefault();
                    showValidationError('Handover date is required');
                    document.querySelector('[name="HandoverDate"]').focus();
                    return false;
                }

                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

                return true;
            });
        }

        function showValidationError(message) {
            const errorDiv = document.createElement('div');
            errorDiv.className = 'alert-toast error';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: #fee;
                border-left: 4px solid var(--danger);
                border-radius: 0.75rem;
                padding: 1rem 1.25rem;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                color: var(--danger);
                font-weight: 500;
                z-index: 1050;
                animation: slideIn 0.3s ease;
                box-shadow: var(--shadow-lg);
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
                <button type="button" style="margin-left: auto; background: none; border: none; cursor: pointer; color: inherit;" onclick="this.parentElement.remove()">
                    <i class="fas fa-times"></i>
                </button>
            `;
            document.body.appendChild(errorDiv);

            setTimeout(() => {
                errorDiv.style.opacity = '0';
                setTimeout(() => errorDiv.remove(), 300);
            }, 5000);
        }
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}