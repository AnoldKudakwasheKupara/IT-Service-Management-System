@model HodApproval

<div class="card">

    <div class="card-header">
        <h4>Head of Department Handover Confirmation</h4>
    </div>

    <div class="card-body">

        <form asp-action="HodReview" method="post">

            <input asp-for="ExitClearanceId" type="hidden" />

            <div class="mb-4">

                <label class="form-label">
                    I,
                </label>

                <input asp-for="ConfirmedBy"
                       class="form-control" />

                <small class="text-muted">
                    confirm the handover of the above-listed items.
                </small>

            </div>

            <div class="row">

                <div class="col-md-6">

                    <label class="form-label">
                        Handover Signature
                    </label>

                    <input asp-for="HandoverSignature"
                           class="form-control" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Date
                    </label>

                    <input asp-for="HandoverDate"
                           type="date"
                           class="form-control" />

                </div>

            </div>

            <div class="mt-4">

                <label class="form-label">
                    Comments
                </label>

                <textarea asp-for="Comments"
                          rows="4"
                          class="form-control">
                </textarea>

            </div>

            <div class="mt-3">

                <button type="submit"
                        class="btn btn-success">
                    Confirm & Forward To HR
                </button>

            </div>

        </form>

    </div>

</div>