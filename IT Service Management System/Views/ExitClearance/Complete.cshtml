@model IT_Service_Management_System.ViewModels.EmployeeClearanceVM

@{
    ViewData["Title"] = "Employee Exit Clearance - Axis IT Helpdesk";
}

<div class="page-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-icon">
                <i class="fas fa-sign-out-alt"></i>
            </div>
            <div>
                <h1 class="hero-title">Employee Exit Clearance</h1>
                <p class="hero-subtitle">Please complete the form below to initiate your clearance process</p>
            </div>
        </div>
    </div>

    <!-- Clearance Form Card -->
    <div class="clearance-form-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-user-circle me-2"></i>
                <span>Employee Exit Clearance Form</span>
            </div>
            <div class="form-steps">
                <span class="step active">1</span>
                <span class="step-line"></span>
                <span class="step">2</span>
                <span class="step-line"></span>
                <span class="step">3</span>
            </div>
        </div>

        <div class="card-body-custom">
            <form asp-action="Complete" method="post" id="clearanceForm">
                @Html.AntiForgeryToken()
                <input asp-for="ExitClearanceId" type="hidden" />
                <input asp-for="AccessToken" type="hidden" />

                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Surname" class="form-label">
                                <i class="fas fa-user"></i>
                                Surname
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-user input-icon"></i>
                                <input asp-for="Surname" class="form-control-modern" placeholder="Enter your surname" />
                            </div>
                            <span asp-validation-for="Surname" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Department" class="form-label">
                                <i class="fas fa-building"></i>
                                Department
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-building input-icon"></i>
                                <input asp-for="Department" class="form-control-modern" placeholder="Enter your department" />
                            </div>
                            <span asp-validation-for="Department" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Supervisor" class="form-label">
                                <i class="fas fa-user-tie"></i>
                                Supervisor
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-user-tie input-icon"></i>
                                <input asp-for="Supervisor" class="form-control-modern" placeholder="Enter supervisor name" />
                            </div>
                            <span asp-validation-for="Supervisor" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="PositionHeld" class="form-label">
                                <i class="fas fa-briefcase"></i>
                                Position Held
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-briefcase input-icon"></i>
                                <input asp-for="PositionHeld" class="form-control-modern" placeholder="Enter your position" />
                            </div>
                            <span asp-validation-for="PositionHeld" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="LengthOfService" class="form-label">
                                <i class="fas fa-chart-line"></i>
                                Length Of Service
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-alt input-icon"></i>
                                <input asp-for="LengthOfService" class="form-control-modern" placeholder="e.g., 3 years" />
                            </div>
                            <span asp-validation-for="LengthOfService" class="validation-message text-danger"></span>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="DateOfNotice" class="form-label">
                                <i class="fas fa-calendar-alt"></i>
                                Date Of Notice
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-alt input-icon"></i>
                                <input asp-for="DateOfNotice" type="date" class="form-control-modern" />
                            </div>
                            <span asp-validation-for="DateOfNotice" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="LastDayOfWork" class="form-label">
                                <i class="fas fa-calendar-check"></i>
                                Last Day Of Work
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-check input-icon"></i>
                                <input asp-for="LastDayOfWork" type="date" class="form-control-modern" />
                            </div>
                            <span asp-validation-for="LastDayOfWork" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Email" class="form-label">
                                <i class="fas fa-envelope"></i>
                                Email
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-envelope input-icon"></i>
                                <input asp-for="Email" type="email" class="form-control-modern" placeholder="your.email@company.com" />
                            </div>
                            <span asp-validation-for="Email" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="ForwardingAddress" class="form-label">
                                <i class="fas fa-map-marker-alt"></i>
                                Forwarding Address
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-map-marker-alt input-icon"></i>
                                <input asp-for="ForwardingAddress" class="form-control-modern" placeholder="Enter forwarding address" />
                            </div>
                            <span asp-validation-for="ForwardingAddress" class="validation-message text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="EmployeeSignature" class="form-label">
                                <i class="fas fa-signature"></i>
                                Employee Signature
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-pen input-icon"></i>
                                <input asp-for="EmployeeSignature" class="form-control-modern" placeholder="Type your full name as signature" />
                            </div>
                            <span asp-validation-for="EmployeeSignature" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Typing your full name serves as your electronic signature
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fas fa-paper-plane"></i>
                        Submit Clearance Form
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        border-radius: 1.5rem;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-lg);
    }

    .hero-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hero-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
    }

    .hero-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.25rem 0;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    /* Clearance Form Card */
    .clearance-form-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .form-steps {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .step {
        width: 30px;
        height: 30px;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

        .step.active {
            background: var(--success);
            border-color: var(--success);
            color: white;
        }

    .step-line {
        width: 40px;
        height: 2px;
        background: var(--gray-300);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-label i {
            color: var(--primary);
            font-size: 0.875rem;
        }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i.input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray-400);
            font-size: 0.875rem;
            pointer-events: none;
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
        }

    input[type="date"].form-control-modern {
        padding-right: 0.75rem;
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-hint i {
            font-size: 0.7rem;
        }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-submit {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        width: 100%;
        justify-content: center;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('clearanceForm');
        const submitBtn = document.getElementById('submitBtn');

        if (form) {
            form.addEventListener('submit', function(e) {
                // Basic validation
                const surname = document.querySelector('[name="Surname"]')?.value.trim();
                const department = document.querySelector('[name="Department"]')?.value.trim();
                const email = document.querySelector('[name="Email"]')?.value.trim();
                const signature = document.querySelector('[name="EmployeeSignature"]')?.value.trim();

                if (!surname) {
                    e.preventDefault();
                    showValidationError('Surname is required');
                    document.querySelector('[name="Surname"]').focus();
                    return false;
                }

                if (!department) {
                    e.preventDefault();
                    showValidationError('Department is required');
                    document.querySelector('[name="Department"]').focus();
                    return false;
                }

                if (!email) {
                    e.preventDefault();
                    showValidationError('Email is required');
                    document.querySelector('[name="Email"]').focus();
                    return false;
                }

                // Email format validation
                const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                if (!emailRegex.test(email)) {
                    e.preventDefault();
                    showValidationError('Please enter a valid email address');
                    document.querySelector('[name="Email"]').focus();
                    return false;
                }

                if (!signature) {
                    e.preventDefault();
                    showValidationError('Employee signature is required');
                    document.querySelector('[name="EmployeeSignature"]').focus();
                    return false;
                }

                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';

                return true;
            });
        }

        function showValidationError(message) {
            const errorDiv = document.createElement('div');
            errorDiv.className = 'alert-toast error';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: #fee;
                border-left: 4px solid var(--danger);
                border-radius: 0.75rem;
                padding: 1rem 1.25rem;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                color: var(--danger);
                font-weight: 500;
                z-index: 1050;
                animation: slideIn 0.3s ease;
                box-shadow: var(--shadow-lg);
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
                <button type="button" style="margin-left: auto; background: none; border: none; cursor: pointer; color: inherit;" onclick="this.parentElement.remove()">
                    <i class="fas fa-times"></i>
                </button>
            `;
            document.body.appendChild(errorDiv);

            setTimeout(() => {
                errorDiv.style.opacity = '0';
                setTimeout(() => errorDiv.remove(), 300);
            }, 5000);
        }
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}