@model IEnumerable<IT_Service_Management_System.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs - Axis IT Helpdesk";
    
    // Pagination values
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
    var hasPreviousPage = ViewBag.HasPreviousPage ?? false;
    var hasNextPage = ViewBag.HasNextPage ?? false;
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-controller="Home" asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-history me-2" style="color: var(--info);"></i>
                    Audit Logs
                </h1>
                <p class="text-muted mt-2">Track system activity and user actions</p>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-cards mb-4">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="stat-info">
                <h3>@ViewBag.TotalCount</h3>
                <p>Total Events</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon created">
                <i class="fas fa-plus-circle"></i>
            </div>
            <div class="stat-info">
                <h3>@ViewBag.CreatedCount</h3>
                <p>Created</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon updated">
                <i class="fas fa-edit"></i>
            </div>
            <div class="stat-info">
                <h3>@ViewBag.UpdatedCount</h3>
                <p>Updated</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon deleted">
                <i class="fas fa-trash-alt"></i>
            </div>
            <div class="stat-info">
                <h3>@ViewBag.DeletedCount</h3>
                <p>Deleted</p>
            </div>
        </div>
    </div>

    <!-- Audit Logs Table -->
    <div class="logs-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-list me-2"></i>
                <span>Activity Log</span>
            </div>
            <div class="log-count">
                <i class="fas fa-chart-simple"></i>
                <span>@ViewBag.TotalCount</span> total entries | Showing @Model.Count() on page @currentPage of @totalPages
            </div>
        </div>

        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="logs-table">
                    <thead>
                        <tr>
                            <th><i class="fas fa-user me-1"></i> User</th>
                            <th><i class="fas fa-tag me-1"></i> Action</th>
                            <th><i class="fas fa-database me-1"></i> Entity</th>
                            <th><i class="fas fa-info-circle me-1"></i> Details</th>
                            <th><i class="fas fa-network-wired me-1"></i> IP Address</th>
                            <th><i class="fas fa-calendar me-1"></i> Date & Time</th>
                            <th><i class="fas fa-map-marker-alt me-1"></i> Location</th>
                            <th><i class="fas fa-laptop me-1"></i> Device</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td class="user-cell">
                                    <div class="user-info">
                                        <div class="user-avatar-small">
                                            @(log.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                        <span>@log.UserName</span>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var action = log.Action;
                                        if (action == "Created")
                                        {
                                            <span class="action-badge action-created">
                                                <i class="fas fa-plus-circle"></i> Created
                                            </span>
                                        }
                                        else if (action == "Updated")
                                        {
                                            <span class="action-badge action-updated">
                                                <i class="fas fa-edit"></i> Updated
                                            </span>
                                        }
                                        else if (action == "Deleted")
                                        {
                                            <span class="action-badge action-deleted">
                                                <i class="fas fa-trash-alt"></i> Deleted
                                            </span>
                                        }
                                        else if (action == "Login")
                                        {
                                            <span class="action-badge action-login">
                                                <i class="fas fa-sign-in-alt"></i> Login
                                            </span>
                                        }
                                        else if (action == "Logout")
                                        {
                                            <span class="action-badge action-logout">
                                                <i class="fas fa-sign-out-alt"></i> Logout
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="action-badge action-other">
                                                <i class="fas fa-circle"></i> @action
                                            </span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (log.Entity == "Ticket")
                                    {
                                        <span class="entity-badge entity-ticket">
                                            <i class="fas fa-ticket-alt"></i> Ticket
                                        </span>
                                    }
                                    else if (log.Entity == "User")
                                    {
                                        <span class="entity-badge entity-user">
                                            <i class="fas fa-user"></i> User
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="entity-badge entity-other">@log.Entity</span>
                                    }
                                </td>
                                <td class="details-cell" title="@log.Details">
                                    @(log.Details?.Length > 50 ? log.Details.Substring(0, 50) + "..." : log.Details)
                                </td>
                                <td class="ip-cell">
                                    <code>@log.IpAddress</code>
                                </td>
                                <td class="date-cell">
                                    <i class="far fa-calendar-alt"></i>
                                    @log.Timestamp.ToString("yyyy-MM-dd HH:mm")
                                </td>
                                <td class="location-cell">
                                    <i class="fas fa-map-marker-alt"></i>
                                    @log.Location
                                </td>
                                <td class="device-cell">
                                    <i class="fas @(log.Device?.Contains("Mobile") == true ? "fa-mobile-alt" : "fa-laptop")"></i>
                                    @log.Device
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-history"></i>
                    <h3>No audit logs found</h3>
                    <p>There are no activity logs to display at this time</p>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    Showing page @currentPage of @totalPages
                </div>
                <div class="pagination-controls">
                    @if (hasPreviousPage)
                    {
                        <a asp-action="Index" asp-route-page="@(currentPage - 1)" class="pagination-btn">
                            <i class="fas fa-chevron-left"></i>
                            Previous
                        </a>
                    }
                    else
                    {
                        <span class="pagination-btn disabled">
                            <i class="fas fa-chevron-left"></i>
                            Previous
                        </span>
                    }

                    @{
                        // Display page numbers
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);
                        
                        if (startPage > 1)
                        {
                            <a asp-action="Index" asp-route-page="1" class="pagination-number">1</a>
                            if (startPage > 2)
                            {
                                <span class="pagination-dots">...</span>
                            }
                        }

                        for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == currentPage)
                            {
                                <span class="pagination-number active">@i</span>
                            }
                            else
                            {
                                <a asp-action="Index" asp-route-page="@i" class="pagination-number">@i</a>
                            }
                        }

                        if (endPage < totalPages)
                        {
                            if (endPage < totalPages - 1)
                            {
                                <span class="pagination-dots">...</span>
                            }
                            <a asp-action="Index" asp-route-page="@totalPages" class="pagination-number">@totalPages</a>
                        }
                    }

                    @if (hasNextPage)
                    {
                        <a asp-action="Index" asp-route-page="@(currentPage + 1)" class="pagination-btn">
                            Next
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                    else
                    {
                        <span class="pagination-btn disabled">
                            Next
                            <i class="fas fa-chevron-right"></i>
                        </span>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Audit Logs Page Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .stat-icon.total { background: linear-gradient(135deg, var(--info), #2563eb); color: white; }
    .stat-icon.created { background: linear-gradient(135deg, var(--success), #059669); color: white; }
    .stat-icon.updated { background: linear-gradient(135deg, var(--warning), #e6a017); color: white; }
    .stat-icon.deleted { background: linear-gradient(135deg, var(--danger), #c53030); color: white; }

    .stat-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-800);
    }

    .stat-info p {
        margin: 0;
        color: var(--gray-500);
        font-size: 0.875rem;
    }

    .logs-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .log-count {
        font-size: 0.875rem;
        font-weight: normal;
        color: var(--gray-500);
    }

    .logs-table {
        width: 100%;
        border-collapse: collapse;
    }

    .logs-table thead {
        background: var(--gray-50);
        border-bottom: 2px solid var(--gray-200);
    }

    .logs-table th {
        padding: 1rem 1.5rem;
        text-align: left;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .logs-table td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        vertical-align: middle;
        font-size: 0.875rem;
    }

    .logs-table tbody tr:hover {
        background-color: var(--gray-50);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .user-avatar-small {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.75rem;
        flex-shrink: 0;
    }

    .action-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .action-created { background: #e6f5e9; color: var(--success); }
    .action-updated { background: #fff5e6; color: var(--warning); }
    .action-deleted { background: #fee; color: var(--danger); }
    .action-login { background: #e6f0ff; color: var(--info); }
    .action-logout { background: var(--gray-100); color: var(--gray-600); }
    .action-other { background: var(--gray-100); color: var(--gray-600); }

    .entity-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .entity-ticket { background: #e6f0ff; color: var(--info); }
    .entity-user { background: #e6f5e9; color: var(--success); }
    .entity-other { background: var(--gray-100); color: var(--gray-600); }

    .details-cell {
        max-width: 250px;
        color: var(--gray-600);
        cursor: help;
    }

    .ip-cell code {
        background: var(--gray-100);
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-family: monospace;
    }

    .date-cell, .location-cell, .device-cell {
        color: var(--gray-500);
        white-space: nowrap;
    }

    .empty-state {
        text-align: center;
        padding: 3rem;
        color: var(--gray-500);
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
    }

    /* Pagination Styles */
    .pagination-container {
        padding: 1.5rem;
        border-top: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        background: white;
    }

    .pagination-info {
        font-size: 0.875rem;
        color: var(--gray-600);
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .pagination-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: white;
        border: 1px solid var(--gray-300);
        border-radius: 0.5rem;
        color: var(--gray-700);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.2s;
        cursor: pointer;
    }

    .pagination-btn:hover:not(.disabled) {
        background: var(--gray-50);
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-1px);
    }

    .pagination-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        background: var(--gray-50);
    }

    .pagination-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        padding: 0 0.5rem;
        background: white;
        border: 1px solid var(--gray-300);
        border-radius: 0.5rem;
        color: var(--gray-700);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.2s;
    }

    .pagination-number:hover {
        background: var(--gray-50);
        border-color: var(--primary);
        color: var(--primary);
    }

    .pagination-number.active {
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-color: var(--primary);
        color: white;
    }

    .pagination-dots {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        color: var(--gray-500);
        font-size: 0.875rem;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add data-label attributes for responsive table
        const tableHeaders = document.querySelectorAll('.logs-table th');
        const tableRows = document.querySelectorAll('.logs-table tbody tr');
        
        tableRows.forEach(row => {
            const cells = row.querySelectorAll('td');
            cells.forEach((cell, index) => {
                if (tableHeaders[index]) {
                    const headerText = tableHeaders[index].innerText.replace(/[^\w\s]/g, '').trim();
                    cell.setAttribute('data-label', headerText);
                }
            });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">