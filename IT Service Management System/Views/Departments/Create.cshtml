@model Department

@{
    ViewData["Title"] = "Create Department - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-plus-circle me-2" style="color: var(--success);"></i>
                    Create Department
                </h1>
                <p class="text-muted mt-2">Add a new department to the organization</p>
            </div>
        </div>
    </div>

    <div class="create-department-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-building me-2"></i>
                <span>Department Information</span>
            </div>
            <div class="form-steps">
                <span class="step active">1</span>
                <span class="step-line"></span>
                <span class="step">2</span>
                <span class="step-line"></span>
                <span class="step">3</span>
            </div>
        </div>

        <form asp-action="Create" method="post" id="createDepartmentForm">
            @Html.AntiForgeryToken()
            
            <div class="card-body-custom">
                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Name" class="form-label">
                                <i class="fas fa-building"></i>
                                Department Name
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-tag input-icon"></i>
                                <input asp-for="Name" class="form-control-modern" placeholder="Enter department name (e.g., IT, HR, Finance)" />
                            </div>
                            <span asp-validation-for="Name" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Unique name that identifies the department
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Description" class="form-label">
                                <i class="fas fa-align-left"></i>
                                Description
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-file-alt textarea-icon"></i>
                                <textarea asp-for="Description" class="form-control-textarea" rows="5" placeholder="Enter department description and responsibilities..."></textarea>
                            </div>
                            <span asp-validation-for="Description" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Brief description of the department's role and responsibilities
                            </div>
                            <div class="char-counter">
                                <span id="charCount">0</span> characters
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tips Section -->
                <div class="tips-section">
                    <div class="tips-header">
                        <i class="fas fa-lightbulb"></i>
                        <span>Department Management Tips</span>
                    </div>
                    <div class="tips-grid">
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Use clear and descriptive department names</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Define department responsibilities clearly</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Departments can be assigned to users and tickets</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Keep department information up to date</span>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-save" id="submitBtn">
                        <i class="fas fa-save"></i>
                        Create Department
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Create Department Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Create Department Card */
    .create-department-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .form-steps {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .step {
        width: 30px;
        height: 30px;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

    .step.active {
        background: var(--success);
        border-color: var(--success);
        color: white;
    }

    .step-line {
        width: 40px;
        height: 2px;
        background: var(--gray-300);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label i {
        color: var(--primary);
        font-size: 0.875rem;
    }

    .required {
        color: var(--danger);
        font-size: 1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .input-icon-wrapper i.input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

    .form-control-modern:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    /* Textarea Styling */
    .textarea-wrapper {
        position: relative;
    }

    .textarea-icon {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
        resize: vertical;
    }

    .form-control-textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    .char-counter {
        font-size: 0.7rem;
        color: var(--gray-500);
        text-align: right;
    }

    /* Tips Section */
    .tips-section {
        background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 2rem;
        border-left: 3px solid var(--info);
    }

    .tips-header {
        font-weight: 600;
        color: var(--info);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .tips-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 0.75rem;
    }

    .tip-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        color: var(--gray-700);
    }

    .tip-item i {
        color: var(--success);
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-hint i {
        font-size: 0.7rem;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-save {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-cancel:hover {
        background: var(--gray-50);
        color: var(--gray-700);
        text-decoration: none;
    }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Character counter for description
        const descriptionTextarea = document.querySelector('[asp-for="Description"]');
        const charCountSpan = document.getElementById('charCount');
        
        if (descriptionTextarea && charCountSpan) {
            function updateCharCount() {
                charCountSpan.textContent = descriptionTextarea.value.length;
            }
            descriptionTextarea.addEventListener('input', updateCharCount);
            updateCharCount();
        }
        
        // Form validation
        const form = document.getElementById('createDepartmentForm');
        const submitBtn = document.getElementById('submitBtn');
        
        if (form) {
            form.addEventListener('submit', function(e) {
                var name = document.querySelector('[name="Name"]').value.trim();
                
                if (!name) {
                    e.preventDefault();
                    showValidationError('Department name is required');
                    document.querySelector('[name="Name"]').focus();
                    return false;
                }
                
                if (name.length < 2) {
                    e.preventDefault();
                    showValidationError('Department name must be at least 2 characters');
                    document.querySelector('[name="Name"]').focus();
                    return false;
                }
                
                if (name.length > 100) {
                    e.preventDefault();
                    showValidationError('Department name must not exceed 100 characters');
                    document.querySelector('[name="Name"]').focus();
                    return false;
                }
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating Department...';
                
                return true;
            });
        }
        
        function showValidationError(message) {
            var errorDiv = document.querySelector('.validation-toast');
            if (errorDiv) errorDiv.remove();
            
            errorDiv = document.createElement('div');
            errorDiv.className = 'validation-toast';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
                animation: slideIn 0.3s ease;
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(errorDiv);
            
            setTimeout(function() {
                errorDiv.style.animation = 'slideOut 0.3s ease';
                setTimeout(function() { errorDiv.remove(); }, 300);
            }, 4000);
        }
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}