@model IT_Service_Management_System.Models.ActivityCategory

@{
    ViewData["Title"] = $"Category Details - {Model.Name} - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-tag me-2" style="color: var(--info);"></i>
                    Category Details
                </h1>
                <p class="text-muted mt-2">View complete category information</p>
            </div>
        </div>
    </div>

    <div class="category-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-tag me-2"></i>
                <span>Category Information</span>
            </div>
            <div class="category-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- Category Summary Header -->
            <div class="category-summary">
                <div class="category-icon-large">
                    <i class="fas fa-tag"></i>
                </div>
                <div class="category-summary-info">
                    <h2 class="category-name">@Model.Name</h2>
                    <div class="category-stats">
                        <span class="stat-badge">
                            <i class="fas fa-tasks"></i>
                            @(Model.Activities?.Count ?? 0) Activities
                        </span>
                    </div>
                </div>
            </div>

            <!-- Details Grid -->
            <div class="details-grid">
                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-hashtag"></i>
                    </div>
                    <div class="detail-content">
                        <label>Category ID</label>
                        <p>#@Model.Id</p>
                        <span class="detail-sub">Unique identifier</span>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-tag"></i>
                    </div>
                    <div class="detail-content">
                        <label>Category Name</label>
                        <p>@Model.Name</p>
                        <span class="detail-sub">Activity category name</span>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-tasks"></i>
                    </div>
                    <div class="detail-content">
                        <label>Total Activities</label>
                        <p>@(Model.Activities?.Count ?? 0)</p>
                        <span class="detail-sub">Activities using this category</span>
                    </div>
                </div>
            </div>

            <!-- Activities Section -->
            <div class="activities-section">
                <h3 class="section-title">
                    <i class="fas fa-tasks"></i>
                    Activities in this Category
                    <span class="activity-count-badge">@(Model.Activities?.Count ?? 0)</span>
                </h3>

                @if (Model.Activities != null && Model.Activities.Any())
                {
                    <div class="table-responsive">
                        <table class="activities-table">
                            <thead>
                                <tr>
                                    <th><i class="fas fa-heading me-1"></i> Title</th>
                                    <th><i class="fas fa-hourglass-start me-1"></i> Date</th>
                                    <th><i class="fas fa-stopwatch me-1"></i> Duration</th>
                                    <th><i class="fas fa-info-circle me-1"></i> Status</th>
                                    <th><i class="fas fa-cog me-1"></i> Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var activity in Model.Activities.OrderByDescending(a => a.StartTime).Take(10))
                                {
                                    var isOngoing = !activity.EndTime.HasValue;

                                    <tr>
                                        <td>
                                            <div class="activity-info">
                                                <i class="fas fa-tasks"></i>
                                                <span>@activity.Title</span>
                                            </div>
                                        </td>

                                        <td class="date-cell">
                                            <i class="far fa-calendar-alt"></i>
                                            @activity.StartTime.ToString("MMM dd, yyyy")
                                        </td>

                                        <td class="duration-cell">
                                            @if (activity.Duration.HasValue)
                                            {
                                                var hours = (int)activity.Duration.Value.TotalHours;
                                                var minutes = activity.Duration.Value.Minutes;

                                                if (hours > 0)
                                                {
                                                    <span>@hours h @minutes m</span>
                                                }
                                                else
                                                {
                                                    <span>@minutes m</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>

                                        <td>
                                            @if (isOngoing)
                                            {
                                                <span class="status-badge-small status-ongoing">
                                                    <i class="fas fa-play-circle"></i> Ongoing
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="status-badge-small status-completed">
                                                    <i class="fas fa-check-circle"></i> Completed
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <a asp-controller="Activities" asp-action="Details" asp-route-id="@activity.Id"
                                                   class="action-link" title="View Activity">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-controller="Activities" asp-action="Edit" asp-route-id="@activity.Id" class="action-link" title="Edit Activity">
                                                <i class="fas fa-pencil-alt"></i>
                                            </a>
                                            <a asp-controller="Activities" asp-action="Delete" asp-route-id="@activity.Id" class="action-link" title="Delete Activity">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                    </tr>                                
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.Activities.Count > 10)
                    {
                        <div class="view-all-link">
                            <a asp-controller="Activities" asp-action="Index" class="view-all-btn">
                                <i class="fas fa-arrow-right"></i>
                                View All @Model.Activities.Count Activities
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-activities">
                        <i class="fas fa-tasks"></i>
                        <p>No activities found in this category</p>
                        <a asp-controller="Activities" asp-action="Create" class="btn-create-activity">
                            <i class="fas fa-plus-circle"></i>
                            Create Activity
                        </a>
                    </div>
                }
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons-container">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">
                    <i class="fas fa-pencil-alt"></i>
                    Edit Category
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-delete-record" onclick="return confirm('Are you sure you want to delete this category? Activities using this category will be affected.');">
                    <i class="fas fa-trash-alt"></i>
                    Delete Category
                </a>
                <a asp-action="Index" class="btn-back-to-list">
                    <i class="fas fa-arrow-left"></i>
                    Back to Categories
                </a>
                <button type="button" class="btn-print" onclick="window.print()">
                    <i class="fas fa-print"></i>
                    Print Details
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Category Details Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Category Details Card */
    .category-details-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .category-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Category Summary */
    .category-summary {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid var(--gray-100);
    }

    .category-icon-large {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .category-icon-large i {
        font-size: 2.5rem;
        color: white;
    }

    .category-summary-info {
        flex: 1;
    }

    .category-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 0.5rem 0;
    }

    .category-stats {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .stat-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: var(--gray-100);
        color: var(--gray-600);
    }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .detail-card {
        background: var(--gray-50);
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        gap: 1rem;
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

    .detail-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        background: white;
    }

    .detail-icon {
        width: 48px;
        height: 48px;
        background: white;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.25rem;
        flex-shrink: 0;
        border: 1px solid var(--gray-200);
    }

    .detail-content {
        flex: 1;
    }

    .detail-content label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--gray-500);
        font-weight: 600;
        display: block;
        margin-bottom: 0.25rem;
    }

    .detail-content p {
        font-size: 1rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0 0 0.5rem 0;
    }

    .detail-sub {
        font-size: 0.7rem;
        color: var(--gray-500);
    }

    /* Activities Section */
    .activities-section {
        margin-bottom: 2rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .activity-count-badge {
        background: var(--primary);
        color: white;
        padding: 0.125rem 0.5rem;
        border-radius: 2rem;
        font-size: 0.7rem;
    }

    .activities-table {
        width: 100%;
        border-collapse: collapse;
    }

    .activities-table thead {
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-200);
    }

    .activities-table th {
        padding: 0.75rem 1rem;
        text-align: left;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .activities-table td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--gray-100);
        vertical-align: middle;
        font-size: 0.875rem;
    }

    .activities-table tbody tr:hover {
        background-color: var(--gray-50);
    }

    .activity-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .activity-info i {
        color: var(--primary);
    }

    .date-cell {
        color: var(--gray-500);
        white-space: nowrap;
    }

    .duration-cell {
        color: var(--gray-600);
    }

    .status-badge-small {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.125rem 0.5rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .status-ongoing {
        background: #fff5e6;
        color: var(--warning);
    }

    .status-completed {
        background: #e6f5e9;
        color: var(--success);
    }

    .action-link {
        color: var(--info);
        text-decoration: none;
        transition: color 0.2s;
    }

    .action-link:hover {
        color: var(--primary-dark);
    }

    .view-all-link {
        margin-top: 1rem;
        text-align: center;
    }

    .view-all-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--gray-100);
        color: var(--gray-600);
        text-decoration: none;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .view-all-btn:hover {
        background: var(--gray-200);
        color: var(--primary);
    }

    .empty-activities {
        text-align: center;
        padding: 2rem;
        background: var(--gray-50);
        border-radius: 0.75rem;
        color: var(--gray-500);
    }

    .empty-activities i {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

    .empty-activities p {
        margin-bottom: 1rem;
    }

    .btn-create-activity {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        text-decoration: none;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-create-activity:hover {
        transform: translateY(-2px);
        color: white;
    }

    /* Action Buttons */
    .action-buttons-container {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
        flex-wrap: wrap;
    }

    .btn-edit {
        background: linear-gradient(100deg, var(--warning), #e6a017);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        color: white;
        text-decoration: none;
    }

    .btn-delete-record {
        background: linear-gradient(100deg, var(--danger), #c53030);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-delete-record:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        color: white;
        text-decoration: none;
    }

    .btn-back-to-list {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-back-to-list:hover {
        background: var(--gray-50);
        color: var(--gray-700);
        text-decoration: none;
    }

    .btn-print {
        background: white;
        color: var(--info);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--info);
        font-size: 0.875rem;
        cursor: pointer;
        flex: 1;
        justify-content: center;
    }

    .btn-print:hover {
        background: var(--info);
        color: white;
        transform: translateY(-2px);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add data-label attributes for responsive activities table
        const tableHeaders = document.querySelectorAll('.activities-table th');
        const tableRows = document.querySelectorAll('.activities-table tbody tr');
        
        tableRows.forEach(row => {
            const cells = row.querySelectorAll('td');
            cells.forEach((cell, index) => {
                if (tableHeaders[index]) {
                    const headerText = tableHeaders[index].innerText.replace(/[^\w\s]/g, '').trim();
                    cell.setAttribute('data-label', headerText);
                }
            });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">