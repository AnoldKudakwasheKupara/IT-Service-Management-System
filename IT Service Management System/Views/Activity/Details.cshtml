@model IT_Service_Management_System.Models.Activity

@{
    ViewData["Title"] = $"Activity Details - {Model.Title} - Axis IT Helpdesk";
    var isOngoing = !Model.EndTime.HasValue;
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-tasks me-2" style="color: var(--info);"></i>
                    Activity Details
                </h1>
                <p class="text-muted mt-2">View complete activity information</p>
            </div>
        </div>
    </div>

    <div class="activity-details-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-tasks me-2"></i>
                <span>Activity Information</span>
            </div>
            <div class="activity-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <div class="card-body-custom">
            <!-- Activity Summary Header -->
            <div class="activity-summary">
                <div class="activity-icon-large">
                    <i class="fas fa-tasks"></i>
                </div>
                <div class="activity-summary-info">
                    <h2 class="activity-title">@Model.Title</h2>
                    <div class="activity-status">
                        @if (isOngoing)
                        {
                            <span class="status-badge status-ongoing">
                                <i class="fas fa-play-circle"></i> Ongoing
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-completed">
                                <i class="fas fa-check-circle"></i> Completed
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Description Section -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="description-section">
                    <h3 class="section-title">
                        <i class="fas fa-align-left"></i>
                        Description
                    </h3>
                    <div class="description-content">
                        @Model.Description
                    </div>
                </div>
            }

            <!-- Details Grid -->
            <div class="details-grid">
                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-tag"></i>
                    </div>
                    <div class="detail-content">
                        <label>Category</label>
                        <p>@(Model.Category?.Name ?? "Uncategorized")</p>
                        <span class="detail-sub">Activity category</span>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-hourglass-start"></i>
                    </div>
                    <div class="detail-content">
                        <label>Start Time</label>
                        <p>@Model.StartTime.ToString("dddd, MMMM dd, yyyy 'at' HH:mm")</p>
                        <span class="detail-sub">@Model.StartTime.ToString("hh:mm tt")</span>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-hourglass-end"></i>
                    </div>
                    <div class="detail-content">
                        <label>End Time</label>
                        @if (Model.EndTime.HasValue)
                        {
                            <p>@Model.EndTime.Value.ToString("dddd, MMMM dd, yyyy 'at' HH:mm")</p>
                            <span class="detail-sub">@Model.EndTime.Value.ToString("hh:mm tt")</span>
                        }
                        else
                        {
                            <p class="text-muted">In Progress</p>
                            <span class="detail-sub">No end time recorded</span>
                        }
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-icon">
                        <i class="fas fa-stopwatch"></i>
                    </div>
                    <div class="detail-content">
                        <label>Duration</label>
                        @if (Model.Duration.HasValue)
                        {
                            var hours = Model.Duration.Value.Hours;
                            var minutes = Model.Duration.Value.Minutes;
                            <p>
                                @if (hours > 0)
                                {
                                    <span>@hours hours @minutes minutes</span>
                                }
                                else
                                {
                                    <span>@minutes minutes</span>
                                }
                            </p>
                            <span class="detail-sub">
                                @if (hours > 0)
                                {
                                    <text>Total time spent: @hours h @minutes m</text>
                                }
                                else
                                {
                                    <text>Total time spent: @minutes minutes</text>
                                }
                            </span>
                        }
                        else
                        {
                            <p class="text-muted">Not calculated</p>
                            <span class="detail-sub">Duration will be calculated when activity ends</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Additional Information Section -->
            <div class="additional-info">
                <h3 class="section-title">
                    <i class="fas fa-info-circle"></i>
                    Additional Information
                </h3>
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Activity ID:</span>
                        <span class="info-value">#@Model.Id</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Title:</span>
                        <span class="info-value">@Model.Title</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Category:</span>
                        <span class="info-value">@(Model.Category?.Name ?? "Uncategorized")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Start Date:</span>
                        <span class="info-value">@Model.StartTime.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Start Time:</span>
                        <span class="info-value">@Model.StartTime.ToString("hh:mm tt")</span>
                    </div>
                    @if (Model.EndTime.HasValue)
                    {
                        <div class="info-item">
                            <span class="info-label">End Date:</span>
                            <span class="info-value">@Model.EndTime.Value.ToString("MMMM dd, yyyy")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">End Time:</span>
                            <span class="info-value">@Model.EndTime.Value.ToString("hh:mm tt")</span>
                        </div>
                    }
                    <div class="info-item">
                        <span class="info-label">Status:</span>
                        <span class="info-value">
                            @if (isOngoing)
                            {
                                <span class="text-warning">
                                    <i class="fas fa-play-circle"></i> Ongoing
                                </span>
                            }
                            else
                            {
                                <span class="text-success">
                                    <i class="fas fa-check-circle"></i> Completed
                                </span>
                            }
                        </span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons-container">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">
                    <i class="fas fa-pencil-alt"></i>
                    Edit Activity
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-delete-record" onclick="return confirm('Are you sure you want to delete this activity?');">
                    <i class="fas fa-trash-alt"></i>
                    Delete Activity
                </a>
                <a asp-action="Index" class="btn-back-to-list">
                    <i class="fas fa-arrow-left"></i>
                    Back to Activities
                </a>
                <button type="button" class="btn-print" onclick="window.print()">
                    <i class="fas fa-print"></i>
                    Print Details
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Activity Details Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
        }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Activity Details Card */
    .activity-details-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .activity-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Activity Summary */
    .activity-summary {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid var(--gray-100);
    }

    .activity-icon-large {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .activity-icon-large i {
            font-size: 2.5rem;
            color: white;
        }

    .activity-summary-info {
        flex: 1;
    }

    .activity-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 0.75rem 0;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 0.875rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-ongoing {
        background: #fff5e6;
        color: var(--warning);
    }

    .status-completed {
        background: #e6f5e9;
        color: var(--success);
    }

    /* Description Section */
    .description-section {
        margin-bottom: 2rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .description-content {
        background: var(--gray-50);
        padding: 1rem;
        border-radius: 0.75rem;
        line-height: 1.6;
        color: var(--gray-700);
    }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .detail-card {
        background: var(--gray-50);
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        gap: 1rem;
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

        .detail-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            background: white;
        }

    .detail-icon {
        width: 48px;
        height: 48px;
        background: white;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.25rem;
        flex-shrink: 0;
        border: 1px solid var(--gray-200);
    }

    .detail-content {
        flex: 1;
    }

        .detail-content label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray-500);
            font-weight: 600;
            display: block;
            margin-bottom: 0.25rem;
        }

        .detail-content p {
            font-size: 1rem;
            font-weight: 600;
            color: var(--gray-800);
            margin: 0 0 0.5rem 0;
        }

    .detail-sub {
        font-size: 0.7rem;
        color: var(--gray-500);
    }

    /* Additional Information */
    .additional-info {
        margin-bottom: 2rem;
    }

    .info-grid {
        background: var(--gray-50);
        border-radius: 0.75rem;
        padding: 1rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem;
        background: white;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
    }

    .info-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

    .info-value {
        font-size: 0.875rem;
        color: var(--gray-700);
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .text-warning {
        color: var(--warning) !important;
    }

    .text-success {
        color: var(--success) !important;
    }

    /* Action Buttons */
    .action-buttons-container {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
        flex-wrap: wrap;
    }

    .btn-edit {
        background: linear-gradient(100deg, var(--warning), #e6a017);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    .btn-delete-record {
        background: linear-gradient(100deg, var(--danger), #c53030);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-delete-record:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    .btn-back-to-list {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-back-to-list:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }

    .btn-print {
        background: white;
        color: var(--info);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--info);
        font-size: 0.875rem;
        cursor: pointer;
        flex: 1;
        justify-content: center;
    }

        .btn-print:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">