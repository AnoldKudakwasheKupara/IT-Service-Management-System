@model IT_Service_Management_System.Models.Activity

@{
    ViewData["Title"] = "Activity Details";
}

<h2 class="mb-4">Activity Details</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <h4>@Model.Title</h4>
        <p class="text-muted">@Model.Description</p>

        <hr />

        <p><strong>Category:</strong> @Model.Category?.Name</p>
        <p><strong>Start:</strong> @Model.StartTime</p>
        <p><strong>End:</strong> @(Model.EndTime?.ToString() ?? "-")</p>
        <p>
            <strong>Duration:</strong>
            @(Model.Duration.HasValue
                ? $"{Model.Duration.Value.Hours}h {Model.Duration.Value.Minutes}m"
                : "-")
        </p>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>

    </div>
</div>