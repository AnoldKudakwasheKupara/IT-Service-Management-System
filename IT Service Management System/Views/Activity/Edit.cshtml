@model IT_Service_Management_System.Models.Activity

@{
    ViewData["Title"] = "Edit Activity - Axis IT Helpdesk";
    var isOngoing = !Model.EndTime.HasValue;
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-edit me-2" style="color: var(--warning);"></i>
                    Edit Activity
                </h1>
                <p class="text-muted mt-2">Update activity details and track time</p>
            </div>
        </div>
    </div>

    <div class="edit-activity-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-tasks me-2"></i>
                <span>Activity Information</span>
            </div>
            <div class="activity-id-badge">
                <i class="fas fa-hashtag"></i>
                ID: @Model.Id
            </div>
        </div>

        <form asp-action="Edit" method="post" id="editActivityForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="card-body-custom">
                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="Title" class="form-label">
                                <i class="fas fa-heading"></i>
                                Title
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-tasks input-icon"></i>
                                <input asp-for="Title" class="form-control-modern" placeholder="Enter activity title" />
                            </div>
                            <span asp-validation-for="Title" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Clear, descriptive title for the activity
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="CategoryId" class="form-label">
                                <i class="fas fa-tag"></i>
                                Category
                                <span class="required">*</span>
                            </label>
                            <div class="select-wrapper">
                                <i class="fas fa-chevron-down select-icon"></i>
                                <select asp-for="CategoryId" class="form-control-modern" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Select Category --</option>
                                </select>
                            </div>
                            <span asp-validation-for="CategoryId" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Categorize the activity for better organization
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Description" class="form-label">
                                <i class="fas fa-align-left"></i>
                                Description
                            </label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-file-alt textarea-icon"></i>
                                <textarea asp-for="Description" class="form-control-textarea" rows="4" placeholder="Provide additional details about the activity..."></textarea>
                            </div>
                            <span asp-validation-for="Description" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Optional: Add more context about the work done
                            </div>
                            <div class="char-counter">
                                <span id="charCount">0</span> characters
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label class="form-label">
                                <i class="fas fa-clock"></i>
                                Time Tracking
                            </label>
                            <div class="time-fields">
                                <div class="time-field">
                                    <label asp-for="StartTime" class="time-label">Start Time</label>
                                    <div class="input-icon-wrapper">
                                        <i class="fas fa-hourglass-start input-icon"></i>
                                        <input asp-for="StartTime" type="datetime-local" class="form-control-modern" id="startTime" />
                                    </div>
                                    <span asp-validation-for="StartTime" class="validation-message text-danger"></span>
                                </div>

                                <div class="time-field">
                                    <label asp-for="EndTime" class="time-label">End Time</label>
                                    <div class="input-icon-wrapper">
                                        <i class="fas fa-hourglass-end input-icon"></i>
                                        <input asp-for="EndTime" type="datetime-local" class="form-control-modern" id="endTime" />
                                    </div>
                                    <span asp-validation-for="EndTime" class="validation-message text-danger"></span>
                                </div>
                            </div>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Leave End Time empty for ongoing activities
                            </div>
                        </div>

                        <!-- Duration Preview -->
                        <div class="duration-preview" id="durationPreview" style="display: none;">
                            <div class="preview-header">
                                <i class="fas fa-stopwatch"></i>
                                <span>Duration Preview</span>
                            </div>
                            <div class="preview-content" id="durationValue">
                                -
                            </div>
                        </div>

                        <!-- Status Indicator -->
                        <div class="status-indicator" id="statusIndicator">
                            @if (isOngoing)
                            {
                                <div class="status-badge status-ongoing">
                                    <i class="fas fa-play-circle"></i>
                                    <span>Ongoing Activity</span>
                                </div>
                            }
                            else
                            {
                                <div class="status-badge status-completed">
                                    <i class="fas fa-check-circle"></i>
                                    <span>Completed Activity</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-update" id="submitBtn">
                        <i class="fas fa-save"></i>
                        Update Activity
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Edit Activity Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

        .btn-back:hover {
            background: var(--gray-50);
            color: var(--primary);
            transform: translateX(-2px);
        }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Edit Activity Card */
    .edit-activity-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .activity-id-badge {
        background: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-label i {
            color: var(--primary);
            font-size: 0.875rem;
        }

    .required {
        color: var(--danger);
        font-size: 1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i.input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray-400);
            font-size: 0.875rem;
            pointer-events: none;
        }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

        .form-control-modern:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
        }

    /* Textarea Styling */
    .textarea-wrapper {
        position: relative;
    }

    .textarea-icon {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-textarea {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
        resize: vertical;
    }

        .form-control-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
        }

    .char-counter {
        font-size: 0.7rem;
        color: var(--gray-500);
        text-align: right;
    }

    /* Select Styling */
    .select-wrapper {
        position: relative;
    }

        .select-wrapper select {
            appearance: none;
            width: 100%;
            padding: 0.75rem 2rem 0.75rem 1rem;
            font-size: 0.875rem;
            border: 1.5px solid var(--gray-200);
            border-radius: 0.75rem;
            cursor: pointer;
            background: white;
        }

            .select-wrapper select:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
            }

    .select-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        pointer-events: none;
        font-size: 0.75rem;
    }

    /* Time Fields */
    .time-fields {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .time-field {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .time-label {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--gray-600);
    }

    /* Duration Preview */
    .duration-preview {
        background: #e6f5e9;
        border-left: 3px solid var(--success);
        padding: 0.75rem;
        border-radius: 0.5rem;
    }

    .preview-header {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--success);
        margin-bottom: 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .preview-content {
        font-size: 1rem;
        font-weight: 700;
        color: var(--success);
    }

    /* Status Indicator */
    .status-indicator {
        margin-top: 0.5rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        width: 100%;
        justify-content: center;
    }

    .status-ongoing {
        background: #fff5e6;
        color: var(--warning);
    }

    .status-completed {
        background: #e6f5e9;
        color: var(--success);
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .form-hint i {
            font-size: 0.7rem;
        }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-update {
        background: linear-gradient(100deg, var(--warning), #e6a017);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gray-50);
            color: var(--gray-700);
            text-decoration: none;
        }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const startTimeInput = document.getElementById('startTime');
        const endTimeInput = document.getElementById('endTime');
        const durationPreview = document.getElementById('durationPreview');
        const durationValue = document.getElementById('durationValue');
        const statusIndicator = document.getElementById('statusIndicator');
        const descriptionTextarea = document.querySelector('[asp-for="Description"]');
        const charCountSpan = document.getElementById('charCount');
        
        // Character counter for description
        if (descriptionTextarea && charCountSpan) {
            function updateCharCount() {
                charCountSpan.textContent = descriptionTextarea.value.length;
            }
            descriptionTextarea.addEventListener('input', updateCharCount);
            updateCharCount();
        }
        
        // Calculate duration between two times
        function calculateDuration() {
            const startTime = startTimeInput.value;
            const endTime = endTimeInput.value;
            
            if (startTime && endTime) {
                const start = new Date(startTime);
                const end = new Date(endTime);
                
                if (end > start) {
                    const diffMs = end - start;
                    const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
                    const diffMinutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
                    
                    durationValue.textContent = `${diffHours}h ${diffMinutes}m`;
                    durationPreview.style.display = 'block';
                    
                    // Update status indicator
                    statusIndicator.innerHTML = `
                        <div class="status-badge status-completed">
                            <i class="fas fa-check-circle"></i>
                            <span>Completed Activity</span>
                        </div>
                    `;
                } else if (endTime && end <= start) {
                    durationValue.textContent = 'Invalid: End time must be after start time';
                    durationPreview.style.display = 'block';
                    durationPreview.style.borderLeftColor = 'var(--danger)';
                    durationPreview.querySelector('.preview-header i').style.color = 'var(--danger)';
                    durationPreview.querySelector('.preview-header span').style.color = 'var(--danger)';
                }
            } else if (startTime && !endTime) {
                durationValue.textContent = 'Ongoing - No end time set';
                durationPreview.style.display = 'block';
                durationPreview.style.borderLeftColor = 'var(--warning)';
                durationPreview.querySelector('.preview-header i').style.color = 'var(--warning)';
                durationPreview.querySelector('.preview-header span').style.color = 'var(--warning)';
                
                // Update status indicator for ongoing
                statusIndicator.innerHTML = `
                    <div class="status-badge status-ongoing">
                        <i class="fas fa-play-circle"></i>
                        <span>Ongoing Activity</span>
                    </div>
                `;
            } else {
                durationPreview.style.display = 'none';
            }
        }
        
        if (startTimeInput && endTimeInput) {
            startTimeInput.addEventListener('change', calculateDuration);
            endTimeInput.addEventListener('change', calculateDuration);
            calculateDuration();
        }
        
        // Form validation
        const form = document.getElementById('editActivityForm');
        const submitBtn = document.getElementById('submitBtn');
        
        if (form) {
            form.addEventListener('submit', function(e) {
                const title = document.querySelector('[name="Title"]').value.trim();
                const categoryId = document.querySelector('[name="CategoryId"]').value;
                const startTime = startTimeInput.value;
                const endTime = endTimeInput.value;
                
                if (!title) {
                    e.preventDefault();
                    showValidationError('Title is required');
                    document.querySelector('[name="Title"]').focus();
                    return false;
                }
                
                if (title.length < 3) {
                    e.preventDefault();
                    showValidationError('Title must be at least 3 characters');
                    document.querySelector('[name="Title"]').focus();
                    return false;
                }
                
                if (!categoryId) {
                    e.preventDefault();
                    showValidationError('Please select a category');
                    document.querySelector('[name="CategoryId"]').focus();
                    return false;
                }
                
                if (!startTime) {
                    e.preventDefault();
                    showValidationError('Start time is required');
                    startTimeInput.focus();
                    return false;
                }
                
                // Validate that end time is after start time if both are provided
                if (startTime && endTime) {
                    const start = new Date(startTime);
                    const end = new Date(endTime);
                    
                    if (end <= start) {
                        e.preventDefault();
                        showValidationError('End time must be after start time');
                        endTimeInput.focus();
                        return false;
                    }
                }
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating Activity...';
                
                return true;
            });
        }
        
        function showValidationError(message) {
            var errorDiv = document.querySelector('.validation-toast');
            if (errorDiv) errorDiv.remove();
            
            errorDiv = document.createElement('div');
            errorDiv.className = 'validation-toast';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
                animation: slideIn 0.3s ease;
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(errorDiv);
            
            setTimeout(function() {
                errorDiv.style.animation = 'slideOut 0.3s ease';
                setTimeout(function() { errorDiv.remove(); }, 300);
            }, 4000);
        }
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}