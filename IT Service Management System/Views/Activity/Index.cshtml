@model IEnumerable<IT_Service_Management_System.Models.Activity>

@{
    ViewData["Title"] = "Today's Activities - Axis IT Helpdesk";

    var totalMinutes = Model
        .Where(a => a.Duration.HasValue)
        .Sum(a => a.Duration.Value.TotalMinutes);

    var totalHours = (int)(totalMinutes / 60);
    var totalMins = (int)(totalMinutes % 60);
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title">
                    <i class="fas fa-calendar-day me-2" style="color: var(--primary);"></i>
                    Today's Activities
                </h1>
                <p class="text-muted mt-2">Track and manage your daily work activities</p>
            </div>
            <a asp-action="Create" class="btn-create-activity">
                <i class="fas fa-plus-circle me-2"></i>
                Log Activity
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-cards mb-4">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-tasks"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count()</h3>
                <p>Total Activities</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon time">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-info">
                <h3>@totalHours h @totalMins m</h3>
                <p>Total Time</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon ongoing">
                <i class="fas fa-play-circle"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(a => !a.EndTime.HasValue)</h3>
                <p>Ongoing</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon completed">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(a => a.EndTime.HasValue)</h3>
                <p>Completed</p>
            </div>
        </div>
    </div>

    <!-- Report Buttons -->
    <div class="report-buttons mb-4">
        <a asp-action="WeeklyReport" class="report-btn">
            <i class="fas fa-calendar-week"></i>
            Weekly Report
        </a>
        <a asp-action="MonthlyReport" class="report-btn">
            <i class="fas fa-calendar-alt"></i>
            Monthly Report
        </a>
    </div>

    <!-- Activities Table -->
    <div class="activities-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-list me-2"></i>
                <span>Activity List</span>
            </div>
            <div class="activity-count">
                <i class="fas fa-chart-simple"></i>
                <span>@Model.Count()</span> activities found
            </div>
        </div>

        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="activities-table">
                    <thead>
                        <tr>
                            <th><i class="fas fa-heading me-1"></i> Title</th>
                            <th><i class="fas fa-tag me-1"></i> Category</th>
                            <th><i class="fas fa-hourglass-start me-1"></i> Start</th>
                            <th><i class="fas fa-hourglass-end me-1"></i> End</th>
                            <th><i class="fas fa-stopwatch me-1"></i> Duration</th>
                            <th><i class="fas fa-cog me-1"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(a => a.StartTime))
                        {
                            var isOngoing = !item.EndTime.HasValue;
                            
                            <tr class="@(isOngoing ? "ongoing-row" : "")">
                                <td class="title-cell">
                                    <div class="activity-info">
                                        <div class="activity-icon">
                                            <i class="fas fa-tasks"></i>
                                        </div>
                                        <div class="activity-title-info">
                                            <strong>@item.Title</strong>
                                        </div>
                                    </div>
                                </td>
                                <td class="category-cell">
                                    @if (item.Category != null)
                                    {
                                        <span class="category-badge">
                                            <i class="fas fa-folder"></i>
                                            @item.Category.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="start-cell">
                                    <i class="far fa-clock"></i>
                                    @item.StartTime.ToString("HH:mm")
                                </td>
                                <td class="end-cell">
                                    @if (isOngoing)
                                    {
                                        <span class="ongoing-badge">
                                            <i class="fas fa-play-circle"></i> Ongoing
                                        </span>
                                    }
                                    else
                                    {
                                        <span>
                                            <i class="far fa-clock"></i>
                                            @item.EndTime.Value.ToString("HH:mm")
                                        </span>
                                    }
                                </td>
                                <td class="duration-cell">
                                    @if (item.Duration.HasValue)
                                    {
                                        var hours = (int)item.Duration.Value.TotalHours;
                                        var minutes = item.Duration.Value.Minutes;
                                        
                                        if (hours > 0)
                                        {
                                            <span class="duration-badge">
                                                <i class="fas fa-hourglass-half"></i>
                                                @hours h @minutes m
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="duration-badge">
                                                <i class="fas fa-hourglass-half"></i>
                                                @minutes m
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn btn-edit" title="Edit Activity">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn btn-delete" title="Delete Activity" onclick="return confirm('Are you sure you want to delete this activity?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-calendar-day"></i>
                    <h3>No activities logged today</h3>
                    <p>Get started by logging your first activity</p>
                    <a asp-action="Create" class="btn-create-activity-sm">
                        <i class="fas fa-plus-circle"></i> Log Activity
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Activities Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Create Activity Button */
    .btn-create-activity {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-sm);
    }

        .btn-create-activity:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    /* Statistics Cards */
    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

        .stat-icon.total {
            background: linear-gradient(135deg, var(--info), #2563eb);
            color: white;
        }

        .stat-icon.time {
            background: linear-gradient(135deg, var(--success), #059669);
            color: white;
        }

        .stat-icon.ongoing {
            background: linear-gradient(135deg, var(--warning), #e6a017);
            color: white;
        }

        .stat-icon.completed {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white;
        }

    .stat-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-800);
    }

    .stat-info p {
        margin: 0;
        color: var(--gray-500);
        font-size: 0.875rem;
    }

    /* Report Buttons */
    .report-buttons {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .report-btn {
        background: white;
        color: var(--gray-600);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
        font-size: 0.875rem;
    }

        .report-btn:hover {
            background: var(--gray-50);
            border-color: var(--primary);
            color: var(--primary);
            text-decoration: none;
        }

    /* Activities Card */
    .activities-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .activity-count {
        font-size: 0.875rem;
        font-weight: normal;
        color: var(--gray-500);
    }

    /* Table Styles */
    .activities-table {
        width: 100%;
        border-collapse: collapse;
    }

        .activities-table thead {
            background: var(--gray-50);
            border-bottom: 2px solid var(--gray-200);
        }

        .activities-table th {
            padding: 1rem 1.5rem;
            text-align: left;
            font-weight: 600;
            color: var(--gray-600);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .activities-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            vertical-align: middle;
            font-size: 0.875rem;
        }

        .activities-table tbody tr {
            transition: background-color 0.2s;
        }

            .activities-table tbody tr:hover {
                background-color: var(--gray-50);
            }

        .activities-table tr.ongoing-row {
            background-color: rgba(44, 125, 160, 0.05);
        }

    /* Title Cell */
    .title-cell {
        min-width: 200px;
    }

    .activity-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .activity-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .activity-title-info strong {
        color: var(--gray-800);
        font-size: 0.875rem;
    }

    /* Category Badge */
    .category-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: #e6f0ff;
        color: var(--info);
    }

    /* Ongoing Badge */
    .ongoing-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: #fff5e6;
        color: var(--warning);
    }

    /* Duration Badge */
    .duration-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: var(--gray-100);
        color: var(--gray-600);
    }

    /* Start/End Cells */
    .start-cell, .end-cell {
        color: var(--gray-600);
        white-space: nowrap;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

    .btn-view {
        background: var(--gray-100);
        color: var(--info);
    }

        .btn-view:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: var(--gray-100);
        color: var(--warning);
    }

        .btn-edit:hover {
            background: var(--warning);
            color: white;
            transform: translateY(-2px);
        }

    .btn-delete {
        background: var(--gray-100);
        color: var(--danger);
    }

        .btn-delete:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 3rem;
        color: var(--gray-500);
    }

        .empty-state i {
            font-size: 4rem;
            color: var(--gray-300);
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
            color: var(--gray-600);
        }

        .empty-state p {
            margin-bottom: 1.5rem;
        }

    .btn-create-activity-sm {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

        .btn-create-activity-sm:hover {
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add data-label attributes for responsive table
        const tableHeaders = document.querySelectorAll('.activities-table th');
        const tableRows = document.querySelectorAll('.activities-table tbody tr');
        
        tableRows.forEach(row => {
            const cells = row.querySelectorAll('td');
            cells.forEach((cell, index) => {
                if (tableHeaders[index]) {
                    const headerText = tableHeaders[index].innerText.replace(/[^\w\s]/g, '').trim();
                    cell.setAttribute('data-label', headerText);
                }
            });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">