@model SSLCertificate

@{
    ViewData["Title"] = "Delete SSL Certificate";
}

<h2>Delete SSL Certificate</h2>

<h4 class="text-danger">Are you sure you want to delete this?</h4>

<div class="mt-3">
    <dl class="row">

        <dt class="col-sm-2">System</dt>
        <dd class="col-sm-10">@Model.SystemName</dd>

        <dt class="col-sm-2">URL</dt>
        <dd class="col-sm-10">@Model.URL</dd>

        <dt class="col-sm-2">Expiry</dt>
        <dd class="col-sm-10">@Model.ExpiryDate.ToString("yyyy-MM-dd")</dd>

    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>