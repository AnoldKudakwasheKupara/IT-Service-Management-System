@model IEnumerable<SSLCertificate>

@{
    ViewData["Title"] = "SSL Certificates - Axis IT Helpdesk";
    var expiringCount = Model.Count(c => c.ExpiryDate <= DateTime.Now.AddDays(30) && c.ExpiryDate > DateTime.Now);
    var expiredCount = Model.Count(c => c.ExpiryDate < DateTime.Now);
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title">
                    <i class="fas fa-lock me-2" style="color: var(--primary);"></i>
                    SSL Certificate Tracker
                </h1>
                <p class="text-muted mt-2">Monitor and manage SSL certificates across your systems</p>
            </div>
            <a asp-action="Create" class="btn-create-certificate">
                <i class="fas fa-plus-circle me-2"></i>
                Add Certificate
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-cards mb-4">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-certificate"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count()</h3>
                <p>Total Certificates</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon healthy">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-info">
                <h3>@Model.Count(c => c.ExpiryDate > DateTime.Now.AddDays(30))</h3>
                <p>Healthy</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon expiring">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-info">
                <h3>@expiringCount</h3>
                <p>Expiring Soon</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon expired">
                <i class="fas fa-times-circle"></i>
            </div>
            <div class="stat-info">
                <h3>@expiredCount</h3>
                <p>Expired</p>
            </div>
        </div>
    </div>

    <!-- Filter Buttons -->
    <div class="filter-buttons mb-4">
        <a asp-action="Index" class="filter-btn active">
            <i class="fas fa-list"></i>
            All
        </a>
        <a asp-action="ExpiringSoon" class="filter-btn">
            <i class="fas fa-exclamation-triangle"></i>
            Expiring Soon
            @if (expiringCount > 0)
            {
                <span class="badge">@expiringCount</span>
            }
        </a>
        <a asp-action="Expired" class="filter-btn">
            <i class="fas fa-times-circle"></i>
            Expired
            @if (expiredCount > 0)
            {
                <span class="badge">@expiredCount</span>
            }
        </a>
    </div>

    <!-- Certificates Table -->
    <div class="certificates-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-list me-2"></i>
                <span>Certificate List</span>
            </div>
            <div class="certificate-count">
                <i class="fas fa-chart-simple"></i>
                <span>@Model.Count()</span> certificates found
            </div>
        </div>

        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="certificates-table">
                    <thead>
                        <tr>
                            <th><i class="fas fa-server me-1"></i> System</th>
                            <th><i class="fas fa-link me-1"></i> URL</th>
                            <th><i class="fas fa-calendar me-1"></i> Expiry Date</th>
                            <th><i class="fas fa-chart-line me-1"></i> Status</th>
                            <th><i class="fas fa-sync-alt me-1"></i> Renewal</th>
                            <th><i class="fas fa-history me-1"></i> Last Renewed</th>
                            <th><i class="fas fa-cog me-1"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cert in Model.OrderBy(c => c.ExpiryDate))
                        {
                            var days = (cert.ExpiryDate - DateTime.Now).Days;
                            var isExpired = days < 0;
                            var isExpiringSoon = days >= 0 && days <= 30;

                            <tr class="@(isExpired ? "expired-row" : isExpiringSoon ? "expiring-row" : "")">
                                <td class="system-cell">
                                    <div class="system-info">
                                        <div class="system-icon">
                                            <i class="fas fa-server"></i>
                                        </div>
                                        <div class="system-name-info">
                                            <strong>@cert.SystemName</strong>
                                        </div>
                                    </div>
                                </td>
                                <td class="url-cell">
                                    <a href="@cert.URL" target="_blank" class="url-link">
                                        <i class="fas fa-external-link-alt"></i>
                                        @cert.URL
                                    </a>
                                </td>
                                <td class="expiry-cell">
                                    <i class="far fa-calendar-alt"></i>
                                    @cert.ExpiryDate.ToString("MMM dd, yyyy")
                                </td>
                                <td>
                                    @if (isExpired)
                                    {
                                        <span class="status-badge status-expired">
                                            <i class="fas fa-times-circle"></i> Expired
                                        </span>
                                    }
                                    else if (days <= 7)
                                    {
                                        <span class="status-badge status-critical">
                                            <i class="fas fa-exclamation-circle"></i> Critical - @days days left
                                        </span>
                                    }
                                    else if (days <= 30)
                                    {
                                        <span class="status-badge status-warning">
                                            <i class="fas fa-exclamation-triangle"></i> @days days left
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-healthy">
                                            <i class="fas fa-check-circle"></i> @days days left
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (cert.IsRenewed)
                                    {
                                        <span class="renewal-badge renewed">
                                            <i class="fas fa-check-circle"></i> Renewed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="renewal-badge pending">
                                            <i class="fas fa-clock"></i> Pending
                                        </span>
                                    }
                                </td>
                                <td class="last-renewed-cell">
                                    @if (cert.LastRenewedDate.HasValue)
                                    {
                                        <span>
                                            <i class="fas fa-history"></i>
                                            @cert.LastRenewedDate.Value.ToString("MMM dd, yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@cert.Id" class="action-btn btn-view" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@cert.Id" class="action-btn btn-edit" title="Edit Certificate">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@cert.Id" class="action-btn btn-delete" title="Delete Certificate" onclick="return confirm('Are you sure you want to delete this certificate?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-certificate"></i>
                    <h3>No certificates found</h3>
                    <p>Get started by adding your first SSL certificate</p>
                    <a asp-action="Create" class="btn-create-certificate-sm">
                        <i class="fas fa-plus-circle"></i> Add Certificate
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* SSL Certificates Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Create Certificate Button */
    .btn-create-certificate {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-sm);
    }

        .btn-create-certificate:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
            text-decoration: none;
        }

    /* Statistics Cards */
    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
    }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

        .stat-icon.total {
            background: linear-gradient(135deg, var(--info), #2563eb);
            color: white;
        }

        .stat-icon.healthy {
            background: linear-gradient(135deg, var(--success), #059669);
            color: white;
        }

        .stat-icon.expiring {
            background: linear-gradient(135deg, var(--warning), #e6a017);
            color: white;
        }

        .stat-icon.expired {
            background: linear-gradient(135deg, var(--danger), #c53030);
            color: white;
        }

    .stat-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-800);
    }

    .stat-info p {
        margin: 0;
        color: var(--gray-500);
        font-size: 0.875rem;
    }

    /* Filter Buttons */
    .filter-buttons {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .filter-btn {
        background: white;
        color: var(--gray-600);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
        font-size: 0.875rem;
    }

        .filter-btn:hover {
            background: var(--gray-50);
            border-color: var(--primary);
            color: var(--primary);
            text-decoration: none;
        }

        .filter-btn.active {
            background: linear-gradient(100deg, var(--primary-dark), var(--primary));
            color: white;
            border-color: var(--primary);
        }

        .filter-btn .badge {
            background: var(--danger);
            color: white;
            padding: 0.125rem 0.375rem;
            border-radius: 0.5rem;
            font-size: 0.7rem;
        }

    /* Certificates Card */
    .certificates-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .certificate-count {
        font-size: 0.875rem;
        font-weight: normal;
        color: var(--gray-500);
    }

    /* Table Styles */
    .certificates-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed; /* ✅ FIX: keeps columns aligned */
    }

        .certificates-table thead {
            background: var(--gray-50);
            border-bottom: 2px solid var(--gray-200);
        }

        .certificates-table th {
            padding: 1rem 1.5rem;
            text-align: left;
            font-weight: 600;
            color: var(--gray-600);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .certificates-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            vertical-align: middle;
            font-size: 0.875rem;
            /* ✅ FIX: prevent column stretching */
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

            /* ✅ FIX: Actions column alignment */
            .certificates-table th:last-child,
            .certificates-table td:last-child {
                width: 120px;
                text-align: center;
            }

        /* Table row hover */
        .certificates-table tbody tr {
            transition: background-color 0.2s;
        }

            .certificates-table tbody tr:hover {
                background-color: var(--gray-50);
            }

        .certificates-table tr.expired-row {
            background-color: rgba(229, 62, 62, 0.05);
        }

        .certificates-table tr.expiring-row {
            background-color: rgba(245, 176, 66, 0.05);
        }

    /* URL Cell */
    .url-cell {
        min-width: 200px;
        /* ✅ FIX: prevent long URLs breaking layout */
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        /* ✅ FIX: keep buttons centered */
        justify-content: center;
    }

        .certificates-table thead {
            background: var(--gray-50);
            border-bottom: 2px solid var(--gray-200);
        }

        .certificates-table th {
            padding: 1rem 1.5rem;
            text-align: left;
            font-weight: 600;
            color: var(--gray-600);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .certificates-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            vertical-align: middle;
            font-size: 0.875rem;
        }

        .certificates-table tbody tr {
            transition: background-color 0.2s;
        }

            .certificates-table tbody tr:hover {
                background-color: var(--gray-50);
            }

        .certificates-table tr.expired-row {
            background-color: rgba(229, 62, 62, 0.05);
        }

        .certificates-table tr.expiring-row {
            background-color: rgba(245, 176, 66, 0.05);
        }

    /* System Cell */
    .system-cell {
        min-width: 150px;
    }

    .system-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .system-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .system-name-info strong {
        color: var(--gray-800);
        font-size: 0.875rem;
    }

    /* URL Cell */
    .url-cell {
        min-width: 200px;
    }

    .url-link {
        color: var(--primary);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .url-link:hover {
            text-decoration: underline;
            color: var(--primary-dark);
        }

    /* Expiry Cell */
    .expiry-cell {
        color: var(--gray-600);
        white-space: nowrap;
    }

    /* Status Badges */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-healthy {
        background: #e6f5e9;
        color: var(--success);
    }

    .status-warning {
        background: #fff5e6;
        color: var(--warning);
    }

    .status-critical {
        background: #fee;
        color: var(--danger);
    }

    .status-expired {
        background: #fee;
        color: var(--danger);
    }

    /* Renewal Badges */
    .renewal-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

        .renewal-badge.renewed {
            background: #e6f5e9;
            color: var(--success);
        }

        .renewal-badge.pending {
            background: var(--gray-100);
            color: var(--gray-600);
        }

    /* Last Renewed Cell */
    .last-renewed-cell {
        color: var(--gray-500);
        white-space: nowrap;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

    .btn-view {
        background: var(--gray-100);
        color: var(--info);
    }

        .btn-view:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: var(--gray-100);
        color: var(--warning);
    }

        .btn-edit:hover {
            background: var(--warning);
            color: white;
            transform: translateY(-2px);
        }

    .btn-delete {
        background: var(--gray-100);
        color: var(--danger);
    }

        .btn-delete:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 3rem;
        color: var(--gray-500);
    }

        .empty-state i {
            font-size: 4rem;
            color: var(--gray-300);
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
            color: var(--gray-600);
        }

        .empty-state p {
            margin-bottom: 1.5rem;
        }

    .btn-create-certificate-sm {
        background: linear-gradient(100deg, var(--primary-dark), var(--primary));
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

        .btn-create-certificate-sm:hover {
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add data-label attributes for responsive table
        const tableHeaders = document.querySelectorAll('.certificates-table th');
        const tableRows = document.querySelectorAll('.certificates-table tbody tr');
        
        tableRows.forEach(row => {
            const cells = row.querySelectorAll('td');
            cells.forEach((cell, index) => {
                if (tableHeaders[index]) {
                    const headerText = tableHeaders[index].innerText.replace(/[^\w\s]/g, '').trim();
                    cell.setAttribute('data-label', headerText);
                }
            });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">