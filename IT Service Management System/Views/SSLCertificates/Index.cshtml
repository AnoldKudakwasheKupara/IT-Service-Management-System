@model IEnumerable<SSLCertificate>

@{
    ViewData["Title"] = "SSL Certificates";
}

<h2>SSL Certificate Tracker</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Add Certificate</a>
    <a asp-action="ExpiringSoon" class="btn btn-warning">⚠ Expiring Soon</a>
    <a asp-action="Expired" class="btn btn-danger">❌ Expired</a>
    <a asp-action="Index" class="btn btn-secondary">All</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>System</th>
            <th>URL</th>
            <th>Expiry</th>
            <th>Status</th>
            <th>Renewal</th>
            <th>Last Renewed</th>
            <th width="220"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cert in Model)
        {
            var days = (cert.ExpiryDate - DateTime.Now).Days;

            string badgeClass = days < 0 ? "danger"
                             : days <= 7 ? "danger"
                             : days <= 30 ? "warning"
                             : "success";

            <tr>
                <td>@cert.SystemName</td>

                <td>
                    <a href="@cert.URL" target="_blank">@cert.URL</a>
                </td>

                <td>@cert.ExpiryDate.ToString("yyyy-MM-dd")</td>

                <td>
                    <span class="badge bg-@badgeClass">
                        @(days < 0 ? "Expired" : $"{days} days left")
                    </span>
                </td>

                <td>
                    @if (cert.IsRenewed)
                    {
                        <span class="badge bg-success">Renewed</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pending</span>
                    }
                </td>

                <td>
                    @(cert.LastRenewedDate?.ToString("yyyy-MM-dd") ?? "-")
                </td>

                <td>
                    <a asp-action="Details" asp-route-id="@cert.Id" class="btn btn-info btn-sm">View</a>
                    <a asp-action="Edit" asp-route-id="@cert.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@cert.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>