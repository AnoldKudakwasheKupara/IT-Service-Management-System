@model SSLCertificate

@{
    ViewData["Title"] = "Edit SSL Certificate";
}

<h2>Edit SSL Certificate</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>System Name</label>
        <input asp-for="SystemName" class="form-control" />
        <span asp-validation-for="SystemName" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label>URL</label>
        <input asp-for="URL" class="form-control" />
        <span asp-validation-for="URL" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label>Expiry Date</label>
        <input asp-for="ExpiryDate" type="date" class="form-control" />
        <span asp-validation-for="ExpiryDate" class="text-danger"></span>
    </div>

    <div class="form-check mt-3">
        <input asp-for="IsRenewed" class="form-check-input" />
        <label class="form-check-label">Certificate Renewed</label>
    </div>

    <div class="mt-2">
        <small class="text-muted">
            Last Renewed:
            @(Model.LastRenewedDate?.ToString("yyyy-MM-dd") ?? "Not yet renewed")
        </small>
    </div>

    <button type="submit" class="btn btn-warning mt-3">Update</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Back</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}