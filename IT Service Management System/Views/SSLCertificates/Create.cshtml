@model SSLCertificate

@{
    ViewData["Title"] = "Add SSL Certificate - Axis IT Helpdesk";
}

<div class="page-container">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="page-title">
                    <i class="fas fa-plus-circle me-2" style="color: var(--success);"></i>
                    Add SSL Certificate
                </h1>
                <p class="text-muted mt-2">Add a new SSL certificate to track expiry and renewal status</p>
            </div>
        </div>
    </div>

    <div class="add-certificate-card">
        <div class="card-header-custom">
            <div>
                <i class="fas fa-lock me-2"></i>
                <span>Certificate Information</span>
            </div>
            <div class="form-steps">
                <span class="step active">1</span>
                <span class="step-line"></span>
                <span class="step">2</span>
                <span class="step-line"></span>
                <span class="step">3</span>
            </div>
        </div>

        <form asp-action="Create" method="post" id="createCertificateForm">
            @Html.AntiForgeryToken()
            
            <div class="card-body-custom">
                <div class="form-grid">
                    <!-- Left Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="SystemName" class="form-label">
                                <i class="fas fa-server"></i>
                                System Name
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-server input-icon"></i>
                                <input asp-for="SystemName" class="form-control-modern" placeholder="Enter system name (e.g., Production Server, API Gateway)" />
                            </div>
                            <span asp-validation-for="SystemName" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Name of the system or server using this certificate
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="URL" class="form-label">
                                <i class="fas fa-link"></i>
                                URL / Domain
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-globe input-icon"></i>
                                <input asp-for="URL" class="form-control-modern" placeholder="https://example.com" />
                            </div>
                            <span asp-validation-for="URL" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Full URL or domain name where the certificate is used
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="form-column">
                        <div class="form-group-modern">
                            <label asp-for="ExpiryDate" class="form-label">
                                <i class="fas fa-calendar"></i>
                                Expiry Date
                                <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-alt input-icon"></i>
                                <input asp-for="ExpiryDate" type="date" class="form-control-modern" />
                            </div>
                            <span asp-validation-for="ExpiryDate" class="validation-message text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Date when the certificate expires
                            </div>
                            <div id="expiryPreview" class="expiry-preview" style="display: none;">
                                <i class="fas fa-info-circle"></i>
                                <span></span>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <div class="checkbox-group">
                                <div class="checkbox-wrapper">
                                    <input asp-for="IsRenewed" type="checkbox" id="IsRenewed" />
                                    <label asp-for="IsRenewed" class="checkbox-label">
                                        <i class="fas fa-sync-alt"></i>
                                        Mark as Renewed
                                    </label>
                                </div>
                                <div class="checkbox-hint">
                                    <i class="fas fa-info-circle"></i> Check if this certificate has already been renewed
                                </div>
                            </div>
                        </div>

                        <div class="form-group-modern" id="lastRenewedGroup" style="display: none;">
                            <label class="form-label">
                                <i class="fas fa-history"></i>
                                Last Renewed Date
                            </label>
                            <div class="input-icon-wrapper">
                                <i class="fas fa-calendar-check input-icon"></i>
                                <input type="date" name="LastRenewedDate" class="form-control-modern" />
                            </div>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i> Date when the certificate was last renewed
                            </div>
                        </div>

                        <!-- Status Preview -->
                        <div class="status-preview" id="statusPreview" style="display: none;">
                            <h4 class="preview-title">
                                <i class="fas fa-chart-line"></i>
                                Certificate Status Preview
                            </h4>
                            <div class="preview-content" id="previewContent">
                                <!-- Dynamic status will appear here -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tips Section -->
                <div class="tips-section">
                    <div class="tips-header">
                        <i class="fas fa-lightbulb"></i>
                        <span>SSL Certificate Management Tips</span>
                    </div>
                    <div class="tips-grid">
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Track certificates at least 30 days before expiry</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Set up renewal reminders for critical certificates</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Keep certificate URLs up to date</span>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Document renewal dates for audit purposes</span>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-save" id="submitBtn">
                        <i class="fas fa-save"></i>
                        Save Certificate
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Add SSL Certificate Page Specific Styles */
    :root {
        --primary-dark: #1e4c6b;
        --primary: #2c7da0;
        --primary-light: #61a5c2;
        --success: #2c9e6e;
        --warning: #f5b042;
        --danger: #e53e3e;
        --info: #3b82f6;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    .page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 0.75rem;
        color: var(--gray-600);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--gray-200);
    }

    .btn-back:hover {
        background: var(--gray-50);
        color: var(--primary);
        transform: translateX(-2px);
    }

    .page-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0;
    }

    /* Add Certificate Card */
    .add-certificate-card {
        background: white;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-200);
    }

    .card-header-custom {
        background: var(--gray-50);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--gray-200);
        font-weight: 600;
        color: var(--gray-700);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .form-steps {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .step {
        width: 30px;
        height: 30px;
        background: white;
        border: 2px solid var(--gray-300);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
    }

    .step.active {
        background: var(--success);
        border-color: var(--success);
        color: white;
    }

    .step-line {
        width: 40px;
        height: 2px;
        background: var(--gray-300);
    }

    .card-body-custom {
        padding: 2rem;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Form Groups */
    .form-group-modern {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--gray-700);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label i {
        color: var(--primary);
        font-size: 0.875rem;
    }

    .required {
        color: var(--danger);
        font-size: 1rem;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .input-icon-wrapper i.input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.875rem;
        border: 1.5px solid var(--gray-200);
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
        background: white;
    }

    .form-control-modern:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
    }

    /* Checkbox Group */
    .checkbox-group {
        background: var(--gray-50);
        padding: 1rem;
        border-radius: 0.75rem;
        border: 1px solid var(--gray-200);
    }

    .checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .checkbox-wrapper input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .checkbox-label {
        font-weight: 600;
        color: var(--gray-700);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .checkbox-label i {
        color: var(--success);
    }

    .checkbox-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-left: 1.75rem;
    }

    /* Expiry Preview */
    .expiry-preview {
        background: #e6f0ff;
        border-left: 3px solid var(--info);
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        color: var(--info);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.25rem;
    }

    /* Status Preview */
    .status-preview {
        background: var(--gray-50);
        border-radius: 0.75rem;
        padding: 1rem;
        border: 1px solid var(--gray-200);
        margin-top: 0.5rem;
    }

    .preview-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--gray-700);
        margin: 0 0 0.75rem 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .preview-content {
        font-size: 0.875rem;
    }

    .status-preview-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 0.875rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    /* Tips Section */
    .tips-section {
        background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 2rem;
        border-left: 3px solid var(--info);
    }

    .tips-header {
        font-weight: 600;
        color: var(--info);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .tips-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 0.75rem;
    }

    .tip-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        color: var(--gray-700);
    }

    .tip-item i {
        color: var(--success);
    }

    /* Validation Messages */
    .validation-message {
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* Form Hints */
    .form-hint {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-hint i {
        font-size: 0.7rem;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }

    .btn-save {
        background: linear-gradient(100deg, var(--success), #1f8a5c);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-cancel {
        background: white;
        color: var(--gray-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid var(--gray-300);
        font-size: 0.875rem;
        flex: 1;
        justify-content: center;
    }

    .btn-cancel:hover {
        background: var(--gray-50);
        color: var(--gray-700);
        text-decoration: none;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const expiryDateInput = document.querySelector('[asp-for="ExpiryDate"]');
        const isRenewedCheckbox = document.getElementById('IsRenewed');
        const lastRenewedGroup = document.getElementById('lastRenewedGroup');
        const expiryPreview = document.getElementById('expiryPreview');
        const statusPreview = document.getElementById('statusPreview');
        const previewContent = document.getElementById('previewContent');
        
        // Toggle last renewed date field based on IsRenewed checkbox
        if (isRenewedCheckbox && lastRenewedGroup) {
            isRenewedCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    lastRenewedGroup.style.display = 'flex';
                } else {
                    lastRenewedGroup.style.display = 'none';
                    const lastRenewedInput = lastRenewedGroup.querySelector('input');
                    if (lastRenewedInput) {
                        lastRenewedInput.value = '';
                    }
                }
            });
        }
        
        // Update expiry preview and status preview
        function updateExpiryPreview() {
            if (expiryDateInput && expiryDateInput.value) {
                const expiryDate = new Date(expiryDateInput.value);
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                
                const days = Math.ceil((expiryDate - today) / (1000 * 60 * 60 * 24));
                
                let statusClass = '';
                let statusText = '';
                let previewHtml = '';
                
                if (days < 0) {
                    statusClass = 'status-expired';
                    statusText = 'Expired';
                    previewHtml = '<i class="fas fa-exclamation-circle"></i> This certificate has expired!';
                    expiryPreview.style.display = 'flex';
                    expiryPreview.style.borderLeftColor = 'var(--danger)';
                    expiryPreview.querySelector('i').style.color = 'var(--danger)';
                    statusPreview.style.display = 'block';
                } else if (days <= 7) {
                    statusClass = 'status-critical';
                    statusText = `Critical - ${days} days left`;
                    previewHtml = `<i class="fas fa-exclamation-triangle"></i> Warning: Certificate expires in ${days} days!`;
                    expiryPreview.style.display = 'flex';
                    expiryPreview.style.borderLeftColor = 'var(--danger)';
                    expiryPreview.querySelector('i').style.color = 'var(--danger)';
                    statusPreview.style.display = 'block';
                } else if (days <= 30) {
                    statusClass = 'status-warning';
                    statusText = `${days} days left`;
                    previewHtml = `<i class="fas fa-exclamation-triangle"></i> Certificate expires in ${days} days. Consider renewing soon.`;
                    expiryPreview.style.display = 'flex';
                    expiryPreview.style.borderLeftColor = 'var(--warning)';
                    expiryPreview.querySelector('i').style.color = 'var(--warning)';
                    statusPreview.style.display = 'block';
                } else {
                    statusClass = 'status-healthy';
                    statusText = `${days} days left`;
                    expiryPreview.style.display = 'none';
                    statusPreview.style.display = 'block';
                }
                
                if (previewContent) {
                    previewContent.innerHTML = `
                        <span class="status-preview-badge ${statusClass}">
                            <i class="fas ${days < 0 ? 'fa-times-circle' : days <= 7 ? 'fa-exclamation-circle' : days <= 30 ? 'fa-exclamation-triangle' : 'fa-check-circle'}"></i>
                            ${statusText}
                        </span>
                    `;
                }
                
                if (expiryPreview && previewHtml) {
                    expiryPreview.querySelector('span').innerHTML = previewHtml;
                }
            } else {
                if (expiryPreview) expiryPreview.style.display = 'none';
                if (statusPreview) statusPreview.style.display = 'none';
            }
        }
        
        if (expiryDateInput) {
            expiryDateInput.addEventListener('change', updateExpiryPreview);
            updateExpiryPreview();
        }
        
        // Form validation
        const form = document.getElementById('createCertificateForm');
        const submitBtn = document.getElementById('submitBtn');
        
        if (form) {
            form.addEventListener('submit', function(e) {
                const systemName = document.querySelector('[name="SystemName"]').value.trim();
                const url = document.querySelector('[name="URL"]').value.trim();
                const expiryDate = expiryDateInput.value;
                
                if (!systemName) {
                    e.preventDefault();
                    showValidationError('System name is required');
                    document.querySelector('[name="SystemName"]').focus();
                    return false;
                }
                
                if (systemName.length < 2) {
                    e.preventDefault();
                    showValidationError('System name must be at least 2 characters');
                    document.querySelector('[name="SystemName"]').focus();
                    return false;
                }
                
                if (!url) {
                    e.preventDefault();
                    showValidationError('URL is required');
                    document.querySelector('[name="URL"]').focus();
                    return false;
                }
                
                // URL format validation
                const urlPattern = /^(https?:\/\/)?([\da-z\.-]+)\.([a-z\.]{2,6})([\/\w \.-]*)*\/?$/;
                if (!urlPattern.test(url)) {
                    e.preventDefault();
                    showValidationError('Please enter a valid URL (e.g., https://example.com)');
                    document.querySelector('[name="URL"]').focus();
                    return false;
                }
                
                if (!expiryDate) {
                    e.preventDefault();
                    showValidationError('Expiry date is required');
                    expiryDateInput.focus();
                    return false;
                }
                
                // Check if expiry date is in the past
                const selectedDate = new Date(expiryDate);
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                
                if (selectedDate < today) {
                    if (!confirm('The expiry date you entered is in the past. Are you sure you want to add an expired certificate?')) {
                        e.preventDefault();
                        return false;
                    }
                }
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving Certificate...';
                
                return true;
            });
        }
        
        function showValidationError(message) {
            var errorDiv = document.querySelector('.validation-toast');
            if (errorDiv) errorDiv.remove();
            
            errorDiv = document.createElement('div');
            errorDiv.className = 'validation-toast';
            errorDiv.style.cssText = `
                position: fixed;
                top: 1rem;
                right: 1rem;
                background: var(--danger);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 0.75rem;
                box-shadow: var(--shadow-lg);
                z-index: 1050;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-size: 0.875rem;
                animation: slideIn 0.3s ease;
            `;
            errorDiv.innerHTML = `
                <i class="fas fa-exclamation-circle"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(errorDiv);
            
            setTimeout(function() {
                errorDiv.style.animation = 'slideOut 0.3s ease';
                setTimeout(function() { errorDiv.remove(); }, 300);
            }, 4000);
        }
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}